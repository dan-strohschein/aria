// Fibonacci sequence in Aria
// Run: aria run examples/fibonacci.aria

fn fibonacci(n: i64) -> i64 {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

entry {
    mut i := 0
    loop {
        if i > 15 { break }
        println("fib({i}) = {fibonacci(i)}")
        i = i + 1
    }
}
