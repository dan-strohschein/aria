mod codegen

// ============================================================
// Codegen Tests — ARM64 encoding and IR
// ============================================================

// --- ARM64 encoding tests ---
// Verified against ARM Architecture Reference Manual

test "enc movz x0 42" {
    inst := enc_movz(X0, 42, 0)
    // MOVZ X0, #42 = 0xD2800540
    assert inst == 0xD2800540
}

test "enc movz x1 0" {
    inst := enc_movz(X1, 0, 0)
    // MOVZ X1, #0 = 0xD2800001
    assert inst == 0xD2800001
}

test "enc add reg" {
    inst := enc_add_reg(X0, X1, X2)
    // ADD X0, X1, X2 = 0x8B020020
    assert inst == 0x8B020020
}

test "enc sub reg" {
    inst := enc_sub_reg(X0, X1, X2)
    // SUB X0, X1, X2 = 0xCB020020
    assert inst == 0xCB020020
}

test "enc ret" {
    inst := enc_ret()
    assert inst == 0xD65F03C0
}

test "enc nop" {
    inst := enc_nop()
    assert inst == 0xD503201F
}

test "enc add imm" {
    inst := enc_add_imm(SP, SP, 16)
    // ADD SP, SP, #16 = 0x910043FF
    assert inst == 0x910043FF
}

test "enc sub imm" {
    inst := enc_sub_imm(SP, SP, 16)
    // SUB SP, SP, #16 = 0xD10043FF
    assert inst == 0xD10043FF
}

test "enc mov reg" {
    inst := enc_mov_reg(X0, X1)
    // MOV X0, X1 = ORR X0, XZR, X1 = 0xAA0103E0
    assert inst == 0xAA0103E0
}

test "enc b unconditional" {
    inst := enc_b(4)
    // B +4 = 0x14000004
    assert inst == 0x14000004
}

test "enc bl call" {
    inst := enc_bl(10)
    // BL +10 = 0x9400000A
    assert inst == 0x9400000A
}

test "enc b eq" {
    inst := enc_b_cond(COND_EQ, 3)
    // B.EQ +3 = 0x54000060
    assert inst == 0x54000060
}

test "enc ldr imm" {
    // LDR X0, [X29, #8] — offset is imm12 in units of 8 bytes, so imm12=1
    inst := enc_ldr_imm(X0, X29, 1)
    // 0xF94007A0
    assert inst == 0xF94007A0
}

test "enc str imm" {
    // STR X0, [X29, #8] — imm12=1
    inst := enc_str_imm(X0, X29, 1)
    // 0xF90007A0
    assert inst == 0xF90007A0
}

test "enc cmp reg" {
    inst := enc_cmp_reg(X0, X1)
    // CMP X0, X1 = SUBS XZR, X0, X1 = 0xEB01001F
    assert inst == 0xEB01001F
}

test "enc mul" {
    inst := enc_mul(X0, X1, X2)
    // MUL X0, X1, X2 = MADD X0, X1, X2, XZR
    // 0x9B027C20
    assert inst == 0x9B027C20
}

test "enc load imm64 small" {
    code := enc_load_imm64(X0, 42)
    // Should be [sentinel, MOVZ X0, #42]
    assert code.len() == 2
    assert code[1] == enc_movz(X0, 42, 0)
}

test "enc prologue" {
    code := enc_prologue(32)
    // [sentinel, STP x29 x30 pre, MOV x29 sp, SUB sp sp 32]
    assert code.len() == 4
}

test "enc epilogue" {
    code := enc_epilogue(32)
    // [sentinel, ADD sp sp 32, LDP x29 x30 post, RET]
    assert code.len() == 4
}

// --- IR type tests ---

test "ir op name" {
    assert ir_op_name(OpConst) == "Const"
    assert ir_op_name(OpAdd) == "Add"
    assert ir_op_name(OpRet) == "Ret"
    assert ir_op_name(OpLabel) == "Label"
}

test "ir func add inst" {
    mut f := new_ir_func("main", 0, 0)
    inst := new_inst(OpConst, 1, 42, 0, "", 0)
    f = func_add_inst(f, inst)
    assert func_inst_count(f) == 1
}

test "ir module add func" {
    mut m := new_ir_module()
    f := new_ir_func("main", 0, 0)
    m = mod_add_func(m, f)
    assert mod_func_count(m) == 1
}

test "ir module add string" {
    mut m := new_ir_module()
    m = mod_add_string(m, "hello")
    idx := mod_find_string(m, "hello")
    assert idx == 1
}

test "ir module find func" {
    mut m := new_ir_module()
    f := new_ir_func("foo", 2, 1)
    m = mod_add_func(m, f)
    found := mod_find_func(m, "foo")
    assert found.name == "foo"
    assert found.param_count == 2
}

// --- Emitter tests ---

test "emit const and ret" {
    mut f := new_ir_func("test_fn", 0, 0)
    f = func_add_inst(f, new_inst(OpConst, 0, 42, 0, "", 0))
    f = func_add_inst(f, new_inst(OpRet, 0, 0, 0, "", 0))
    f = func_set_locals(f, 1)
    em := emit_function(f)
    // Should have emitted some code
    assert emitter_code_size(em) > 0
}

test "emit add" {
    mut f := new_ir_func("test_add", 2, 0)
    f = func_add_inst(f, new_inst(OpAdd, 2, 0, 1, "", 0))
    f = func_add_inst(f, new_inst(OpRet, 0, 2, 0, "", 0))
    f = func_set_locals(f, 3)
    em := emit_function(f)
    assert emitter_code_size(em) > 0
}

test "emit branch and label" {
    mut f := new_ir_func("test_branch", 0, 0)
    f = func_add_inst(f, new_inst(OpConst, 0, 1, 0, "", 0))
    f = func_add_inst(f, new_inst(OpBranchFalse, 0, 0, 0, "", 0))  // branch to label 0 if false
    f = func_add_inst(f, new_inst(OpConst, 1, 42, 0, "", 0))
    f = func_add_inst(f, new_inst(OpLabel, 0, 0, 0, "", 0))        // label 0
    f = func_add_inst(f, new_inst(OpConst, 1, 0, 0, "", 0))
    f = func_add_inst(f, new_inst(OpRet, 0, 1, 0, "", 0))
    f = func_set_locals(f, 2)
    em := emit_function(f)
    assert emitter_code_size(em) > 0
}

// --- Runtime tests (removed: build_runtime_module/runtime_externals no longer exist) ---

// --- SHA-256 tests ---

test "sha256 empty" {
    data := [0]
    hash := _sha256_hash(data)
    assert hash.len() == 33  // sentinel + 32 bytes
    // SHA-256("") = e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
    assert hash[1] == 0xE3
    assert hash[2] == 0xB0
    assert hash[3] == 0xC4
    assert hash[4] == 0x42
    assert hash[31] == 0xB8
    assert hash[32] == 0x55
}

test "sha256 abc" {
    mut data := [0]
    data = data.append(97)
    data = data.append(98)
    data = data.append(99)
    hash := _sha256_hash(data)
    assert hash.len() == 33
    // SHA-256("abc") = ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
    assert hash[1] == 0xBA
    assert hash[2] == 0x78
    assert hash[3] == 0x16
    assert hash[4] == 0xBF
    assert hash[29] == 0xF2
    assert hash[30] == 0x00
    assert hash[31] == 0x15
    assert hash[32] == 0xAD
}

// --- Mach-O tests ---

test "macho builds binary" {
    // Minimal: just exit(0)
    mut code := [0]
    code = code.append(enc_movz(X0, 0, 0))
    code = code.append(enc_movz(X16, 1, 0))
    code = code.append(enc_svc(0x80))
    cstrings := [0]
    binary := build_macho(code, cstrings, 0)
    // Binary should start with MH_MAGIC_64 bytes (CF FA ED FE in little-endian)
    assert binary.len() > 100
    assert binary[1] == 0xCF   // first byte of 0xFEEDFACF in LE
    assert binary[2] == 0xFA
    assert binary[3] == 0xED
    assert binary[4] == 0xFE
}

test "macho has code signature" {
    mut code := [0]
    code = code.append(enc_movz(X0, 0, 0))
    code = code.append(enc_movz(X16, 1, 0))
    code = code.append(enc_svc(0x80))
    binary := build_macho(code, [0], 0)
    // File should be > 16KB (TEXT page + LINKEDIT)
    assert binary.len() - 1 > 16384
    // Code signature SuperBlob magic at LINKEDIT+56 (big-endian 0xFADE0CC0)
    // LINKEDIT starts at 16384, chained_fixups(48) + exports(8) = 56
    assert binary[16441] == 0xFA
    assert binary[16442] == 0xDE
    assert binary[16443] == 0x0C
    assert binary[16444] == 0xC0
}

