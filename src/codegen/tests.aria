mod codegen

// ============================================================
// Code Generator Tests
// NOTE: Integration tests are consolidated to reduce Go test
// compilation time (many _gen_source calls are slow to compile)
// ============================================================

use diagnostic
use lexer
use resolver
use checker

// --- Helpers ---

fn _gen_source(source: str) -> GenResult {
    lex := tokenize(source, "test.aria")
    toks := get_tokens(lex)
    rr := resolve(toks, "test.aria")
    cr := check(toks, rr.table, "test.aria")
    generate_no_runtime(toks, cr.store, cr.registry, rr.table, "test.aria")
}

fn _code_contains(result: GenResult, needle: str) -> bool = result.code.contains(needle)

// --- Unit tests (no codegen pipeline, fast) ---

test "c type mapping" {
    st := new_store()
    assert aria_to_c_type(st, TY_I64) == "int64_t"
    assert aria_to_c_type(st, TY_BOOL) == "bool"
    assert aria_to_c_type(st, TY_STR) == "AriaStr"
    assert aria_to_c_type(st, TY_F64) == "double"
    assert aria_to_c_type(st, TY_U8) == "uint8_t"
    assert aria_to_c_type(st, TY_UNIT) == "void"
}

test "name mangling" {
    assert mangle_name("int") == "aria_int"
    assert mangle_name("return") == "aria_return"
    assert mangle_name("struct") == "aria_struct"
    assert mangle_name("foo") == "foo"
}

test "c string escape" {
    assert escape_c_string("hello") == "hello"
}

test "runtime preamble" {
    preamble := c_runtime_preamble()
    assert preamble.len() > 100
    assert preamble.contains("#include")
    assert preamble.contains("AriaStr")
}

// --- Integration tests (consolidated into fewer tests to reduce compile time) ---

test "gen functions" {
    r1 := _gen_source("mod test\nfn foo() -> i64 = 42")
    assert _code_contains(r1, "int64_t foo(void)")
    assert _code_contains(r1, "return 42")

    r2 := _gen_source("mod test\nfn add(a: i64, b: i64) -> i64 = a + b")
    assert _code_contains(r2, "int64_t add(int64_t a, int64_t b)")

    r3 := _gen_source("mod test\nfn is_pos(x: i64) -> bool = x > 0")
    assert _code_contains(r3, "bool is_pos")
}

test "gen forward decls and entry" {
    r1 := _gen_source("mod test\nfn foo() -> i64 = bar()\nfn bar() -> i64 = 42")
    assert _code_contains(r1, "int64_t foo(void);")
    assert _code_contains(r1, "int64_t bar(void);")

    lb := "\{"
    rb := "\}"
    r2 := _gen_source("mod test\nfn foo() -> i64 = 42\nentry " + lb + "\n    foo()\n" + rb)
    assert _code_contains(r2, "int main(")
}

test "gen types and bindings" {
    source1 := "mod test\ntype Color =\n    | Red\n    | Green\n    | Blue\nfn foo() -> i64 = 42"
    r1 := _gen_source(source1)
    assert _code_contains(r1, "Color_Red")

    lb := "\{"
    rb := "\}"
    source2 := "mod test\nfn foo() -> i64 " + lb + "\n    x := 42\n    x\n" + rb
    r2 := _gen_source(source2)
    assert _code_contains(r2, "int64_t x = 42")
}

test "gen control flow" {
    lb := "\{"
    rb := "\}"
    source1 := "mod test\nfn foo() -> i64 " + lb + "\n    mut x := 10\n    while x > 0 " + lb + "\n        x = x - 1\n    " + rb + "\n    x\n" + rb
    r1 := _gen_source(source1)
    assert _code_contains(r1, "while (")

    source2 := "mod test\nfn foo() -> i64 " + lb + "\n    assert 1 == 1\n    42\n" + rb
    r2 := _gen_source(source2)
    assert _code_contains(r2, "aria_assert")
}
