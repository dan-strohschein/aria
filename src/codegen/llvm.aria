        srt := _str_ret_type()
        res := "%sca_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_str_charAt(i8* " + s_p + ", i64 " + s_len + ", i64 " + idx_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "sca")
        return gg
    }

    if op == "StrSubstring" {
        mut gg := g
        s_ptr := "%ssub_sp_" + _i2s(idx)
        s_len := "%ssub_sl_" + _i2s(idx)
        gg = _lg_emit(gg, s_ptr + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, s_len + " = load i64, i64* " + _t(inst.arg1 + 1))
        start_v := "%ssub_st_" + _i2s(idx)
        gg = _lg_emit(gg, start_v + " = load i64, i64* " + _t(inst.arg2))
        end_v := "%ssub_en_" + _i2s(idx)
        gg = _lg_emit(gg, end_v + " = load i64, i64* " + _t(inst.type_id))
        s_p := "%ssub_spi_" + _i2s(idx)
        gg = _lg_emit(gg, s_p + " = inttoptr i64 " + s_ptr + " to i8*")
        srt := _str_ret_type()
        res := "%ssub_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_str_substring(i8* " + s_p + ", i64 " + s_len + ", i64 " + start_v + ", i64 " + end_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "ssub")
        return gg
    }

    if op == "StrContains" { return _gen_str_binop_returning_i64(g, "@_aria_str_contains", inst, idx) }
    if op == "StrStartsWith" { return _gen_str_binop_returning_i64(g, "@_aria_str_startsWith", inst, idx) }
    if op == "StrEndsWith" { return _gen_str_binop_returning_i64(g, "@_aria_str_endsWith", inst, idx) }
    if op == "StrIndexOf" { return _gen_str_binop_returning_i64(g, "@_aria_str_indexOf", inst, idx) }

    if op == "StrTrim" {
        mut gg := g
        s_ptr := "%strim_sp_" + _i2s(idx)
        s_len := "%strim_sl_" + _i2s(idx)
        gg = _lg_emit(gg, s_ptr + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, s_len + " = load i64, i64* " + _t(inst.arg1 + 1))
        s_p := "%strim_spi_" + _i2s(idx)
        gg = _lg_emit(gg, s_p + " = inttoptr i64 " + s_ptr + " to i8*")
        srt := _str_ret_type()
        res := "%strim_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_str_trim(i8* " + s_p + ", i64 " + s_len + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "strim")
        return gg
    }

    if op == "StrReplace" {
        mut gg := g
        s_ptr := "%srep_sp_" + _i2s(idx)
        s_len := "%srep_sl_" + _i2s(idx)
        gg = _lg_emit(gg, s_ptr + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, s_len + " = load i64, i64* " + _t(inst.arg1 + 1))
        o_ptr := "%srep_op_" + _i2s(idx)
        o_len := "%srep_ol_" + _i2s(idx)
        gg = _lg_emit(gg, o_ptr + " = load i64, i64* " + _t(inst.arg2))
        gg = _lg_emit(gg, o_len + " = load i64, i64* " + _t(inst.arg2 + 1))
        n_ptr := "%srep_np_" + _i2s(idx)
        n_len := "%srep_nl_" + _i2s(idx)
        gg = _lg_emit(gg, n_ptr + " = load i64, i64* " + _t(inst.type_id))
        gg = _lg_emit(gg, n_len + " = load i64, i64* " + _t(inst.type_id + 1))
        sp := "%srep_spi_" + _i2s(idx)
        op2 := "%srep_opi_" + _i2s(idx)
        np := "%srep_npi_" + _i2s(idx)
        gg = _lg_emit(gg, sp + " = inttoptr i64 " + s_ptr + " to i8*")
        gg = _lg_emit(gg, op2 + " = inttoptr i64 " + o_ptr + " to i8*")
        gg = _lg_emit(gg, np + " = inttoptr i64 " + n_ptr + " to i8*")
        srt := _str_ret_type()
        res := "%srep_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_str_replace(i8* " + sp + ", i64 " + s_len + ", i8* " + op2 + ", i64 " + o_len + ", i8* " + np + ", i64 " + n_len + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "srep")
        return gg
    }

    if op == "StrToLower" {
        mut gg := g
        s_ptr := "%slwr_sp_" + _i2s(idx)
        s_len := "%slwr_sl_" + _i2s(idx)
        gg = _lg_emit(gg, s_ptr + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, s_len + " = load i64, i64* " + _t(inst.arg1 + 1))
        s_p := "%slwr_spi_" + _i2s(idx)
        gg = _lg_emit(gg, s_p + " = inttoptr i64 " + s_ptr + " to i8*")
        srt := _str_ret_type()
        res := "%slwr_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_str_toLower(i8* " + s_p + ", i64 " + s_len + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "slwr")
        return gg
    }

    if op == "StrToUpper" {
        mut gg := g
        s_ptr := "%supr_sp_" + _i2s(idx)
        s_len := "%supr_sl_" + _i2s(idx)
        gg = _lg_emit(gg, s_ptr + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, s_len + " = load i64, i64* " + _t(inst.arg1 + 1))
        s_p := "%supr_spi_" + _i2s(idx)
        gg = _lg_emit(gg, s_p + " = inttoptr i64 " + s_ptr + " to i8*")
        srt := _str_ret_type()
        res := "%supr_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_str_toUpper(i8* " + s_p + ", i64 " + s_len + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "supr")
        return gg
    }

    if op == "StrSplit" {
        mut gg := g
        s_ptr := "%sspl_sp_" + _i2s(idx)
        s_len := "%sspl_sl_" + _i2s(idx)
        gg = _lg_emit(gg, s_ptr + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, s_len + " = load i64, i64* " + _t(inst.arg1 + 1))
        d_ptr := "%sspl_dp_" + _i2s(idx)
        d_len := "%sspl_dl_" + _i2s(idx)
        gg = _lg_emit(gg, d_ptr + " = load i64, i64* " + _t(inst.arg2))
        gg = _lg_emit(gg, d_len + " = load i64, i64* " + _t(inst.arg2 + 1))
        sp := "%sspl_spi_" + _i2s(idx)
        dp := "%sspl_dpi_" + _i2s(idx)
        gg = _lg_emit(gg, sp + " = inttoptr i64 " + s_ptr + " to i8*")
        gg = _lg_emit(gg, dp + " = inttoptr i64 " + d_ptr + " to i8*")
        res := "%sspl_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_str_split(i8* " + sp + ", i64 " + s_len + ", i8* " + dp + ", i64 " + d_len + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if op == "StrToInt" {
        // Returns {value, success} — we store both to consecutive temps
        mut gg := g
        ptr_v := "%sti_p_" + _i2s(idx)
        len_v := "%sti_l_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        ptr_cast := "%sti_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_cast + " = inttoptr i64 " + ptr_v + " to i8*")
        srt := _str_ret_type()
        res := "%sti_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_str_to_int(i8* " + ptr_cast + ", i64 " + len_v + ")")
        // Extract value (field 0) and success (field 1)
        val := "%sti_val_" + _i2s(idx)
        suc := "%sti_suc_" + _i2s(idx)
        gg = _lg_emit(gg, val + " = extractvalue " + srt + " " + res + ", 0")
        gg = _lg_emit(gg, suc + " = extractvalue " + srt + " " + res + ", 1")
        // Cast ptr back to i64 for the value
        val_int := "%sti_vi_" + _i2s(idx)
        gg = _lg_emit(gg, val_int + " = ptrtoint i8* " + val + " to i64")
        gg = _lg_emit(gg, "store i64 " + val_int + ", i64* " + _t(inst.dest))
        dest_suc := inst.dest + 1
        gg = _lg_emit(gg, "store i64 " + suc + ", i64* " + _t(dest_suc))
        return gg
    }

    if op == "MapNew" {
        mut gg := g
        cap_v := "%mnew_cap_" + _i2s(idx)
        gg = _lg_emit(gg, cap_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%mnew_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_map_new(i64 " + cap_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if op == "MapSet" {
        // arg1 = map ptr, arg2 = key (str temp), type_id = value temp
        mut gg := g
        map_v := "%mset_m_" + _i2s(idx)
        gg = _lg_emit(gg, map_v + " = load i64, i64* " + _t(inst.arg1))
        key_p := "%mset_kp_" + _i2s(idx)
        key_l := "%mset_kl_" + _i2s(idx)
        gg = _lg_emit(gg, key_p + " = load i64, i64* " + _t(inst.arg2))
        gg = _lg_emit(gg, key_l + " = load i64, i64* " + _t(inst.arg2 + 1))
        key_pc := "%mset_kpc_" + _i2s(idx)
        gg = _lg_emit(gg, key_pc + " = inttoptr i64 " + key_p + " to i8*")
        val_v := "%mset_v_" + _i2s(idx)
        gg = _lg_emit(gg, val_v + " = load i64, i64* " + _t(inst.type_id))
        gg = _lg_emit(gg, "call void @_aria_map_set(i64 " + map_v + ", i8* " + key_pc + ", i64 " + key_l + ", i64 " + val_v + ")")
        return gg
    }

    if op == "MapGet" {
        // arg1 = map ptr, arg2 = key (str temp), dest = result
        mut gg := g
        map_v := "%mget_m_" + _i2s(idx)
        gg = _lg_emit(gg, map_v + " = load i64, i64* " + _t(inst.arg1))
        key_p := "%mget_kp_" + _i2s(idx)
        key_l := "%mget_kl_" + _i2s(idx)
        gg = _lg_emit(gg, key_p + " = load i64, i64* " + _t(inst.arg2))
        gg = _lg_emit(gg, key_l + " = load i64, i64* " + _t(inst.arg2 + 1))
        key_pc := "%mget_kpc_" + _i2s(idx)
        gg = _lg_emit(gg, key_pc + " = inttoptr i64 " + key_p + " to i8*")
        res := "%mget_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_map_get(i64 " + map_v + ", i8* " + key_pc + ", i64 " + key_l + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if op == "MapContains" {
        mut gg := g
        map_v := "%mhas_m_" + _i2s(idx)
        gg = _lg_emit(gg, map_v + " = load i64, i64* " + _t(inst.arg1))
        key_p := "%mhas_kp_" + _i2s(idx)
        key_l := "%mhas_kl_" + _i2s(idx)
        gg = _lg_emit(gg, key_p + " = load i64, i64* " + _t(inst.arg2))
        gg = _lg_emit(gg, key_l + " = load i64, i64* " + _t(inst.arg2 + 1))
        key_pc := "%mhas_kpc_" + _i2s(idx)
        gg = _lg_emit(gg, key_pc + " = inttoptr i64 " + key_p + " to i8*")
        res := "%mhas_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_map_contains(i64 " + map_v + ", i8* " + key_pc + ", i64 " + key_l + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if op == "MapLen" {
        mut gg := g
        map_v := "%mlen_m_" + _i2s(idx)
        gg = _lg_emit(gg, map_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%mlen_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_map_len(i64 " + map_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if op == "MapKeys" {
        mut gg := g
        map_v := "%mkeys_m_" + _i2s(idx)
        gg = _lg_emit(gg, map_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%mkeys_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_map_keys(i64 " + map_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if op == "IntToStr" {
        mut gg := g
        v := "%its_v_" + _i2s(idx)
        gg = _lg_emit(gg, v + " = load i64, i64* " + _t(inst.arg1))
        srt := _str_ret_type()
        res := "%its_res_" + _i2s(idx)
        if inst.s1 == "f64" {
            gg = _lg_emit(gg, res + " = call " + srt + " @_aria_float_to_str(i64 " + v + ")")
        } else {
            gg = _lg_emit(gg, res + " = call " + srt + " @_aria_int_to_str(i64 " + v + ")")
        }
        gg = _extract_str_result(gg, res, inst.dest, idx, "its")
        return gg
    }


    g
}

// ============================================================
// Helpers
// ============================================================

fn _str_ret_type() -> str = _lb() + " i8*, i64 " + _rb()

fn _extract_str_result(g: LlvmGen, res_name: str, dest: i64, idx: i64, prefix: str) -> LlvmGen {
    srt := _str_ret_type()
    mut gg := g
    r_ptr := "%" + prefix + "_rp_" + _i2s(idx)
    r_len := "%" + prefix + "_rl_" + _i2s(idx)
    gg = _lg_emit(gg, r_ptr + " = extractvalue " + srt + " " + res_name + ", 0")
    gg = _lg_emit(gg, r_len + " = extractvalue " + srt + " " + res_name + ", 1")
    rpi := "%" + prefix + "_rpi_" + _i2s(idx)
    gg = _lg_emit(gg, rpi + " = ptrtoint i8* " + r_ptr + " to i64")
    gg = _lg_emit(gg, "store i64 " + rpi + ", i64* " + _t(dest))
    gg = _lg_emit(gg, "store i64 " + r_len + ", i64* " + _t(dest + 1))
    gg
}

fn _gen_binop(g: LlvmGen, llvm_op: str, inst: IrInst) -> LlvmGen {
    mut gg := g
    a := "%binop_a_" + _i2s(inst.dest)
    b := "%binop_b_" + _i2s(inst.dest)
    gg = _lg_emit(gg, a + " = load i64, i64* " + _t(inst.arg1))
    gg = _lg_emit(gg, b + " = load i64, i64* " + _t(inst.arg2))
    res := "%binop_r_" + _i2s(inst.dest)
    gg = _lg_emit(gg, res + " = " + llvm_op + " i64 " + a + ", " + b)
    gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
    gg
}

fn _gen_cmp(g: LlvmGen, cmp_op: str, inst: IrInst, idx: i64) -> LlvmGen {
    mut gg := g
    a := "%cmp_a_" + _i2s(idx)
    b := "%cmp_b_" + _i2s(idx)
    gg = _lg_emit(gg, a + " = load i64, i64* " + _t(inst.arg1))
    gg = _lg_emit(gg, b + " = load i64, i64* " + _t(inst.arg2))
    cmp := "%cmp_c_" + _i2s(idx)
    gg = _lg_emit(gg, cmp + " = icmp " + cmp_op + " i64 " + a + ", " + b)
    res := "%cmp_r_" + _i2s(idx)
    gg = _lg_emit(gg, res + " = zext i1 " + cmp + " to i64")
    gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
    gg
}

fn _gen_str_binop_returning_str(g: LlvmGen, func_name: str, inst: IrInst, idx: i64) -> LlvmGen {
    mut gg := g
    a_ptr := "%sbr_ap_" + _i2s(idx)
    a_len := "%sbr_al_" + _i2s(idx)
    b_ptr := "%sbr_bp_" + _i2s(idx)
    b_len := "%sbr_bl_" + _i2s(idx)
    gg = _lg_emit(gg, a_ptr + " = load i64, i64* " + _t(inst.arg1))
    gg = _lg_emit(gg, a_len + " = load i64, i64* " + _t(inst.arg1 + 1))
    gg = _lg_emit(gg, b_ptr + " = load i64, i64* " + _t(inst.arg2))
    gg = _lg_emit(gg, b_len + " = load i64, i64* " + _t(inst.arg2 + 1))
    a_p := "%sbr_api_" + _i2s(idx)
    b_p := "%sbr_bpi_" + _i2s(idx)
    gg = _lg_emit(gg, a_p + " = inttoptr i64 " + a_ptr + " to i8*")
    gg = _lg_emit(gg, b_p + " = inttoptr i64 " + b_ptr + " to i8*")
    srt := _str_ret_type()
    res := "%sbr_res_" + _i2s(idx)
    gg = _lg_emit(gg, res + " = call " + srt + " " + func_name + "(i8* " + a_p + ", i64 " + a_len + ", i8* " + b_p + ", i64 " + b_len + ")")
    gg = _extract_str_result(gg, res, inst.dest, idx, "sbr")
    gg
}

fn _gen_str_binop_returning_i64(g: LlvmGen, func_name: str, inst: IrInst, idx: i64) -> LlvmGen {
    mut gg := g
    a_ptr := "%sbi_ap_" + _i2s(idx)
    a_len := "%sbi_al_" + _i2s(idx)
    b_ptr := "%sbi_bp_" + _i2s(idx)
    b_len := "%sbi_bl_" + _i2s(idx)
    gg = _lg_emit(gg, a_ptr + " = load i64, i64* " + _t(inst.arg1))
    gg = _lg_emit(gg, a_len + " = load i64, i64* " + _t(inst.arg1 + 1))
    gg = _lg_emit(gg, b_ptr + " = load i64, i64* " + _t(inst.arg2))
    gg = _lg_emit(gg, b_len + " = load i64, i64* " + _t(inst.arg2 + 1))
    a_p := "%sbi_api_" + _i2s(idx)
    b_p := "%sbi_bpi_" + _i2s(idx)
    gg = _lg_emit(gg, a_p + " = inttoptr i64 " + a_ptr + " to i8*")
    gg = _lg_emit(gg, b_p + " = inttoptr i64 " + b_ptr + " to i8*")
    res := "%sbi_res_" + _i2s(idx)
    gg = _lg_emit(gg, res + " = call i64 " + func_name + "(i8* " + a_p + ", i64 " + a_len + ", i8* " + b_p + ", i64 " + b_len + ")")
    gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
    gg
}

// Inline StrEq: length-first check avoids memcmp call for most comparisons
fn _gen_str_eq_inline(g: LlvmGen, inst: IrInst, idx: i64) -> LlvmGen {
    mut gg := g
    a_ptr := "%seq_ap_" + _i2s(idx)
    a_len := "%seq_al_" + _i2s(idx)
    b_ptr := "%seq_bp_" + _i2s(idx)
    b_len := "%seq_bl_" + _i2s(idx)
    gg = _lg_emit(gg, a_ptr + " = load i64, i64* " + _t(inst.arg1))
    gg = _lg_emit(gg, a_len + " = load i64, i64* " + _t(inst.arg1 + 1))
    gg = _lg_emit(gg, b_ptr + " = load i64, i64* " + _t(inst.arg2))
    gg = _lg_emit(gg, b_len + " = load i64, i64* " + _t(inst.arg2 + 1))
    // Fast path: if lengths differ, not equal
    len_eq := "%seq_leq_" + _i2s(idx)
    gg = _lg_emit(gg, len_eq + " = icmp eq i64 " + a_len + ", " + b_len)
    lbl1 := _lg_fresh_label(gg)
    gg = lbl1.g
    lbl2 := _lg_fresh_label(gg)
    gg = lbl2.g
    lbl3 := _lg_fresh_label(gg)
    gg = lbl3.g
    do_cmp_lbl := "Lseq_cmp_" + _i2s(lbl1.id)
    not_eq_lbl := "Lseq_ne_" + _i2s(lbl2.id)
    done_lbl := "Lseq_done_" + _i2s(lbl3.id)
    gg = _lg_emit_term(gg, "br i1 " + len_eq + ", label %" + do_cmp_lbl + ", label %" + not_eq_lbl)
    // Lengths match: call memcmp via _aria_str_eq
    gg = _lg_emit_label(gg, do_cmp_lbl)
    a_p := "%seq_api_" + _i2s(idx)
    b_p := "%seq_bpi_" + _i2s(idx)
    gg = _lg_emit(gg, a_p + " = inttoptr i64 " + a_ptr + " to i8*")
    gg = _lg_emit(gg, b_p + " = inttoptr i64 " + b_ptr + " to i8*")
    res_cmp := "%seq_rc_" + _i2s(idx)
    gg = _lg_emit(gg, res_cmp + " = call i64 @_aria_str_eq(i8* " + a_p + ", i64 " + a_len + ", i8* " + b_p + ", i64 " + b_len + ")")
    gg = _lg_emit_term(gg, "br label %" + done_lbl)
    // Lengths differ: result is 0 (false)
    gg = _lg_emit_label(gg, not_eq_lbl)
    gg = _lg_emit_term(gg, "br label %" + done_lbl)
    // Merge with phi
    gg = _lg_emit_label(gg, done_lbl)
    res := "%seq_res_" + _i2s(idx)
    gg = _lg_emit(gg, res + " = phi i64 [ " + res_cmp + ", %" + do_cmp_lbl + " ], [ 0, %" + not_eq_lbl + " ]")
    gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
    gg
}

// ============================================================
// Generate function call
// ============================================================

fn _gen_call(g: LlvmGen, m: IrModule, f: IrFunc, inst: IrInst, idx: i64) -> LlvmGen {
    name := inst.s1
    mut gg := g

    if name == "_aria_println_str" || name == "_aria_print_str" || name == "_aria_eprintln_str" {
        ptr_v := "%call_p_" + _i2s(idx)
        len_v := "%call_l_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        ptr_cast := "%call_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_cast + " = inttoptr i64 " + ptr_v + " to i8*")
        gg = _lg_emit(gg, "call void @" + name + "(i8* " + ptr_cast + ", i64 " + len_v + ")")
        return gg
    }

    if name == "_aria_exit" {
        v := "%call_exit_" + _i2s(idx)
        gg = _lg_emit(gg, v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @_aria_exit(i64 " + v + ")")
        return gg
    }

    if name == "_aria_panic" {
        ptr_v := "%call_p_" + _i2s(idx)
        len_v := "%call_l_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        ptr_cast := "%call_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_cast + " = inttoptr i64 " + ptr_v + " to i8*")
        gg = _lg_emit(gg, "call void @_aria_panic(i8* " + ptr_cast + ", i64 " + len_v + ")")
        gg = _lg_emit_term(gg, "unreachable")
        return gg
    }

    if name == "_aria_alloc" {
        v := "%call_alloc_sz_" + _i2s(idx)
        gg = _lg_emit(gg, v + " = load i64, i64* " + _t(inst.arg1))
        raw := "%call_alloc_r_" + _i2s(idx)
        gg = _lg_emit(gg, raw + " = call i8* @_aria_alloc(i64 " + v + ")")
        res := "%call_alloc_i_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = ptrtoint i8* " + raw + " to i64")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_read_file" {
        ptr_v := "%call_rf_p_" + _i2s(idx)
        len_v := "%call_rf_l_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        ptr_cast := "%call_rf_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_cast + " = inttoptr i64 " + ptr_v + " to i8*")
        srt := _str_ret_type()
        res := "%call_rf_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_read_file(i8* " + ptr_cast + ", i64 " + len_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "call_rf")
        return gg
    }

    if name == "_aria_write_file" {
        pp := "%call_wf_pp_" + _i2s(idx)
        pl := "%call_wf_pl_" + _i2s(idx)
        cp := "%call_wf_cp_" + _i2s(idx)
        cl := "%call_wf_cl_" + _i2s(idx)
        gg = _lg_emit(gg, pp + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, pl + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, cp + " = load i64, i64* " + _t(inst.arg1 + 2))
        gg = _lg_emit(gg, cl + " = load i64, i64* " + _t(inst.arg1 + 3))
        pp_c := "%call_wf_ppc_" + _i2s(idx)
        cp_c := "%call_wf_cpc_" + _i2s(idx)
        gg = _lg_emit(gg, pp_c + " = inttoptr i64 " + pp + " to i8*")
        gg = _lg_emit(gg, cp_c + " = inttoptr i64 " + cp + " to i8*")
        gg = _lg_emit(gg, "call void @_aria_write_file(i8* " + pp_c + ", i64 " + pl + ", i8* " + cp_c + ", i64 " + cl + ")")
        return gg
    }

    if name == "_aria_write_binary_file" {
        pp := "%call_wbf_pp_" + _i2s(idx)
        pl := "%call_wbf_pl_" + _i2s(idx)
        dp := "%call_wbf_dp_" + _i2s(idx)
        dl := "%call_wbf_dl_" + _i2s(idx)
        gg = _lg_emit(gg, pp + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, pl + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, dp + " = load i64, i64* " + _t(inst.arg1 + 2))
        gg = _lg_emit(gg, dl + " = load i64, i64* " + _t(inst.arg1 + 3))
        pp_c := "%call_wbf_ppc_" + _i2s(idx)
        dp_c := "%call_wbf_dpc_" + _i2s(idx)
        gg = _lg_emit(gg, pp_c + " = inttoptr i64 " + pp + " to i8*")
        gg = _lg_emit(gg, dp_c + " = inttoptr i64 " + dp + " to i64*")
        gg = _lg_emit(gg, "call void @_aria_write_binary_file(i8* " + pp_c + ", i64 " + pl + ", i64* " + dp_c + ", i64 " + dl + ")")
        return gg
    }

    if name == "_aria_args" {
        res := "%call_args_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_args_get()")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_exec" {
        ptr_v := "%call_exec_p_" + _i2s(idx)
        len_v := "%call_exec_l_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        ptr_cast := "%call_exec_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_cast + " = inttoptr i64 " + ptr_v + " to i8*")
        res := "%call_exec_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_exec(i8* " + ptr_cast + ", i64 " + len_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    // --- Environment ---
    if name == "_aria_getenv" {
        ptr_v := "%call_ge_p_" + _i2s(idx)
        len_v := "%call_ge_l_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        ptr_cast := "%call_ge_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_cast + " = inttoptr i64 " + ptr_v + " to i8*")
        srt := _str_ret_type()
        res := "%call_ge_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_getenv(i8* " + ptr_cast + ", i64 " + len_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "call_ge")
        return gg
    }

    // --- TCP Networking ---
    if name == "_aria_tcp_socket" {
        res := "%call_ts_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_tcp_socket()")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_tcp_bind" {
        // args: fd, addr_ptr, addr_len, port — 4 consecutive i64 temps starting at arg1
        fd_v := "%call_tb_fd_" + _i2s(idx)
        ap := "%call_tb_ap_" + _i2s(idx)
        al := "%call_tb_al_" + _i2s(idx)
        port_v := "%call_tb_port_" + _i2s(idx)
        gg = _lg_emit(gg, fd_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, ap + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, al + " = load i64, i64* " + _t(inst.arg1 + 2))
        gg = _lg_emit(gg, port_v + " = load i64, i64* " + _t(inst.arg1 + 3))
        apc := "%call_tb_apc_" + _i2s(idx)
        gg = _lg_emit(gg, apc + " = inttoptr i64 " + ap + " to i8*")
        res := "%call_tb_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_tcp_bind(i64 " + fd_v + ", i8* " + apc + ", i64 " + al + ", i64 " + port_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_tcp_listen" {
        fd_v := "%call_tl_fd_" + _i2s(idx)
        bl_v := "%call_tl_bl_" + _i2s(idx)
        gg = _lg_emit(gg, fd_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, bl_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        res := "%call_tl_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_tcp_listen(i64 " + fd_v + ", i64 " + bl_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_tcp_accept" {
        fd_v := "%call_ta_fd_" + _i2s(idx)
        gg = _lg_emit(gg, fd_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_ta_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_tcp_accept(i64 " + fd_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_tcp_read" {
        fd_v := "%call_tr_fd_" + _i2s(idx)
        ml_v := "%call_tr_ml_" + _i2s(idx)
        gg = _lg_emit(gg, fd_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, ml_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        srt := _str_ret_type()
        res := "%call_tr_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_tcp_read(i64 " + fd_v + ", i64 " + ml_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "call_tr")
        return gg
    }

    if name == "_aria_tcp_write" {
        fd_v := "%call_tw_fd_" + _i2s(idx)
        ptr_v := "%call_tw_p_" + _i2s(idx)
        len_v := "%call_tw_l_" + _i2s(idx)
        gg = _lg_emit(gg, fd_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 2))
        ptrc := "%call_tw_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptrc + " = inttoptr i64 " + ptr_v + " to i8*")
        res := "%call_tw_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_tcp_write(i64 " + fd_v + ", i8* " + ptrc + ", i64 " + len_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_tcp_close" {
        fd_v := "%call_tc_fd_" + _i2s(idx)
        gg = _lg_emit(gg, fd_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @_aria_tcp_close(i64 " + fd_v + ")")
        return gg
    }

    if name == "_aria_tcp_peer_addr" {
        fd_v := "%call_tpa_fd_" + _i2s(idx)
        gg = _lg_emit(gg, fd_v + " = load i64, i64* " + _t(inst.arg1))
        srt := _str_ret_type()
        res := "%call_tpa_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_tcp_peer_addr(i64 " + fd_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "call_tpa")
        return gg
    }

    if name == "_aria_tcp_set_timeout" {
        fd_v := "%call_tst_fd_" + _i2s(idx)
        k_v := "%call_tst_k_" + _i2s(idx)
        ms_v := "%call_tst_ms_" + _i2s(idx)
        gg = _lg_emit(gg, fd_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, k_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, ms_v + " = load i64, i64* " + _t(inst.arg1 + 2))
        res := "%call_tst_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_tcp_set_timeout(i64 " + fd_v + ", i64 " + k_v + ", i64 " + ms_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    // --- PostgreSQL ---
    if name == "_aria_pg_connect" {
        // str arg (ptr, len) → i64
        ptr_v := "%call_pgc_p_" + _i2s(idx)
        len_v := "%call_pgc_l_" + _i2s(idx)
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        ptrc := "%call_pgc_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptrc + " = inttoptr i64 " + ptr_v + " to i8*")
        res := "%call_pgc_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_pg_connect(i8* " + ptrc + ", i64 " + len_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_pg_close" {
        h_v := "%call_pgcl_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @_aria_pg_close(i64 " + h_v + ")")
        return gg
    }

    if name == "_aria_pg_status" {
        h_v := "%call_pgs_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_pgs_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_pg_status(i64 " + h_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_pg_error" {
        h_v := "%call_pge_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        srt := _str_ret_type()
        res := "%call_pge_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_pg_error(i64 " + h_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "call_pge")
        return gg
    }

    if name == "_aria_pg_exec" {
        // conn (i64) + query str (ptr, len) = 3 temps
        conn_v := "%call_pgex_c_" + _i2s(idx)
        ptr_v := "%call_pgex_p_" + _i2s(idx)
        len_v := "%call_pgex_l_" + _i2s(idx)
        gg = _lg_emit(gg, conn_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 2))
        ptrc := "%call_pgex_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptrc + " = inttoptr i64 " + ptr_v + " to i8*")
        res := "%call_pgex_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_pg_exec(i64 " + conn_v + ", i8* " + ptrc + ", i64 " + len_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_pg_exec_params" {
        // conn (i64) + query str (ptr, len) + params arr (i64) = 4 temps
        conn_v := "%call_pgep_c_" + _i2s(idx)
        ptr_v := "%call_pgep_p_" + _i2s(idx)
        len_v := "%call_pgep_l_" + _i2s(idx)
        arr_v := "%call_pgep_a_" + _i2s(idx)
        gg = _lg_emit(gg, conn_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, ptr_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, len_v + " = load i64, i64* " + _t(inst.arg1 + 2))
        gg = _lg_emit(gg, arr_v + " = load i64, i64* " + _t(inst.arg1 + 3))
        ptrc := "%call_pgep_pc_" + _i2s(idx)
        gg = _lg_emit(gg, ptrc + " = inttoptr i64 " + ptr_v + " to i8*")
        res := "%call_pgep_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_pg_exec_params(i64 " + conn_v + ", i8* " + ptrc + ", i64 " + len_v + ", i64 " + arr_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_pg_result_status" {
        h_v := "%call_pgrs_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_pgrs_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_pg_result_status(i64 " + h_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_pg_result_error" {
        h_v := "%call_pgre_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        srt := _str_ret_type()
        res := "%call_pgre_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_pg_result_error(i64 " + h_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "call_pgre")
        return gg
    }

    if name == "_aria_pg_nrows" {
        h_v := "%call_pgnr_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_pgnr_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_pg_nrows(i64 " + h_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_pg_ncols" {
        h_v := "%call_pgnc_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_pgnc_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_pg_ncols(i64 " + h_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_pg_field_name" {
        // result handle + col index = 2 temps
        h_v := "%call_pgfn_h_" + _i2s(idx)
        c_v := "%call_pgfn_c_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, c_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        srt := _str_ret_type()
        res := "%call_pgfn_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_pg_field_name(i64 " + h_v + ", i64 " + c_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "call_pgfn")
        return gg
    }

    if name == "_aria_pg_get_value" {
        // result handle + row + col = 3 temps
        h_v := "%call_pggv_h_" + _i2s(idx)
        r_v := "%call_pggv_r_" + _i2s(idx)
        c_v := "%call_pggv_c_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, r_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, c_v + " = load i64, i64* " + _t(inst.arg1 + 2))
        srt := _str_ret_type()
        res := "%call_pggv_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_pg_get_value(i64 " + h_v + ", i64 " + r_v + ", i64 " + c_v + ")")
        gg = _extract_str_result(gg, res, inst.dest, idx, "call_pggv")
        return gg
    }

    if name == "_aria_pg_is_null" {
        // result handle + row + col = 3 temps
        h_v := "%call_pgin_h_" + _i2s(idx)
        r_v := "%call_pgin_r_" + _i2s(idx)
        c_v := "%call_pgin_c_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, r_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, c_v + " = load i64, i64* " + _t(inst.arg1 + 2))
        res := "%call_pgin_res_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_pg_is_null(i64 " + h_v + ", i64 " + r_v + ", i64 " + c_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_pg_clear" {
        h_v := "%call_pgcr_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @_aria_pg_clear(i64 " + h_v + ")")
        return gg
    }

    // --- Concurrency ---
    if name == "_aria_spawn" {
        // args: fn_ptr, env_ptr — 2 consecutive i64 temps
        fp_v := "%call_sp_fp_" + _i2s(idx)
        ep_v := "%call_sp_ep_" + _i2s(idx)
        gg = _lg_emit(gg, fp_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, ep_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        res := "%call_sp_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_spawn(i64 " + fp_v + ", i64 " + ep_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_task_await" {
        h_v := "%call_ta_h_" + _i2s(idx)
        gg = _lg_emit(gg, h_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_ta_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_task_await(i64 " + h_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_chan_new" {
        cap_v := "%call_cn_c_" + _i2s(idx)
        gg = _lg_emit(gg, cap_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_cn_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_chan_new(i64 " + cap_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_chan_send" {
        ch_v := "%call_cs_ch_" + _i2s(idx)
        val_v := "%call_cs_v_" + _i2s(idx)
        gg = _lg_emit(gg, ch_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, val_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        res := "%call_cs_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_chan_send(i64 " + ch_v + ", i64 " + val_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_chan_recv" {
        ch_v := "%call_cr_ch_" + _i2s(idx)
        gg = _lg_emit(gg, ch_v + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_cr_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_chan_recv(i64 " + ch_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_chan_close" {
        ch_v := "%call_cc_ch_" + _i2s(idx)
        gg = _lg_emit(gg, ch_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @_aria_chan_close(i64 " + ch_v + ")")
        return gg
    }

    if name == "_aria_mutex_new" {
        res := "%call_mn_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_mutex_new()")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }

    if name == "_aria_mutex_lock" {
        m_v := "%call_ml_m_" + _i2s(idx)
        gg = _lg_emit(gg, m_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @_aria_mutex_lock(i64 " + m_v + ")")
        return gg
    }

    if name == "_aria_mutex_unlock" {
        m_v := "%call_mu_m_" + _i2s(idx)
        gg = _lg_emit(gg, m_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @_aria_mutex_unlock(i64 " + m_v + ")")
        return gg
    }

    // RWMutex
    if name == "_aria_rwmutex_new" {
        res := "%call_rwn_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_rwmutex_new()")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }
    if name == "_aria_rwmutex_rlock" || name == "_aria_rwmutex_runlock" || name == "_aria_rwmutex_wlock" || name == "_aria_rwmutex_wunlock" {
        h := "%call_rw_h_" + _i2s(idx)
        gg = _lg_emit(gg, h + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @" + name + "(i64 " + h + ")")
        return gg
    }
    // WaitGroup
    if name == "_aria_wg_new" {
        res := "%call_wgn_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_wg_new()")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }
    if name == "_aria_wg_add" {
        h := "%call_wga_h_" + _i2s(idx)
        d := "%call_wga_d_" + _i2s(idx)
        gg = _lg_emit(gg, h + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, d + " = load i64, i64* " + _t(inst.arg1 + 1))
        gg = _lg_emit(gg, "call void @_aria_wg_add(i64 " + h + ", i64 " + d + ")")
        return gg
    }
    if name == "_aria_wg_done" || name == "_aria_wg_wait" {
        h := "%call_wg_h_" + _i2s(idx)
        gg = _lg_emit(gg, h + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @" + name + "(i64 " + h + ")")
        return gg
    }
    // Once
    if name == "_aria_once_new" {
        res := "%call_on_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_once_new()")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }
    // Task extended ops
    if name == "_aria_task_done" || name == "_aria_task_result" || name == "_aria_cancel_check" {
        h := "%call_td_h_" + _i2s(idx)
        gg = _lg_emit(gg, h + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_td_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @" + name + "(i64 " + h + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }
    if name == "_aria_task_cancel" {
        h := "%call_tc_h_" + _i2s(idx)
        gg = _lg_emit(gg, h + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, "call void @_aria_task_cancel(i64 " + h + ")")
        return gg
    }
    // Spawn2 / await2 (enhanced task API)
    if name == "_aria_spawn2" {
        fp_v := "%call_sp2_fp_" + _i2s(idx)
        ep_v := "%call_sp2_ep_" + _i2s(idx)
        gg = _lg_emit(gg, fp_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, ep_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        res := "%call_sp2_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_spawn2(i64 " + fp_v + ", i64 " + ep_v + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }
    if name == "_aria_task_await2" {
        h := "%call_ta2_h_" + _i2s(idx)
        gg = _lg_emit(gg, h + " = load i64, i64* " + _t(inst.arg1))
        res := "%call_ta2_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call i64 @_aria_task_await2(i64 " + h + ")")
        gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
        return gg
    }
    // Channel extended ops
    if name == "_aria_chan_try_recv" {
        ch_v := "%call_ctr_ch_" + _i2s(idx)
        gg = _lg_emit(gg, ch_v + " = load i64, i64* " + _t(inst.arg1))
        srt := _str_ret_type()
        res := "%call_ctr_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_chan_try_recv(i64 " + ch_v + ")")
        val := "%call_ctr_v_" + _i2s(idx)
        gg = _lg_emit(gg, val + " = extractvalue " + srt + " " + res + ", 0")
        gg = _lg_emit(gg, "store i64 " + val + ", i64* " + _t(inst.dest))
        sta := "%call_ctr_s_" + _i2s(idx)
        gg = _lg_emit(gg, sta + " = extractvalue " + srt + " " + res + ", 1")
        gg = _lg_emit(gg, "store i64 " + sta + ", i64* " + _t(inst.dest + 1))
        return gg
    }
    if name == "_aria_chan_select" {
        arr_v := "%call_cs_a_" + _i2s(idx)
        to_v := "%call_cs_t_" + _i2s(idx)
        gg = _lg_emit(gg, arr_v + " = load i64, i64* " + _t(inst.arg1))
        gg = _lg_emit(gg, to_v + " = load i64, i64* " + _t(inst.arg1 + 1))
        srt := _str_ret_type()
        res := "%call_cs_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + srt + " @_aria_chan_select(i64 " + arr_v + ", i64 " + to_v + ")")
        idx_v := "%call_cs_i_" + _i2s(idx)
        gg = _lg_emit(gg, idx_v + " = extractvalue " + srt + " " + res + ", 0")
        gg = _lg_emit(gg, "store i64 " + idx_v + ", i64* " + _t(inst.dest))
        val_v := "%call_cs_v_" + _i2s(idx)
        gg = _lg_emit(gg, val_v + " = extractvalue " + srt + " " + res + ", 1")
        gg = _lg_emit(gg, "store i64 " + val_v + ", i64* " + _t(inst.dest + 1))
        return gg
    }

    // Generic user function call
    mut args := ""
    mut ai := 0
    while ai < inst.arg2 {
        if ai > 0 { args = args + ", " }
        av := "%call_a" + _i2s(ai) + "_" + _i2s(idx)
        gg = _lg_emit(gg, av + " = load i64, i64* " + _t(inst.arg1 + ai))
        args = args + "i64 " + av
        ai = ai + 1
    }

    si64 := _struct_i64_i64()

    target_func := mod_find_func(m, name)
    if target_func.name != "" && target_func.return_type == 12 {
        res := "%call_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + si64 + " @" + name + "(" + args + ")")
        r0 := "%call_r0_" + _i2s(idx)
        r1 := "%call_r1_" + _i2s(idx)
        gg = _lg_emit(gg, r0 + " = extractvalue " + si64 + " " + res + ", 0")
        gg = _lg_emit(gg, r1 + " = extractvalue " + si64 + " " + res + ", 1")
        gg = _lg_emit(gg, "store i64 " + r0 + ", i64* " + _t(inst.dest))
        gg = _lg_emit(gg, "store i64 " + r1 + ", i64* " + _t(inst.dest + 1))
        return gg
    }

    if inst.type_id == 12 {
        res := "%call_r_" + _i2s(idx)
        gg = _lg_emit(gg, res + " = call " + si64 + " @" + name + "(" + args + ")")
        r0 := "%call_r0_" + _i2s(idx)
        r1 := "%call_r1_" + _i2s(idx)
        gg = _lg_emit(gg, r0 + " = extractvalue " + si64 + " " + res + ", 0")
        gg = _lg_emit(gg, r1 + " = extractvalue " + si64 + " " + res + ", 1")
        gg = _lg_emit(gg, "store i64 " + r0 + ", i64* " + _t(inst.dest))
        gg = _lg_emit(gg, "store i64 " + r1 + ", i64* " + _t(inst.dest + 1))
        return gg
    }

    if target_func.name != "" && target_func.return_type == 0 {
        gg = _lg_emit(gg, "call void @" + name + "(" + args + ")")
        return gg
    }

    res := "%call_r_" + _i2s(idx)
    gg = _lg_emit(gg, res + " = call i64 @" + name + "(" + args + ")")
    gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
    gg
}

// ============================================================
// Float helpers
// ============================================================

fn _gen_float_binop(g: LlvmGen, llvm_op: str, inst: IrInst, idx: i64) -> LlvmGen {
    mut gg := g
    ai := "%fb_ai_" + _i2s(idx)
    bi := "%fb_bi_" + _i2s(idx)
    gg = _lg_emit(gg, ai + " = load i64, i64* " + _t(inst.arg1))
    gg = _lg_emit(gg, bi + " = load i64, i64* " + _t(inst.arg2))
    af := "%fb_af_" + _i2s(idx)
    bf := "%fb_bf_" + _i2s(idx)
    gg = _lg_emit(gg, af + " = bitcast i64 " + ai + " to double")
    gg = _lg_emit(gg, bf + " = bitcast i64 " + bi + " to double")
    rf := "%fb_rf_" + _i2s(idx)
    gg = _lg_emit(gg, rf + " = " + llvm_op + " double " + af + ", " + bf)
    ri := "%fb_ri_" + _i2s(idx)
    gg = _lg_emit(gg, ri + " = bitcast double " + rf + " to i64")
    gg = _lg_emit(gg, "store i64 " + ri + ", i64* " + _t(inst.dest))
    gg
}

fn _gen_fcmp(g: LlvmGen, cmp_op: str, inst: IrInst, idx: i64) -> LlvmGen {
    mut gg := g
    ai := "%fc_ai_" + _i2s(idx)
    bi := "%fc_bi_" + _i2s(idx)
    gg = _lg_emit(gg, ai + " = load i64, i64* " + _t(inst.arg1))
    gg = _lg_emit(gg, bi + " = load i64, i64* " + _t(inst.arg2))
    af := "%fc_af_" + _i2s(idx)
    bf := "%fc_bf_" + _i2s(idx)
    gg = _lg_emit(gg, af + " = bitcast i64 " + ai + " to double")
    gg = _lg_emit(gg, bf + " = bitcast i64 " + bi + " to double")
    cmp := "%fc_c_" + _i2s(idx)
    gg = _lg_emit(gg, cmp + " = fcmp " + cmp_op + " double " + af + ", " + bf)
    res := "%fc_r_" + _i2s(idx)
    gg = _lg_emit(gg, res + " = zext i1 " + cmp + " to i64")
    gg = _lg_emit(gg, "store i64 " + res + ", i64* " + _t(inst.dest))
    gg
}
