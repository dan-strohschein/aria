mod codegen

// ============================================================
// LLVM IR Generator
// Translates IrModule → LLVM IR text (.ll file)
// Uses alloca+load/store for all temps (LLVM mem2reg optimizes)
//
// Performance: uses [str] parts arrays + divide-and-conquer join
// to avoid O(n²) string concatenation.
// ============================================================

// Brace helpers (Aria requires escaped braces in strings)
fn _lb() -> str = "\{"
fn _rb() -> str = "\}"
fn _nl() -> str = "\n"

// ============================================================
// Fast string join: divide-and-conquer O(L * log N)
// ============================================================

// Join string array into one string.
// Uses chunked approach: join groups of 64, then join the chunks.
// This is O(L * N/64 + L * 64) ≈ O(L * N/64) instead of O(L * N).
fn _join(parts: [str]) -> str {
    // First pass: join chunks of 64 parts
    mut chunks := [""]
    mut i := 1
    while i < parts.len() {
        mut chunk := ""
        mut j := 0
        while j < 64 && (i + j) < parts.len() {
            chunk = chunk + parts[i + j]
            j = j + 1
        }
        chunks = chunks.append(chunk)
        i = i + 64
    }
    // Second pass: join the chunks
    mut result := ""
    mut ci := 1
    while ci < chunks.len() {
        result = result + chunks[ci]
        ci = ci + 1
    }
    return result
}

// --- String constant escaping ---

fn _llvm_escape_str(s: str) -> str {
    mut result := ""
    mut i := 0
    while i < s.len() {
        ch := s.charAt(i)
        if ch == "\\" {
            result = result + "\\5C"
        } else if ch == "\"" {
            result = result + "\\22"
        } else if ch == "\n" {
            result = result + "\\0A"
        } else if ch == "\r" {
            result = result + "\\0D"
        } else if ch == "\t" {
            result = result + "\\09"
        } else {
            result = result + ch
        }
        i = i + 1
    }
    result
}

// --- LLVM IR text builder (array-based) ---

struct LlvmGen {
    parts: [str]
    label_counter: i64
    last_was_term: bool
}

fn _lg_new() -> LlvmGen = LlvmGen{parts: [""], label_counter: 0, last_was_term: false}

fn _lg_emit(g: LlvmGen, line: str) -> LlvmGen =
    LlvmGen{parts: g.parts.append("  " + line + "\n"), label_counter: g.label_counter, last_was_term: false}

fn _lg_emit_term(g: LlvmGen, line: str) -> LlvmGen =
    LlvmGen{parts: g.parts.append("  " + line + "\n"), label_counter: g.label_counter, last_was_term: true}

fn _lg_emit_label(g: LlvmGen, label: str) -> LlvmGen =
    LlvmGen{parts: g.parts.append(label + ":\n"), label_counter: g.label_counter, last_was_term: false}

fn _lg_fresh_label(g: LlvmGen) -> LT_label {
    id := g.label_counter + 1
    LT_label{g: LlvmGen{parts: g.parts, label_counter: id, last_was_term: g.last_was_term}, id: id}
}

struct LT_label {
    g: LlvmGen
    id: i64
}

fn _i2s(n: i64) -> str {
    if n < 0 { return "-" + _i2s(0 - n) }
    if n == 0 { return "0" }
    if n == 1 { return "1" }
    if n == 2 { return "2" }
    if n == 3 { return "3" }
    if n == 4 { return "4" }
    if n == 5 { return "5" }
    if n == 6 { return "6" }
    if n == 7 { return "7" }
    if n == 8 { return "8" }
    if n == 9 { return "9" }
    return _i2s(n / 10) + _i2s(n % 10)
}

fn _t(n: i64) -> str = "%t" + _i2s(n)
fn _v(n: i64) -> str = "%v" + _i2s(n)
fn _lbl(n: i64) -> str = "L" + _i2s(n)
fn _fall(n: i64) -> str = "Lfall" + _i2s(n)

fn _struct_i64_i64() -> str = _lb() + " i64, i64 " + _rb()

// Collect all function names called by OpCall instructions
fn _collect_called_names(m: IrModule) -> [str] {
    mut names := [""]
    mut fi := 1
    while fi < m.funcs.len() {
        f := m.funcs[fi]
        mut ii := 1
        while ii < f.insts.len() {
            if ir_op_name(f.insts[ii].op) == "Call" {
                cname := f.insts[ii].s1
                if _name_in_list(cname, names) == false {
                    names = names.append(cname)
                }
            }
            ii = ii + 1
        }
        fi = fi + 1
    }
    return names
}

fn _name_in_list(name: str, list: [str]) -> bool {
    mut i := 1
    while i < list.len() {
        if list[i] == name { return true }
        i = i + 1
    }
    return false
}

// ============================================================
// Main entry: generate_llvm_ir
// ============================================================

fn generate_llvm_ir(m: IrModule) -> str {
    nl := _nl()
    si64 := _struct_i64_i64()
    mut p := [""]

    // Module header
    p = p.append("target datalayout = \"e-m:o-i64:64-i128:128-n32:64-S128\"" + nl)
    p = p.append("target triple = \"arm64-apple-macosx14.0.0\"" + nl + nl)

    // String constants
    mut si := 1
    while si < m.string_constants.len() {
        s := m.string_constants[si]
        escaped := _llvm_escape_str(s)
        slen := s.len()
        p = p.append("@.str." + _i2s(si) + " = private unnamed_addr constant [" + _i2s(slen + 1) + " x i8] c\"" + escaped + "\\00\"" + nl)
        si = si + 1
    }
    p = p.append(nl)

    // Runtime declarations
    p = p.append("; Runtime declarations" + nl)
    p = p.append("declare void @_aria_exit(i64)" + nl)
    p = p.append("declare i64 @_aria_write(i64, i8*, i64)" + nl)
    p = p.append("declare void @_aria_println_str(i8*, i64)" + nl)
    p = p.append("declare void @_aria_print_str(i8*, i64)" + nl)
    p = p.append("declare void @_aria_eprintln_str(i8*, i64)" + nl)
    p = p.append("declare i8* @_aria_alloc(i64)" + nl)
    p = p.append("declare void @_aria_memcpy(i8*, i8*, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_read_file(i8*, i64)" + nl)
    p = p.append("declare void @_aria_write_file(i8*, i64, i8*, i64)" + nl)
    p = p.append("declare void @_aria_write_binary_file(i8*, i64, i64*, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_int_to_str(i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_str_concat(i8*, i64, i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_str_eq(i8*, i64, i8*, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_str_charAt(i8*, i64, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_str_substring(i8*, i64, i64, i64)" + nl)
    p = p.append("declare i64 @_aria_str_contains(i8*, i64, i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_str_startsWith(i8*, i64, i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_str_endsWith(i8*, i64, i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_str_indexOf(i8*, i64, i8*, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_str_trim(i8*, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_str_replace(i8*, i64, i8*, i64, i8*, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_str_toLower(i8*, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_str_toUpper(i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_str_split(i8*, i64, i8*, i64)" + nl)
    p = p.append("declare void @_aria_map_set_str(i64, i8*, i64, i64, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_map_get_str(i64, i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_array_new(i64)" + nl)
    p = p.append("declare i64 @_aria_array_len(i64)" + nl)
    p = p.append("declare i64 @_aria_array_get(i64, i64)" + nl)
    p = p.append("declare void @_aria_array_set(i64, i64, i64)" + nl)
    p = p.append("declare i64 @_aria_array_append(i64, i64)" + nl)
    p = p.append("declare i64 @_aria_array_slice(i64, i64)" + nl)
    p = p.append("declare i64 @_aria_list_dir(i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_is_dir(i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_args_get()" + nl)
    p = p.append("declare i64 @_aria_exec(i8*, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_str_to_int(i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_str_to_float(i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_map_new(i64)" + nl)
    p = p.append("declare void @_aria_map_set(i64, i8*, i64, i64)" + nl)
    p = p.append("declare i64 @_aria_map_get(i64, i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_map_contains(i64, i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_map_len(i64)" + nl)
    p = p.append("declare i64 @_aria_map_keys(i64)" + nl)
    // Networking + environment
    p = p.append("declare " + si64 + " @_aria_getenv(i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_tcp_socket()" + nl)
    p = p.append("declare i64 @_aria_tcp_bind(i64, i8*, i64, i64)" + nl)
    p = p.append("declare i64 @_aria_tcp_listen(i64, i64)" + nl)
    p = p.append("declare i64 @_aria_tcp_accept(i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_tcp_read(i64, i64)" + nl)
    p = p.append("declare i64 @_aria_tcp_write(i64, i8*, i64)" + nl)
    p = p.append("declare void @_aria_tcp_close(i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_tcp_peer_addr(i64)" + nl)
    p = p.append("declare i64 @_aria_tcp_set_timeout(i64, i64, i64)" + nl)
    // PostgreSQL
    p = p.append("declare i64 @_aria_pg_connect(i8*, i64)" + nl)
    p = p.append("declare void @_aria_pg_close(i64)" + nl)
    p = p.append("declare i64 @_aria_pg_status(i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_pg_error(i64)" + nl)
    p = p.append("declare i64 @_aria_pg_exec(i64, i8*, i64)" + nl)
    p = p.append("declare i64 @_aria_pg_exec_params(i64, i8*, i64, i64)" + nl)
    p = p.append("declare i64 @_aria_pg_result_status(i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_pg_result_error(i64)" + nl)
    p = p.append("declare i64 @_aria_pg_nrows(i64)" + nl)
    p = p.append("declare i64 @_aria_pg_ncols(i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_pg_field_name(i64, i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_pg_get_value(i64, i64, i64)" + nl)
    p = p.append("declare i64 @_aria_pg_is_null(i64, i64, i64)" + nl)
    p = p.append("declare void @_aria_pg_clear(i64)" + nl)
    // Concurrency
    p = p.append("declare i64 @_aria_spawn(i64, i64)" + nl)
    p = p.append("declare i64 @_aria_task_await(i64)" + nl)
    p = p.append("declare i64 @_aria_chan_new(i64)" + nl)
    p = p.append("declare i64 @_aria_chan_send(i64, i64)" + nl)
    p = p.append("declare i64 @_aria_chan_recv(i64)" + nl)
    p = p.append("declare void @_aria_chan_close(i64)" + nl)
    p = p.append("declare i64 @_aria_mutex_new()" + nl)
    p = p.append("declare void @_aria_mutex_lock(i64)" + nl)
    p = p.append("declare void @_aria_mutex_unlock(i64)" + nl)
    // RWMutex, WaitGroup, Once
    p = p.append("declare i64 @_aria_rwmutex_new()" + nl)
    p = p.append("declare void @_aria_rwmutex_rlock(i64)" + nl)
    p = p.append("declare void @_aria_rwmutex_runlock(i64)" + nl)
    p = p.append("declare void @_aria_rwmutex_wlock(i64)" + nl)
    p = p.append("declare void @_aria_rwmutex_wunlock(i64)" + nl)
    p = p.append("declare i64 @_aria_wg_new()" + nl)
    p = p.append("declare void @_aria_wg_add(i64, i64)" + nl)
    p = p.append("declare void @_aria_wg_done(i64)" + nl)
    p = p.append("declare void @_aria_wg_wait(i64)" + nl)
    p = p.append("declare i64 @_aria_once_new()" + nl)
    p = p.append("declare i64 @_aria_once_call(i64, i64, i64)" + nl)
    // Extended channel/task ops
    p = p.append("declare " + si64 + " @_aria_chan_try_recv(i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_chan_select(i64, i64)" + nl)
    p = p.append("declare i64 @_aria_spawn2(i64, i64)" + nl)
    p = p.append("declare i64 @_aria_task_await2(i64)" + nl)
    p = p.append("declare i64 @_aria_task_done(i64)" + nl)
    p = p.append("declare void @_aria_task_cancel(i64)" + nl)
    p = p.append("declare i64 @_aria_task_result(i64)" + nl)
    p = p.append("declare i64 @_aria_cancel_check(i64)" + nl)
    p = p.append("declare " + si64 + " @_aria_float_to_str(i64)" + nl)
    p = p.append(nl)

    // _aria_panic: print message to stderr and exit(1)
    ob := "\{"
    cb := "\}"
    p = p.append("define void @_aria_panic(i8* %ptr, i64 %len) " + ob + nl)
    p = p.append("  call void @_aria_eprintln_str(i8* %ptr, i64 %len)" + nl)
    p = p.append("  call void @_aria_exit(i64 1)" + nl)
    p = p.append("  unreachable" + nl)
    p = p.append(cb + nl)
    p = p.append(nl)

    // User functions — collect defined names for forward declarations
    mut defined_names := [""]
    mut fi := 1
    while fi < m.funcs.len() {
        f := m.funcs[fi]
        if f.name != "" {
            defined_names = defined_names.append(f.name)
            fn_parts := _gen_function(m, f)
            mut fpi := 1
            while fpi < fn_parts.len() {
                p = p.append(fn_parts[fpi])
                fpi = fpi + 1
            }
            p = p.append(nl)
        }
        fi = fi + 1
    }

    // Forward-declare any called but undefined functions as i64(...)
    // This handles functions lost during multi-file token merging
    mut called_names := _collect_called_names(m)
    mut ci := 1
    while ci < called_names.len() {
        cname := called_names[ci]
        if _name_in_list(cname, defined_names) == false {
            // Check it's not a runtime function (already declared above)
            if cname.startsWith("_aria_") == false {
                // Declare as varargs i64 return
                p = p.append("declare i64 @" + cname + "(...)" + nl)
            }
        }
        ci = ci + 1
    }

    // Entry point wrapper
    if m.entry_func != "" {
        lb := _lb()
        rb := _rb()
        p = p.append("; Entry wrapper" + nl)
        p = p.append("define void @_aria_entry() " + lb + nl)
        p = p.append("entry:" + nl)
        p = p.append("  call void @" + m.entry_func + "()" + nl)
        p = p.append("  ret void" + nl)
        p = p.append(rb + nl + nl)
    }

    _join(p)
}

// ============================================================
// Generate one function → returns [str] parts
// ============================================================

fn _gen_function(m: IrModule, f: IrFunc) -> [str] {
    nl := _nl()
    lb := _lb()
    rb := _rb()
    si64 := _struct_i64_i64()

    mut ret_type := "void"
    mut is_void := true
    if f.return_type == 12 {
        ret_type = si64
        is_void = false
    } else if f.return_type > 0 {
        ret_type = "i64"
        is_void = false
    }

    mut has_ret := false
    mut ii := 1
    while ii < f.insts.len() {
        op := ir_op_name(f.insts[ii].op)
        if op == "Ret" { has_ret = true }
        ii = ii + 1
    }
    if has_ret && is_void {
        ret_type = "i64"
        is_void = false
    }

    mut params := ""
    mut pi := 0
    while pi < f.param_count {
        if pi > 0 { params = params + ", " }
        params = params + "i64 %p" + _i2s(pi)
        pi = pi + 1
    }

    mut p := [""]
    p = p.append("define " + ret_type + " @" + f.name + "(" + params + ") " + lb + nl)
    p = p.append("entry:" + nl)

    // Allocate all temps — only count fields that are temp references
    // Skip: OpConst (arg1 = value), OpConstStr (arg1 = str_id, arg2 = str_len),
    //        OpFieldGet/Set (arg2 = field index), OpLabel/Jump/Branch (arg1/arg2 = label)
    mut max_temp := f.param_count
    mut ti := 1
    while ti < f.insts.len() {
        inst := f.insts[ti]
        op := ir_op_name(inst.op)
        if inst.dest > max_temp { max_temp = inst.dest }
        // arg1 is a temp for most ops except Const, ConstStr, Jump, Label
        if op != "Const" && op != "ConstStr" && op != "Jump" && op != "Label" && op != "Nop" {
            if inst.arg1 > max_temp { max_temp = inst.arg1 }
        }
        // arg2 is a temp for binary ops and ArrayGet, but NOT for FieldGet/Set (field index),
        // ConstStr (length), Call (reg count), Branch (label)
        if op != "FieldGet" && op != "FieldSet" && op != "ConstStr" && op != "Call" &&
           op != "CallIndirect" && op != "FnRef" &&
           op != "BranchTrue" && op != "BranchFalse" && op != "Nop" && op != "Const" &&
           op != "Alloc" && op != "Jump" && op != "Label" &&
           op != "TraitObject" && op != "VtableCall" {
            if inst.arg2 > max_temp { max_temp = inst.arg2 }
        }
        ti = ti + 1
    }
    max_temp = max_temp + 2

    mut ai := 0
    while ai <= max_temp {
        p = p.append("  " + _t(ai) + " = alloca i64, align 8" + nl)
        ai = ai + 1
    }

    // Store parameters
    pi = 0
    while pi < f.param_count {
        p = p.append("  store i64 %p" + _i2s(pi) + ", i64* " + _t(pi) + nl)
        pi = pi + 1
    }

    // Generate instructions
    mut g := _lg_new()
    mut idx := 1
    while idx < f.insts.len() {
        inst := f.insts[idx]
        g = _gen_inst(g, m, f, inst, idx)
        idx = idx + 1
    }

    // Default return
    if g.last_was_term == false {
        if is_void {
            g = _lg_emit_term(g, "ret void")
        } else if ret_type == si64 {
            g = _lg_emit_term(g, "ret " + si64 + " zeroinitializer")
        } else {
            g = _lg_emit_term(g, "ret i64 0")
        }
    }

    // Merge instruction parts into function parts
    mut gi := 1
    while gi < g.parts.len() {
        p = p.append(g.parts[gi])
        gi = gi + 1
    }

    p = p.append(rb + nl)
    p
}

// ============================================================
// Generate one IR instruction
// ============================================================

fn _gen_inst(g: LlvmGen, m: IrModule, f: IrFunc, inst: IrInst, idx: i64) -> LlvmGen {
    op := ir_op_name(inst.op)

    if op == "Nop" { return g }

    if op == "Const" {
        return _lg_emit(g, "store i64 " + _i2s(inst.arg1) + ", i64* " + _t(inst.dest))
    }

    if op == "ConstStr" {
        str_id := inst.arg1
        str_len := inst.arg2
        // Float constant marker: arg2 == -9
        if str_len == 0 - 9 {
            // Float literal — str_id points to the literal text in string constants
            float_text := m.string_constants[str_id]
            mut gg := g
            fval := "%fconst_" + _i2s(idx)
            gg = _lg_emit(gg, fval + " = bitcast double " + float_text + " to i64")
            gg = _lg_emit(gg, "store i64 " + fval + ", i64* " + _t(inst.dest))
            return gg
        }
        mut gg := g
        lbl := _lg_fresh_label(gg)
        gg = lbl.g
        tmp_name := "%str_ptr_" + _i2s(lbl.id)
        gg = _lg_emit(gg, tmp_name + " = getelementptr [" + _i2s(str_len + 1) + " x i8], [" + _i2s(str_len + 1) + " x i8]* @.str." + _i2s(str_id) + ", i64 0, i64 0")
        tmp_int := "%str_int_" + _i2s(lbl.id)
        gg = _lg_emit(gg, tmp_int + " = ptrtoint i8* " + tmp_name + " to i64")
        gg = _lg_emit(gg, "store i64 " + tmp_int + ", i64* " + _t(inst.dest))
        gg = _lg_emit(gg, "store i64 " + _i2s(str_len) + ", i64* " + _t(inst.dest + 1))
        return gg
    }


    if op == "Add" {
        if inst.s1 == "f64" { return _gen_float_binop(g, "fadd", inst, idx) }
        return _gen_binop(g, "add", inst)
    }
    if op == "Sub" {
        if inst.s1 == "f64" { return _gen_float_binop(g, "fsub", inst, idx) }
        return _gen_binop(g, "sub", inst)
    }
    if op == "Mul" {
        if inst.s1 == "f64" { return _gen_float_binop(g, "fmul", inst, idx) }
        return _gen_binop(g, "mul", inst)
    }
    if op == "Div" {
        if inst.s1 == "f64" { return _gen_float_binop(g, "fdiv", inst, idx) }
        return _gen_binop(g, "sdiv", inst)
    }
    if op == "Mod" { return _gen_binop(g, "srem", inst) }



    if op == "Neg" {
        if inst.s1 == "f64" {
            mut gg := g
            v := "%fneg_v_" + _i2s(idx)
            gg = _lg_emit(gg, v + " = load i64, i64* " + _t(inst.arg1))
            dv := "%fneg_d_" + _i2s(idx)
            gg = _lg_emit(gg, dv + " = bitcast i64 " + v + " to double")
            res := "%fneg_r_" + _i2s(idx)
            gg = _lg_emit(gg, res + " = fneg double " + dv)
            ri := "%fneg_i_" + _i2s(idx)
            gg = _lg_emit(gg, ri + " = bitcast double " + res + " to i64")
