            if name == "_ariaTcpPeerAddr" {
                ll = _ladv(ll)  // skip (
                fd_arg := _lower_expr(ll)
                ll = fd_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_str_temp(ll)
