                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_pg_close", 0))
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgStatus" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
