                ll = _lemit(ll, new_inst(OpCall, nt.temp, fd_arg.temp, 1, "_aria_tcp_peer_addr", 12))
                ll = _lset_type(ll, nt.temp, 12)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaTcpSetTimeout" {
                ll = _ladv(ll)  // skip (
                fd_arg := _lower_expr(ll)
