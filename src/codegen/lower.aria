            if name == "_ariaTcpClose" {
                ll = _ladv(ll)  // skip (
                fd_arg := _lower_expr(ll)
                ll = fd_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, fd_arg.temp, 1, "_aria_tcp_close", 0))
                return LT{l: ll, temp: nt.temp}
