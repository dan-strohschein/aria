                // fd (1 temp) + str (2 temps) = 3 consecutive temps
                ll = _lemit(ll, new_inst(OpCall, nt.temp, fd_arg.temp, 3, "_aria_tcp_write", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
