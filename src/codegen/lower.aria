                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, path_arg.temp, 4, "_aria_write_file", 0))
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaExec" {
                ll = _ladv(ll)  // skip (
                // One arg: command (str = 2 temps)
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                // String arg = 2 regs (ptr + len), returns i64 exit code
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 2, "_aria_exec", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaArgs" {
                // Skip args
                ll = _ladv(ll)
                while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                // Call _aria_args runtime to get the args array (type 13 = [str])
                ll = _lemit(ll, new_inst(OpCall, nt.temp, 0, 0, "_aria_args", 0))
                ll = _lset_type(ll, nt.temp, 13)
                return LT{l: ll, temp: nt.temp}
            }
            // --- Environment ---
            if name == "_ariaGetenv" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 2, "_aria_getenv", 12))
                ll = _lset_type(ll, nt.temp, 12)
                return LT{l: ll, temp: nt.temp}
            }

            // --- TCP Networking ---
            if name == "_ariaTcpSocket" {
                ll = _ladv(ll)  // skip (
                while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, 0, 0, "_aria_tcp_socket", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaTcpBind" {
                ll = _ladv(ll)  // skip (
                // args: fd, addr (str = 2 temps), port
                fd_arg := _lower_expr(ll)
                ll = fd_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                addr_arg := _lower_expr(ll)
                ll = addr_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                port_arg := _lower_expr(ll)
                ll = port_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                // Pack: fd, addr_ptr, addr_len, port into consecutive temps
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, fd_arg.temp, 4, "_aria_tcp_bind", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaTcpListen" {
                ll = _ladv(ll)  // skip (
                fd_arg := _lower_expr(ll)
                ll = fd_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                backlog_arg := _lower_expr(ll)
                ll = backlog_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, fd_arg.temp, 2, "_aria_tcp_listen", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaTcpAccept" {
                ll = _ladv(ll)  // skip (
                fd_arg := _lower_expr(ll)
                ll = fd_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, fd_arg.temp, 1, "_aria_tcp_accept", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaTcpRead" {
                ll = _ladv(ll)  // skip (
                fd_arg := _lower_expr(ll)
                ll = fd_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
