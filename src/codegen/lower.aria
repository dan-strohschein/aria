                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_pg_status", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgError" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_pg_error", 12))
                ll = _lset_type(ll, nt.temp, 12)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgExec" {
                ll = _ladv(ll)  // skip (
                conn_arg := _lower_expr(ll)
                ll = conn_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                query_arg := _lower_expr(ll)
                ll = query_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                // conn (1 temp) + str (2 temps) = 3 consecutive temps
                ll = _lemit(ll, new_inst(OpCall, nt.temp, conn_arg.temp, 3, "_aria_pg_exec", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgExecParams" {
                ll = _ladv(ll)  // skip (
                conn_arg := _lower_expr(ll)
                ll = conn_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                query_arg := _lower_expr(ll)
                ll = query_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                params_arg := _lower_expr(ll)
                ll = params_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                // conn (1) + str (2) + arr handle (1) = 4 consecutive temps
                ll = _lemit(ll, new_inst(OpCall, nt.temp, conn_arg.temp, 4, "_aria_pg_exec_params", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgResultStatus" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_pg_result_status", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgResultError" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_pg_result_error", 12))
                ll = _lset_type(ll, nt.temp, 12)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgNrows" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_pg_nrows", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgNcols" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_pg_ncols", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgFieldName" {
                ll = _ladv(ll)  // skip (
                res_arg := _lower_expr(ll)
                ll = res_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                col_arg := _lower_expr(ll)
                ll = col_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, res_arg.temp, 2, "_aria_pg_field_name", 12))
                ll = _lset_type(ll, nt.temp, 12)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgGetValue" {
                ll = _ladv(ll)  // skip (
                res_arg := _lower_expr(ll)
                ll = res_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                row_arg := _lower_expr(ll)
                ll = row_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                col_arg := _lower_expr(ll)
                ll = col_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, res_arg.temp, 3, "_aria_pg_get_value", 12))
                ll = _lset_type(ll, nt.temp, 12)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgIsNull" {
                ll = _ladv(ll)  // skip (
                res_arg := _lower_expr(ll)
                ll = res_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                row_arg := _lower_expr(ll)
                ll = row_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                col_arg := _lower_expr(ll)
                ll = col_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, res_arg.temp, 3, "_aria_pg_is_null", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaPgClear" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_pg_clear", 0))
                return LT{l: ll, temp: nt.temp}
            }

            // --- Concurrency ---
            if name == "_ariaSpawn" {
                ll = _ladv(ll)  // skip (
                // One arg: closure (fat pointer = fn_ptr + env_ptr)
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                // Extract fn_ptr (slot 0) and env_ptr (slot 1) from closure
                fn_ptr_nt := _lnew_temp(ll)
                ll = fn_ptr_nt.l
                ll = _lemit(ll, new_inst(OpFieldGet, fn_ptr_nt.temp, arg.temp, 0, "_fn", 0))
                env_ptr_nt := _lnew_temp(ll)
                ll = env_ptr_nt.l
                ll = _lemit(ll, new_inst(OpFieldGet, env_ptr_nt.temp, arg.temp, 1, "_env", 0))
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, fn_ptr_nt.temp, 2, "_aria_spawn", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaTaskAwait" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_task_await", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaChanNew" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_chan_new", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaChanSend" {
                ll = _ladv(ll)  // skip (
                ch_arg := _lower_expr(ll)
                ll = ch_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                val_arg := _lower_expr(ll)
                ll = val_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                // Pack into consecutive temps
                pack0 := _lnew_temp(ll)
                ll = pack0.l
                ll = _lemit(ll, new_inst(OpStore, pack0.temp, ch_arg.temp, 0, "", 0))
                pack1 := _lnew_temp(ll)
                ll = pack1.l
                ll = _lemit(ll, new_inst(OpStore, pack1.temp, val_arg.temp, 0, "", 0))
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, pack0.temp, 2, "_aria_chan_send", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaChanRecv" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_chan_recv", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaChanClose" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_chan_close", 0))
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaMutexNew" {
                ll = _ladv(ll)  // skip (
                while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, 0, 0, "_aria_mutex_new", 1))
                ll = _lset_type(ll, nt.temp, 1)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaMutexLock" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_mutex_lock", 0))
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaMutexUnlock" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_mutex_unlock", 0))
                return LT{l: ll, temp: nt.temp}
            }

            // Check if it's a closure/function variable — indirect call
            fn_slot := _lenv_lookup(ll, name)
            if fn_slot >= 0 {
                // Load fat pointer (closure object)
                closure_nt := _lnew_temp(ll)
                ll = closure_nt.l
                ll = _lemit(ll, new_inst(OpLoad, closure_nt.temp, fn_slot, 0, "", 0))
                // Extract fn_ptr from slot 0 and env_ptr from slot 1
                fn_ptr_nt := _lnew_temp(ll)
                ll = fn_ptr_nt.l
                ll = _lemit(ll, new_inst(OpFieldGet, fn_ptr_nt.temp, closure_nt.temp, 0, "_fn", 0))
                env_ptr_nt := _lnew_temp(ll)
                ll = env_ptr_nt.l
                ll = _lemit(ll, new_inst(OpFieldGet, env_ptr_nt.temp, closure_nt.temp, 1, "_env", 0))
                // Collect args
                ll = _ladv(ll)  // skip (
                ll = _lskip_nl(ll)
                mut first_arg := -1
                mut ic_arg_count := 0
                while _lk(ll) != ")" && _lk(ll) != "EOF" {
                    ll = _lskip_nl(ll)
                    arg := _lower_expr(ll)
                    ll = arg.l
                    if ic_arg_count == 0 { first_arg = arg.temp }
                    ic_arg_count = ic_arg_count + 1
                    ll = _lskip_nl(ll)
                    if _lk(ll) == "," { ll = _ladv(ll) }
                }
                if _lk(ll) == ")" { ll = _ladv(ll) }
                // Store env_ptr as first arg, then user args follow
                // We use OpStore to pack: env_ptr at first_arg-1 position
                // Actually: emit CallIndirect with env_ptr and user args
                // The function expects (env_ptr, arg0, arg1, ...)
                nt := _lnew_temp(ll)
                ll = nt.l
                mut fa := env_ptr_nt.temp
                // CallIndirect: fn_ptr, arg_count+1 (including env), first_arg = env_ptr
                // The user args follow env_ptr in consecutive temps
                // We need to pack env_ptr + user args into consecutive temps
                // Simplest: store env_ptr into a temp, then args follow
                // But args may not be consecutive with env_ptr...
                // Solution: copy env_ptr and all args into consecutive temps
                pack_start := _lnew_temp(ll)
                ll = pack_start.l
                ll = _lemit(ll, new_inst(OpStore, pack_start.temp, env_ptr_nt.temp, 0, "", 0))
                mut pack_idx := 1
                if ic_arg_count > 0 && first_arg >= 0 {
                    mut ai := 0
                    while ai < ic_arg_count {
                        pack_t := _lnew_temp(ll)
                        ll = pack_t.l
                        ll = _lemit(ll, new_inst(OpLoad, pack_t.temp, first_arg + ai, 0, "", 0))
                        ll = _lemit(ll, new_inst(OpStore, pack_start.temp + pack_idx, pack_t.temp, 0, "", 0))
                        pack_idx = pack_idx + 1
                        ai = ai + 1
                    }
                }
                total_args := ic_arg_count + 1
                ll = _lemit(ll, new_inst(OpCallIndirect, nt.temp, fn_ptr_nt.temp, total_args, "", pack_start.temp))
                return LT{l: ll, temp: nt.temp}
            }
            // Truly unknown — skip args
            ll = _ladv(ll)
            while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
            if _lk(ll) == ")" { ll = _ladv(ll) }
            nt := _lnew_temp(ll)
            ll = nt.l
            return LT{l: ll, temp: nt.temp}
        }

        // Generic struct literal: Name[Type]{...}
        lb := "\{"
        if _lk(ll) == "[" {
            sdef := reg_find_struct(ll.registry, name)
            if sdef.name != "" && struct_is_generic(sdef) {
                // Skip type args: [Type, ...]
                mut gd := 1
                ll = _ladv(ll)  // skip [
                // Build specialized name from type args
                mut gs_suffix := ""
                while gd > 0 && _lk(ll) != "EOF" {
                    if _lk(ll) == "[" { gd = gd + 1 }
                    if _lk(ll) == "]" { gd = gd - 1 }
                    if gd > 0 {
                        if _lk(ll) == "IDENT" && gs_suffix == "" {
                            // First type arg — resolve its name to build suffix
                            ta_name := _lcur(ll).text
                            ta_id := resolve_type_name(ll.store, ta_name)
                            gs_suffix = _type_name_suffix(ll.store, ta_id)
                        }
                        ll = _ladv(ll)
                    }
                }
                if _lk(ll) == "]" { ll = _ladv(ll) }
                // Build specialized struct name
                mut spec_sname := name
                if gs_suffix != "" {
                    spec_sname = name + "_" + gs_suffix
                }
                // Lower as regular struct literal with specialized name
                if _lk(ll) == lb {
                    return _lower_struct_lit(ll, spec_sname)
                }
            }
        }

        // Struct literal — only if name is a known struct type
        if _lk(ll) == lb {
            sdef := reg_find_struct(ll.registry, name)
            if sdef.name != "" {
                return _lower_struct_lit(ll, name)
            }
        }

        // None — Optional empty value
        if name == "None" {
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpAlloc, nt.temp, 1, 0, "_Optional", 0))
            tag_nt := _lnew_temp(ll)
            ll = tag_nt.l
            ll = _lemit(ll, new_inst(OpConst, tag_nt.temp, 0, 0, "", 0))
            ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, tag_nt.temp, 0, "_tag", 0))
            ll = _lset_type(ll, nt.temp, 201)
            return LT{l: ll, temp: nt.temp}
        }

        // Variable reference
        slot := _lenv_lookup(ll, name)
        if slot >= 0 {
            src_type := _lget_type(ll, slot)
            if src_type == 12 {
                // String: copy both ptr (slot) and len (slot+1)
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpLoad, nt.temp, slot, 0, "", 0))
                ll = _lemit(ll, new_inst(OpLoad, nt.temp + 1, slot + 1, 0, "", 0))
                ll = _lset_type(ll, nt.temp, 12)
                return LT{l: ll, temp: nt.temp}
            } else {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpLoad, nt.temp, slot, 0, "", 0))
                if src_type != 0 {
                    ll = _lset_type(ll, nt.temp, src_type)
                }
                return LT{l: ll, temp: nt.temp}
            }
        }

        // Sum type variant — tag-only (data variants handled above in function call section)
        tag := _variant_tag(ll.registry, name)
        if tag > 0 {
            parent := _variant_parent(ll.registry, name)
            if sum_has_data(parent) {
                // Tag-only variant in a sum type that has data variants:
                // allocate struct with tag but no data
                alloc_sz := sum_alloc_size(parent)
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpAlloc, nt.temp, alloc_sz, 0, parent.name, 0))
                st_id := _struct_type_id(ll.registry, parent.name)
                if st_id > 0 { ll = _lset_type(ll, nt.temp, st_id) }
                tag_nt := _lnew_temp(ll)
                ll = tag_nt.l
                ll = _lemit(ll, new_inst(OpConst, tag_nt.temp, tag, 0, "", 0))
                ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, tag_nt.temp, 0, "_tag", 0))
                return LT{l: ll, temp: nt.temp}
            }
            // Pure tag-only sum type (no variant has data) — just emit tag constant
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpConst, nt.temp, tag, 0, "", 0))
            return LT{l: ll, temp: nt.temp}
        }

        // Const integer lookup
        if _lconst_has(ll, name) {
            cval := _lconst_lookup(ll, name)
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpConst, nt.temp, cval, 0, "", 0))
            ll = _lset_type(ll, nt.temp, 1)
            return LT{l: ll, temp: nt.temp}
        }

        // Const string lookup
        if _lconst_str_has(ll, name) {
            sval := _lconst_str_lookup(ll, name)
            // Add to string constant pool
            mut str_idx := mod_find_string(ll.module, sval)
            if str_idx == 0 {
                new_mod := mod_add_string(ll.module, sval)
                str_idx = new_mod.string_constants.len() - 1
                ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                             table: ll.table, file: ll.file, module: new_mod,
                             current_func: ll.current_func,
                             temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                             env_names: ll.env_names, env_slots: ll.env_slots,
                             loop_start: ll.loop_start, loop_end: ll.loop_end,
                             const_names: ll.const_names, const_vals: ll.const_vals,
                             const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                             temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
            }
            nt := _lnew_str_temp(ll)
            ll = _lemit(nt.l, new_inst(OpConstStr, nt.temp, str_idx, sval.len(), "", 0))
            ll = _lset_type(ll, nt.temp, 12)
            return LT{l: ll, temp: nt.temp}
        }

        // Unknown identifier — return 0
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpConst, nt.temp, 0, 0, "", 0))
        return LT{l: ll, temp: nt.temp}
    }

    if k == "(" {
        mut ll := _ladv(l)
        ll = _lskip_nl(ll)
        result := _lower_expr(ll)
        ll = result.l
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        return LT{l: ll, temp: result.temp}
    }

    if k == "[" {
        // Array literal — do NOT type as [str] since [""] sentinels are used for all array types
        mut ll := _ladv(l)
        ll = _lskip_nl(ll)
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpArrayNew, nt.temp, 0, 0, "", 0))
        ll = _lset_type(ll, nt.temp, 1)
        while _lk(ll) != "]" && _lk(ll) != "EOF" {
            ll = _lskip_nl(ll)
            elem := _lower_expr(ll)
            ll = elem.l
            ll = _lemit(ll, new_inst(OpArrayAppend, nt.temp, nt.temp, elem.temp, "", 0))
            ll = _lskip_nl(ll)
            if _lk(ll) == "," { ll = _ladv(ll) }
        }
        if _lk(ll) == "]" { ll = _ladv(ll) }
        return LT{l: ll, temp: nt.temp}
    }

    // Default: advance and return 0
    nt := _lnew_temp(l)
    ll := _lemit(_ladv(nt.l), new_inst(OpConst, nt.temp, 0, 0, "", 0))
    LT{l: ll, temp: nt.temp}
}

// --- Lower method call ---

// Lower type conversion: .to[Type]() or .trunc[Type]()
fn _lower_conversion(l: Lowerer, obj: i64, method: str, target: str) -> LT {
    mut ll := l
    obj_type := _lget_type(ll, obj)

    if method == "to" {
        // Checked conversion — returns Result
        if obj_type == 12 && target == "i64" {
            // String to int — call _aria_str_to_int, wrap in Result
            result_nt := _lnew_temp(ll)
            ll = result_nt.l
            extra := _lnew_temp(ll)
            ll = extra.l
            ll = _lemit(ll, new_inst(OpStrToInt, result_nt.temp, obj, 0, "", 0))
            // result_nt = parsed value, result_nt+1 = success flag
            // Build Result: if success, Ok(value), else Err(0)
            success_nt := _lnew_temp(ll)
            ll = success_nt.l
            ll = _lemit(ll, new_inst(OpLoad, success_nt.temp, result_nt.temp + 1, 0, "", 0))
            err_lbl := _lnew_label(ll)
            ll = err_lbl.l
            ok_lbl := _lnew_label(ll)
            ll = ok_lbl.l
            end_lbl := _lnew_label(ll)
            ll = end_lbl.l
            ll = _lemit(ll, new_inst(OpBranchTrue, 0, success_nt.temp, ok_lbl.temp, "", 0))
            // Err path: allocate Result with tag=1
            err_res := _lnew_temp(ll)
            ll = err_res.l
            ll = _lemit(ll, new_inst(OpAlloc, err_res.temp, 2, 0, "_Result", 0))
            err_tag := _lnew_temp(ll)
            ll = err_tag.l
            ll = _lemit(ll, new_inst(OpConst, err_tag.temp, 1, 0, "", 0))
            ll = _lemit(ll, new_inst(OpFieldSet, err_res.temp, err_tag.temp, 0, "_tag", 0))
            err_val := _lnew_temp(ll)
            ll = err_val.l
            ll = _lemit(ll, new_inst(OpConst, err_val.temp, 0, 0, "", 0))
            ll = _lemit(ll, new_inst(OpFieldSet, err_res.temp, err_val.temp, 1, "_val", 0))
            final_nt := _lnew_temp(ll)
            ll = final_nt.l
            ll = _lemit(ll, new_inst(OpStore, final_nt.temp, err_res.temp, 0, "", 0))
            ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))
            // Ok path: allocate Result with tag=0
            ll = _lemit(ll, new_inst(OpLabel, 0, ok_lbl.temp, 0, "", 0))
            ok_res := _lnew_temp(ll)
            ll = ok_res.l
            ll = _lemit(ll, new_inst(OpAlloc, ok_res.temp, 2, 0, "_Result", 0))
            ok_tag := _lnew_temp(ll)
            ll = ok_tag.l
            ll = _lemit(ll, new_inst(OpConst, ok_tag.temp, 0, 0, "", 0))
            ll = _lemit(ll, new_inst(OpFieldSet, ok_res.temp, ok_tag.temp, 0, "_tag", 0))
            ll = _lemit(ll, new_inst(OpFieldSet, ok_res.temp, result_nt.temp, 1, "_val", 0))
            ll = _lemit(ll, new_inst(OpStore, final_nt.temp, ok_res.temp, 0, "", 0))
            // End
            ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
            ll = _lset_type(ll, final_nt.temp, 200)
            return LT{l: ll, temp: final_nt.temp}
        }
        // Numeric to numeric checked — for MVP, just pass through (same i64 representation)
        return LT{l: ll, temp: obj}
    }

    if method == "trunc" {
        // Truncating conversion — just pass value through (all ints are i64 in IR)
        return LT{l: ll, temp: obj}
    }

    // Unknown conversion — pass through
    LT{l: ll, temp: obj}
}

fn _lower_method_call(l: Lowerer, obj: i64, method: str) -> LT {
    mut ll := _ladv(l)  // skip (
    ll = _lskip_nl(ll)

    if method == "len" {
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        // Distinguish string vs array vs map by type tracking
        obj_type := _lget_type(ll, obj)
        if obj_type == 12 {
            ll = _lemit(ll, new_inst(OpStrLen, nt.temp, obj, 0, "", 0))
        } else if obj_type == 300 {
            ll = _lemit(ll, new_inst(OpMapLen, nt.temp, obj, 0, "", 0))
        } else {
            ll = _lemit(ll, new_inst(OpArrayLen, nt.temp, obj, 0, "", 0))
        }
        ll = _lset_type(ll, nt.temp, 1)
        return LT{l: ll, temp: nt.temp}
    }

    // Map methods
    if method == "set" {
        // map.set(key, value)
        key := _lower_expr(ll)
        ll = key.l
        if _lk(ll) == "," { ll = _ladv(ll) }
        val := _lower_expr(ll)
        ll = val.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        ll = _lemit(ll, new_inst(OpMapSet, 0, obj, key.temp, "", val.temp))
        return LT{l: ll, temp: obj}
    }

    if method == "get" {
        // map.get(key) -> value
        key := _lower_expr(ll)
        ll = key.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpMapGet, nt.temp, obj, key.temp, "", 0))
        return LT{l: ll, temp: nt.temp}
    }

    if method == "has" {
        // map.has(key) -> bool
        key := _lower_expr(ll)
        ll = key.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpMapContains, nt.temp, obj, key.temp, "", 0))
        return LT{l: ll, temp: nt.temp}
    }

    if method == "keys" {
        // map.keys() -> [str]
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpMapKeys, nt.temp, obj, 0, "", 0))
        ll = _lset_type(ll, nt.temp, 13)  // type 13 = [str] array
        return LT{l: ll, temp: nt.temp}
    }

    // Array.filter(fn) — returns new array with elements where fn returns true
    if method == "filter" {
        obj_type := _lget_type(ll, obj)
        // Lower the predicate closure argument
        pred := _lower_expr(ll)
        ll = pred.l
        if _lk(ll) == ")" { ll = _ladv(ll) }

        // Create new result array
        new_arr := _lnew_temp(ll)
        ll = new_arr.l
        cap_nt := _lnew_temp(ll)
        ll = cap_nt.l
        ll = _lemit(ll, new_inst(OpConst, cap_nt.temp, 8, 0, "", 0))
        ll = _lemit(ll, new_inst(OpArrayNew, new_arr.temp, cap_nt.temp, 0, "", 0))

        // Get array length
        len_nt := _lnew_temp(ll)
        ll = len_nt.l
        ll = _lemit(ll, new_inst(OpArrayLen, len_nt.temp, obj, 0, "", 0))

        // Loop: i = 0; while i < len
        idx_nt := _lnew_temp(ll)
        ll = idx_nt.l
        ll = _lemit(ll, new_inst(OpConst, idx_nt.temp, 0, 0, "", 0))

        loop_lbl := _lnew_label(ll)
        ll = loop_lbl.l
        end_lbl := _lnew_label(ll)
        ll = end_lbl.l
        body_lbl := _lnew_label(ll)
        ll = body_lbl.l

        ll = _lemit(ll, new_inst(OpLabel, 0, loop_lbl.temp, 0, "", 0))
        // Check i < len
        cmp_nt := _lnew_temp(ll)
        ll = cmp_nt.l
        ll = _lemit(ll, new_inst(OpLt, cmp_nt.temp, idx_nt.temp, len_nt.temp, "", 0))
        ll = _lemit(ll, new_inst(OpBranchFalse, 0, cmp_nt.temp, end_lbl.temp, "", 0))

        // Get element
        elem_nt := _lnew_temp(ll)
        ll = elem_nt.l
        ll = _lemit(ll, new_inst(OpArrayGet, elem_nt.temp, obj, idx_nt.temp, "", 0))

        // Call predicate: fn_ptr = pred slot 0, env_ptr = pred slot 1
        fn_ptr := _lnew_temp(ll)
        ll = fn_ptr.l
        ll = _lemit(ll, new_inst(OpFieldGet, fn_ptr.temp, pred.temp, 0, "", 0))
        // Pack args: [env_ptr, element] in consecutive temps
        arg_start := _lnew_temp(ll)
        ll = arg_start.l
        arg_elem := _lnew_temp(ll)
        ll = arg_elem.l
        // Load env_ptr into arg_start
        env_ptr := _lnew_temp(ll)
        ll = env_ptr.l
        ll = _lemit(ll, new_inst(OpFieldGet, env_ptr.temp, pred.temp, 1, "", 0))
        ll = _lemit(ll, new_inst(OpStore, arg_start.temp, env_ptr.temp, 0, "", 0))
        // Load element into arg_start+1
        ll = _lemit(ll, new_inst(OpStore, arg_elem.temp, elem_nt.temp, 0, "", 0))
        result_nt := _lnew_temp(ll)
        ll = result_nt.l
        ll = _lemit(ll, new_inst(OpCallIndirect, result_nt.temp, fn_ptr.temp, 2, "", arg_start.temp))

        // If result is true, append element
        skip_lbl := _lnew_label(ll)
        ll = skip_lbl.l
        ll = _lemit(ll, new_inst(OpBranchFalse, 0, result_nt.temp, skip_lbl.temp, "", 0))
        ll = _lemit(ll, new_inst(OpArrayAppend, new_arr.temp, new_arr.temp, elem_nt.temp, "", 0))
        ll = _lemit(ll, new_inst(OpLabel, 0, skip_lbl.temp, 0, "", 0))

        // i = i + 1
        one_nt := _lnew_temp(ll)
        ll = one_nt.l
        ll = _lemit(ll, new_inst(OpConst, one_nt.temp, 1, 0, "", 0))
        ll = _lemit(ll, new_inst(OpAdd, idx_nt.temp, idx_nt.temp, one_nt.temp, "", 0))
        ll = _lemit(ll, new_inst(OpJump, 0, loop_lbl.temp, 0, "", 0))

        ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
        if obj_type > 0 { ll = _lset_type(ll, new_arr.temp, obj_type) }
        return LT{l: ll, temp: new_arr.temp}
    }

    if method == "append" {
        elem := _lower_expr(ll)
        ll = elem.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        // Pack string elements when element type is str
        obj_type := _lget_type(ll, obj)
        elem_type := _lget_type(ll, elem.temp)
        if elem_type == 12 || obj_type == 13 {
            ll = _lemit(ll, new_inst(OpArrayAppend, nt.temp, obj, elem.temp, "", 12))
            ll = _lset_type(ll, nt.temp, 13)
        } else {
            ll = _lemit(ll, new_inst(OpArrayAppend, nt.temp, obj, elem.temp, "", 0))
            if obj_type > 0 {
                ll = _lset_type(ll, nt.temp, obj_type)
            }
        }
        return LT{l: ll, temp: nt.temp}
    }

    if method == "contains" {
        arg := _lower_expr(ll)
        ll = arg.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrContains, nt.temp, obj, arg.temp, "", 0))
        return LT{l: ll, temp: nt.temp}
    }

    if method == "charAt" {
        arg := _lower_expr(ll)
        ll = arg.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrCharAt, nt.temp, obj, arg.temp, "", 0))
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "startsWith" {
        arg := _lower_expr(ll)
        ll = arg.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrStartsWith, nt.temp, obj, arg.temp, "", 0))
        return LT{l: ll, temp: nt.temp}
    }

    if method == "endsWith" {
        arg := _lower_expr(ll)
        ll = arg.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrEndsWith, nt.temp, obj, arg.temp, "", 0))
        return LT{l: ll, temp: nt.temp}
    }

    if method == "indexOf" {
        arg := _lower_expr(ll)
        ll = arg.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrIndexOf, nt.temp, obj, arg.temp, "", 0))
        ll = _lset_type(ll, nt.temp, 1)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "trim" {
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrTrim, nt.temp, obj, 0, "", 0))
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "replace" {
        old_arg := _lower_expr(ll)
        ll = old_arg.l
        if _lk(ll) == "," { ll = _ladv(ll) }
        new_arg := _lower_expr(ll)
        ll = new_arg.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrReplace, nt.temp, obj, old_arg.temp, "", new_arg.temp))
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "toLower" {
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrToLower, nt.temp, obj, 0, "", 0))
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "toUpper" {
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrToUpper, nt.temp, obj, 0, "", 0))
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "split" {
        arg := _lower_expr(ll)
        ll = arg.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpStrSplit, nt.temp, obj, arg.temp, "", 0))
        ll = _lset_type(ll, nt.temp, 13)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "substring" {
        start := _lower_expr(ll)
        ll = start.l
        if _lk(ll) == "," { ll = _ladv(ll) }
        end := _lower_expr(ll)
        ll = end.l
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        // Pass end temp via type_id field
        ll = _lemit(ll, new_inst(OpStrSubstring, nt.temp, obj, start.temp, "", end.temp))
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "debug_str" {
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        // Generate debug string: "TypeName{field1: val1, field2: val2}"
        obj_type := _lget_type(ll, obj)
        sname := _struct_name_for_type(ll.store, ll.registry, obj_type)
        if sname != "" {
            def := reg_find_struct(ll.registry, sname)
            // Start with struct name + "{"
            mut hdr_idx := mod_find_string(ll.module, sname + "\{")
            if hdr_idx == 0 {
                new_mod := mod_add_string(ll.module, sname + "\{")
                hdr_idx = new_mod.string_constants.len() - 1
                ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                             table: ll.table, file: ll.file, module: new_mod,
                             current_func: ll.current_func,
                             temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                             env_names: ll.env_names, env_slots: ll.env_slots,
                             loop_start: ll.loop_start, loop_end: ll.loop_end,
                             const_names: ll.const_names, const_vals: ll.const_vals,
                             const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                             temp_types: ll.temp_types,
                             fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
            }
            hdr_len := sname.len() + 1
            result_nt := _lnew_str_temp(ll)
            ll = result_nt.l
            ll = _lemit(ll, new_inst(OpConstStr, result_nt.temp, hdr_idx, hdr_len, "", 0))
            ll = _lset_type(ll, result_nt.temp, 12)

            // For each field, append "name: " + value
            mut fi := 1
            mut field_slot := 0
            while fi < def.fields.len() {
                fld := def.fields[fi]
                ft := fld.type_id
                // Add separator ", " for second+ fields
                if fi > 1 {
                    mut sep_idx := mod_find_string(ll.module, ", ")
                    if sep_idx == 0 {
                        new_mod := mod_add_string(ll.module, ", ")
                        sep_idx = new_mod.string_constants.len() - 1
                        ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                                     table: ll.table, file: ll.file, module: new_mod,
                                     current_func: ll.current_func,
                                     temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                                     env_names: ll.env_names, env_slots: ll.env_slots,
                                     loop_start: ll.loop_start, loop_end: ll.loop_end,
                                     const_names: ll.const_names, const_vals: ll.const_vals,
                                     const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                                     temp_types: ll.temp_types,
                                     fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
                    }
                    sep_nt := _lnew_str_temp(ll)
                    ll = sep_nt.l
                    ll = _lemit(ll, new_inst(OpConstStr, sep_nt.temp, sep_idx, 2, "", 0))
                    concat_nt := _lnew_str_temp(ll)
                    ll = concat_nt.l
                    ll = _lemit(ll, new_inst(OpStrConcat, concat_nt.temp, result_nt.temp, sep_nt.temp, "", 0))
                    result_nt = concat_nt
                }
                // Add "fieldname: "
                fname_str := fld.name + ": "
                mut fname_idx := mod_find_string(ll.module, fname_str)
                if fname_idx == 0 {
                    new_mod := mod_add_string(ll.module, fname_str)
                    fname_idx = new_mod.string_constants.len() - 1
                    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                                 table: ll.table, file: ll.file, module: new_mod,
                                 current_func: ll.current_func,
                                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                                 env_names: ll.env_names, env_slots: ll.env_slots,
                                 loop_start: ll.loop_start, loop_end: ll.loop_end,
                                 const_names: ll.const_names, const_vals: ll.const_vals,
                                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                                 temp_types: ll.temp_types,
                                 fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
                }
                fname_nt := _lnew_str_temp(ll)
                ll = fname_nt.l
                ll = _lemit(ll, new_inst(OpConstStr, fname_nt.temp, fname_idx, fname_str.len(), "", 0))
                c1 := _lnew_str_temp(ll)
                ll = c1.l
                ll = _lemit(ll, new_inst(OpStrConcat, c1.temp, result_nt.temp, fname_nt.temp, "", 0))

                // Get field value as string
                if ft == 12 {
                    // String field — get ptr+len and concat directly
                    fval := _lnew_str_temp(ll)
                    ll = fval.l
                    ll = _lemit(ll, new_inst(OpFieldGet, fval.temp, obj, field_slot, fld.name, 0))
                    fidx_len := field_slot + 1
                    ll = _lemit(ll, new_inst(OpFieldGet, fval.temp + 1, obj, fidx_len, fld.name, 0))
                    c2 := _lnew_str_temp(ll)
                    ll = c2.l
                    ll = _lemit(ll, new_inst(OpStrConcat, c2.temp, c1.temp, fval.temp, "", 0))
                    result_nt = c2
                    field_slot = field_slot + 2
                } else {
                    // Numeric field — convert to string then concat
                    fval := _lnew_temp(ll)
                    ll = fval.l
                    ll = _lemit(ll, new_inst(OpFieldGet, fval.temp, obj, field_slot, fld.name, 0))
                    fstr := _lnew_str_temp(ll)
                    ll = fstr.l
                    ll = _lemit(ll, new_inst(OpIntToStr, fstr.temp, fval.temp, 0, "", 0))
                    c2 := _lnew_str_temp(ll)
                    ll = c2.l
                    ll = _lemit(ll, new_inst(OpStrConcat, c2.temp, c1.temp, fstr.temp, "", 0))
                    result_nt = c2
                    field_slot = field_slot + 1
                }
                fi = fi + 1
            }

            // Add closing "}"
            mut close_idx := mod_find_string(ll.module, "\}")
            if close_idx == 0 {
                new_mod := mod_add_string(ll.module, "\}")
                close_idx = new_mod.string_constants.len() - 1
                ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                             table: ll.table, file: ll.file, module: new_mod,
                             current_func: ll.current_func,
                             temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                             env_names: ll.env_names, env_slots: ll.env_slots,
                             loop_start: ll.loop_start, loop_end: ll.loop_end,
                             const_names: ll.const_names, const_vals: ll.const_vals,
                             const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                             temp_types: ll.temp_types,
                             fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
            }
            close_nt := _lnew_str_temp(ll)
            ll = close_nt.l
            ll = _lemit(ll, new_inst(OpConstStr, close_nt.temp, close_idx, 1, "", 0))
            final_nt := _lnew_str_temp(ll)
            ll = final_nt.l
            ll = _lemit(ll, new_inst(OpStrConcat, final_nt.temp, result_nt.temp, close_nt.temp, "", 0))
            ll = _lset_type(ll, final_nt.temp, 12)
            return LT{l: ll, temp: final_nt.temp}
        }
        // Unknown struct — return empty string
        nt := _lnew_str_temp(ll)
        ll = nt.l
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    if method == "toString" || method == "toStr" {
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        obj_type := _lget_type(ll, obj)
        if obj_type == 12 {
            // Already a string — just return it
            return LT{l: ll, temp: obj}
        }
        if _is_float_type(obj_type) {
            ll = _lemit(ll, new_inst(OpIntToStr, nt.temp, obj, 0, "f64", 0))
        } else {
            ll = _lemit(ll, new_inst(OpIntToStr, nt.temp, obj, 0, "", 0))
        }
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    // Check for trait object dispatch (dyn Trait)
    dyn_obj_type := _lget_type(ll, obj)
    if dyn_obj_type == 500 {
        // Trait object — dispatch via vtable
        // Compute method index: scan all registered fns to find the position of
        // methods matching *_methodName pattern (same order as vtable construction)
        // Since vtable is built per-type scanning Type_* methods, we need to find
        // which index `method` corresponds to. Use method suffix matching.
        mut method_idx := 0
        mut found_idx := false
        mut scan_i := 1
        mut scan_count := 0
        while scan_i < ll.registry.fn_sigs.len() {
            sig := ll.registry.fn_sigs[scan_i]
            if sig.name != "" && sig.name.len() > 1 {
                // Check if this fn ends with "_" + method
                suffix := "_" + method
                if sig.name.len() > suffix.len() {
                    tail := sig.name.substring(sig.name.len() - suffix.len(), sig.name.len())
                    if tail == suffix && found_idx == false {
                        method_idx = scan_count
                        found_idx = true
                    }
                }
                // Count all methods for any type (we use first match)
            }
            scan_i = scan_i + 1
        }
        // Lower args (skip for now — self is passed via data_ptr in vtable call)
        while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpVtableCall, nt.temp, obj, method_idx, method, 0))
        return LT{l: ll, temp: nt.temp}
    }

    // Try user-defined method: qualified name first (Type_method), then plain name
    // Determine object type for qualified lookup
    obj_type := _lget_type(ll, obj)
    obj_sname := _struct_name_for_type(ll.store, ll.registry, obj_type)
    mut qualified_method := method
    if obj_sname != "" {
        qualified_method = obj_sname + "_" + method
    }
    mut method_sig := reg_find_fn(ll.registry, qualified_method)
    if method_sig.name == "" {
        // Fallback to plain method name
        method_sig = reg_find_fn(ll.registry, method)
        qualified_method = method
    }
    if method_sig.name != "" {
        // Call as method: obj is first arg (self)
        mut first_arg := obj
        mut arg_count := 1
        while _lk(ll) != ")" && _lk(ll) != "EOF" {
            ll = _lskip_nl(ll)
            if _lk(ll) == ")" { return LT{l: _ladv(ll), temp: obj} }
            arg := _lower_expr(ll)
            ll = arg.l
            arg_count = arg_count + 1
            ll = _lskip_nl(ll)
            if _lk(ll) == "," { ll = _ladv(ll) }
        }
        if _lk(ll) == ")" { ll = _ladv(ll) }
        // Use _lnew_str_temp for string return types (2 consecutive slots)
        mut nt_temp := 0
        if method_sig.return_type == 12 {
            nt := _lnew_str_temp(ll)
            ll = nt.l
            nt_temp = nt.temp
        } else {
            nt := _lnew_temp(ll)
            ll = nt.l
            nt_temp = nt.temp
        }
        ll = _lemit(ll, new_inst(OpCall, nt_temp, first_arg, arg_count, qualified_method, 0))
        if method_sig.return_type == 12 {
            ll = _lset_type(ll, nt_temp, 12)
        } else if method_sig.return_type > 16 {
            // Struct/named return type — track for method dispatch
            ret_sname := format_type(ll.store, method_sig.return_type)
            ret_st_id := _struct_type_id(ll.registry, ret_sname)
            if ret_st_id > 0 { ll = _lset_type(ll, nt_temp, ret_st_id) }
        }
        return LT{l: ll, temp: nt_temp}
    }

    // Unknown method — skip args, return 0
    while _lk(ll) != ")" && _lk(ll) != "EOF" { ll = _ladv(ll) }
    if _lk(ll) == ")" { ll = _ladv(ll) }
    nt := _lnew_temp(ll)
    ll = nt.l
    ll = _lemit(ll, new_inst(OpConst, nt.temp, 0, 0, "", 0))
    LT{l: ll, temp: nt.temp}
}

// --- Lower function call args ---

fn _lower_call_args(l: Lowerer, callee: i64) -> LT {
    mut ll := _ladv(l)  // skip (
    ll = _lskip_nl(ll)
    while _lk(ll) != ")" && _lk(ll) != "EOF" {
        ll = _lskip_nl(ll)
        arg := _lower_expr(ll)
        ll = arg.l
        ll = _lskip_nl(ll)
        if _lk(ll) == "," { ll = _ladv(ll) }
    }
    if _lk(ll) == ")" { ll = _ladv(ll) }
    return LT{l: ll, temp: callee}
}

// --- Field index lookup ---

fn _field_index(reg: TypeRegistry, struct_name: str, field_name: str) -> i64 {
    def := reg_find_struct(reg, struct_name)
    if def.name == "" { return 0 }
    // Compute memory-level slot index, accounting for string fields taking 2 slots
    mut slot := 0
    mut i := 1
    while i < def.fields.len() {
        if def.fields[i].name == field_name {
            return slot
        }
        if def.fields[i].type_id == 12 {
            slot = slot + 2  // string takes ptr + len
        } else {
            slot = slot + 1
        }
        i = i + 1
    }
    0
}


// Search all struct defs for a field name and return its memory-level slot index
// WARNING: Ambiguous if multiple structs have same field name. Prefer _field_index with known struct.
fn _field_index_any(reg: TypeRegistry, field_name: str) -> i64 {
    mut si := 1
    while si < reg.struct_defs.len() {
        def := reg.struct_defs[si]
        if def.name != "" && def.is_sum == false {
            mut fi := 1
            while fi < def.fields.len() {
                if def.fields[fi].name == field_name {
                    // Use type-aware _field_index for correct memory layout
                    return _field_index(reg, def.name, field_name)
                }
                fi = fi + 1
            }
        }
        si = si + 1
    }
    0
}

fn _struct_name_from_type(reg: TypeRegistry, type_id: i64) -> str {
    // type_id >= 100 means struct index = type_id - 100 + 1
    idx := type_id - 99
    if idx >= 1 && idx < reg.struct_defs.len() {
        return reg.struct_defs[idx].name
    }
    return ""
}

fn _struct_type_id(reg: TypeRegistry, struct_name: str) -> i64 {
    mut i := 1
    while i < reg.struct_defs.len() {
        if reg.struct_defs[i].name == struct_name {
            return 99 + i  // 100-based
        }
        i = i + 1
    }
    0
}

fn _field_type_id(l: Lowerer, struct_name: str, field_name: str) -> i64 {
    def := reg_find_struct(l.registry, struct_name)
    if def.name == "" { return 0 }
    mut i := 1
    while i < def.fields.len() {
        if def.fields[i].name == field_name {
            return def.fields[i].type_id
        }
        i = i + 1
    }
    0
}

// Search all struct defs for a field name and return its type_id
// WARNING: Ambiguous if multiple structs have same field name. Prefer _field_type_id with known struct.
fn _field_type_id_any(reg: TypeRegistry, field_name: str) -> i64 {
    mut si := 1
    while si < reg.struct_defs.len() {
        def := reg.struct_defs[si]
        if def.name != "" && def.is_sum == false {
            mut fi := 1
            while fi < def.fields.len() {
                if def.fields[fi].name == field_name {
                    return def.fields[fi].type_id
                }
                fi = fi + 1
            }
        }
        si = si + 1
    }
    0
}

fn _struct_field_count(reg: TypeRegistry, struct_name: str) -> i64 {
    def := reg_find_struct(reg, struct_name)
    if def.name == "" { return 0 }
    // Count memory slots, accounting for string fields taking 2 slots
    mut slots := 0
    mut i := 1
    while i < def.fields.len() {
        if def.fields[i].type_id == 12 {
            slots = slots + 2
        } else {
            slots = slots + 1
        }
        i = i + 1
    }
    slots
}

// --- Lower struct literal ---

fn _lower_struct_lit(l: Lowerer, name: str) -> LT {
    lb := "\{"
    rb := "\}"
    mut ll := _ladv(l)  // skip {
    ll = _lskip_nl(ll)

    field_count := _struct_field_count(ll.registry, name)
    nt := _lnew_temp(ll)
    ll = nt.l
    ll = _lemit(ll, new_inst(OpAlloc, nt.temp, field_count, 0, name, 0))
    // Set struct type on result temp
    st_id := _struct_type_id(ll.registry, name)
    if st_id > 0 { ll = _lset_type(ll, nt.temp, st_id) }

    while _lk(ll) != rb && _lk(ll) != "EOF" {
        if _lk(ll) == "IDENT" {
            fname := _lcur(ll).text
            ll = _ladv(ll)
            if _lk(ll) == ":" {
                ll = _ladv(ll)
                val := _lower_expr(ll)
                ll = val.l
                fidx := _field_index(ll.registry, name, fname)
                val_type := _lget_type(ll, val.temp)
                ft := _field_type_id(ll, name, fname)
                if val_type == 12 || ft == 12 {
                    // String field: store both ptr and len to consecutive field slots
                    fidx_len := fidx + 1
                    val_len := val.temp + 1
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, fidx, fname, 0))
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val_len, fidx_len, fname, 0))
                } else {
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, fidx, fname, 0))
                }
            }
        } else {
            ll = _ladv(ll)
        }
        ll = _lskip_nl(ll)
        if _lk(ll) == "," {
            ll = _ladv(ll)
            ll = _lskip_nl(ll)
        }
    }
    if _lk(ll) == rb { ll = _ladv(ll) }
    LT{l: ll, temp: nt.temp}
}

// --- Lower atom: primary + postfix (.field, .method(), [index]) ---
// Used as operand parser for binary ops and conditions.

fn _lower_atom(l: Lowerer) -> LT {
    lb := "\{"
    result := _lower_primary(l)
    mut ll := result.l
    mut left := result.temp

    // Handle postfix: .field, .method(), [index]
    mut running := true
    while running {
        k := _lk(ll)
        if k == "." {
            ll = _ladv(ll)
            if _lk(ll) == "IDENT" {
                field := _lcur(ll).text
                ll = _ladv(ll)
                if _lk(ll) == "(" {
                    mr := _lower_method_call(ll, left, field)
                    ll = mr.l
                    left = mr.temp
                } else if _lk(ll) == "[" && (field == "to" || field == "trunc") {
                    // Conversion method with type arg: .to[Type]() or .trunc[Type]()
                    ll = _ladv(ll)  // skip [
                    mut target_type_name := ""
                    if _lk(ll) == "IDENT" {
                        target_type_name = _lcur(ll).text
                        ll = _ladv(ll)
                    }
                    if _lk(ll) == "]" { ll = _ladv(ll) }
                    if _lk(ll) == "(" { ll = _ladv(ll) }
                    if _lk(ll) == ")" { ll = _ladv(ll) }
                    mr := _lower_conversion(ll, left, field, target_type_name)
                    ll = mr.l
                    left = mr.temp
                } else {
                    // Type-aware field access
                    left_type := _lget_type(ll, left)
                    sname := _struct_name_for_type(ll.store, ll.registry, left_type)
                    mut fidx := 0
                    mut ft := 0
                    if sname != "" {
                        fidx = _field_index(ll.registry, sname, field)
                        ft = _field_type_id(ll, sname, field)
                    } else {
                        fidx = _field_index_any(ll.registry, field)
                        ft = _field_type_id_any(ll.registry, field)
                    }
                    mut nt_temp := 0
                    if ft == 12 {
                        nt := _lnew_str_temp(ll)
                        ll = nt.l
                        nt_temp = nt.temp
                    } else {
                        nt := _lnew_temp(ll)
                        ll = nt.l
                        nt_temp = nt.temp
                    }
                    if ft == 12 {
                        // String field: load both ptr and len from consecutive field slots
                        fidx_len := fidx + 1
                        nt_len := nt_temp + 1
                        ll = _lemit(ll, new_inst(OpFieldGet, nt_temp, left, fidx, field, 0))
                        ll = _lemit(ll, new_inst(OpFieldGet, nt_len, left, fidx_len, field, 0))
                    } else {
                        ll = _lemit(ll, new_inst(OpFieldGet, nt_temp, left, fidx, field, 0))
                    }
                    if ft > 0 { ll = _lset_type(ll, nt_temp, ft) }
                    left = nt_temp
                }
            } else {
                running = false
            }
        } else if k == "[" {
            ll = _ladv(ll)
            idx := _lower_expr(ll)
            ll = idx.l
            if _lk(ll) == "]" { ll = _ladv(ll) }
            // Determine array element type
            left_type := _lget_type(ll, left)
            elem_type := _array_elem_type(ll.store, left_type)
            if elem_type == 12 {
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpArrayGet, nt.temp, left, idx.temp, "", 12))
                ll = _lset_type(ll, nt.temp, 12)
                left = nt.temp
            } else {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpArrayGet, nt.temp, left, idx.temp, "", 0))
                if elem_type > 0 {
                    ll = _lset_type(ll, nt.temp, elem_type)
                }
                left = nt.temp
            }
        } else if k == "(" {
            cr := _lower_call_args(ll, left)
            ll = cr.l
            left = cr.temp
        } else if k == "?" {
            // Error propagation: unwrap Ok or early-return Err
            ll = _ladv(ll)
            // Extract tag from slot 0
            tag_nt := _lnew_temp(ll)
            ll = tag_nt.l
            ll = _lemit(ll, new_inst(OpFieldGet, tag_nt.temp, left, 0, "_tag", 0))
            // Compare tag to 1 (Err)
            const_one := _lnew_temp(ll)
            ll = const_one.l
            ll = _lemit(ll, new_inst(OpConst, const_one.temp, 1, 0, "", 0))
            is_err := _lnew_temp(ll)
            ll = is_err.l
            ll = _lemit(ll, new_inst(OpEq, is_err.temp, tag_nt.temp, const_one.temp, "", 0))
            // Branch on error
            err_lbl := _lnew_label(ll)
            ll = err_lbl.l
            ok_lbl := _lnew_label(ll)
            ll = ok_lbl.l
            ll = _lemit(ll, new_inst(OpBranchTrue, 0, is_err.temp, err_lbl.temp, "", 0))
            // Ok path: extract value from slot 1
            ok_val := _lnew_temp(ll)
            ll = ok_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, ok_val.temp, left, 1, "_val", 0))
            ll = _lemit(ll, new_inst(OpJump, 0, ok_lbl.temp, 0, "", 0))
            // Err path: early return the Result
            ll = _lemit(ll, new_inst(OpLabel, 0, err_lbl.temp, 0, "", 0))
            ll = _emit_defers(ll)
            ll = _lemit(ll, new_inst(OpRet, 0, left, 0, "", 0))
            // Continue with Ok value
            ll = _lemit(ll, new_inst(OpLabel, 0, ok_lbl.temp, 0, "", 0))
            left = ok_val.temp
        } else if k == "!" {
            // Assert-unwrap: unwrap Ok or panic
            ll = _ladv(ll)
            // Extract tag from slot 0
            tag_nt := _lnew_temp(ll)
            ll = tag_nt.l
            ll = _lemit(ll, new_inst(OpFieldGet, tag_nt.temp, left, 0, "_tag", 0))
            // Compare tag to 1 (Err)
            const_one := _lnew_temp(ll)
            ll = const_one.l
            ll = _lemit(ll, new_inst(OpConst, const_one.temp, 1, 0, "", 0))
            is_err := _lnew_temp(ll)
            ll = is_err.l
            ll = _lemit(ll, new_inst(OpEq, is_err.temp, tag_nt.temp, const_one.temp, "", 0))
            // Branch on error
            panic_lbl := _lnew_label(ll)
            ll = panic_lbl.l
            ok_lbl := _lnew_label(ll)
            ll = ok_lbl.l
            ll = _lemit(ll, new_inst(OpBranchTrue, 0, is_err.temp, panic_lbl.temp, "", 0))
            // Ok path: extract value
            ok_val := _lnew_temp(ll)
            ll = ok_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, ok_val.temp, left, 1, "_val", 0))
            ll = _lemit(ll, new_inst(OpJump, 0, ok_lbl.temp, 0, "", 0))
            // Panic path: call _aria_panic
            ll = _lemit(ll, new_inst(OpLabel, 0, panic_lbl.temp, 0, "", 0))
            // Add panic message as string constant
            mut panic_str_idx := mod_find_string(ll.module, "unwrap failed on Err value")
            if panic_str_idx == 0 {
                new_mod := mod_add_string(ll.module, "unwrap failed on Err value")
                panic_str_idx = new_mod.string_constants.len() - 1
                ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                             table: ll.table, file: ll.file, module: new_mod,
                             current_func: ll.current_func,
                             temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                             env_names: ll.env_names, env_slots: ll.env_slots,
                             loop_start: ll.loop_start, loop_end: ll.loop_end,
                             const_names: ll.const_names, const_vals: ll.const_vals,
                             const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                             temp_types: ll.temp_types,
                             fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
            }
            panic_ptr := _lnew_str_temp(ll)
            ll = panic_ptr.l
            ll = _lemit(ll, new_inst(OpConstStr, panic_ptr.temp, panic_str_idx, 25, "", 0))
            ll = _lemit(ll, new_inst(OpCall, 0, panic_ptr.temp, 2, "_aria_panic", 0))
            // Continue with Ok value
            ll = _lemit(ll, new_inst(OpLabel, 0, ok_lbl.temp, 0, "", 0))
            left = ok_val.temp
        } else {
            running = false
        }
    }
    LT{l: ll, temp: left}
}

fn _lower_if_cond(l: Lowerer) -> LT {
    lb := "\{"
    result := _lower_atom(l)
    mut ll := result.l
    mut left := result.temp

    mut running := true
    while running {
        k := _lk(ll)
        if k == lb || k == "EOF" || k == "NEWLINE" {
            running = false
        } else if k == "==" || k == "!=" || k == "<" || k == ">" || k == "<=" || k == ">=" {
            ll = _ladv(ll)
            right := _lower_additive(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            left_type := _lget_type(ll, left)
            if (k == "==" || k == "!=") && left_type == 12 {
                ll = _lemit(ll, new_inst(OpStrEq, nt.temp, left, right.temp, "", 0))
                if k == "!=" {
                    not_nt := _lnew_temp(ll)
                    ll = not_nt.l
                    ll = _lemit(ll, new_inst(OpNot, not_nt.temp, nt.temp, 0, "", 0))
                    left = not_nt.temp
                } else {
                    left = nt.temp
                }
            } else if _is_float_type(left_type) || _is_float_type(_lget_type(ll, right.temp)) {
                ll = _lemit(ll, new_inst(_cmp_op(k), nt.temp, left, right.temp, "f64", 0))
                left = nt.temp
            } else {
                ll = _lemit(ll, new_inst(_cmp_op(k), nt.temp, left, right.temp, "", 0))
                left = nt.temp
            }
        } else if k == "&&" {
            ll = _ladv(ll)
            right := _lower_comparison(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpAnd, nt.temp, left, right.temp, "", 0))
            left = nt.temp
        } else if k == "||" {
            ll = _ladv(ll)
            right := _lower_comparison(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpOr, nt.temp, left, right.temp, "", 0))
            left = nt.temp
        } else if k == "+" || k == "-" {
            ll = _ladv(ll)
            right := _lower_multiplicative(ll)
            ll = right.l
            left_type := _lget_type(ll, left)
            right_type := _lget_type(ll, right.temp)
            if k == "+" && left_type == 12 {
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpStrConcat, nt.temp, left, right.temp, "", 0))
                ll = _lset_type(ll, nt.temp, 12)
                left = nt.temp
            } else if _is_float_type(left_type) || _is_float_type(right_type) {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "f64", 0))
                ll = _lset_type(ll, nt.temp, 9)
                left = nt.temp
            } else {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "", 0))
                left = nt.temp
            }
        } else if k == "*" || k == "/" || k == "%" {
            ll = _ladv(ll)
            right := _lower_atom(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            left_type := _lget_type(ll, left)
            right_type := _lget_type(ll, right.temp)
            if _is_float_type(left_type) || _is_float_type(right_type) {
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "f64", 0))
                ll = _lset_type(ll, nt.temp, 9)
            } else {
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "", 0))
            }
            left = nt.temp
        } else {
            running = false
        }
    }
    // Skip remaining tokens until {
    while _lk(ll) != lb && _lk(ll) != "EOF" { ll = _ladv(ll) }
    LT{l: ll, temp: left}
}

// --- Lower if expression ---

fn _lower_if(l: Lowerer) -> LT {
    mut ll := _ladv(l)  // skip if
    lb := "\{"
    rb := "\}"

    // Lower condition using full expression parser
    cond := _lower_if_cond(ll)
    ll = cond.l

    else_lbl := _lnew_label(ll)
    ll = else_lbl.l
    end_lbl := _lnew_label(ll)
    ll = end_lbl.l

    // Allocate result temp (2 slots for potential string result)
    result_nt := _lnew_str_temp(ll)
    ll = result_nt.l

    // Branch to else if condition is false
    ll = _lemit(ll, new_inst(OpBranchFalse, 0, cond.temp, else_lbl.temp, "", 0))

    // Then block — process statements and capture last expression
    if _lk(ll) == lb {
        ll = _ladv(ll)
        ll = _lskip_nl(ll)
        mut then_last := -1
        while _lk(ll) != rb && _lk(ll) != "EOF" {
            k := _lk(ll)
            if k == "return" || k == "mut" || k == "break" || k == "continue" || k == "for" || k == "while" || k == "loop" || k == "assert" || k == "defer" {
                ll = _lower_stmt(ll)
            } else if k == "if" {
                r := _lower_if(ll)
                ll = r.l
                then_last = r.temp
            } else {
                r := _lower_expr_result(ll)
                ll = r.l
                then_last = r.temp
            }
            ll = _lskip_nl(ll)
        }
        if _lk(ll) == rb { ll = _ladv(ll) }
        // Store last expression to result temp (always copy both ptr+len slots)
        if then_last >= 0 {
            ll = _lemit(ll, new_inst(OpStore, result_nt.temp, then_last, 0, "", 0))
            then_len_dst := result_nt.temp + 1
            then_len_src := then_last + 1
            ll = _lemit(ll, new_inst(OpStore, then_len_dst, then_len_src, 0, "", 0))
        }
    }
    ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))

    // Else label
    ll = _lemit(ll, new_inst(OpLabel, 0, else_lbl.temp, 0, "", 0))

    // Else block
    if _lk(ll) == "else" {
        ll = _ladv(ll)
        if _lk(ll) == "if" {
            else_result := _lower_if(ll)
            ll = else_result.l
            ll = _lemit(ll, new_inst(OpStore, result_nt.temp, else_result.temp, 0, "", 0))
            eif_len_dst := result_nt.temp + 1
            eif_len_src := else_result.temp + 1
            ll = _lemit(ll, new_inst(OpStore, eif_len_dst, eif_len_src, 0, "", 0))
        } else if _lk(ll) == lb {
            ll = _ladv(ll)
            ll = _lskip_nl(ll)
            mut else_last := -1
            while _lk(ll) != rb && _lk(ll) != "EOF" {
                k := _lk(ll)
                if k == "return" || k == "mut" || k == "break" || k == "continue" || k == "for" || k == "while" || k == "loop" || k == "assert" || k == "defer" {
                    ll = _lower_stmt(ll)
                } else if k == "if" {
                    r := _lower_if(ll)
                    ll = r.l
                    else_last = r.temp
                } else {
                    r := _lower_expr_result(ll)
                    ll = r.l
                    else_last = r.temp
                }
                ll = _lskip_nl(ll)
            }
            if _lk(ll) == rb { ll = _ladv(ll) }
            if else_last >= 0 {
                ll = _lemit(ll, new_inst(OpStore, result_nt.temp, else_last, 0, "", 0))
                else_len_dst := result_nt.temp + 1
                else_len_src := else_last + 1
                ll = _lemit(ll, new_inst(OpStore, else_len_dst, else_len_src, 0, "", 0))
            }
        }
    }

    // End label
    ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))

    LT{l: ll, temp: result_nt.temp}
}

// --- Lower while loop ---

fn _lower_while(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip while
    lb := "\{"

    loop_lbl := _lnew_label(ll)
    ll = loop_lbl.l
    end_lbl := _lnew_label(ll)
    ll = end_lbl.l

    // Loop start
    ll = _lemit(ll, new_inst(OpLabel, 0, loop_lbl.temp, 0, "", 0))

    // Lower condition using full expression parser (stops at {)
    cond := _lower_if_cond(ll)
    ll = cond.l

    // Branch to end if false
    ll = _lemit(ll, new_inst(OpBranchFalse, 0, cond.temp, end_lbl.temp, "", 0))

    // Set loop labels for break/continue
    prev_start := ll.loop_start
    prev_end := ll.loop_end
    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: ll.current_func,
                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                 env_names: ll.env_names, env_slots: ll.env_slots,
                 loop_start: loop_lbl.temp, loop_end: end_lbl.temp,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}

    // Body
    ll = _lower_block(ll)

    // Restore loop labels
    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: ll.current_func,
                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                 env_names: ll.env_names, env_slots: ll.env_slots,
                 loop_start: prev_start, loop_end: prev_end,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}

    // Jump back to loop start
    ll = _lemit(ll, new_inst(OpJump, 0, loop_lbl.temp, 0, "", 0))

    // End label
    ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
    ll
}

// --- Lower for-in with range ---

fn _lower_for_range(l: Lowerer, var_name: str, inclusive: bool) -> Lowerer {
    mut ll := l
    lb := "\{"

    // Lower start expression (before .. or ..=)
    start := _lower_expr(ll)
    ll = start.l
    // Skip .. or ..=
    if _lk(ll) == ".." || _lk(ll) == "..=" { ll = _ladv(ll) }
    // Lower end expression
    end := _lower_expr(ll)
    ll = end.l
    // Skip remaining until {
    while _lk(ll) != lb && _lk(ll) != "EOF" { ll = _ladv(ll) }

    // If inclusive, add 1 to end: end_val = end + 1
    mut limit_temp := end.temp
    if inclusive {
        one_nt := _lnew_temp(ll)
        ll = one_nt.l
        ll = _lemit(ll, new_inst(OpConst, one_nt.temp, 1, 0, "", 0))
        inc_nt := _lnew_temp(ll)
        ll = inc_nt.l
        ll = _lemit(ll, new_inst(OpAdd, inc_nt.temp, end.temp, one_nt.temp, "", 0))
        limit_temp = inc_nt.temp
    }

    // Initialize loop var to start
    idx_nt := _lnew_temp(ll)
    ll = idx_nt.l
    ll = _lemit(ll, new_inst(OpStore, idx_nt.temp, start.temp, 0, "", 0))

    // Labels
    loop_lbl := _lnew_label(ll)
    ll = loop_lbl.l
    end_lbl := _lnew_label(ll)
    ll = end_lbl.l
    inc_lbl := _lnew_label(ll)
    ll = inc_lbl.l

    // Loop start
    ll = _lemit(ll, new_inst(OpLabel, 0, loop_lbl.temp, 0, "", 0))

    // Condition: idx < limit
    cond_nt := _lnew_temp(ll)
    ll = cond_nt.l
    ll = _lemit(ll, new_inst(OpLt, cond_nt.temp, idx_nt.temp, limit_temp, "", 0))
    ll = _lemit(ll, new_inst(OpBranchFalse, 0, cond_nt.temp, end_lbl.temp, "", 0))

    // Bind loop variable
    if var_name != "" {
        ll = _lenv_add(ll, var_name, idx_nt.temp)
    }

    // Set break/continue labels (continue jumps to increment)
    prev_start := ll.loop_start
    prev_end := ll.loop_end
    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: ll.current_func,
                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                 env_names: ll.env_names, env_slots: ll.env_slots,
                 loop_start: inc_lbl.temp, loop_end: end_lbl.temp,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}

    // Body
    ll = _lower_block(ll)

    // Restore loop labels
    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: ll.current_func,
                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                 env_names: ll.env_names, env_slots: ll.env_slots,
                 loop_start: prev_start, loop_end: prev_end,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}

    // Increment label (continue target)
    ll = _lemit(ll, new_inst(OpLabel, 0, inc_lbl.temp, 0, "", 0))

    // Increment: idx = idx + 1
    one_nt := _lnew_temp(ll)
    ll = one_nt.l
    ll = _lemit(ll, new_inst(OpConst, one_nt.temp, 1, 0, "", 0))
    inc_nt := _lnew_temp(ll)
    ll = inc_nt.l
    ll = _lemit(ll, new_inst(OpAdd, inc_nt.temp, idx_nt.temp, one_nt.temp, "", 0))
    ll = _lemit(ll, new_inst(OpStore, idx_nt.temp, inc_nt.temp, 0, "", 0))

    // Jump back
    ll = _lemit(ll, new_inst(OpJump, 0, loop_lbl.temp, 0, "", 0))

    // End label
    ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
    ll
}

// --- Lower loop (infinite) ---

fn _lower_loop(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip loop

    loop_lbl := _lnew_label(ll)
    ll = loop_lbl.l
    end_lbl := _lnew_label(ll)
    ll = end_lbl.l

    // Loop start
    ll = _lemit(ll, new_inst(OpLabel, 0, loop_lbl.temp, 0, "", 0))

    // Set loop labels for break/continue
    prev_start := ll.loop_start
    prev_end := ll.loop_end
    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: ll.current_func,
                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                 env_names: ll.env_names, env_slots: ll.env_slots,
                 loop_start: loop_lbl.temp, loop_end: end_lbl.temp,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}

    // Body
    ll = _lower_block(ll)

    // Restore loop labels
    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: ll.current_func,
                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                 env_names: ll.env_names, env_slots: ll.env_slots,
                 loop_start: prev_start, loop_end: prev_end,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}

    // Jump back to loop start
    ll = _lemit(ll, new_inst(OpJump, 0, loop_lbl.temp, 0, "", 0))

    // End label
    ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
    ll
}

// --- Lower for loop ---

fn _lower_for(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip for
    lb := "\{"

    // Get loop variable name
    mut var_name := ""
    if _lk(ll) == "IDENT" {
        var_name = _lcur(ll).text
        ll = _ladv(ll)
    }
    if _lk(ll) == "in" { ll = _ladv(ll) }

    // Check if iterator is a range expression (peek for .. or ..=)
    mut is_range := false
    mut is_inclusive := false
    mut peek := ll.pos
    while peek < ll.tokens.len() {
        pk := token_name(ll.tokens[peek].kind)
        if pk == ".." { is_range = true }
        if pk == "..=" { is_range = true }
        if pk == "..=" { is_inclusive = true }
        if pk == lb || pk == "EOF" || pk == "NEWLINE" { peek = ll.tokens.len() }
        peek = peek + 1
    }

    if is_range {
        return _lower_for_range(ll, var_name, is_inclusive)
    }

    // Array iteration path
    // Lower iterator expression (the array)
    iter := _lower_expr(ll)
    ll = iter.l
    // Skip remaining until {
    while _lk(ll) != lb && _lk(ll) != "EOF" { ll = _ladv(ll) }

    // Get array length
    len_nt := _lnew_temp(ll)
    ll = len_nt.l
    ll = _lemit(ll, new_inst(OpArrayLen, len_nt.temp, iter.temp, 0, "", 0))

    // Initialize index to 0
    idx_nt := _lnew_temp(ll)
    ll = idx_nt.l
    ll = _lemit(ll, new_inst(OpConst, idx_nt.temp, 0, 0, "", 0))

    // Determine array element type
    iter_type := _lget_type(ll, iter.temp)

    // Labels
    loop_lbl := _lnew_label(ll)
    ll = loop_lbl.l
    end_lbl := _lnew_label(ll)
    ll = end_lbl.l
    inc_lbl := _lnew_label(ll)
    ll = inc_lbl.l

    // Loop start
    ll = _lemit(ll, new_inst(OpLabel, 0, loop_lbl.temp, 0, "", 0))

    // Condition: idx < len
    cond_nt := _lnew_temp(ll)
    ll = cond_nt.l
    ll = _lemit(ll, new_inst(OpLt, cond_nt.temp, idx_nt.temp, len_nt.temp, "", 0))
    ll = _lemit(ll, new_inst(OpBranchFalse, 0, cond_nt.temp, end_lbl.temp, "", 0))

    // Load arr[idx] into loop variable
    if var_name != "" {
        if iter_type == 13 || _is_str_array_type(ll.store, iter_type) {
            elem_nt := _lnew_str_temp(ll)
            ll = elem_nt.l
            ll = _lemit(ll, new_inst(OpArrayGet, elem_nt.temp, iter.temp, idx_nt.temp, "", 12))
            ll = _lset_type(ll, elem_nt.temp, 12)
            ll = _lenv_add(ll, var_name, elem_nt.temp)
        } else {
            elem_nt := _lnew_temp(ll)
            ll = elem_nt.l
            ll = _lemit(ll, new_inst(OpArrayGet, elem_nt.temp, iter.temp, idx_nt.temp, "", 0))
            ll = _lenv_add(ll, var_name, elem_nt.temp)
        }
    }

    // Set break/continue labels (continue jumps to increment)
    prev_start := ll.loop_start
    prev_end := ll.loop_end
    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: ll.current_func,
                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                 env_names: ll.env_names, env_slots: ll.env_slots,
                 loop_start: inc_lbl.temp, loop_end: end_lbl.temp,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}

    // Body
    ll = _lower_block(ll)

    // Restore loop labels
    ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: ll.current_func,
                 temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                 env_names: ll.env_names, env_slots: ll.env_slots,
                 loop_start: prev_start, loop_end: prev_end,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}

    // Increment label (continue target)
    ll = _lemit(ll, new_inst(OpLabel, 0, inc_lbl.temp, 0, "", 0))

    // Increment index: idx = idx + 1
    one_nt := _lnew_temp(ll)
    ll = one_nt.l
    ll = _lemit(ll, new_inst(OpConst, one_nt.temp, 1, 0, "", 0))
    inc_nt := _lnew_temp(ll)
    ll = inc_nt.l
    ll = _lemit(ll, new_inst(OpAdd, inc_nt.temp, idx_nt.temp, one_nt.temp, "", 0))
    ll = _lemit(ll, new_inst(OpStore, idx_nt.temp, inc_nt.temp, 0, "", 0))

    // Jump back
    ll = _lemit(ll, new_inst(OpJump, 0, loop_lbl.temp, 0, "", 0))

    // End label
    ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
    ll
}

// --- Lower interpolated string ---

fn _lower_interpolated_string(l: Lowerer) -> LT {
    // STRING_START text, expr tokens..., (STRING_MIDDLE text, expr tokens...)*, STRING_END text
    // Build result by concatenating: start_text + toString(expr) + middle_text + toString(expr2) + ... + end_text
    mut ll := l

    // Emit start string
    start_text := _lcur(ll).text
    start_result := _lower_string_const(ll, start_text)
    ll = start_result.l
    ll = _ladv(ll)  // skip STRING_START token
    mut result := start_result.temp

    // Process expression + optional middle segments
    mut running := true
    while running {
        if _lk(ll) == "STRING_END" || _lk(ll) == "STRING_MIDDLE" || _lk(ll) == "EOF" {
            running = false
        } else {
            // Lower interpolated expression
            expr := _lower_expr(ll)
            ll = expr.l
            // Convert to string if not already a string
            expr_type := _lget_type(ll, expr.temp)
            mut str_temp := expr.temp
            if expr_type != 12 {
                conv_nt := _lnew_str_temp(ll)
                ll = conv_nt.l
                if _is_float_type(expr_type) {
                    ll = _lemit(ll, new_inst(OpIntToStr,conv_nt.temp, expr.temp, 0, "", 0))
                } else {
                    ll = _lemit(ll, new_inst(OpIntToStr, conv_nt.temp, expr.temp, 0, "", 0))
                }
                ll = _lset_type(ll, conv_nt.temp, 12)
                str_temp = conv_nt.temp
            }
            // Concatenate with result
            cat_nt := _lnew_str_temp(ll)
            ll = cat_nt.l
            ll = _lemit(ll, new_inst(OpStrConcat, cat_nt.temp, result, str_temp, "", 0))
            ll = _lset_type(ll, cat_nt.temp, 12)
            result = cat_nt.temp
        }
    }

    // Process STRING_MIDDLE or STRING_END
    while _lk(ll) == "STRING_MIDDLE" {
        mid_text := _lcur(ll).text
        ll = _ladv(ll)  // skip STRING_MIDDLE
        // Concat middle text
        if mid_text.len() > 0 {
            mid_result := _lower_string_const(ll, mid_text)
            ll = mid_result.l
            cat_nt := _lnew_str_temp(ll)
            ll = cat_nt.l
            ll = _lemit(ll, new_inst(OpStrConcat, cat_nt.temp, result, mid_result.temp, "", 0))
            ll = _lset_type(ll, cat_nt.temp, 12)
            result = cat_nt.temp
        }
        // Lower next expression
        mut expr_running := true
        while expr_running {
            if _lk(ll) == "STRING_END" || _lk(ll) == "STRING_MIDDLE" || _lk(ll) == "EOF" {
                expr_running = false
            } else {
                expr := _lower_expr(ll)
                ll = expr.l
                expr_type := _lget_type(ll, expr.temp)
                mut str_temp := expr.temp
                if expr_type != 12 {
                    conv_nt := _lnew_str_temp(ll)
                    ll = conv_nt.l
                    if _is_float_type(expr_type) {
                        ll = _lemit(ll, new_inst(OpIntToStr,conv_nt.temp, expr.temp, 0, "", 0))
                    } else {
                        ll = _lemit(ll, new_inst(OpIntToStr, conv_nt.temp, expr.temp, 0, "", 0))
                    }
                    ll = _lset_type(ll, conv_nt.temp, 12)
                    str_temp = conv_nt.temp
                }
                cat_nt := _lnew_str_temp(ll)
                ll = cat_nt.l
                ll = _lemit(ll, new_inst(OpStrConcat, cat_nt.temp, result, str_temp, "", 0))
                ll = _lset_type(ll, cat_nt.temp, 12)
                result = cat_nt.temp
            }
        }
    }

    // STRING_END
    if _lk(ll) == "STRING_END" {
        end_text := _lcur(ll).text
        ll = _ladv(ll)  // skip STRING_END
        if end_text.len() > 0 {
            end_result := _lower_string_const(ll, end_text)
            ll = end_result.l
            cat_nt := _lnew_str_temp(ll)
            ll = cat_nt.l
            ll = _lemit(ll, new_inst(OpStrConcat, cat_nt.temp, result, end_result.temp, "", 0))
            ll = _lset_type(ll, cat_nt.temp, 12)
            result = cat_nt.temp
        }
    }

    ll = _lset_type(ll, result, 12)
    LT{l: ll, temp: result}
}

// --- Defer helpers ---

fn _lset_defer(l: Lowerer, new_count: i64, start: i64, end: i64, idx: i64) -> Lowerer {
    mut ds0 := l.defer_start_0
    mut ds1 := l.defer_start_1
    mut ds2 := l.defer_start_2
    mut ds3 := l.defer_start_3
    mut de0 := l.defer_end_0
    mut de1 := l.defer_end_1
    mut de2 := l.defer_end_2
    mut de3 := l.defer_end_3
    if idx == 0 { ds0 = start }
    if idx == 0 { de0 = end }
    if idx == 1 { ds1 = start }
    if idx == 1 { de1 = end }
    if idx == 2 { ds2 = start }
    if idx == 2 { de2 = end }
    if idx == 3 { ds3 = start }
    if idx == 3 { de3 = end }
    Lowerer{tokens: l.tokens, pos: l.pos, store: l.store, registry: l.registry,
            table: l.table, file: l.file, module: l.module,
            current_func: l.current_func,
            temp_counter: l.temp_counter, label_counter: l.label_counter,
            env_names: l.env_names, env_slots: l.env_slots,
            loop_start: l.loop_start, loop_end: l.loop_end,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: l.temp_types,
            fn_error_type: l.fn_error_type, defer_count: new_count, defer_start_0: ds0, defer_start_1: ds1, defer_start_2: ds2, defer_start_3: ds3, defer_end_0: de0, defer_end_1: de1, defer_end_2: de2, defer_end_3: de3}
}

// Emit deferred expressions in reverse order (LIFO)
fn _emit_defers(l: Lowerer) -> Lowerer {
    mut ll := l
    // Emit drop calls for bindings whose types implement Drop (reverse order)
    ll = _emit_drops(ll)
    if ll.defer_count == 0 { return ll }
    // Emit in reverse order: last defer first
    mut di := ll.defer_count - 1
    while di >= 0 {
        mut ds := 0
        mut de := 0
        if di == 0 { ds = ll.defer_start_0 }
        if di == 0 { de = ll.defer_end_0 }
        if di == 1 { ds = ll.defer_start_1 }
        if di == 1 { de = ll.defer_end_1 }
        if di == 2 { ds = ll.defer_start_2 }
        if di == 2 { de = ll.defer_end_2 }
        if di == 3 { ds = ll.defer_start_3 }
        if di == 3 { de = ll.defer_end_3 }
        if ds > 0 && de > ds {
            saved_pos := ll.pos
            ll = _lset_pos(ll, ds)
            result := _lower_expr(ll)
            ll = result.l
            ll = _lset_pos(ll, saved_pos)
        }
        di = di - 1
    }
    ll
}

// --- Trait object (dyn Trait) construction ---
// Creates a fat pointer: (data_ptr, vtable_ptr) where vtable contains fn ptrs.
// concrete_type: the struct type name, trait_name: the trait being implemented
// The vtable stores fn ptrs for each method: ConcreteType_methodName
fn _lower_make_trait_object(l: Lowerer, data_temp: i64, concrete_type: str, trait_name: str) -> LT {
    mut ll := l
    // Build vtable: allocate N slots, store fn ptrs
    // Find methods by pattern: concrete_type + "_" + common trait methods
    // For each registered fn matching ConcreteType_*, store fn ptr in vtable
    mut vtable_methods := [""]  // sentinel
    mut mi := 1
    while mi < ll.registry.fn_sigs.len() {
        sig := ll.registry.fn_sigs[mi]
        if sig.name != "" {
            // Check if this fn starts with "ConcreteType_"
            prefix := concrete_type + "_"
            if sig.name.len() > prefix.len() && sig.name.substring(0, prefix.len()) == prefix {
                vtable_methods = vtable_methods.append(sig.name)
            }
        }
        mi = mi + 1
    }
    method_count := vtable_methods.len() - 1  // subtract sentinel
    if method_count == 0 {
        // No methods found — return data as-is (degenerate trait object)
        return LT{l: ll, temp: data_temp}
    }
    // Allocate vtable
    vt_nt := _lnew_temp(ll)
    ll = vt_nt.l
    ll = _lemit(ll, new_inst(OpAlloc, vt_nt.temp, method_count, 0, "_vtable", 0))
    // Store fn ptrs in vtable slots
    mut vi := 1
    while vi < vtable_methods.len() {
        fn_name := vtable_methods[vi]
        // Get fn ptr
        fn_nt := _lnew_temp(ll)
        ll = fn_nt.l
        ll = _lemit(ll, new_inst(OpFnRef, fn_nt.temp, 0, 0, fn_name, 0))
        // Store in vtable slot
        ll = _lemit(ll, new_inst(OpFieldSet, vt_nt.temp, vi - 1, fn_nt.temp, "", 0))
        vi = vi + 1
    }
    // Create trait object: alloc 2 slots, store data_ptr and vtable_ptr
    to_nt := _lnew_temp(ll)
    ll = to_nt.l
    ll = _lemit(ll, new_inst(OpTraitObject, to_nt.temp, data_temp, vt_nt.temp, "", 0))
    ll = _lset_type(ll, to_nt.temp, 500)  // 500 = trait object marker
    LT{l: ll, temp: to_nt.temp}
}

// Emit drop calls for bindings with Drop-implementing types
// scope_start: index in env_names where current scope begins (only drop bindings >= scope_start)
fn _emit_drops_scoped(l: Lowerer, scope_start: i64) -> Lowerer {
    mut ll := l
    // Walk bindings in reverse order (LIFO destruction order)
    mut i := ll.env_names.len() - 1
    while i >= scope_start && i > 0 {
        slot := ll.env_slots[i]
        // Check if this binding's type has a drop function
        obj_type := _lget_type(ll, slot)
        sname := _struct_name_for_type(ll.store, ll.registry, obj_type)
        if sname != "" {
            drop_fn := sname + "_drop"
            drop_sig := reg_find_fn(ll.registry, drop_fn)
            if drop_sig.name != "" {
                // Emit: TypeName_drop(binding)
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, slot, 1, drop_fn, 0))
            }
        }
        i = i - 1
    }
    ll
}

// Emit drops for all bindings (used at function exit)
fn _emit_drops(l: Lowerer) -> Lowerer =
    _emit_drops_scoped(l, 1)

// --- Lower closure expression ---

fn _lower_closure(l: Lowerer) -> LT {
    mut ll := _ladv(l)  // skip fn
    // Generate unique closure name based on module function count
    closure_name := "_closure_" + _closure_i2s(ll.module.funcs.len())

    // Parse parameter names and count
    mut param_count := 0
    mut pname_0 := ""
    mut pname_1 := ""
    mut pname_2 := ""
    mut pname_3 := ""
    if _lk(ll) == "(" {
        ll = _ladv(ll)  // skip (
        while _lk(ll) != ")" && _lk(ll) != "EOF" {
            if _lk(ll) == "IDENT" || _lk(ll) == "self" {
                ptext := _lcur(ll).text
                if param_count == 0 { pname_0 = ptext }
                if param_count == 1 { pname_1 = ptext }
                if param_count == 2 { pname_2 = ptext }
                if param_count == 3 { pname_3 = ptext }
                param_count = param_count + 1
                ll = _ladv(ll)
                // Skip type annotation
                if _lk(ll) == ":" {
                    ll = _ladv(ll)
                    while _lk(ll) != "," && _lk(ll) != ")" && _lk(ll) != "EOF" {
                        ll = _ladv(ll)
                    }
                }
            } else {
                ll = _ladv(ll)
            }
            if _lk(ll) == "," { ll = _ladv(ll) }
        }
        if _lk(ll) == ")" { ll = _ladv(ll) }
    }
    // Skip return type annotation
    lb2 := "\{"
    if _lk(ll) == "->" {
        ll = _ladv(ll)
        while _lk(ll) != "=>" && _lk(ll) != lb2 && _lk(ll) != "EOF" { ll = _ladv(ll) }
    }
    // Skip =>
    if _lk(ll) == "=>" { ll = _ladv(ll) }
    ll = _lskip_nl(ll)

    // Save body position — we'll lower it inside the closure function
    body_start := ll.pos

    // Skip body expression to find the end (for the outer context)
    // The body is a single expression until newline or }
    lb := "\{"
    if _lk(ll) == lb {
        ll = _skip_braces_l(ll)
    } else {
        // Skip single expression — advance until statement boundary
        mut depth := 0
        while _lk(ll) != "NEWLINE" && _lk(ll) != "EOF" {
            if _lk(ll) == "(" { depth = depth + 1 }
            if _lk(ll) == ")" {
                if depth == 0 { return LT{l: ll, temp: 0} }
                depth = depth - 1
            }
            if _lk(ll) == "," && depth == 0 { return LT{l: ll, temp: 0} }
            ll = _ladv(ll)
        }
    }
    body_end := ll.pos

    // Save current function state
    saved_func := ll.current_func
    saved_temp := ll.temp_counter
    saved_label := ll.label_counter
    saved_env_names := ll.env_names
    saved_env_slots := ll.env_slots
    saved_types := ll.temp_types

    // Scan for captured variables: identifiers in body that exist in outer env
    // but are NOT closure parameters
    mut cap_count := 0
    mut cap_name_0 := ""
    mut cap_name_1 := ""
    mut cap_name_2 := ""
    mut cap_name_3 := ""
    mut cap_name_4 := ""
    mut cap_name_5 := ""
    mut cap_name_6 := ""
    mut cap_name_7 := ""
    mut cap_slot_0 := 0
    mut cap_slot_1 := 0
    mut cap_slot_2 := 0
    mut cap_slot_3 := 0
    mut cap_slot_4 := 0
    mut cap_slot_5 := 0
    mut cap_slot_6 := 0
    mut cap_slot_7 := 0
    // Scan body tokens for captures
    mut scan_pos := body_start
    while scan_pos < body_end && scan_pos < ll.tokens.len() {
        stok := ll.tokens[scan_pos]
        if token_name(stok.kind) == "IDENT" {
            sname := stok.text
            // Check if it's in outer env
            outer_slot := _lenv_lookup(ll, sname)
            if outer_slot >= 0 {
                // Check it's not a closure parameter
                mut is_param := false
                if param_count > 0 && pname_0 == sname { is_param = true }
                if param_count > 1 && pname_1 == sname { is_param = true }
                if param_count > 2 && pname_2 == sname { is_param = true }
                if param_count > 3 && pname_3 == sname { is_param = true }
                if is_param == false {
                    // Check not already captured
                    mut already := false
                    if cap_count > 0 && cap_name_0 == sname { already = true }
                    if cap_count > 1 && cap_name_1 == sname { already = true }
                    if cap_count > 2 && cap_name_2 == sname { already = true }
                    if cap_count > 3 && cap_name_3 == sname { already = true }
                    if cap_count > 4 && cap_name_4 == sname { already = true }
                    if cap_count > 5 && cap_name_5 == sname { already = true }
                    if cap_count > 6 && cap_name_6 == sname { already = true }
                    if cap_count > 7 && cap_name_7 == sname { already = true }
                    if already == false && cap_count < 8 {
                        if cap_count == 0 { cap_name_0 = sname }
                        if cap_count == 0 { cap_slot_0 = outer_slot }
                        if cap_count == 1 { cap_name_1 = sname }
                        if cap_count == 1 { cap_slot_1 = outer_slot }
                        if cap_count == 2 { cap_name_2 = sname }
                        if cap_count == 2 { cap_slot_2 = outer_slot }
                        if cap_count == 3 { cap_name_3 = sname }
                        if cap_count == 3 { cap_slot_3 = outer_slot }
                        if cap_count == 4 { cap_name_4 = sname }
                        if cap_count == 4 { cap_slot_4 = outer_slot }
                        if cap_count == 5 { cap_name_5 = sname }
                        if cap_count == 5 { cap_slot_5 = outer_slot }
                        if cap_count == 6 { cap_name_6 = sname }
                        if cap_count == 6 { cap_slot_6 = outer_slot }
                        if cap_count == 7 { cap_name_7 = sname }
                        if cap_count == 7 { cap_slot_7 = outer_slot }
                        cap_count = cap_count + 1
                    }
                }
            }
        }
        scan_pos = scan_pos + 1
    }

    // Create closure function: param_count + 1 (extra env_ptr as first param)
    actual_params := param_count + 1
    ll = _lset_func(ll, new_ir_func(closure_name, actual_params, 1))

    // First param is env_ptr
    env_param := _lnew_temp(ll)
    ll = env_param.l
    ll = _lenv_add(ll, "_env", env_param.temp)

    // Register closure parameters (after env_ptr)
    mut pi := 0
    while pi < param_count {
        nt := _lnew_temp(ll)
        ll = nt.l
        mut pn := ""
        if pi == 0 { pn = pname_0 }
        if pi == 1 { pn = pname_1 }
        if pi == 2 { pn = pname_2 }
        if pi == 3 { pn = pname_3 }
        ll = _lenv_add(ll, pn, nt.temp)
        pi = pi + 1
    }

    // Load captured variables from env struct into local temps
    if cap_count > 0 {
        mut ci := 0
        while ci < cap_count {
            mut cn := ""
            if ci == 0 { cn = cap_name_0 }
            if ci == 1 { cn = cap_name_1 }
            if ci == 2 { cn = cap_name_2 }
            if ci == 3 { cn = cap_name_3 }
            if ci == 4 { cn = cap_name_4 }
            if ci == 5 { cn = cap_name_5 }
            if ci == 6 { cn = cap_name_6 }
            if ci == 7 { cn = cap_name_7 }
            cap_nt := _lnew_temp(ll)
            ll = cap_nt.l
            ll = _lemit(ll, new_inst(OpFieldGet, cap_nt.temp, env_param.temp, ci, "", 0))
            ll = _lenv_add(ll, cn, cap_nt.temp)
            ci = ci + 1
        }
    }

    // Lower body
    ll = _lset_pos(ll, body_start)
    lb3 := "\{"
    if body_start < body_end {
        if _lk(ll) == lb3 {
            // Block body: use _lower_fn_body which handles multi-statement blocks
            // and emits OpRet for the last expression
            ll = _lower_fn_body(ll, 1)
        } else {
            result := _lower_expr(ll)
            ll = result.l
            ll = _lemit(ll, new_inst(OpRet, 0, result.temp, 0, "", 0))
        }
    }

    // Finish closure function
    ll = _lfinish_func(ll)

    // Restore outer function state
    ll = Lowerer{tokens: ll.tokens, pos: body_end, store: ll.store, registry: ll.registry,
                 table: ll.table, file: ll.file, module: ll.module,
                 current_func: saved_func,
                 temp_counter: saved_temp, label_counter: saved_label,
                 env_names: saved_env_names, env_slots: saved_env_slots,
                 loop_start: ll.loop_start, loop_end: ll.loop_end,
                 const_names: ll.const_names, const_vals: ll.const_vals,
                 const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                 temp_types: saved_types,
                 fn_error_type: 0, defer_count: 0, defer_start_0: 0, defer_start_1: 0, defer_start_2: 0, defer_start_3: 0, defer_end_0: 0, defer_end_1: 0, defer_end_2: 0, defer_end_3: 0}

    // Build fat pointer: {fn_ptr, env_ptr}
    // Allocate 2-slot struct
    fat_nt := _lnew_temp(ll)
    ll = fat_nt.l
    ll = _lemit(ll, new_inst(OpAlloc, fat_nt.temp, 2, 0, "_closure", 0))

    // Store fn_ptr at slot 0
    fnref_nt := _lnew_temp(ll)
    ll = fnref_nt.l
    ll = _lemit(ll, new_inst(OpFnRef, fnref_nt.temp, 0, 0, closure_name, 0))
    ll = _lemit(ll, new_inst(OpFieldSet, fat_nt.temp, fnref_nt.temp, 0, "_fn", 0))

    // Build and store env_ptr at slot 1
    if cap_count > 0 {
        // Allocate env struct with cap_count slots
        env_nt := _lnew_temp(ll)
        ll = env_nt.l
        ll = _lemit(ll, new_inst(OpAlloc, env_nt.temp, cap_count, 0, "_env", 0))
        // Copy captured values into env
        mut ci := 0
        while ci < cap_count {
            mut cs := 0
            if ci == 0 { cs = cap_slot_0 }
            if ci == 1 { cs = cap_slot_1 }
            if ci == 2 { cs = cap_slot_2 }
            if ci == 3 { cs = cap_slot_3 }
            if ci == 4 { cs = cap_slot_4 }
            if ci == 5 { cs = cap_slot_5 }
            if ci == 6 { cs = cap_slot_6 }
            if ci == 7 { cs = cap_slot_7 }
            val_nt := _lnew_temp(ll)
            ll = val_nt.l
            ll = _lemit(ll, new_inst(OpLoad, val_nt.temp, cs, 0, "", 0))
            ll = _lemit(ll, new_inst(OpFieldSet, env_nt.temp, val_nt.temp, ci, "", 0))
            ci = ci + 1
        }
        ll = _lemit(ll, new_inst(OpFieldSet, fat_nt.temp, env_nt.temp, 1, "_env", 0))
    } else {
        // No captures: store 0 as env_ptr
        null_nt := _lnew_temp(ll)
        ll = null_nt.l
        ll = _lemit(ll, new_inst(OpConst, null_nt.temp, 0, 0, "", 0))
        ll = _lemit(ll, new_inst(OpFieldSet, fat_nt.temp, null_nt.temp, 1, "_env", 0))
    }

    LT{l: ll, temp: fat_nt.temp}
}

fn _closure_i2s(n: i64) -> str {
    if n == 0 { return "0" }
    mut result := ""
    mut v := n
    while v > 0 {
        d := v % 10
        v = v / 10
        if d == 0 { result = "0" + result }
        if d == 1 { result = "1" + result }
        if d == 2 { result = "2" + result }
        if d == 3 { result = "3" + result }
        if d == 4 { result = "4" + result }
        if d == 5 { result = "5" + result }
        if d == 6 { result = "6" + result }
        if d == 7 { result = "7" + result }
        if d == 8 { result = "8" + result }
        if d == 9 { result = "9" + result }
    }
    result
}

// --- Newtype detection ---

fn _is_newtype(def: StructDef) -> bool {
    if def.fields.len() != 2 { return false }
    def.fields[1].name == "value"
}

// --- Variant tag lookup ---

fn _variant_tag(reg: TypeRegistry, name: str) -> i64 {
    // Search all sum types for a variant with this name
    mut si := 1
    while si < reg.struct_defs.len() {
        def := reg.struct_defs[si]
        if def.is_sum {
            mut vi := 1
            while vi < def.variant_names.len() {
                if def.variant_names[vi] == name {
                    return vi  // 1-based tag
                }
                vi = vi + 1
            }
        }
        si = si + 1
    }
    0  // not found
}

// Find the parent sum type StructDef for a variant name
fn _variant_parent(reg: TypeRegistry, name: str) -> StructDef {
    mut si := 1
    while si < reg.struct_defs.len() {
        def := reg.struct_defs[si]
        if def.is_sum {
            mut vi := 1
            while vi < def.variant_names.len() {
                if def.variant_names[vi] == name {
                    return def
                }
                vi = vi + 1
            }
        }
        si = si + 1
    }
    _sentinel_struct_def()
}

// --- Helper: parse integer literal string to i64 ---

fn _parse_int_literal(val: str) -> i64 {
    mut num := 0
    mut i := 0
    mut neg := false
    if val.len() > 0 && val.charAt(0) == "-" {
        neg = true
        i = 1
    }
    // Check for base prefix (0x, 0o, 0b)
    if val.len() > i + 1 && val.charAt(i) == "0" {
        p := val.charAt(i + 1)
        if p == "x" || p == "X" {
            num = _parse_hex(val, i + 2)
            if neg { num = 0 - num }
            return num
        }
        if p == "o" || p == "O" {
            num = _parse_oct(val, i + 2)
            if neg { num = 0 - num }
            return num
        }
        if p == "b" || p == "B" {
            num = _parse_bin(val, i + 2)
            if neg { num = 0 - num }
            return num
        }
    }
    while i < val.len() {
        ch := val.charAt(i)
        if ch != "_" {
            mut digit := 0
            if ch == "0" { digit = 0 } else if ch == "1" { digit = 1 } else if ch == "2" { digit = 2 } else if ch == "3" { digit = 3 } else if ch == "4" { digit = 4 } else if ch == "5" { digit = 5 } else if ch == "6" { digit = 6 } else if ch == "7" { digit = 7 } else if ch == "8" { digit = 8 } else if ch == "9" { digit = 9 }
            num = num * 10 + digit
        }
        i = i + 1
    }
    if neg { num = 0 - num }
    num
}

fn _char_to_code(ch: str) -> i64 {
    if ch == "\n" { return 10 }
    if ch == "\t" { return 9 }
    if ch == "\r" { return 13 }
    if ch == "\0" { return 0 }
    if ch == " " { return 32 }
    if ch == "!" { return 33 }
    if ch == "\"" { return 34 }
    if ch == "#" { return 35 }
    if ch == "$" { return 36 }
    if ch == "%" { return 37 }
    if ch == "&" { return 38 }
    if ch == "'" { return 39 }
    if ch == "(" { return 40 }
    if ch == ")" { return 41 }
    if ch == "*" { return 42 }
    if ch == "+" { return 43 }
    if ch == "," { return 44 }
    if ch == "-" { return 45 }
    if ch == "." { return 46 }
    if ch == "/" { return 47 }
    if ch == "0" { return 48 }
    if ch == "1" { return 49 }
    if ch == "2" { return 50 }
    if ch == "3" { return 51 }
    if ch == "4" { return 52 }
    if ch == "5" { return 53 }
    if ch == "6" { return 54 }
    if ch == "7" { return 55 }
    if ch == "8" { return 56 }
    if ch == "9" { return 57 }
    if ch == ":" { return 58 }
    if ch == ";" { return 59 }
    if ch == "<" { return 60 }
    if ch == "=" { return 61 }
    if ch == ">" { return 62 }
    if ch == "?" { return 63 }
    if ch == "@" { return 64 }
    if ch == "A" { return 65 }
    if ch == "B" { return 66 }
    if ch == "C" { return 67 }
    if ch == "D" { return 68 }
    if ch == "E" { return 69 }
    if ch == "F" { return 70 }
    if ch == "G" { return 71 }
    if ch == "H" { return 72 }
    if ch == "I" { return 73 }
    if ch == "J" { return 74 }
    if ch == "K" { return 75 }
    if ch == "L" { return 76 }
    if ch == "M" { return 77 }
    if ch == "N" { return 78 }
    if ch == "O" { return 79 }
    if ch == "P" { return 80 }
    if ch == "Q" { return 81 }
    if ch == "R" { return 82 }
    if ch == "S" { return 83 }
    if ch == "T" { return 84 }
    if ch == "U" { return 85 }
    if ch == "V" { return 86 }
    if ch == "W" { return 87 }
    if ch == "X" { return 88 }
    if ch == "Y" { return 89 }
    if ch == "Z" { return 90 }
    if ch == "[" { return 91 }
    if ch == "\\" { return 92 }
    if ch == "]" { return 93 }
    if ch == "^" { return 94 }
    if ch == "_" { return 95 }
    if ch == "`" { return 96 }
    if ch == "a" { return 97 }
    if ch == "b" { return 98 }
    if ch == "c" { return 99 }
    if ch == "d" { return 100 }
    if ch == "e" { return 101 }
    if ch == "f" { return 102 }
    if ch == "g" { return 103 }
    if ch == "h" { return 104 }
    if ch == "i" { return 105 }
    if ch == "j" { return 106 }
    if ch == "k" { return 107 }
    if ch == "l" { return 108 }
    if ch == "m" { return 109 }
    if ch == "n" { return 110 }
    if ch == "o" { return 111 }
    if ch == "p" { return 112 }
    if ch == "q" { return 113 }
    if ch == "r" { return 114 }
    if ch == "s" { return 115 }
    if ch == "t" { return 116 }
    if ch == "u" { return 117 }
    if ch == "v" { return 118 }
    if ch == "w" { return 119 }
    if ch == "x" { return 120 }
    if ch == "y" { return 121 }
    if ch == "z" { return 122 }
    if ch == "\{" { return 123 }
    if ch == "|" { return 124 }
    if ch == "\}" { return 125 }
    if ch == "~" { return 126 }
    0
}

fn _parse_hex(val: str, start: i64) -> i64 {
    mut num := 0
    mut i := start
    while i < val.len() {
        ch := val.charAt(i)
        if ch != "_" {
            mut digit := 0
            if ch == "0" { digit = 0 } else if ch == "1" { digit = 1 } else if ch == "2" { digit = 2 } else if ch == "3" { digit = 3 } else if ch == "4" { digit = 4 } else if ch == "5" { digit = 5 } else if ch == "6" { digit = 6 } else if ch == "7" { digit = 7 } else if ch == "8" { digit = 8 } else if ch == "9" { digit = 9 } else if ch == "a" || ch == "A" { digit = 10 } else if ch == "b" || ch == "B" { digit = 11 } else if ch == "c" || ch == "C" { digit = 12 } else if ch == "d" || ch == "D" { digit = 13 } else if ch == "e" || ch == "E" { digit = 14 } else if ch == "f" || ch == "F" { digit = 15 }
            num = num * 16 + digit
        }
        i = i + 1
    }
    num
}

fn _parse_oct(val: str, start: i64) -> i64 {
    mut num := 0
    mut i := start
    while i < val.len() {
        ch := val.charAt(i)
        if ch != "_" {
            mut digit := 0
            if ch == "0" { digit = 0 } else if ch == "1" { digit = 1 } else if ch == "2" { digit = 2 } else if ch == "3" { digit = 3 } else if ch == "4" { digit = 4 } else if ch == "5" { digit = 5 } else if ch == "6" { digit = 6 } else if ch == "7" { digit = 7 }
            num = num * 8 + digit
        }
        i = i + 1
    }
    num
}

fn _parse_bin(val: str, start: i64) -> i64 {
    mut num := 0
    mut i := start
    while i < val.len() {
        ch := val.charAt(i)
        if ch != "_" {
            if ch == "1" { num = num * 2 + 1 } else { num = num * 2 }
        }
        i = i + 1
    }
    num
}

// --- Helper: lower a string literal value to a temp (for pattern matching) ---

fn _lower_string_const(l: Lowerer, val: str) -> LT {
    mut ll := l
    mut str_idx := mod_find_string(ll.module, val)
    if str_idx == 0 {
        new_mod := mod_add_string(ll.module, val)
        str_idx = new_mod.string_constants.len() - 1
        ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                     table: ll.table, file: ll.file, module: new_mod,
                     current_func: ll.current_func,
                     temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                     env_names: ll.env_names, env_slots: ll.env_slots,
                     loop_start: ll.loop_start, loop_end: ll.loop_end,
                     const_names: ll.const_names, const_vals: ll.const_vals,
                     const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                     temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
    }
    nt := _lnew_str_temp(ll)
    ll = nt.l
    ll = _lemit(ll, new_inst(OpConstStr, nt.temp, str_idx, val.len(), "", 0))
    ll = _lset_type(ll, nt.temp, 12)
    LT{l: ll, temp: nt.temp}
}

// --- Lower match subject (avoid greedy { consumption) ---

fn _lower_match_subject(l: Lowerer) -> LT {
    k := _lk(l)

    if k == "IDENT" {
        name := _lcur(l).text
        mut ll := _ladv(l)

        // Check for function call
        if _lk(ll) == "(" {
            sig := reg_find_fn(ll.registry, name)
            if sig.name != "" {
                ll = _ladv(ll)  // skip (
                ll = _lskip_nl(ll)
                mut first_arg := -1
                mut arg_count := 0
                while _lk(ll) != ")" && _lk(ll) != "EOF" {
                    ll = _lskip_nl(ll)
                    arg := _lower_expr(ll)
                    ll = arg.l
                    if arg_count == 0 { first_arg = arg.temp }
                    arg_count = arg_count + 1
                    ll = _lskip_nl(ll)
                    if _lk(ll) == "," { ll = _ladv(ll) }
                }
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                mut fa := 0
                if first_arg >= 0 { fa = first_arg }
                ll = _lemit(ll, new_inst(OpCall, nt.temp, fa, arg_count, name, 0))
                return LT{l: ll, temp: nt.temp}
            }
        }

        // Field access: obj.field (without consuming {)
        if _lk(ll) == "." {
            slot := _lenv_lookup(ll, name)
            if slot >= 0 {
                src_type := _lget_type(ll, slot)
                mut base_temp := 0
                if src_type == 12 {
                    nt_base := _lnew_str_temp(ll)
                    ll = nt_base.l
                    base_temp = nt_base.temp
                } else {
                    nt_base := _lnew_temp(ll)
                    ll = nt_base.l
                    base_temp = nt_base.temp
                }
                ll = _lemit(ll, new_inst(OpLoad, base_temp, slot, 0, "", 0))
                if src_type != 0 {
                    ll = _lset_type(ll, base_temp, src_type)
                }
                mut cur := base_temp
                while _lk(ll) == "." {
                    ll = _ladv(ll)
                    if _lk(ll) == "IDENT" {
                        field := _lcur(ll).text
                        ll = _ladv(ll)
                        nt := _lnew_temp(ll)
                        ll = nt.l
                        ll = _lemit(ll, new_inst(OpFieldGet, nt.temp, cur, 0, field, 0))
                        cur = nt.temp
                    }
                }
                return LT{l: ll, temp: cur}
            }
        }

        // Variable reference (do NOT try struct literal — the { is the match body)
        slot := _lenv_lookup(ll, name)
        if slot >= 0 {
            // Use _lnew_str_temp for string sources (2 consecutive slots)
            src_type := _lget_type(ll, slot)
            mut nt_temp := 0
            if src_type == 12 {
                nt := _lnew_str_temp(ll)
                ll = nt.l
                nt_temp = nt.temp
            } else {
                nt := _lnew_temp(ll)
                ll = nt.l
                nt_temp = nt.temp
            }
            ll = _lemit(ll, new_inst(OpLoad, nt_temp, slot, 0, "", 0))
            if src_type != 0 {
                ll = _lset_type(ll, nt_temp, src_type)
            }
            return LT{l: ll, temp: nt_temp}
        }

        // Variant tag
        tag := _variant_tag(ll.registry, name)
        if tag > 0 {
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpConst, nt.temp, tag, 0, "", 0))
            return LT{l: ll, temp: nt.temp}
        }

        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpConst, nt.temp, 0, 0, "", 0))
        return LT{l: ll, temp: nt.temp}
    }

    if k == "INT" {
        return _lower_primary(l)
    }

    if k == "(" {
        return _lower_primary(l)
    }

    // Fallback
    nt := _lnew_temp(l)
    ll := _lemit(_ladv(nt.l), new_inst(OpConst, nt.temp, 0, 0, "", 0))
    LT{l: ll, temp: nt.temp}
}

// --- Lower match expression ---

fn _lower_match(l: Lowerer) -> LT {
    mut ll := _ladv(l)  // skip match
    lb := "\{"
    rb := "\}"

    // Lower subject — use _lower_match_subject to avoid greedy struct literal parsing
    subj := _lower_match_subject(ll)
    ll = subj.l
    while _lk(ll) != lb && _lk(ll) != "EOF" { ll = _ladv(ll) }

    ll = _lskip_nl(ll)
    if _lk(ll) != lb {
        nt := _lnew_temp(ll)
        return LT{l: nt.l, temp: nt.temp}
    }
    ll = _ladv(ll)  // skip {
    ll = _lskip_nl(ll)

    // Allocate result temp and end label
    // Use str temp (2 slots) since match may return strings
    result_nt := _lnew_str_temp(ll)
    ll = result_nt.l
    end_lbl := _lnew_label(ll)
    ll = end_lbl.l

    // Determine if the subject is a data sum type (struct-allocated with tag at slot 0)
    // Scan the arms to find the first non-wildcard variant name and check its parent type
    mut is_data_sum := false
    mut subj_tag_temp := subj.temp  // for tag-only sums, subject IS the tag
    // Peek at arm patterns (we're already past { and newlines at this point)
    mut peek_pos := ll.pos
    while peek_pos < ll.tokens.len() && token_name(ll.tokens[peek_pos].kind) == "NEWLINE" {
        peek_pos = peek_pos + 1
    }
    // First token in arm should be a pattern name
    if peek_pos < ll.tokens.len() && token_name(ll.tokens[peek_pos].kind) == "IDENT" {
        first_pat := ll.tokens[peek_pos].text
        if first_pat != "_" {
            pat_parent := _variant_parent(ll.registry, first_pat)
            if pat_parent.name != "" && sum_has_data(pat_parent) {
                is_data_sum = true
                // Extract tag from slot 0 of the struct
                tag_ext := _lnew_temp(ll)
                ll = tag_ext.l
                ll = _lemit(ll, new_inst(OpFieldGet, tag_ext.temp, subj.temp, 0, "_tag", 0))
                subj_tag_temp = tag_ext.temp
            }
        }
    }

    // Process each arm
    while _lk(ll) != rb && _lk(ll) != "EOF" {
        ll = _lskip_nl(ll)
        if _lk(ll) == rb || _lk(ll) == "EOF" { return LT{l: ll, temp: result_nt.temp} }

        // Read pattern — determine pattern kind
        pattern := _lcur(ll).text
        pattern_kind := _lk(ll)  // "IDENT", "INT", "STRING", "true", "false"
        is_wildcard := pattern == "_"
        is_variant := false
        is_literal := false
        is_binding := false
        if pattern_kind == "INT" || pattern_kind == "STRING" || pattern_kind == "true" || pattern_kind == "false" {
            is_literal = true
        }
        if pattern_kind == "IDENT" && is_wildcard == false {
            vtag_check := _variant_tag(ll.registry, pattern)
            if vtag_check > 0 {
                is_variant = true
            } else {
                // Identifier that's not a variant name = binding pattern
                is_binding = true
            }
        }

        if is_wildcard {
            ll = _ladv(ll)  // skip _
        } else {
            ll = _ladv(ll)  // skip pattern token
        }

        // Check for or-pattern: Red | Blue => ... (multiple patterns for same arm)
        // Collect additional or-pattern variant names
        mut or_count := 0
        mut or_name_0 := ""
        mut or_name_1 := ""
        mut or_name_2 := ""
        mut or_name_3 := ""
        if is_variant && _lk(ll) == "|" {
            while _lk(ll) == "|" {
                ll = _ladv(ll)  // skip |
                ll = _lskip_nl(ll)
                if _lk(ll) == "IDENT" {
                    oname := _lcur(ll).text
                    if or_count == 0 { or_name_0 = oname }
                    if or_count == 1 { or_name_1 = oname }
                    if or_count == 2 { or_name_2 = oname }
                    if or_count == 3 { or_name_3 = oname }
                    or_count = or_count + 1
                    ll = _ladv(ll)
                }
                ll = _lskip_nl(ll)
            }
        }

        // Collect destructuring binding names into parallel token-saved arrays
        mut has_bindings := false
        mut bind_name_0 := ""
        mut bind_name_1 := ""
        mut bind_name_2 := ""
        mut bind_name_3 := ""
        mut bind_total := 0
        if _lk(ll) == "(" {
            ll = _ladv(ll)  // skip (
            ll = _lskip_nl(ll)
            while _lk(ll) != ")" && _lk(ll) != "EOF" {
                if _lk(ll) == "IDENT" {
                    btext := _lcur(ll).text
                    if bind_total == 0 { bind_name_0 = btext }
                    if bind_total == 1 { bind_name_1 = btext }
                    if bind_total == 2 { bind_name_2 = btext }
                    if bind_total == 3 { bind_name_3 = btext }
                    bind_total = bind_total + 1
                    has_bindings = true
                    ll = _ladv(ll)
                } else {
                    ll = _ladv(ll)
                }
                ll = _lskip_nl(ll)
                if _lk(ll) == "," { ll = _ladv(ll) }
                ll = _lskip_nl(ll)
            }
            if _lk(ll) == ")" { ll = _ladv(ll) }
        }

        // Check for guard clause: `if <expr>` before `=>`
        mut has_guard := false
        mut guard_start := 0
        mut guard_end := 0
        if _lk(ll) == "if" {
            has_guard = true
            ll = _ladv(ll)  // skip `if`
            guard_start = ll.pos
            // Skip until => to find guard end
            while _lk(ll) != "=>" && _lk(ll) != "EOF" {
                ll = _ladv(ll)
            }
            guard_end = ll.pos
        }

        // Skip =>
        if _lk(ll) == "=>" { ll = _ladv(ll) }
        ll = _lskip_nl(ll)

        if is_wildcard || is_binding {
            // Wildcard or binding: no comparison needed
            // For binding patterns, bind subject to the pattern name
            if is_binding {
                ll = _lenv_add(ll, pattern, subj.temp)
            }

            // Evaluate guard clause if present
            if has_guard {
                next_lbl := _lnew_label(ll)
                ll = next_lbl.l
                saved_pos := ll.pos
                ll = _lset_pos(ll, guard_start)
                guard_result := _lower_expr(ll)
                ll = guard_result.l
                ll = _lset_pos(ll, saved_pos)
                ll = _lemit(ll, new_inst(OpBranchFalse, 0, guard_result.temp, next_lbl.temp, "", 0))

                // Lower arm body
                if _lk(ll) == lb {
                    ll = _lower_block(ll)
                    ll = _lemit(ll, new_inst(OpConst, result_nt.temp, 0, 0, "", 0))
                } else {
                    arm_result := _lower_expr(ll)
                    ll = arm_result.l
                    ll = _lemit(ll, new_inst(OpStore, result_nt.temp, arm_result.temp, 0, "", 0))
                    result_len := result_nt.temp + 1
                    arm_len := arm_result.temp + 1
                    ll = _lemit(ll, new_inst(OpStore, result_len, arm_len, 0, "", 0))
                }
                ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))
                ll = _lemit(ll, new_inst(OpLabel, 0, next_lbl.temp, 0, "", 0))
            } else {
                if _lk(ll) == lb {
                    ll = _lower_block(ll)
                    ll = _lemit(ll, new_inst(OpConst, result_nt.temp, 0, 0, "", 0))
                } else {
                    arm_result := _lower_expr(ll)
                    ll = arm_result.l
                    ll = _lemit(ll, new_inst(OpStore, result_nt.temp, arm_result.temp, 0, "", 0))
                    result_len := result_nt.temp + 1
                    arm_len := arm_result.temp + 1
                    ll = _lemit(ll, new_inst(OpStore, result_len, arm_len, 0, "", 0))
                }
                ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))
            }
        } else if is_literal {
            // Literal pattern: compare subject against literal value
            next_lbl := _lnew_label(ll)
            ll = next_lbl.l

            if pattern_kind == "INT" {
                // Integer literal comparison
                lit_nt := _lnew_temp(ll)
                ll = lit_nt.l
                lit_val := _parse_int_literal(pattern)
                ll = _lemit(ll, new_inst(OpConst, lit_nt.temp, lit_val, 0, "", 0))
                cmp_nt := _lnew_temp(ll)
                ll = cmp_nt.l
                ll = _lemit(ll, new_inst(OpEq, cmp_nt.temp, subj.temp, lit_nt.temp, "", 0))
                ll = _lemit(ll, new_inst(OpBranchFalse, 0, cmp_nt.temp, next_lbl.temp, "", 0))
            } else if pattern_kind == "true" {
                // true literal: subject == 1
                lit_nt := _lnew_temp(ll)
                ll = lit_nt.l
                ll = _lemit(ll, new_inst(OpConst, lit_nt.temp, 1, 0, "", 0))
                cmp_nt := _lnew_temp(ll)
                ll = cmp_nt.l
                ll = _lemit(ll, new_inst(OpEq, cmp_nt.temp, subj.temp, lit_nt.temp, "", 0))
                ll = _lemit(ll, new_inst(OpBranchFalse, 0, cmp_nt.temp, next_lbl.temp, "", 0))
            } else if pattern_kind == "false" {
                // false literal: subject == 0
                lit_nt := _lnew_temp(ll)
                ll = lit_nt.l
                ll = _lemit(ll, new_inst(OpConst, lit_nt.temp, 0, 0, "", 0))
                cmp_nt := _lnew_temp(ll)
                ll = cmp_nt.l
                ll = _lemit(ll, new_inst(OpEq, cmp_nt.temp, subj.temp, lit_nt.temp, "", 0))
                ll = _lemit(ll, new_inst(OpBranchFalse, 0, cmp_nt.temp, next_lbl.temp, "", 0))
            } else if pattern_kind == "STRING" {
                // String literal comparison
                lit_result := _lower_string_const(ll, pattern)
                ll = lit_result.l
                cmp_nt := _lnew_temp(ll)
                ll = cmp_nt.l
                ll = _lemit(ll, new_inst(OpStrEq, cmp_nt.temp, subj.temp, lit_result.temp, "", 0))
                ll = _lemit(ll, new_inst(OpBranchFalse, 0, cmp_nt.temp, next_lbl.temp, "", 0))
            }

            // Evaluate guard clause if present
            if has_guard {
                saved_pos := ll.pos
                ll = _lset_pos(ll, guard_start)
                guard_result := _lower_expr(ll)
                ll = guard_result.l
                ll = _lset_pos(ll, saved_pos)
                ll = _lemit(ll, new_inst(OpBranchFalse, 0, guard_result.temp, next_lbl.temp, "", 0))
            }

            // Lower arm body
            if _lk(ll) == lb {
                ll = _lower_block(ll)
                ll = _lemit(ll, new_inst(OpConst, result_nt.temp, 0, 0, "", 0))
            } else {
                arm_result := _lower_expr(ll)
                ll = arm_result.l
                ll = _lemit(ll, new_inst(OpStore, result_nt.temp, arm_result.temp, 0, "", 0))
                result_len := result_nt.temp + 1
                arm_len := arm_result.temp + 1
                ll = _lemit(ll, new_inst(OpStore, result_len, arm_len, 0, "", 0))
            }
            ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))
            ll = _lemit(ll, new_inst(OpLabel, 0, next_lbl.temp, 0, "", 0))
        } else {
            // Variant pattern: compare subject tag with variant tag
            tag := _variant_tag(ll.registry, pattern)
            next_lbl := _lnew_label(ll)
            ll = next_lbl.l

            if or_count > 0 {
                // Or-pattern: check primary tag OR any or-pattern tag
                body_lbl := _lnew_label(ll)
                ll = body_lbl.l

                // Check primary pattern
                tag_nt := _lnew_temp(ll)
                ll = tag_nt.l
                ll = _lemit(ll, new_inst(OpConst, tag_nt.temp, tag, 0, "", 0))
                cmp_nt := _lnew_temp(ll)
                ll = cmp_nt.l
                ll = _lemit(ll, new_inst(OpEq, cmp_nt.temp, subj_tag_temp, tag_nt.temp, "", 0))
                ll = _lemit(ll, new_inst(OpBranchTrue, 0, cmp_nt.temp, body_lbl.temp, "", 0))

                // Check or-patterns
                mut oi := 0
                while oi < or_count {
                    mut oname := ""
                    if oi == 0 { oname = or_name_0 }
                    if oi == 1 { oname = or_name_1 }
                    if oi == 2 { oname = or_name_2 }
                    if oi == 3 { oname = or_name_3 }
                    otag := _variant_tag(ll.registry, oname)
                    otag_nt := _lnew_temp(ll)
                    ll = otag_nt.l
                    ll = _lemit(ll, new_inst(OpConst, otag_nt.temp, otag, 0, "", 0))
                    ocmp_nt := _lnew_temp(ll)
                    ll = ocmp_nt.l
                    ll = _lemit(ll, new_inst(OpEq, ocmp_nt.temp, subj_tag_temp, otag_nt.temp, "", 0))
                    if oi == or_count - 1 {
                        // Last or-pattern: branch false to next arm
                        ll = _lemit(ll, new_inst(OpBranchFalse, 0, ocmp_nt.temp, next_lbl.temp, "", 0))
                    } else {
                        ll = _lemit(ll, new_inst(OpBranchTrue, 0, ocmp_nt.temp, body_lbl.temp, "", 0))
                    }
                    oi = oi + 1
                }

                // Body label
                ll = _lemit(ll, new_inst(OpLabel, 0, body_lbl.temp, 0, "", 0))
            } else {
                // Simple single-variant check
                tag_nt := _lnew_temp(ll)
                ll = tag_nt.l
                ll = _lemit(ll, new_inst(OpConst, tag_nt.temp, tag, 0, "", 0))

                cmp_nt := _lnew_temp(ll)
                ll = cmp_nt.l
                ll = _lemit(ll, new_inst(OpEq, cmp_nt.temp, subj_tag_temp, tag_nt.temp, "", 0))

                ll = _lemit(ll, new_inst(OpBranchFalse, 0, cmp_nt.temp, next_lbl.temp, "", 0))
            }

            // Evaluate guard clause if present (before bindings, need next_lbl)
            // Actually: bindings first, then guard, so guard can use bound vars

            // Bind destructured fields: extract from struct and add to env
            if has_bindings {
                parent := _variant_parent(ll.registry, pattern)
                mut bi := 0
                while bi < bind_total {
                    mut bname := ""
                    if bi == 0 { bname = bind_name_0 }
                    if bi == 1 { bname = bind_name_1 }
                    if bi == 2 { bname = bind_name_2 }
                    if bi == 3 { bname = bind_name_3 }
                    mut data_slot := 1
                    mut si := 0
                    while si < bi {
                        ft := variant_field_type(parent, tag, si)
                        if ft == 12 {
                            data_slot = data_slot + 2
                        } else {
                            data_slot = data_slot + 1
                        }
                        si = si + 1
                    }
                    ft := variant_field_type(parent, tag, bi)
                    if ft == 12 {
                        bnt := _lnew_str_temp(ll)
                        ll = bnt.l
                        ll = _lemit(ll, new_inst(OpFieldGet, bnt.temp, subj.temp, data_slot, "", 0))
                        ll = _lemit(ll, new_inst(OpFieldGet, bnt.temp + 1, subj.temp, data_slot + 1, "", 0))
                        ll = _lset_type(ll, bnt.temp, 12)
                        ll = _lenv_add(ll, bname, bnt.temp)
                    } else {
                        bnt := _lnew_temp(ll)
                        ll = bnt.l
                        ll = _lemit(ll, new_inst(OpFieldGet, bnt.temp, subj.temp, data_slot, "", 0))
                        if ft != 0 { ll = _lset_type(ll, bnt.temp, ft) }
                        ll = _lenv_add(ll, bname, bnt.temp)
                    }
                    bi = bi + 1
                }
            }

            // Evaluate guard clause if present
            if has_guard {
                saved_pos := ll.pos
                ll = _lset_pos(ll, guard_start)
                guard_result := _lower_expr(ll)
                ll = guard_result.l
                ll = _lset_pos(ll, saved_pos)
                ll = _lemit(ll, new_inst(OpBranchFalse, 0, guard_result.temp, next_lbl.temp, "", 0))
            }

            // Lower arm body
            if _lk(ll) == lb {
                ll = _lower_block(ll)
                ll = _lemit(ll, new_inst(OpConst, result_nt.temp, 0, 0, "", 0))
            } else {
                arm_result := _lower_expr(ll)
                ll = arm_result.l
                ll = _lemit(ll, new_inst(OpStore, result_nt.temp, arm_result.temp, 0, "", 0))
                result_len := result_nt.temp + 1
                arm_len := arm_result.temp + 1
                ll = _lemit(ll, new_inst(OpStore, result_len, arm_len, 0, "", 0))
            }

            ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))
            ll = _lemit(ll, new_inst(OpLabel, 0, next_lbl.temp, 0, "", 0))
        }

        ll = _lskip_nl(ll)
    }
    if _lk(ll) == rb { ll = _ladv(ll) }

    // End label
    ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))

    LT{l: ll, temp: result_nt.temp}
}

fn _skip_braces_l(l: Lowerer) -> Lowerer {
    lb := "\{"
    rb := "\}"
    if _lk(l) != lb { return l }
    mut ll := _ladv(l)
    mut d := 1
    while d > 0 && _lk(ll) != "EOF" {
        if _lk(ll) == lb { d = d + 1 }
        if _lk(ll) == rb { d = d - 1 }
        if d > 0 { ll = _ladv(ll) }
    }
    if _lk(ll) == rb { ll = _ladv(ll) }
    return ll
}

// --- Lower assert ---

fn _lower_assert(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip assert
    result := _lower_expr(ll)
    ll = result.l
    // If false, call exit(1)
    ok_lbl := _lnew_label(ll)
    ll = ok_lbl.l
    ll = _lemit(ll, new_inst(OpBranchTrue, 0, result.temp, ok_lbl.temp, "", 0))
    // Assertion failed — exit
    nt := _lnew_temp(ll)
    ll = nt.l
    ll = _lemit(ll, new_inst(OpConst, nt.temp, 1, 0, "", 0))
    ll = _lemit(ll, new_inst(OpCall, 0, nt.temp, 1, "_aria_exit", 0))
    ll = _lemit(ll, new_inst(OpLabel, 0, ok_lbl.temp, 0, "", 0))
    ll
}

// --- Skip type tokens ---

fn _skip_type_l(l: Lowerer) -> Lowerer {
    mut ll := l
    k := _lk(ll)
    if k == "IDENT" || k == "Self" {
        ll = _ladv(ll)
        while _lk(ll) == "." { ll = _ladv(_ladv(ll)) }
        if _lk(ll) == "[" {
            mut d := 1
            ll = _ladv(ll)
            while d > 0 && _lk(ll) != "EOF" {
                if _lk(ll) == "[" { d = d + 1 }
                if _lk(ll) == "]" { d = d - 1 }
                if d > 0 { ll = _ladv(ll) }
            }
            if _lk(ll) == "]" { ll = _ladv(ll) }
        }
        if _lk(ll) == "?" { ll = _ladv(ll) }
        if _lk(ll) == "!" {
            ll = _ladv(ll)
            ll = _skip_type_l(ll)
        }
        return ll
    }
    if k == "[" {
        ll = _ladv(ll)
        ll = _skip_type_l(ll)
        if _lk(ll) == "]" { ll = _ladv(ll) }
        return ll
    }
    if k == "fn" {
        ll = _ladv(ll)
        if _lk(ll) == "(" {
            ll = _ladv(ll)
            while _lk(ll) != ")" && _lk(ll) != "EOF" {
                ll = _skip_type_l(ll)
                if _lk(ll) == "," { ll = _ladv(ll) }
            }
            if _lk(ll) == ")" { ll = _ladv(ll) }
        }
        if _lk(ll) == "->" {
            ll = _ladv(ll)
            ll = _skip_type_l(ll)
        }
        return ll
    }
    ll
}

// ============================================================
// Public API
// ============================================================

fn lower(tokens: [Token], store: TypeStore, reg: TypeRegistry, table: SymbolTable, file: str) -> IrModule {
    mut l := _new_lowerer(tokens, store, reg, table, file)
    l = _scan_consts(l)
    l = _lower_bodies(l)
    l = _lower_mono_pass(l)
    return l.module
}

// Lower for test mode: compile test blocks and generate a test runner _main
fn lower_for_tests(tokens: [Token], store: TypeStore, reg: TypeRegistry, table: SymbolTable, file: str) -> IrModule {
    mut l := _new_lowerer(tokens, store, reg, table, file)
    l = _scan_consts(l)
    l = _lower_bodies(l)
    l = _lower_mono_pass(l)
    // Generate test runner _main that calls each _test_N function
    l = _generate_test_runner(l)
    return l.module
}

fn _generate_test_runner(l: Lowerer) -> Lowerer {
    mut ll := l
    test_count := ll.module.test_count
    if test_count == 0 {
        // No tests — generate empty _main that prints "no tests found"
        ll = _lset_func(ll, new_ir_func("_main", 0, 0))
        mut no_tests_idx := mod_find_string(ll.module, "no tests found")
        if no_tests_idx == 0 {
            new_mod := mod_add_string(ll.module, "no tests found")
            no_tests_idx = new_mod.string_constants.len() - 1
            ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                         table: ll.table, file: ll.file, module: new_mod,
                         current_func: ll.current_func,
                         temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                         env_names: ll.env_names, env_slots: ll.env_slots,
                         loop_start: ll.loop_start, loop_end: ll.loop_end,
                         const_names: ll.const_names, const_vals: ll.const_vals,
                         const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                         temp_types: ll.temp_types,
                         fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
        }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpConstStr, nt.temp, no_tests_idx, 14, "", 0))
        ll = _lemit(ll, new_inst(OpCall, 0, nt.temp, 2, "_aria_println_str", 0))
        exit_nt := _lnew_temp(ll)
        ll = exit_nt.l
        ll = _lemit(ll, new_inst(OpConst, exit_nt.temp, 0, 0, "", 0))
        ll = _lemit(ll, new_inst(OpCall, 0, exit_nt.temp, 1, "_aria_exit", 0))
        ll = _lfinish_func(ll)
        mut new_mod2 := mod_set_entry(ll.module, "_main")
        ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                     table: ll.table, file: ll.file, module: new_mod2,
                     current_func: ll.current_func,
                     temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                     env_names: ll.env_names, env_slots: ll.env_slots,
                     loop_start: ll.loop_start, loop_end: ll.loop_end,
                     const_names: ll.const_names, const_vals: ll.const_vals,
                     const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                     temp_types: ll.temp_types,
                     fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
        return ll
    }

    // Generate _main that calls each test, prints results
    ll = _lset_func(ll, new_ir_func("_main", 0, 0))

    // For each test, call it and print pass
    mut ti := 0
    while ti < test_count {
        test_fn_name := "_test_" + _i2s_lower(ti)
        // 1-based index into test_names (0 is sentinel)
        test_label_idx := ti + 1

        // Print test name
        mut label_str_idx := 0
        if test_label_idx < ll.module.test_names.len() {
            label_text := ll.module.test_names[test_label_idx]
            label_str_idx = mod_find_string(ll.module, label_text)
        }

        // Call the test function
        ll = _lemit(ll, new_inst(OpCall, 0, 0, 0, test_fn_name, 0))

        // Print "PASS: <test name>"
        // Add "PASS: " string
        mut pass_idx := mod_find_string(ll.module, "PASS: ")
        if pass_idx == 0 {
            new_mod := mod_add_string(ll.module, "PASS: ")
            pass_idx = new_mod.string_constants.len() - 1
            ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                         table: ll.table, file: ll.file, module: new_mod,
                         current_func: ll.current_func,
                         temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                         env_names: ll.env_names, env_slots: ll.env_slots,
                         loop_start: ll.loop_start, loop_end: ll.loop_end,
                         const_names: ll.const_names, const_vals: ll.const_vals,
                         const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                         temp_types: ll.temp_types,
                         fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
        }
        // Print "PASS: " + test name by concatenating
        pass_nt := _lnew_str_temp(ll)
        ll = pass_nt.l
        ll = _lemit(ll, new_inst(OpConstStr, pass_nt.temp, pass_idx, 6, "", 0))
        if label_str_idx > 0 {
            label_nt := _lnew_str_temp(ll)
            ll = label_nt.l
            label_text := ll.module.test_names[test_label_idx]
            ll = _lemit(ll, new_inst(OpConstStr, label_nt.temp, label_str_idx, label_text.len(), "", 0))
            concat_nt := _lnew_str_temp(ll)
            ll = concat_nt.l
            ll = _lemit(ll, new_inst(OpStrConcat, concat_nt.temp, pass_nt.temp, label_nt.temp, "", 0))
            ll = _lemit(ll, new_inst(OpCall, 0, concat_nt.temp, 2, "_aria_println_str", 0))
        } else {
            ll = _lemit(ll, new_inst(OpCall, 0, pass_nt.temp, 2, "_aria_println_str", 0))
        }

        ti = ti + 1
    }

    // Print summary
    mut done_idx := mod_find_string(ll.module, "all tests passed")
    if done_idx == 0 {
        new_mod := mod_add_string(ll.module, "all tests passed")
        done_idx = new_mod.string_constants.len() - 1
        ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                     table: ll.table, file: ll.file, module: new_mod,
                     current_func: ll.current_func,
                     temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                     env_names: ll.env_names, env_slots: ll.env_slots,
                     loop_start: ll.loop_start, loop_end: ll.loop_end,
                     const_names: ll.const_names, const_vals: ll.const_vals,
                     const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                     temp_types: ll.temp_types,
                     fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
    }
    done_nt := _lnew_str_temp(ll)
    ll = done_nt.l
    ll = _lemit(ll, new_inst(OpConstStr, done_nt.temp, done_idx, 16, "", 0))
    ll = _lemit(ll, new_inst(OpCall, 0, done_nt.temp, 2, "_aria_println_str", 0))

    // Exit 0
    exit_nt := _lnew_temp(ll)
    ll = exit_nt.l
    ll = _lemit(ll, new_inst(OpConst, exit_nt.temp, 0, 0, "", 0))
    ll = _lemit(ll, new_inst(OpCall, 0, exit_nt.temp, 1, "_aria_exit", 0))

    ll = _lfinish_func(ll)
    mut new_mod := mod_set_entry(ll.module, "_main")
    Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
            table: ll.table, file: ll.file, module: new_mod,
            current_func: ll.current_func,
            temp_counter: ll.temp_counter, label_counter: ll.label_counter,
            env_names: ll.env_names, env_slots: ll.env_slots,
            loop_start: ll.loop_start, loop_end: ll.loop_end,
            const_names: ll.const_names, const_vals: ll.const_vals,
            const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
            temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
}

// Monomorphization pass: generate specialized copies of generic functions
fn _lower_mono_pass(l: Lowerer) -> Lowerer {
    mut ll := l
    mut mi := 1
    while mi < ll.registry.mono_specs.len() {
        spec := ll.registry.mono_specs[mi]
        generic_sig := reg_find_fn(ll.registry, spec.generic_name)
        if generic_sig.name != "" && fn_is_generic(generic_sig) {
            ll = _lset_pos(ll, generic_sig.token_start)
            ll = _lower_mono_fn(ll, spec)
        }
        mi = mi + 1
    }
    ll
}

// Lower a monomorphized copy of a generic function
fn _lower_mono_fn(l: Lowerer, spec: MonoSpec) -> Lowerer {
    mut ll := _ladv(l)  // skip fn
    if _lk(ll) != "IDENT" { return ll }
    ll = _ladv(ll)  // skip generic fn name

    // Skip generic params [T, U, ...]
    if _lk(ll) == "[" {
        mut d := 1
        ll = _ladv(ll)
        while d > 0 && _lk(ll) != "EOF" {
            if _lk(ll) == "[" { d = d + 1 }
            if _lk(ll) == "]" { d = d - 1 }
            if d > 0 { ll = _ladv(ll) }
        }
        if _lk(ll) == "]" { ll = _ladv(ll) }
    }

    // Look up the specialized FnSig
    sig := reg_find_fn(ll.registry, spec.specialized_name)
    if sig.name == "" { return ll }

    // Count actual register args
    mut actual_param_count := 0
    mut pi := 1
    while pi < sig.param_names.len() {
        if pi <= sig.param_types.len() - 1 && sig.param_types[pi] == 12 {
            actual_param_count = actual_param_count + 2
        } else {
            actual_param_count = actual_param_count + 1
        }
        pi = pi + 1
    }

    // Start a new IR function with the specialized name
    ll = _lset_func(ll, new_ir_func(spec.specialized_name, actual_param_count, sig.return_type))

    // Allocate temps for parameters
    pi = 1
    while pi < sig.param_names.len() {
        if pi <= sig.param_types.len() - 1 && sig.param_types[pi] == 12 {
            nt := _lnew_str_temp(ll)
            ll = nt.l
            ll = _lenv_add(ll, sig.param_names[pi], nt.temp)
            ll = _lset_type(ll, nt.temp, 12)
        } else {
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lenv_add(ll, sig.param_names[pi], nt.temp)
            if pi <= sig.param_types.len() - 1 && sig.param_types[pi] > 0 {
                pt := sig.param_types[pi]
                if _is_str_array_type(ll.store, pt) {
                    ll = _lset_type(ll, nt.temp, 13)
                } else {
                    ll = _lset_type(ll, nt.temp, pt)
                }
            }
        }
        pi = pi + 1
    }

    // Skip past parameter declaration tokens to body
    // We need to skip: (params...) -> RetType
    if _lk(ll) == "(" {
        mut d := 1
        ll = _ladv(ll)
        while d > 0 && _lk(ll) != "EOF" {
            if _lk(ll) == "(" { d = d + 1 }
            if _lk(ll) == ")" { d = d - 1 }
            if d > 0 { ll = _ladv(ll) }
        }
        if _lk(ll) == ")" { ll = _ladv(ll) }
    }

    // Skip return type annotation
    if _lk(ll) == "->" {
        ll = _ladv(ll)
        // Skip type tokens
        while _lk(ll) == "IDENT" || _lk(ll) == "[" || _lk(ll) == "]" || _lk(ll) == "!" || _lk(ll) == "?" {
            ll = _ladv(ll)
        }
    }

    // Skip error type
    if _lk(ll) == "!" {
        ll = _ladv(ll)
        while _lk(ll) == "IDENT" { ll = _ladv(ll) }
    }

    // Now lower the body
    lb := "\{"
    if _lk(ll) == "=" {
        ll = _ladv(ll)
        ll = _lskip_nl(ll)
        result := _lower_expr(ll)
        ll = result.l
        ll = _emit_defers(ll)
        ret_type := _lget_type(ll, result.temp)
        ll = _lemit(ll, new_inst(OpRet, 0, result.temp, 0, "", ret_type))
    } else if _lk(ll) == lb {
        ll = _lower_fn_body(ll, sig.return_type)
    } else {
        ll = _lskip_nl(ll)
        if _lk(ll) == lb {
            ll = _lower_fn_body(ll, sig.return_type)
        }
    }

    ll = _lfinish_func(ll)
    return ll
}
