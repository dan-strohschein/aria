mod codegen

// ============================================================
// Lowering — Token Stream to IR
// Multi-pass token walker (mirrors checker pattern).
// Pass 1: Collect type layouts (struct sizes, field offsets)
// Pass 2: Collect function signatures
// Pass 3: Lower function/entry/test bodies to IR
// ============================================================

use diagnostic
use lexer
use resolver
use checker

// --- Lowerer state ---

struct Lowerer {
    tokens: [Token]
    pos: i64
    store: TypeStore
    registry: TypeRegistry
    table: SymbolTable
    file: str
    module: IrModule
    current_func: IrFunc
    temp_counter: i64
    label_counter: i64
    env_names: [str]
    env_slots: [i64]
    loop_start: i64
    loop_end: i64
    // Const pre-scan arrays
    const_names: [str]
    const_vals: [i64]
    const_str_names: [str]
    const_str_vals: [str]
    // Type tracking per temp: 0=unknown, 1=i64, 12=str, 100+=struct
    temp_types: [i64]
    // Error type for current function (0 = not fallible)
    fn_error_type: i64
    // Defer tracking: token positions of deferred expressions (up to 4)
    defer_count: i64
    defer_start_0: i64
    defer_start_1: i64
    defer_start_2: i64
    defer_start_3: i64
    defer_end_0: i64
    defer_end_1: i64
    defer_end_2: i64
    defer_end_3: i64
}

// --- Lowerer + temp result (like CE) ---

struct LT {
    l: Lowerer
    temp: i64
}

// --- Constructor ---

fn _new_lowerer(tokens: [Token], store: TypeStore, reg: TypeRegistry, table: SymbolTable, file: str) -> Lowerer =
    Lowerer{
        tokens: tokens, pos: 0, store: store, registry: reg,
        table: table, file: file,
        module: new_ir_module(),
        current_func: _sentinel_func(),
        temp_counter: 0, label_counter: 0,
        env_names: [""], env_slots: [0],
        loop_start: -1, loop_end: -1,
        const_names: [""], const_vals: [0],
        const_str_names: [""], const_str_vals: [""],
        temp_types: [0],
        fn_error_type: 0, defer_count: 0, defer_start_0: 0, defer_start_1: 0, defer_start_2: 0, defer_start_3: 0, defer_end_0: 0, defer_end_1: 0, defer_end_2: 0, defer_end_3: 0
    }

// --- Helpers ---

fn _lcur(l: Lowerer) -> Token {
    if l.pos >= l.tokens.len() {
        return Token{kind: TkEof, text: "", line: 0, col: 0, offset: 0}
    }
    return l.tokens[l.pos]
}


fn _lk(l: Lowerer) -> str = token_name(_lcur(l).kind)

fn _ladv(l: Lowerer) -> Lowerer =
    Lowerer{tokens: l.tokens, pos: l.pos + 1, store: l.store, registry: l.registry,
            table: l.table, file: l.file, module: l.module,
            current_func: l.current_func,
            temp_counter: l.temp_counter, label_counter: l.label_counter,
            env_names: l.env_names, env_slots: l.env_slots,
            loop_start: l.loop_start, loop_end: l.loop_end,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: l.temp_types,
            fn_error_type: l.fn_error_type, defer_count: l.defer_count, defer_start_0: l.defer_start_0, defer_start_1: l.defer_start_1, defer_start_2: l.defer_start_2, defer_start_3: l.defer_start_3, defer_end_0: l.defer_end_0, defer_end_1: l.defer_end_1, defer_end_2: l.defer_end_2, defer_end_3: l.defer_end_3}

fn _lset_pos(l: Lowerer, pos: i64) -> Lowerer =
    Lowerer{tokens: l.tokens, pos: pos, store: l.store, registry: l.registry,
            table: l.table, file: l.file, module: l.module,
            current_func: l.current_func,
            temp_counter: l.temp_counter, label_counter: l.label_counter,
            env_names: l.env_names, env_slots: l.env_slots,
            loop_start: l.loop_start, loop_end: l.loop_end,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: l.temp_types,
            fn_error_type: l.fn_error_type, defer_count: l.defer_count, defer_start_0: l.defer_start_0, defer_start_1: l.defer_start_1, defer_start_2: l.defer_start_2, defer_start_3: l.defer_start_3, defer_end_0: l.defer_end_0, defer_end_1: l.defer_end_1, defer_end_2: l.defer_end_2, defer_end_3: l.defer_end_3}

fn _lskip_nl(l: Lowerer) -> Lowerer {
    mut ll := l
    while _lk(ll) == "NEWLINE" { ll = _ladv(ll) }
    ll
}

fn _lnew_temp(l: Lowerer) -> LT {
    temp := l.temp_counter
    ll := Lowerer{tokens: l.tokens, pos: l.pos, store: l.store, registry: l.registry,
                  table: l.table, file: l.file, module: l.module,
                  current_func: l.current_func,
                  temp_counter: l.temp_counter + 1, label_counter: l.label_counter,
                  env_names: l.env_names, env_slots: l.env_slots,
            loop_start: l.loop_start, loop_end: l.loop_end,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: l.temp_types,
            fn_error_type: l.fn_error_type, defer_count: l.defer_count, defer_start_0: l.defer_start_0, defer_start_1: l.defer_start_1, defer_start_2: l.defer_start_2, defer_start_3: l.defer_start_3, defer_end_0: l.defer_end_0, defer_end_1: l.defer_end_1, defer_end_2: l.defer_end_2, defer_end_3: l.defer_end_3}
    LT{l: ll, temp: temp}
}

fn _lnew_label(l: Lowerer) -> LT {
    lbl := l.label_counter
    ll := Lowerer{tokens: l.tokens, pos: l.pos, store: l.store, registry: l.registry,
                  table: l.table, file: l.file, module: l.module,
                  current_func: l.current_func,
                  temp_counter: l.temp_counter, label_counter: l.label_counter + 1,
                  env_names: l.env_names, env_slots: l.env_slots,
            loop_start: l.loop_start, loop_end: l.loop_end,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: l.temp_types,
            fn_error_type: l.fn_error_type, defer_count: l.defer_count, defer_start_0: l.defer_start_0, defer_start_1: l.defer_start_1, defer_start_2: l.defer_start_2, defer_start_3: l.defer_start_3, defer_end_0: l.defer_end_0, defer_end_1: l.defer_end_1, defer_end_2: l.defer_end_2, defer_end_3: l.defer_end_3}
    LT{l: ll, temp: lbl}
}

fn _lemit(l: Lowerer, inst: IrInst) -> Lowerer {
    new_func := func_add_inst(l.current_func, inst)
    Lowerer{tokens: l.tokens, pos: l.pos, store: l.store, registry: l.registry,
            table: l.table, file: l.file, module: l.module,
            current_func: new_func,
            temp_counter: l.temp_counter, label_counter: l.label_counter,
            env_names: l.env_names, env_slots: l.env_slots,
            loop_start: l.loop_start, loop_end: l.loop_end,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: l.temp_types,
            fn_error_type: l.fn_error_type, defer_count: l.defer_count, defer_start_0: l.defer_start_0, defer_start_1: l.defer_start_1, defer_start_2: l.defer_start_2, defer_start_3: l.defer_start_3, defer_end_0: l.defer_end_0, defer_end_1: l.defer_end_1, defer_end_2: l.defer_end_2, defer_end_3: l.defer_end_3}
}

fn _lset_func(l: Lowerer, f: IrFunc) -> Lowerer =
    Lowerer{tokens: l.tokens, pos: l.pos, store: l.store, registry: l.registry,
            table: l.table, file: l.file, module: l.module,
            current_func: f,
            temp_counter: 0, label_counter: 0,
            env_names: [""], env_slots: [0],
            loop_start: -1, loop_end: -1,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: [0],
            fn_error_type: 0, defer_count: 0, defer_start_0: 0, defer_start_1: 0, defer_start_2: 0, defer_start_3: 0, defer_end_0: 0, defer_end_1: 0, defer_end_2: 0, defer_end_3: 0}

fn _lfinish_func(l: Lowerer) -> Lowerer {
    f := func_set_locals(l.current_func, l.temp_counter)
    new_mod := mod_add_func(l.module, f)
    Lowerer{tokens: l.tokens, pos: l.pos, store: l.store, registry: l.registry,
            table: l.table, file: l.file, module: new_mod,
            current_func: _sentinel_func(),
            temp_counter: 0, label_counter: l.label_counter,
            env_names: [""], env_slots: [0],
            loop_start: -1, loop_end: -1,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: l.temp_types,
            fn_error_type: l.fn_error_type, defer_count: l.defer_count, defer_start_0: l.defer_start_0, defer_start_1: l.defer_start_1, defer_start_2: l.defer_start_2, defer_start_3: l.defer_start_3, defer_end_0: l.defer_end_0, defer_end_1: l.defer_end_1, defer_end_2: l.defer_end_2, defer_end_3: l.defer_end_3}
}

fn _lenv_add(l: Lowerer, name: str, slot: i64) -> Lowerer =
    Lowerer{tokens: l.tokens, pos: l.pos, store: l.store, registry: l.registry,
            table: l.table, file: l.file, module: l.module,
            current_func: l.current_func,
            temp_counter: l.temp_counter, label_counter: l.label_counter,
            env_names: l.env_names.append(name), env_slots: l.env_slots.append(slot),
            loop_start: l.loop_start, loop_end: l.loop_end,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: l.temp_types,
            fn_error_type: l.fn_error_type, defer_count: l.defer_count, defer_start_0: l.defer_start_0, defer_start_1: l.defer_start_1, defer_start_2: l.defer_start_2, defer_start_3: l.defer_start_3, defer_end_0: l.defer_end_0, defer_end_1: l.defer_end_1, defer_end_2: l.defer_end_2, defer_end_3: l.defer_end_3}

fn _lenv_lookup(l: Lowerer, name: str) -> i64 {
    mut i := l.env_names.len() - 1
    while i > 0 {
        if l.env_names[i] == name { return l.env_slots[i] }
        i = i - 1
    }
    return -1
}

// Helper: allocate 2 consecutive temp slots for a string fat pointer (ptr + len)
fn _lnew_str_temp(l: Lowerer) -> LT {
    nt := _lnew_temp(l)
    nt2 := _lnew_temp(nt.l)
    LT{l: nt2.l, temp: nt.temp}
}

// --- Const lookup helpers ---

fn _lconst_lookup(l: Lowerer, name: str) -> i64 {
    mut i := 1
    while i < l.const_names.len() {
        if l.const_names[i] == name { return l.const_vals[i] }
        i = i + 1
    }
    return -9999999  // sentinel: not found
}

fn _lconst_str_lookup(l: Lowerer, name: str) -> str {
    mut i := 1
    while i < l.const_str_names.len() {
        if l.const_str_names[i] == name { return l.const_str_vals[i] }
        i = i + 1
    }
    return ""  // not found
}

fn _lconst_has(l: Lowerer, name: str) -> bool {
    mut i := 1
    while i < l.const_names.len() {
        if l.const_names[i] == name { return true }
        i = i + 1
    }
    return false
}

fn _lconst_str_has(l: Lowerer, name: str) -> bool {
    mut i := 1
    while i < l.const_str_names.len() {
        if l.const_str_names[i] == name { return true }
        i = i + 1
    }
    return false
}

// Get the element type of an array type. Returns the element's type_id, or 0 if unknown.
// For [str] (type 13 in lowerer), returns 12 (TY_STR).
// For store-based array types, looks up the element type in the store.
fn _array_elem_type(store: TypeStore, arr_type: i64) -> i64 {
    if arr_type == 13 { return 12 }
    if arr_type <= 16 { return 0 }
    info := store_get(store, arr_type)
    if type_kind_name(info.kind) == "Array" {
        return info.type_id
    }
    return 0
}

// Check if a type_id from the store represents [str] (array of strings)
fn _is_str_array_type(store: TypeStore, tid: i64) -> bool {
    info := store_get(store, tid)
    if type_kind_name(info.kind) == "Array" && info.type_id == 12 {
        return true
    }
    return false
}

// Check if a type_id represents a named/struct type (not a builtin)
fn _is_named_type(store: TypeStore, tid: i64) -> bool {
    if tid >= 100 { return true }
    if tid <= 16 { return false }
    info := store_get(store, tid)
    if type_kind_name(info.kind) == "Named" { return true }
    return false
}

// Get struct name for a type_id using the store + registry
// Handles both store-based type_ids (from checker) and registry-based 100+ ids (from lowerer)
// Generate field-by-field struct equality comparison.
// Sets result_temp to 1 if all fields equal, 0 otherwise.
fn _lower_struct_eq(l: Lowerer, a: i64, b: i64, sname: str, result_temp: i64) -> Lowerer {
    mut ll := l
    def := reg_find_struct(ll.registry, sname)
    if def.name == "" || def.fields.len() <= 1 {
        ll = _lemit(ll, new_inst(OpEq, result_temp, a, b, "", 0))
        return ll
    }

    // Compare each field, chain with AND into fresh temps
    mut last_cmp := -1
    mut fi := 1  // skip sentinel
    mut field_slot := 0
    while fi < def.fields.len() {
        fld := def.fields[fi]
        ft := fld.type_id

        if ft == 12 {
            a_str := _lnew_str_temp(ll)
            ll = a_str.l
            ll = _lemit(ll, new_inst(OpFieldGet, a_str.temp, a, field_slot, fld.name, 0))
            fidx_len := field_slot + 1
            ll = _lemit(ll, new_inst(OpFieldGet, a_str.temp + 1, a, fidx_len, fld.name, 0))
            b_str := _lnew_str_temp(ll)
            ll = b_str.l
            ll = _lemit(ll, new_inst(OpFieldGet, b_str.temp, b, field_slot, fld.name, 0))
            ll = _lemit(ll, new_inst(OpFieldGet, b_str.temp + 1, b, fidx_len, fld.name, 0))
            cmp := _lnew_temp(ll)
            ll = cmp.l
            ll = _lemit(ll, new_inst(OpStrEq, cmp.temp, a_str.temp, b_str.temp, "", 0))
            if last_cmp >= 0 {
                and_nt := _lnew_temp(ll)
                ll = and_nt.l
                ll = _lemit(ll, new_inst(OpAnd, and_nt.temp, last_cmp, cmp.temp, "", 0))
                last_cmp = and_nt.temp
            } else {
                last_cmp = cmp.temp
            }
            field_slot = field_slot + 2
        } else {
            a_val := _lnew_temp(ll)
            ll = a_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, a_val.temp, a, field_slot, fld.name, 0))
            b_val := _lnew_temp(ll)
            ll = b_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, b_val.temp, b, field_slot, fld.name, 0))
            cmp := _lnew_temp(ll)
            ll = cmp.l
            ll = _lemit(ll, new_inst(OpEq, cmp.temp, a_val.temp, b_val.temp, "", 0))
            if last_cmp >= 0 {
                and_nt := _lnew_temp(ll)
                ll = and_nt.l
                ll = _lemit(ll, new_inst(OpAnd, and_nt.temp, last_cmp, cmp.temp, "", 0))
                last_cmp = and_nt.temp
            } else {
                last_cmp = cmp.temp
            }
            field_slot = field_slot + 1
        }
        fi = fi + 1
    }
    // Copy final result to result_temp
    if last_cmp >= 0 {
        ll = _lemit(ll, new_inst(OpStore, result_temp, last_cmp, 0, "", 0))
    } else {
        ll = _lemit(ll, new_inst(OpConst, result_temp, 1, 0, "", 0))
    }
    ll
}

fn _is_struct_type(store: TypeStore, reg: TypeRegistry, tid: i64) -> bool {
    if tid >= 100 { return true }
    if tid <= 16 { return false }
    info := store_get(store, tid)
    if type_kind_name(info.kind) == "Named" {
        def := reg_find_struct(reg, info.name)
        if def.name != "" && def.is_sum == false { return true }
    }
    false
}

fn _struct_name_for_type(store: TypeStore, reg: TypeRegistry, tid: i64) -> str {
    // Check registry-based 100+ range first
    if tid >= 100 {
        return _struct_name_from_type(reg, tid)
    }
    // Check store-based type_ids
    if tid <= 16 { return "" }
    info := store_get(store, tid)
    if type_kind_name(info.kind) == "Named" {
        return info.name
    }
    return ""
}

// --- Type tracking helpers ---
// Type IDs: 0=unknown, 1=i64, 12=str, 13=[str], 100+=struct types

fn _lset_type(l: Lowerer, temp: i64, type_id: i64) -> Lowerer {
    // Bounds check: temp should never exceed a few thousand in any function
    if temp < 0 { return l }
    if temp > 5000 { return l }
    // Grow temp_types if needed
    mut types := l.temp_types
    while types.len() <= temp + 1 {
        types = types.append(0)
    }
    // Rebuild array with updated value
    mut new_types := [0]
    mut idx := 1
    while idx < types.len() {
        target := temp + 1
        if idx == target {
            new_types = new_types.append(type_id)
        } else {
            new_types = new_types.append(types[idx])
        }
        idx = idx + 1
    }
    return Lowerer{tokens: l.tokens, pos: l.pos, store: l.store, registry: l.registry,
            table: l.table, file: l.file, module: l.module,
            current_func: l.current_func,
            temp_counter: l.temp_counter, label_counter: l.label_counter,
            env_names: l.env_names, env_slots: l.env_slots,
            loop_start: l.loop_start, loop_end: l.loop_end,
            const_names: l.const_names, const_vals: l.const_vals,
            const_str_names: l.const_str_names, const_str_vals: l.const_str_vals,
            temp_types: new_types,
            fn_error_type: l.fn_error_type, defer_count: l.defer_count, defer_start_0: l.defer_start_0, defer_start_1: l.defer_start_1, defer_start_2: l.defer_start_2, defer_start_3: l.defer_start_3, defer_end_0: l.defer_end_0, defer_end_1: l.defer_end_1, defer_end_2: l.defer_end_2, defer_end_3: l.defer_end_3}
}

fn _lget_type(l: Lowerer, temp: i64) -> i64 {
    idx := temp + 1
    if idx >= 0 && idx < l.temp_types.len() {
        return l.temp_types[idx]
    }
    return 0
}

// --- Op selection helpers (avoid mut reassignment of sum types) ---

fn _arith_op(k: str) -> IrOp {
    if k == "+" { return OpAdd }
    if k == "-" { return OpSub }
    if k == "*" { return OpMul }
    if k == "/" { return OpDiv }
    if k == "%" { return OpMod }
    return OpAdd
}

fn _cmp_op(k: str) -> IrOp {
    if k == "==" { return OpEq }
    if k == "!=" { return OpNeq }
    if k == "<" { return OpLt }
    if k == ">" { return OpGt }
    if k == "<=" { return OpLte }
    if k == ">=" { return OpGte }
    return OpEq
}

fn _unary_op(k: str) -> IrOp {
    if k == "!" { return OpNot }
    return OpNeg
}

fn _cmp_or_logic_op(k: str) -> IrOp {
    if k == "==" { return OpEq }
    if k == "!=" { return OpNeq }
    if k == "<" { return OpLt }
    if k == ">" { return OpGt }
    if k == "<=" { return OpLte }
    if k == ">=" { return OpGte }
    if k == "&&" { return OpAnd }
    if k == "||" { return OpOr }
    return OpEq
}

fn _is_float_type(t: i64) -> bool = t == 9

// Expression continuation check
fn _is_cont_l(k: str) -> bool =
    k == "+" || k == "-" || k == "*" || k == "/" || k == "%" ||
    k == "==" || k == "!=" || k == "<" || k == ">" || k == "<=" || k == ">=" ||
    k == "&&" || k == "||" || k == "&" || k == "|" || k == "^" ||
    k == "<<" || k == ">>" || k == "|>" ||
    k == "." || k == "(" || k == "[" || k == "?" || k == "!" ||
    k == "," || k == "=>"

// ============================================================
// Pass 1-2: Skip (reuse checker's TypeStore and TypeRegistry)
// ============================================================

// ============================================================
// Const pre-scan: collect const values before lowering bodies
// ============================================================

fn _scan_consts(l: Lowerer) -> Lowerer {
    mut ll := _lset_pos(l, 0)
    ll = _lskip_nl(ll)
    if ll.pos == 0 { ll = _ladv(ll) }
    if _lk(ll) == "mod" { ll = _ladv(_ladv(ll)) }
    ll = _lskip_nl(ll)
    while _lk(ll) == "use" {
        while _lk(ll) != "NEWLINE" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        ll = _lskip_nl(ll)
    }

    while _lk(ll) != "EOF" {
        ll = _lskip_nl(ll)
        if _lk(ll) == "EOF" { return ll }
        if _lk(ll) == "pub" { ll = _ladv(ll) }

        if _lk(ll) == "const" {
            ll = _ladv(ll)  // skip const
            if _lk(ll) == "IDENT" {
                cname := _lcur(ll).text
                ll = _ladv(ll)  // skip name
                // Skip : TYPE if present
                if _lk(ll) == ":" {
                    ll = _ladv(ll)
                    ll = _skip_type_l(ll)
                }
                if _lk(ll) == "=" {
                    ll = _ladv(ll)
                    ll = _lskip_nl(ll)
                    if _lk(ll) == "INT" {
                        // Parse integer value
                        val_text := _lcur(ll).text
                        mut num := 0
                        mut ci := 0
                        mut neg := false
                        if val_text.len() > 0 && val_text.charAt(0) == "-" {
                            neg = true
                            ci = 1
                        }
                        while ci < val_text.len() {
                            ch := val_text.charAt(ci)
                            if ch != "_" {
                                mut digit := 0
                                if ch == "0" { digit = 0 } else if ch == "1" { digit = 1 } else if ch == "2" { digit = 2 } else if ch == "3" { digit = 3 } else if ch == "4" { digit = 4 } else if ch == "5" { digit = 5 } else if ch == "6" { digit = 6 } else if ch == "7" { digit = 7 } else if ch == "8" { digit = 8 } else if ch == "9" { digit = 9 }
                                num = num * 10 + digit
                            }
                            ci = ci + 1
                        }
                        if neg { num = 0 - num }
                        ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                                     table: ll.table, file: ll.file, module: ll.module,
                                     current_func: ll.current_func,
                                     temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                                     env_names: ll.env_names, env_slots: ll.env_slots,
                                     loop_start: ll.loop_start, loop_end: ll.loop_end,
                                     const_names: ll.const_names.append(cname), const_vals: ll.const_vals.append(num),
                                     const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                                     temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
                        ll = _ladv(ll)
                    } else if _lk(ll) == "STRING" {
                        sval := _lcur(ll).text
                        ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                                     table: ll.table, file: ll.file, module: ll.module,
                                     current_func: ll.current_func,
                                     temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                                     env_names: ll.env_names, env_slots: ll.env_slots,
                                     loop_start: ll.loop_start, loop_end: ll.loop_end,
                                     const_names: ll.const_names, const_vals: ll.const_vals,
                                     const_str_names: ll.const_str_names.append(cname), const_str_vals: ll.const_str_vals.append(sval),
                                     temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
                        ll = _ladv(ll)
                    } else if _lk(ll) == "-" {
                        // Negative int: - INT
                        ll = _ladv(ll)
                        if _lk(ll) == "INT" {
                            val_text := _lcur(ll).text
                            mut num := 0
                            mut ci := 0
                            while ci < val_text.len() {
                                ch := val_text.charAt(ci)
                                if ch != "_" {
                                    mut digit := 0
                                    if ch == "0" { digit = 0 } else if ch == "1" { digit = 1 } else if ch == "2" { digit = 2 } else if ch == "3" { digit = 3 } else if ch == "4" { digit = 4 } else if ch == "5" { digit = 5 } else if ch == "6" { digit = 6 } else if ch == "7" { digit = 7 } else if ch == "8" { digit = 8 } else if ch == "9" { digit = 9 }
                                    num = num * 10 + digit
                                }
                                ci = ci + 1
                            }
                            num = 0 - num
                            ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                                         table: ll.table, file: ll.file, module: ll.module,
                                         current_func: ll.current_func,
                                         temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                                         env_names: ll.env_names, env_slots: ll.env_slots,
                                         loop_start: ll.loop_start, loop_end: ll.loop_end,
                                         const_names: ll.const_names.append(cname), const_vals: ll.const_vals.append(num),
                                         const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                                         temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
                            ll = _ladv(ll)
                        }
                    }
                }
            }
        }
        ll = _ladv(ll)
        ll = _lskip_nl(ll)
    }
    ll
}

// ============================================================
// Pass 3: Lower function/entry/test bodies
// ============================================================

fn _lower_bodies(l: Lowerer) -> Lowerer {
    mut ll := _lset_pos(l, 0)
    ll = _lskip_nl(ll)
    if ll.pos == 0 { ll = _ladv(ll) }

    if _lk(ll) == "mod" { ll = _ladv(_ladv(ll)) }
    ll = _lskip_nl(ll)
    while _lk(ll) == "use" {
        while _lk(ll) != "NEWLINE" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        ll = _lskip_nl(ll)
    }

    while _lk(ll) != "EOF" {
        ll = _lskip_nl(ll)
        if _lk(ll) == "EOF" { return ll }
        if _lk(ll) == "pub" { ll = _ladv(ll) }

        k := _lk(ll)
        if k == "fn" {
            ll = _lower_fn(ll)
        } else if k == "entry" {
            ll = _lower_entry(ll)
        } else if k == "test" {
            ll = _lower_test(ll)
        } else if k == "impl" {
            ll = _lower_impl(ll)
        } else if k == "const" {
            ll = _skip_to_next_l(ll)
        } else {
            ll = _skip_to_next_l(ll)
        }
        ll = _lskip_nl(ll)
    }
    ll
}

fn _skip_to_next_l(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)
    lb := "\{"
    rb := "\}"
    while _lk(ll) != "EOF" {
        if _lk(ll) == lb {
            mut d := 1
            ll = _ladv(ll)
            while d > 0 && _lk(ll) != "EOF" {
                if _lk(ll) == lb { d = d + 1 }
                if _lk(ll) == rb { d = d - 1 }
                if d > 0 { ll = _ladv(ll) }
            }
            if _lk(ll) == rb { ll = _ladv(ll) }
            return ll
        }
        if _lk(ll) == "NEWLINE" {
            ll = _lskip_nl(ll)
            nk := _lk(ll)
            if nk == "fn" || nk == "pub" || nk == "type" || nk == "struct" ||
               nk == "enum" || nk == "trait" || nk == "impl" || nk == "const" ||
               nk == "entry" || nk == "test" || nk == "EOF" {
                return ll
            }
        }
        ll = _ladv(ll)
    }
    ll
}

// --- Lower function ---

fn _lower_fn(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip fn
    if _lk(ll) != "IDENT" { return ll }
    name := _lcur(ll).text
    ll = _ladv(ll)

    sig := reg_find_fn(ll.registry, name)
    if sig.name == "" { return _skip_to_next_l(ll) }

    // Skip generic function bodies — they are lowered via monomorphization
    if fn_is_generic(sig) { return _skip_to_next_l(ll) }

    // Count actual register args (strings take 2 regs each)
    mut actual_param_count := 0
    mut pi := 1
    while pi < sig.param_names.len() {
        if pi <= sig.param_types.len() - 1 && sig.param_types[pi] == 12 {
            actual_param_count = actual_param_count + 2
        } else {
            actual_param_count = actual_param_count + 1
        }
        pi = pi + 1
    }

    // Start a new IR function with actual register arg count
    ll = _lset_func(ll, new_ir_func(name, actual_param_count, sig.return_type))

    // Track error type for Ok wrapping and ? operator
    if sig.error_type > 0 {
        ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                table: ll.table, file: ll.file, module: ll.module,
                current_func: ll.current_func,
                temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                env_names: ll.env_names, env_slots: ll.env_slots,
                loop_start: ll.loop_start, loop_end: ll.loop_end,
                const_names: ll.const_names, const_vals: ll.const_vals,
                const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                temp_types: ll.temp_types,
                fn_error_type: sig.error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
    }

    // Allocate temps for parameters
    pi = 1
    while pi < sig.param_names.len() {
        if pi <= sig.param_types.len() - 1 && sig.param_types[pi] == 12 {
            nt := _lnew_str_temp(ll)
            ll = nt.l
            ll = _lenv_add(ll, sig.param_names[pi], nt.temp)
            ll = _lset_type(ll, nt.temp, 12)
        } else {
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lenv_add(ll, sig.param_names[pi], nt.temp)
            // Track types for field access and string array detection
            if pi <= sig.param_types.len() - 1 && sig.param_types[pi] > 0 {
                pt := sig.param_types[pi]
                // Check if this is a [str] array type
                if _is_str_array_type(ll.store, pt) {
                    ll = _lset_type(ll, nt.temp, 13)
                } else {
                    ll = _lset_type(ll, nt.temp, pt)
                }
            }
        }
        pi = pi + 1
    }

    // Skip to body
    lb := "\{"
    while _lk(ll) != "=" && _lk(ll) != lb && _lk(ll) != "EOF" {
        ll = _ladv(ll)
    }

    if _lk(ll) == "=" {
        ll = _ladv(ll)
        ll = _lskip_nl(ll)
        result := _lower_expr(ll)
        ll = result.l
        // Emit defers before return
        ll = _emit_defers(ll)
        // Implicit Ok wrapping for fallible functions (skip if already Ok/Err)
        if ll.fn_error_type > 0 && _lget_type(ll, result.temp) != 200 {
            ret_type := _lget_type(ll, result.temp)
            mut ok_slots := 2
            if ret_type == 12 { ok_slots = 3 }
            ok_nt := _lnew_temp(ll)
            ll = ok_nt.l
            ll = _lemit(ll, new_inst(OpAlloc, ok_nt.temp, ok_slots, 0, "_Result", 0))
            tag_nt := _lnew_temp(ll)
            ll = tag_nt.l
            ll = _lemit(ll, new_inst(OpConst, tag_nt.temp, 0, 0, "", 0))
            ll = _lemit(ll, new_inst(OpFieldSet, ok_nt.temp, tag_nt.temp, 0, "_tag", 0))
            if ret_type == 12 {
                ll = _lemit(ll, new_inst(OpFieldSet, ok_nt.temp, result.temp, 1, "_val", 0))
                val_len := result.temp + 1
                ll = _lemit(ll, new_inst(OpFieldSet, ok_nt.temp, val_len, 2, "_val_len", 0))
            } else {
                ll = _lemit(ll, new_inst(OpFieldSet, ok_nt.temp, result.temp, 1, "_val", 0))
            }
            ll = _lemit(ll, new_inst(OpRet, 0, ok_nt.temp, 0, "", 0))
        } else {
            // Pass return type in type_id so emitter loads X1 for string returns
            ret_type := _lget_type(ll, result.temp)
            ll = _lemit(ll, new_inst(OpRet, 0, result.temp, 0, "", ret_type))
        }
    } else if _lk(ll) == lb {
        ll = _lower_fn_body(ll, sig.return_type)
    } else {
        ll = _lskip_nl(ll)
        if _lk(ll) == lb {
            ll = _lower_fn_body(ll, sig.return_type)
        }
    }

    ll = _lfinish_func(ll)
    return ll
}

// --- Lower entry block ---

fn _lower_entry(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip entry
    ll = _lset_func(ll, new_ir_func("_main", 0, 0))

    lb := "\{"
    if _lk(ll) == lb {
        ll = _lower_block(ll)
    }

    // Add exit call at end
    nt := _lnew_temp(ll)
    ll = nt.l
    ll = _lemit(ll, new_inst(OpConst, nt.temp, 0, 0, "", 0))
    ll = _lemit(ll, new_inst(OpCall, 0, nt.temp, 1, "_aria_exit", 0))

    ll = _lfinish_func(ll)
    mut new_mod := ll.module
    new_mod = mod_set_entry(new_mod, "_main")
    Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
            table: ll.table, file: ll.file, module: new_mod,
            current_func: ll.current_func,
            temp_counter: ll.temp_counter, label_counter: ll.label_counter,
            env_names: ll.env_names, env_slots: ll.env_slots,
            loop_start: ll.loop_start, loop_end: ll.loop_end,
            const_names: ll.const_names, const_vals: ll.const_vals,
            const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
            temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
}

// --- Lower test block ---

fn _lower_test(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip test

    // Get test name from string literal or identifier
    mut test_name := "_test_" + _i2s_lower(ll.module.test_count)
    mut test_label := "test " + _i2s_lower(ll.module.test_count)
    if _lk(ll) == "STRING" {
        test_label = _lcur(ll).text
        ll = _ladv(ll)
    } else if _lk(ll) == "IDENT" {
        test_label = _lcur(ll).text
        ll = _ladv(ll)
    }

    // Create IR function for this test
    ll = _lset_func(ll, new_ir_func(test_name, 0, 0))

    lb := "\{"
    if _lk(ll) == lb {
        ll = _lower_block(ll)
    }

    // Return void at end
    ll = _lemit(ll, new_inst(OpRetVoid, 0, 0, 0, "", 0))
    ll = _lfinish_func(ll)

    // Register test in module
    mut new_mod := mod_add_test(ll.module, test_label)
    // Also add the string constant for the test name for printing
    new_mod = mod_add_string(new_mod, test_label)
    Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
            table: ll.table, file: ll.file, module: new_mod,
            current_func: ll.current_func,
            temp_counter: ll.temp_counter, label_counter: ll.label_counter,
            env_names: ll.env_names, env_slots: ll.env_slots,
            loop_start: ll.loop_start, loop_end: ll.loop_end,
            const_names: ll.const_names, const_vals: ll.const_vals,
            const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
            temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
}

fn _i2s_lower(n: i64) -> str {
    if n == 0 { return "0" }
    mut result := ""
    mut v := n
    while v > 0 {
        d := v % 10
        v = v / 10
        if d == 0 { result = "0" + result }
        if d == 1 { result = "1" + result }
        if d == 2 { result = "2" + result }
        if d == 3 { result = "3" + result }
        if d == 4 { result = "4" + result }
        if d == 5 { result = "5" + result }
        if d == 6 { result = "6" + result }
        if d == 7 { result = "7" + result }
        if d == 8 { result = "8" + result }
        if d == 9 { result = "9" + result }
    }
    result
}

// --- Lower impl block ---

fn _lower_impl(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip impl
    // Capture impl type name for qualified method names
    mut impl_type := ""
    if _lk(ll) == "IDENT" {
        impl_type = _lcur(ll).text
        ll = _ladv(ll)
    }
    if _lk(ll) == "for" {
        ll = _ladv(ll)
        if _lk(ll) == "IDENT" {
            impl_type = _lcur(ll).text
            ll = _ladv(ll)
        }
    }
    lb := "\{"
    rb := "\}"
    while _lk(ll) != lb && _lk(ll) != "EOF" { ll = _ladv(ll) }
    if _lk(ll) != lb { return ll }
    ll = _ladv(ll)
    ll = _lskip_nl(ll)
    while _lk(ll) != rb && _lk(ll) != "EOF" {
        ll = _lskip_nl(ll)
        if _lk(ll) == "pub" { ll = _ladv(ll) }
        if _lk(ll) == "fn" {
            ll = _lower_impl_fn(ll, impl_type)
        } else if _lk(ll) == rb || _lk(ll) == "EOF" {
            return ll
        } else {
            ll = _ladv(ll)
        }
        ll = _lskip_nl(ll)
    }
    if _lk(ll) == rb { ll = _ladv(ll) }
    return ll
}

// Lower a function inside an impl block — uses qualified name Type_method
fn _lower_impl_fn(l: Lowerer, impl_type: str) -> Lowerer {
    mut ll := _ladv(l)  // skip fn
    if _lk(ll) != "IDENT" { return ll }
    raw_name := _lcur(ll).text
    name := impl_type + "_" + raw_name
    ll = _ladv(ll)

    sig := reg_find_fn(ll.registry, name)
    if sig.name == "" { return _skip_to_next_l(ll) }

    // Skip generic method bodies — they are lowered via monomorphization
    if fn_is_generic(sig) { return _skip_to_next_l(ll) }

    // Count actual register args (strings take 2 regs each)
    mut actual_param_count := 0
    mut pi := 1
    while pi < sig.param_names.len() {
        if pi <= sig.param_types.len() - 1 && sig.param_types[pi] == 12 {
            actual_param_count = actual_param_count + 2
        } else {
            actual_param_count = actual_param_count + 1
        }
        pi = pi + 1
    }

    ll = _lset_func(ll, new_ir_func(name, actual_param_count, sig.return_type))

    // Allocate temps for parameters
    pi = 1
    while pi < sig.param_names.len() {
        if pi <= sig.param_types.len() - 1 && sig.param_types[pi] == 12 {
            nt := _lnew_str_temp(ll)
            ll = nt.l
            ll = _lenv_add(ll, sig.param_names[pi], nt.temp)
            ll = _lset_type(ll, nt.temp, 12)
        } else {
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lenv_add(ll, sig.param_names[pi], nt.temp)
            if pi <= sig.param_types.len() - 1 && sig.param_types[pi] > 0 {
                pt := sig.param_types[pi]
                if _is_str_array_type(ll.store, pt) {
                    ll = _lset_type(ll, nt.temp, 13)
                } else {
                    ll = _lset_type(ll, nt.temp, pt)
                }
            }
        }
        pi = pi + 1
    }

    // Skip to body
    lb := "\{"
    while _lk(ll) != "=" && _lk(ll) != lb && _lk(ll) != "EOF" {
        ll = _ladv(ll)
    }

    if _lk(ll) == "=" {
        ll = _ladv(ll)
        ll = _lskip_nl(ll)
        result := _lower_expr(ll)
        ll = result.l
        ret_type := _lget_type(ll, result.temp)
        ll = _lemit(ll, new_inst(OpRet, 0, result.temp, 0, "", ret_type))
    } else if _lk(ll) == lb {
        ll = _lower_fn_body(ll, sig.return_type)
    }
    ll = _lfinish_func(ll)
    ll
}

// --- Lower function body block { ... } with implicit return ---
// Like _lower_block but emits OpRet for the last expression if
// the function has a non-void return type.

fn _lower_fn_body(l: Lowerer, return_type: i64) -> Lowerer {
    lb := "\{"
    rb := "\}"
    if _lk(l) != lb { return l }
    mut ll := _ladv(l)  // skip {
    ll = _lskip_nl(ll)

    mut last_temp := -1
    while _lk(ll) != rb && _lk(ll) != "EOF" {
        // Check if this is the last statement before }
        // Lower it as an expression to capture its temp
        k := _lk(ll)
        if k == "return" {
            // Explicit return — lower normally, it emits OpRet
            ll = _lower_stmt(ll)
            last_temp = -1  // return already handled
        } else if k == "mut" || k == "break" || k == "continue" || k == "for" || k == "while" || k == "loop" || k == "assert" || k == "defer" {
            ll = _lower_stmt(ll)
        } else if k == "if" {
            result := _lower_if(ll)
            ll = result.l
            last_temp = result.temp
        } else if k == "match" {
            result := _lower_match(ll)
            ll = result.l
            last_temp = result.temp
        } else {
            // Expression or binding — capture the temp
            result := _lower_expr_result(ll)
            ll = result.l
            last_temp = result.temp
        }
        ll = _lskip_nl(ll)
    }
    if _lk(ll) == rb { ll = _ladv(ll) }

    // If function has a return type and we have a last expression temp,
    // and the last instruction isn't already a Ret/RetVoid, emit OpRet
    if return_type > 0 && last_temp >= 0 {
        // Check if last instruction is already a return
        inst_count := ll.current_func.insts.len()
        mut already_returned := false
        if inst_count > 1 {
            last_op := ir_op_name(ll.current_func.insts[inst_count - 1].op)
            if last_op == "Ret" || last_op == "RetVoid" {
                already_returned = true
            }
        }
        if already_returned == false {
            ll = _emit_defers(ll)
            ret_type := _lget_type(ll, last_temp)
            ll = _lemit(ll, new_inst(OpRet, 0, last_temp, 0, "", ret_type))
        }
    }
    return ll
}

// --- Lower expression statement, returning LT with result temp ---

fn _lower_expr_result(l: Lowerer) -> LT {
    if _lk(l) == "IDENT" {
        name := _lcur(l).text
        next_pos := l.pos + 1
        if next_pos < l.tokens.len() {
            next_k := token_name(l.tokens[next_pos].kind)
            if next_k == ":=" {
                mut ll := _ladv(l)   // skip name
                ll = _ladv(ll)       // skip :=
                result := _lower_expr(ll)
                ll = result.l
                ll = _lenv_add(ll, name, result.temp)
                return LT{l: ll, temp: result.temp}
            }
            if next_k == "=" {
                mut ll := _ladv(l)   // skip name
                ll = _ladv(ll)       // skip =
                result := _lower_expr(ll)
                ll = result.l
                slot := _lenv_lookup(ll, name)
                if slot >= 0 {
                    ll = _lemit(ll, new_inst(OpStore, slot, result.temp, 0, "", 0))
                    result_type := _lget_type(ll, result.temp)
                    if result_type == 12 {
                        ll = _lemit(ll, new_inst(OpStore, slot + 1, result.temp + 1, 0, "", 0))
                    }
                }
                return LT{l: ll, temp: result.temp}
            }
        }
    }
    // Plain expression
    return _lower_expr(l)
}

// --- Lower block { ... } ---

fn _lower_block(l: Lowerer) -> Lowerer {
    lb := "\{"
    rb := "\}"
    if _lk(l) != lb { return l }
    mut ll := _ladv(l)  // skip {
    ll = _lskip_nl(ll)
    scope_start := ll.env_names.len()

    while _lk(ll) != rb && _lk(ll) != "EOF" {
        ll = _lower_stmt(ll)
        ll = _lskip_nl(ll)
    }
    // Emit drops for bindings created in this block scope
    ll = _emit_drops_scoped(ll, scope_start)
    if _lk(ll) == rb { ll = _ladv(ll) }
    ll
}

// --- Lower statement ---

fn _lower_stmt(l: Lowerer) -> Lowerer {
    k := _lk(l)

    if k == "mut" { return _lower_mut_binding(l) }
    if k == "return" { return _lower_return(l) }
    if k == "break" {
        mut ll := _ladv(l)
        if l.loop_end >= 0 {
            ll = _lemit(ll, new_inst(OpJump, 0, l.loop_end, 0, "", 0))
        }
        return ll
    }
    if k == "continue" {
        mut ll := _ladv(l)
        if l.loop_start >= 0 {
            ll = _lemit(ll, new_inst(OpJump, 0, l.loop_start, 0, "", 0))
        }
        return ll
    }
    if k == "for" { return _lower_for(l) }
    if k == "while" { return _lower_while(l) }
    if k == "loop" { return _lower_loop(l) }
    if k == "if" {
        result := _lower_if(l)
        return result.l
    }
    if k == "assert" { return _lower_assert(l) }
    if k == "with" {
        // with expr { body } — resource block with guaranteed cleanup
        // Check if this is effect clause (with [...]) or resource block
        mut ll := _ladv(l)  // skip with
        if _lk(ll) != "[" {
            // Resource block: lower resource expr
            resource := _lower_expr(ll)
            ll = resource.l
            // Store resource in a named slot for drop access
            res_slot := resource.temp
            // Determine the drop function name
            obj_type := _lget_type(ll, res_slot)
            sname := _struct_name_for_type(ll.store, ll.registry, obj_type)
            mut has_drop := false
            mut drop_fn := ""
            if sname != "" {
                drop_fn = sname + "_drop"
                drop_sig := reg_find_fn(ll.registry, drop_fn)
                if drop_sig.name != "" { has_drop = true }
            }
            // Save defer state, add synthetic defer for drop
            saved_defer_count := ll.defer_count
            // We can't easily add a token-based defer for a synthesized call,
            // so we manually manage: lower body, then emit drop, and also
            // ensure _emit_defers in returns covers this.
            // Approach: lower the block, emit drops at the end, and rely on
            // _emit_drops_scoped for early return cleanup (resource is in env)
            scope_start := ll.env_names.len()
            ll = _lower_block(ll)
            // Emit resource drop after body
            if has_drop {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, res_slot, 1, drop_fn, 0))
            }
            return ll
        }
        // Otherwise it's effect clause — skip (handled by checker, not lowerer)
        while _lk(ll) != "NEWLINE" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        return ll
    }
    if k == "defer" {
        mut ll := _ladv(l)  // skip defer
        // Save the token position of the deferred expression
        defer_start := ll.pos
        // Skip the expression tokens to find the end
        // Advance until newline or block end
        lb2 := "\{"
        if _lk(ll) == lb2 {
            ll = _skip_braces_l(ll)
        } else {
            while _lk(ll) != "NEWLINE" && _lk(ll) != "EOF" { ll = _ladv(ll) }
        }
        defer_end := ll.pos
        // Store defer position
        dc := ll.defer_count
        if dc == 0 {
            ll = _lset_defer(ll, dc + 1, defer_start, defer_end, 0)
        } else if dc == 1 {
            ll = _lset_defer(ll, dc + 1, defer_start, defer_end, 1)
        } else if dc == 2 {
            ll = _lset_defer(ll, dc + 1, defer_start, defer_end, 2)
        } else if dc == 3 {
            ll = _lset_defer(ll, dc + 1, defer_start, defer_end, 3)
        }
        return ll
    }

    return _lower_expr_or_binding(l)
}

// --- Lower mut binding ---

fn _lower_mut_binding(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip mut
    if _lk(ll) != "IDENT" { return ll }
    name := _lcur(ll).text
    ll = _ladv(ll)

    // Check for type annotation to infer str type
    mut is_str_type := false
    if _lk(ll) == ":" {
        ll = _ladv(ll)
        if _lk(ll) == "IDENT" && _lcur(ll).text == "str" {
            is_str_type = true
        }
        ll = _skip_type_l(ll)
        if _lk(ll) == "=" { ll = _ladv(ll) }
    } else if _lk(ll) == ":=" {
        ll = _ladv(ll)
    }

    result := _lower_expr(ll)
    ll = result.l
    // Propagate type to binding
    if is_str_type {
        ll = _lset_type(ll, result.temp, 12)
    }
    ll = _lenv_add(ll, name, result.temp)
    return ll
}

// --- Lower return ---

fn _lower_return(l: Lowerer) -> Lowerer {
    mut ll := _ladv(l)  // skip return
    rb := "\}"
    if _lk(ll) == "NEWLINE" || _lk(ll) == "EOF" || _lk(ll) == rb {
        ll = _emit_defers(ll)
        ll = _lemit(ll, new_inst(OpRetVoid, 0, 0, 0, "", 0))
        return ll
    }
    result := _lower_expr(ll)
    ll = result.l
    ll = _emit_defers(ll)
    // Implicit Ok wrapping for fallible functions (skip if already Ok/Err)
    if ll.fn_error_type > 0 && _lget_type(ll, result.temp) != 200 {
        ret_type := _lget_type(ll, result.temp)
        mut ok_slots := 2
        if ret_type == 12 { ok_slots = 3 }
        ok_nt := _lnew_temp(ll)
        ll = ok_nt.l
        ll = _lemit(ll, new_inst(OpAlloc, ok_nt.temp, ok_slots, 0, "_Result", 0))
        tag_nt := _lnew_temp(ll)
        ll = tag_nt.l
        ll = _lemit(ll, new_inst(OpConst, tag_nt.temp, 0, 0, "", 0))
        ll = _lemit(ll, new_inst(OpFieldSet, ok_nt.temp, tag_nt.temp, 0, "_tag", 0))
        if ret_type == 12 {
            ll = _lemit(ll, new_inst(OpFieldSet, ok_nt.temp, result.temp, 1, "_val", 0))
            val_len := result.temp + 1
            ll = _lemit(ll, new_inst(OpFieldSet, ok_nt.temp, val_len, 2, "_val_len", 0))
        } else {
            ll = _lemit(ll, new_inst(OpFieldSet, ok_nt.temp, result.temp, 1, "_val", 0))
        }
        ll = _lemit(ll, new_inst(OpRet, 0, ok_nt.temp, 0, "", 0))
    } else {
        ret_type := _lget_type(ll, result.temp)
        ll = _lemit(ll, new_inst(OpRet, 0, result.temp, 0, "", ret_type))
    }
    return ll
}

// --- Lower expression or binding ---

fn _lower_expr_or_binding(l: Lowerer) -> Lowerer {
    if _lk(l) == "IDENT" {
        name := _lcur(l).text
        next_pos := l.pos + 1
        if next_pos < l.tokens.len() {
            next_k := token_name(l.tokens[next_pos].kind)
            if next_k == ":=" {
                mut ll := _ladv(l)   // skip name
                ll = _ladv(ll)       // skip :=
                result := _lower_expr(ll)
                ll = result.l
                ll = _lenv_add(ll, name, result.temp)
                return ll
            }
            // Compound assignment: += -= *= /= %=
            if (next_k == "+" || next_k == "-" || next_k == "*" || next_k == "/" || next_k == "%") {
                // Check if followed by =
                eq_pos := l.pos + 2
                if eq_pos < l.tokens.len() && token_name(l.tokens[eq_pos].kind) == "=" {
                    op_k := next_k
                    mut ll := _ladv(l)   // skip name
                    ll = _ladv(ll)       // skip op
                    ll = _ladv(ll)       // skip =
                    // Desugar: x += expr → x = x + expr
                    slot := _lenv_lookup(ll, name)
                    if slot >= 0 {
                        // Load current value
                        cur_nt := _lnew_temp(ll)
                        ll = cur_nt.l
                        ll = _lemit(ll, new_inst(OpLoad, cur_nt.temp, slot, 0, "", 0))
                        // Evaluate RHS
                        rhs := _lower_expr(ll)
                        ll = rhs.l
                        // Apply operation (float-aware)
                        res_nt := _lnew_temp(ll)
                        ll = res_nt.l
                        cur_type := _lget_type(ll, slot)
                        if _is_float_type(cur_type) || _is_float_type(_lget_type(ll, rhs.temp)) {
                            ll = _lemit(ll, new_inst(_arith_op(op_k), res_nt.temp, cur_nt.temp, rhs.temp, "f64", 0))
                            ll = _lset_type(ll, res_nt.temp, 9)
                        } else {
                            ll = _lemit(ll, new_inst(_arith_op(op_k), res_nt.temp, cur_nt.temp, rhs.temp, "", 0))
                        }
                        // Store back
                        ll = _lemit(ll, new_inst(OpStore, slot, res_nt.temp, 0, "", 0))
                    }
                    return ll
                }
            }
            if next_k == "=" {
                // Assignment: name = expr
                mut ll := _ladv(l)   // skip name
                ll = _ladv(ll)       // skip =
                result := _lower_expr(ll)
                ll = result.l
                slot := _lenv_lookup(ll, name)
                if slot >= 0 {
                    ll = _lemit(ll, new_inst(OpStore, slot, result.temp, 0, "", 0))
                    // For strings, also copy the len slot
                    result_type := _lget_type(ll, result.temp)
                    if result_type == 12 {
                        ll = _lemit(ll, new_inst(OpStore, slot + 1, result.temp + 1, 0, "", 0))
                    }
                    // Propagate type to variable slot (critical for arrays that change type)
                    if result_type > 0 {
                        ll = _lset_type(ll, slot, result_type)
                    }
                }
                return ll
            }
        }
    }
    // Expression statement
    result := _lower_expr(l)
    return result.l
}

// --- Lower multiplicative (atom [*|/|% atom]*) ---
// Handles *, /, % which bind tighter than +, -

fn _lower_multiplicative(l: Lowerer) -> LT {
    result := _lower_atom(l)
    mut ll := result.l
    mut left := result.temp
    mut running := true
    while running {
        k := _lk(ll)
        if k == "*" || k == "/" || k == "%" {
            ll = _ladv(ll)
            right := _lower_atom(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            left_type := _lget_type(ll, left)
            right_type := _lget_type(ll, right.temp)
            if _is_float_type(left_type) || _is_float_type(right_type) {
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "f64", 0))
                ll = _lset_type(ll, nt.temp, 9)
            } else {
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "", 0))
                ll = _lset_type(ll, nt.temp, 1)
            }
            left = nt.temp
        } else {
            running = false
        }
    }
    LT{l: ll, temp: left}
}

// --- Lower additive (multiplicative [+|- multiplicative]*) ---
// Handles +, - which bind tighter than comparison

fn _lower_additive(l: Lowerer) -> LT {
    result := _lower_multiplicative(l)
    mut ll := result.l
    mut left := result.temp
    mut running := true
    while running {
        k := _lk(ll)
        if k == "+" || k == "-" {
            ll = _ladv(ll)
            right := _lower_multiplicative(ll)
            ll = right.l
            left_type := _lget_type(ll, left)
            right_type := _lget_type(ll, right.temp)
            if k == "+" && left_type == 12 {
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpStrConcat, nt.temp, left, right.temp, "", 0))
                ll = _lset_type(ll, nt.temp, 12)
                left = nt.temp
            } else if _is_float_type(left_type) || _is_float_type(right_type) {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "f64", 0))
                ll = _lset_type(ll, nt.temp, 9)
                left = nt.temp
            } else {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "", 0))
                ll = _lset_type(ll, nt.temp, 1)
                left = nt.temp
            }
        } else {
            running = false
        }
    }
    LT{l: ll, temp: left}
}

// --- Lower comparison (additive [cmp additive]) ---
// Used as right-hand side of && and || to get correct precedence

fn _lower_comparison(l: Lowerer) -> LT {
    result := _lower_additive(l)
    mut ll := result.l
    mut left := result.temp
    k := _lk(ll)
    if k == "==" || k == "!=" || k == "<" || k == ">" || k == "<=" || k == ">=" {
        ll = _ladv(ll)
        right := _lower_additive(ll)
        ll = right.l
        nt := _lnew_temp(ll)
        ll = nt.l
        left_type := _lget_type(ll, left)
        if (k == "==" || k == "!=") && left_type == 12 {
            ll = _lemit(ll, new_inst(OpStrEq, nt.temp, left, right.temp, "", 0))
            if k == "!=" {
                not_nt := _lnew_temp(ll)
                ll = not_nt.l
                ll = _lemit(ll, new_inst(OpNot, not_nt.temp, nt.temp, 0, "", 0))
                left = not_nt.temp
                ll = _lset_type(ll, not_nt.temp, 1)
            } else {
                left = nt.temp
            }
        } else if (k == "==" || k == "!=") && _is_struct_type(ll.store, ll.registry, left_type) {
            // Struct equality: compare field by field
            sname := _struct_name_for_type(ll.store, ll.registry, left_type)
            if sname != "" {
                eq_result := _lower_struct_eq(ll, left, right.temp, sname, nt.temp)
                ll = eq_result
                if k == "!=" {
                    not_nt := _lnew_temp(ll)
                    ll = not_nt.l
                    ll = _lemit(ll, new_inst(OpNot, not_nt.temp, nt.temp, 0, "", 0))
                    left = not_nt.temp
                    ll = _lset_type(ll, not_nt.temp, 1)
                } else {
                    left = nt.temp
                }
            } else {
                ll = _lemit(ll, new_inst(_cmp_op(k), nt.temp, left, right.temp, "", 0))
                left = nt.temp
            }
        } else if _is_float_type(left_type) || _is_float_type(_lget_type(ll, right.temp)) {
            ll = _lemit(ll, new_inst(_cmp_op(k), nt.temp, left, right.temp, "f64", 0))
            left = nt.temp
        } else {
            ll = _lemit(ll, new_inst(_cmp_op(k), nt.temp, left, right.temp, "", 0))
            left = nt.temp
        }
        ll = _lset_type(ll, nt.temp, 1)
    }
    LT{l: ll, temp: left}
}

// --- Lower expression ---

fn _lower_expr(l: Lowerer) -> LT {
    result := _lower_primary(l)
    mut ll := result.l
    mut left := result.temp

    // Handle binary operators and postfix
    mut running := true
    while running {
        k := _lk(ll)

        if k == "+" || k == "-" {
            ll = _ladv(ll)
            right := _lower_multiplicative(ll)
            ll = right.l
            // Check if left operand is a string for +
            left_type := _lget_type(ll, left)
            right_type := _lget_type(ll, right.temp)
            if k == "+" && left_type == 12 {
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpStrConcat, nt.temp, left, right.temp, "", 0))
                ll = _lset_type(ll, nt.temp, 12)
                left = nt.temp
            } else if _is_float_type(left_type) || _is_float_type(right_type) {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "f64", 0))
                ll = _lset_type(ll, nt.temp, 9)
                left = nt.temp
            } else {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "", 0))
                ll = _lset_type(ll, nt.temp, 1)
                left = nt.temp
            }
        } else if k == "*" || k == "/" || k == "%" {
            ll = _ladv(ll)
            right := _lower_atom(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            left_type := _lget_type(ll, left)
            right_type := _lget_type(ll, right.temp)
            if _is_float_type(left_type) || _is_float_type(right_type) {
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "f64", 0))
                ll = _lset_type(ll, nt.temp, 9)
            } else {
                ll = _lemit(ll, new_inst(_arith_op(k), nt.temp, left, right.temp, "", 0))
                ll = _lset_type(ll, nt.temp, 1)
            }
            left = nt.temp
        } else if k == "==" || k == "!=" || k == "<" || k == ">" || k == "<=" || k == ">=" {
            ll = _ladv(ll)
            right := _lower_additive(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            left_type := _lget_type(ll, left)
            if (k == "==" || k == "!=") && left_type == 12 {
                ll = _lemit(ll, new_inst(OpStrEq, nt.temp, left, right.temp, "", 0))
                if k == "!=" {
                    not_nt := _lnew_temp(ll)
                    ll = not_nt.l
                    ll = _lemit(ll, new_inst(OpNot, not_nt.temp, nt.temp, 0, "", 0))
                    left = not_nt.temp
                    ll = _lset_type(ll, not_nt.temp, 1)
                } else {
                    left = nt.temp
                }
            } else if (k == "==" || k == "!=") && _is_struct_type(ll.store, ll.registry, left_type) {
                sname := _struct_name_for_type(ll.store, ll.registry, left_type)
                if sname != "" {
                    eq_result := _lower_struct_eq(ll, left, right.temp, sname, nt.temp)
                    ll = eq_result
                    if k == "!=" {
                        not_nt := _lnew_temp(ll)
                        ll = not_nt.l
                        ll = _lemit(ll, new_inst(OpNot, not_nt.temp, nt.temp, 0, "", 0))
                        left = not_nt.temp
                        ll = _lset_type(ll, not_nt.temp, 1)
                    } else {
                        left = nt.temp
                    }
                } else {
                    ll = _lemit(ll, new_inst(_cmp_op(k), nt.temp, left, right.temp, "", 0))
                    left = nt.temp
                }
            } else if _is_float_type(left_type) || _is_float_type(_lget_type(ll, right.temp)) {
                ll = _lemit(ll, new_inst(_cmp_op(k), nt.temp, left, right.temp, "f64", 0))
                left = nt.temp
            } else {
                ll = _lemit(ll, new_inst(_cmp_op(k), nt.temp, left, right.temp, "", 0))
                left = nt.temp
            }
            ll = _lset_type(ll, nt.temp, 1)
        } else if k == "&&" {
            ll = _ladv(ll)
            right := _lower_comparison(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpAnd, nt.temp, left, right.temp, "", 0))
            left = nt.temp
        } else if k == "||" {
            ll = _ladv(ll)
            right := _lower_comparison(ll)
            ll = right.l
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpOr, nt.temp, left, right.temp, "", 0))
            left = nt.temp
        } else if k == "|>" {
            ll = _ladv(ll)
            // Pipe: a |> f → f(a)
            if _lk(ll) == "IDENT" {
                fname := _lcur(ll).text
                ll = _ladv(ll)
                pipe_sig := reg_find_fn(ll.registry, fname)
                mut pipe_call_name := fname
                mut pipe_call_sig := pipe_sig
                // Handle generic pipe target: infer type from piped value
                if pipe_sig.name != "" && fn_is_generic(pipe_sig) {
                    left_type := _lget_type(ll, left)
                    suffix := _type_name_suffix(ll.store, left_type)
                    if suffix != "unknown" {
                        pipe_call_name = fname + "_" + suffix
                        sp_sig := reg_find_fn(ll.registry, pipe_call_name)
                        if sp_sig.name != "" { pipe_call_sig = sp_sig }
                    }
                }
                mut nt_temp := 0
                if pipe_call_sig.name != "" && pipe_call_sig.return_type == 12 {
                    nt := _lnew_str_temp(ll)
                    ll = nt.l
                    nt_temp = nt.temp
                } else {
                    nt := _lnew_temp(ll)
                    ll = nt.l
                    nt_temp = nt.temp
                }
                ll = _lemit(ll, new_inst(OpCall, nt_temp, left, 1, pipe_call_name, 0))
                if pipe_call_sig.name != "" && pipe_call_sig.return_type == 12 {
                    ll = _lset_type(ll, nt_temp, 12)
                } else if pipe_call_sig.name != "" && pipe_call_sig.return_type > 0 {
                    ll = _lset_type(ll, nt_temp, pipe_call_sig.return_type)
                }
                left = nt_temp
            }
        } else if k == "." {
            ll = _ladv(ll)
            if _lk(ll) == "IDENT" {
                field := _lcur(ll).text
                ll = _ladv(ll)
                if _lk(ll) == "(" {
                    // Method call
                    mr := _lower_method_call(ll, left, field)
                    ll = mr.l
                    left = mr.temp
                } else if _lk(ll) == "[" && (field == "to" || field == "trunc") {
                    // Conversion with type arg: .to[Type]() or .trunc[Type]()
                    ll = _ladv(ll)  // skip [
                    mut target_type_name := ""
                    if _lk(ll) == "IDENT" {
                        target_type_name = _lcur(ll).text
                        ll = _ladv(ll)
                    }
                    if _lk(ll) == "]" { ll = _ladv(ll) }
                    if _lk(ll) == "(" { ll = _ladv(ll) }
                    if _lk(ll) == ")" { ll = _ladv(ll) }
                    mr := _lower_conversion(ll, left, field, target_type_name)
                    ll = mr.l
                    left = mr.temp
                } else {
                    // Field access — use type-aware lookup
                    left_type := _lget_type(ll, left)
                    sname := _struct_name_for_type(ll.store, ll.registry, left_type)
                    mut fidx := 0
                    mut ft := 0
                    if sname != "" {
                        fidx = _field_index(ll.registry, sname, field)
                        ft = _field_type_id(ll, sname, field)
                    } else {
                        fidx = _field_index_any(ll.registry, field)
                        ft = _field_type_id_any(ll.registry, field)
                    }
                    // Use _lnew_str_temp for string fields (2 consecutive slots)
                    mut nt_temp := 0
                    if ft == 12 {
                        nt := _lnew_str_temp(ll)
                        ll = nt.l
                        nt_temp = nt.temp
                    } else {
                        nt := _lnew_temp(ll)
                        ll = nt.l
                        nt_temp = nt.temp
                    }
                    if ft == 12 {
                        // String field: load both ptr and len from consecutive field slots
                        fidx_len := fidx + 1
                        nt_len := nt_temp + 1
                        ll = _lemit(ll, new_inst(OpFieldGet, nt_temp, left, fidx, field, 0))
                        ll = _lemit(ll, new_inst(OpFieldGet, nt_len, left, fidx_len, field, 0))
                    } else {
                        ll = _lemit(ll, new_inst(OpFieldGet, nt_temp, left, fidx, field, 0))
                    }
                    if ft > 0 { ll = _lset_type(ll, nt_temp, ft) }
                    left = nt_temp
                }
            } else {
                running = false
            }
        } else if k == "(" {
            // Function call on result
            cr := _lower_call_args(ll, left)
            ll = cr.l
            left = cr.temp
        } else if k == "catch" {
            // catch |e| { body } — unwrap Ok or run recovery with error bound to e
            ll = _ladv(ll)  // skip catch
            // Parse error binding: |e| or |_|
            mut err_name := "_"
            if _lk(ll) == "|" {
                ll = _ladv(ll)  // skip |
                if _lk(ll) == "IDENT" {
                    err_name = _lcur(ll).text
                    ll = _ladv(ll)
                } else {
                    ll = _ladv(ll)  // skip _
                }
                if _lk(ll) == "|" { ll = _ladv(ll) }  // skip |
            }
            // Extract tag from result
            tag_nt := _lnew_temp(ll)
            ll = tag_nt.l
            ll = _lemit(ll, new_inst(OpFieldGet, tag_nt.temp, left, 0, "_tag", 0))
            const_one := _lnew_temp(ll)
            ll = const_one.l
            ll = _lemit(ll, new_inst(OpConst, const_one.temp, 1, 0, "", 0))
            is_err := _lnew_temp(ll)
            ll = is_err.l
            ll = _lemit(ll, new_inst(OpEq, is_err.temp, tag_nt.temp, const_one.temp, "", 0))
            // Labels
            catch_lbl := _lnew_label(ll)
            ll = catch_lbl.l
            end_lbl := _lnew_label(ll)
            ll = end_lbl.l
            ll = _lemit(ll, new_inst(OpBranchTrue, 0, is_err.temp, catch_lbl.temp, "", 0))
            // Ok path: extract value
            ok_val := _lnew_temp(ll)
            ll = ok_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, ok_val.temp, left, 1, "_val", 0))
            // Store to final result temp
            final_nt := _lnew_temp(ll)
            ll = final_nt.l
            ll = _lemit(ll, new_inst(OpStore, final_nt.temp, ok_val.temp, 0, "", 0))
            ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))
            // Catch path: bind error, lower body
            ll = _lemit(ll, new_inst(OpLabel, 0, catch_lbl.temp, 0, "", 0))
            err_val := _lnew_temp(ll)
            ll = err_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, err_val.temp, left, 1, "_val", 0))
            if err_name != "_" {
                ll = _lenv_add(ll, err_name, err_val.temp)
            }
            // Lower catch body block
            lb := "\{"
            rb := "\}"
            if _lk(ll) == lb {
                ll = _ladv(ll)  // skip {
                ll = _lskip_nl(ll)
                mut catch_last := -1
                while _lk(ll) != rb && _lk(ll) != "EOF" {
                    ck := _lk(ll)
                    if ck == "return" || ck == "mut" || ck == "break" || ck == "continue" || ck == "assert" {
                        ll = _lower_stmt(ll)
                    } else {
                        cr := _lower_expr_result(ll)
                        ll = cr.l
                        catch_last = cr.temp
                    }
                    ll = _lskip_nl(ll)
                }
                if _lk(ll) == rb { ll = _ladv(ll) }
                if catch_last >= 0 {
                    ll = _lemit(ll, new_inst(OpStore, final_nt.temp, catch_last, 0, "", 0))
                }
            }
            // End
            ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
            left = final_nt.temp
        } else if k == "??" {
            // Null coalesce: left ?? default — if Some, unwrap; else use default
            ll = _ladv(ll)
            default_val := _lower_additive(ll)
            ll = default_val.l
            // Check tag: 0 = None, 1 = Some
            tag_nt := _lnew_temp(ll)
            ll = tag_nt.l
            ll = _lemit(ll, new_inst(OpFieldGet, tag_nt.temp, left, 0, "_tag", 0))
            some_lbl := _lnew_label(ll)
            ll = some_lbl.l
            end_lbl := _lnew_label(ll)
            ll = end_lbl.l
            final_nt := _lnew_temp(ll)
            ll = final_nt.l
            ll = _lemit(ll, new_inst(OpBranchTrue, 0, tag_nt.temp, some_lbl.temp, "", 0))
            // None path: use default
            ll = _lemit(ll, new_inst(OpStore, final_nt.temp, default_val.temp, 0, "", 0))
            ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))
            // Some path: unwrap value from slot 1
            ll = _lemit(ll, new_inst(OpLabel, 0, some_lbl.temp, 0, "", 0))
            some_val := _lnew_temp(ll)
            ll = some_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, some_val.temp, left, 1, "_val", 0))
            ll = _lemit(ll, new_inst(OpStore, final_nt.temp, some_val.temp, 0, "", 0))
            ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
            left = final_nt.temp
        } else if k == "?." {
            // Optional chaining: left?.field — if None, return None; else access field
            ll = _ladv(ll)
            if _lk(ll) == "IDENT" {
                field := _lcur(ll).text
                ll = _ladv(ll)
                // Check tag
                tag_nt := _lnew_temp(ll)
                ll = tag_nt.l
                ll = _lemit(ll, new_inst(OpFieldGet, tag_nt.temp, left, 0, "_tag", 0))
                some_lbl := _lnew_label(ll)
                ll = some_lbl.l
                end_lbl := _lnew_label(ll)
                ll = end_lbl.l
                final_nt := _lnew_temp(ll)
                ll = final_nt.l
                ll = _lemit(ll, new_inst(OpBranchTrue, 0, tag_nt.temp, some_lbl.temp, "", 0))
                // None path: result is None (alloc None optional)
                none_nt := _lnew_temp(ll)
                ll = none_nt.l
                ll = _lemit(ll, new_inst(OpAlloc, none_nt.temp, 1, 0, "_Optional", 0))
                none_tag := _lnew_temp(ll)
                ll = none_tag.l
                ll = _lemit(ll, new_inst(OpConst, none_tag.temp, 0, 0, "", 0))
                ll = _lemit(ll, new_inst(OpFieldSet, none_nt.temp, none_tag.temp, 0, "_tag", 0))
                ll = _lemit(ll, new_inst(OpStore, final_nt.temp, none_nt.temp, 0, "", 0))
                ll = _lemit(ll, new_inst(OpJump, 0, end_lbl.temp, 0, "", 0))
                // Some path: unwrap, access field, wrap in Some
                ll = _lemit(ll, new_inst(OpLabel, 0, some_lbl.temp, 0, "", 0))
                inner := _lnew_temp(ll)
                ll = inner.l
                ll = _lemit(ll, new_inst(OpFieldGet, inner.temp, left, 1, "_val", 0))
                // Access field on inner value
                inner_type := _lget_type(ll, left)
                // For now, use _field_index_any to find the field
                fidx := _field_index_any(ll.registry, field)
                field_val := _lnew_temp(ll)
                ll = field_val.l
                ll = _lemit(ll, new_inst(OpFieldGet, field_val.temp, inner.temp, fidx, field, 0))
                // Wrap in Some
                some_result := _lnew_temp(ll)
                ll = some_result.l
                ll = _lemit(ll, new_inst(OpAlloc, some_result.temp, 2, 0, "_Optional", 0))
                some_tag := _lnew_temp(ll)
                ll = some_tag.l
                ll = _lemit(ll, new_inst(OpConst, some_tag.temp, 1, 0, "", 0))
                ll = _lemit(ll, new_inst(OpFieldSet, some_result.temp, some_tag.temp, 0, "_tag", 0))
                ll = _lemit(ll, new_inst(OpFieldSet, some_result.temp, field_val.temp, 1, "_val", 0))
                ll = _lemit(ll, new_inst(OpStore, final_nt.temp, some_result.temp, 0, "", 0))
                ll = _lemit(ll, new_inst(OpLabel, 0, end_lbl.temp, 0, "", 0))
                ll = _lset_type(ll, final_nt.temp, 201)
                left = final_nt.temp
            }
        } else if k == "[" {
            // Array index
            ll = _ladv(ll)
            idx := _lower_expr(ll)
            ll = idx.l
            if _lk(ll) == "]" { ll = _ladv(ll) }
            // Determine array element type
            left_type := _lget_type(ll, left)
            elem_type := _array_elem_type(ll.store, left_type)
            if elem_type == 12 {
                // String array: dereference string struct pointer
                nt := _lnew_str_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpArrayGet, nt.temp, left, idx.temp, "", 12))
                ll = _lset_type(ll, nt.temp, 12)
                left = nt.temp
            } else {
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpArrayGet, nt.temp, left, idx.temp, "", 0))
                // Propagate element type (e.g., struct type for [Diagnostic])
                if elem_type > 0 {
                    ll = _lset_type(ll, nt.temp, elem_type)
                }
                left = nt.temp
            }
        } else if k == "?" {
            // Error propagation in expression context
            ll = _ladv(ll)
            tag_nt := _lnew_temp(ll)
            ll = tag_nt.l
            ll = _lemit(ll, new_inst(OpFieldGet, tag_nt.temp, left, 0, "_tag", 0))
            const_one := _lnew_temp(ll)
            ll = const_one.l
            ll = _lemit(ll, new_inst(OpConst, const_one.temp, 1, 0, "", 0))
            is_err := _lnew_temp(ll)
            ll = is_err.l
            ll = _lemit(ll, new_inst(OpEq, is_err.temp, tag_nt.temp, const_one.temp, "", 0))
            err_lbl := _lnew_label(ll)
            ll = err_lbl.l
            ok_lbl := _lnew_label(ll)
            ll = ok_lbl.l
            ll = _lemit(ll, new_inst(OpBranchTrue, 0, is_err.temp, err_lbl.temp, "", 0))
            ok_val := _lnew_temp(ll)
            ll = ok_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, ok_val.temp, left, 1, "_val", 0))
            ll = _lemit(ll, new_inst(OpJump, 0, ok_lbl.temp, 0, "", 0))
            ll = _lemit(ll, new_inst(OpLabel, 0, err_lbl.temp, 0, "", 0))
            ll = _emit_defers(ll)
            ll = _lemit(ll, new_inst(OpRet, 0, left, 0, "", 0))
            ll = _lemit(ll, new_inst(OpLabel, 0, ok_lbl.temp, 0, "", 0))
            left = ok_val.temp
        } else if k == "!" {
            // Assert-unwrap in expression context
            ll = _ladv(ll)
            tag_nt := _lnew_temp(ll)
            ll = tag_nt.l
            ll = _lemit(ll, new_inst(OpFieldGet, tag_nt.temp, left, 0, "_tag", 0))
            const_one := _lnew_temp(ll)
            ll = const_one.l
            ll = _lemit(ll, new_inst(OpConst, const_one.temp, 1, 0, "", 0))
            is_err := _lnew_temp(ll)
            ll = is_err.l
            ll = _lemit(ll, new_inst(OpEq, is_err.temp, tag_nt.temp, const_one.temp, "", 0))
            panic_lbl := _lnew_label(ll)
            ll = panic_lbl.l
            ok_lbl := _lnew_label(ll)
            ll = ok_lbl.l
            ll = _lemit(ll, new_inst(OpBranchTrue, 0, is_err.temp, panic_lbl.temp, "", 0))
            ok_val := _lnew_temp(ll)
            ll = ok_val.l
            ll = _lemit(ll, new_inst(OpFieldGet, ok_val.temp, left, 1, "_val", 0))
            ll = _lemit(ll, new_inst(OpJump, 0, ok_lbl.temp, 0, "", 0))
            ll = _lemit(ll, new_inst(OpLabel, 0, panic_lbl.temp, 0, "", 0))
            mut panic_str_idx := mod_find_string(ll.module, "unwrap failed on Err value")
            if panic_str_idx == 0 {
                new_mod := mod_add_string(ll.module, "unwrap failed on Err value")
                panic_str_idx = new_mod.string_constants.len() - 1
                ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                             table: ll.table, file: ll.file, module: new_mod,
                             current_func: ll.current_func,
                             temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                             env_names: ll.env_names, env_slots: ll.env_slots,
                             loop_start: ll.loop_start, loop_end: ll.loop_end,
                             const_names: ll.const_names, const_vals: ll.const_vals,
                             const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                             temp_types: ll.temp_types,
                             fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
            }
            panic_ptr := _lnew_str_temp(ll)
            ll = panic_ptr.l
            ll = _lemit(ll, new_inst(OpConstStr, panic_ptr.temp, panic_str_idx, 25, "", 0))
            ll = _lemit(ll, new_inst(OpCall, 0, panic_ptr.temp, 2, "_aria_panic", 0))
            ll = _lemit(ll, new_inst(OpLabel, 0, ok_lbl.temp, 0, "", 0))
            left = ok_val.temp
        } else {
            running = false
        }
    }

    LT{l: ll, temp: left}
}

// --- Lower primary expression ---

fn _lower_primary(l: Lowerer) -> LT {
    k := _lk(l)
    if k == "-" || k == "!" || k == "~" {
        ll := _ladv(l)
        operand := _lower_atom(ll)
        nt := _lnew_temp(operand.l)
        op_type := _lget_type(nt.l, operand.temp)
        if k == "-" && _is_float_type(op_type) {
            lll := _lemit(nt.l, new_inst(OpNeg, nt.temp, operand.temp, 0, "f64", 0))
            llll := _lset_type(lll, nt.temp, 9)
            return LT{l: llll, temp: nt.temp}
        }
        lll := _lemit(nt.l, new_inst(_unary_op(k), nt.temp, operand.temp, 0, "", 0))
        return LT{l: lll, temp: nt.temp}
    }

    if k == "INT" {
        val := _lcur(l).text
        // Parse integer (simplified — just decimal for now)
        mut num := 0
        mut i := 0
        mut neg := false
        if val.len() > 0 && val.charAt(0) == "-" {
            neg = true
            i = 1
        }
        while i < val.len() {
            ch := val.charAt(i)
            if ch != "_" {
                mut digit := 0
                if ch == "0" { digit = 0 } else if ch == "1" { digit = 1 } else if ch == "2" { digit = 2 } else if ch == "3" { digit = 3 } else if ch == "4" { digit = 4 } else if ch == "5" { digit = 5 } else if ch == "6" { digit = 6 } else if ch == "7" { digit = 7 } else if ch == "8" { digit = 8 } else if ch == "9" { digit = 9 }
                num = num * 10 + digit
            }
            i = i + 1
        }
        if neg { num = 0 - num }
        nt := _lnew_temp(l)
        mut ll := _lemit(_ladv(nt.l), new_inst(OpConst, nt.temp, num, 0, "", 0))
        ll = _lset_type(ll, nt.temp, 1)
        return LT{l: ll, temp: nt.temp}
    }

    if k == "FLOAT" {
        val := _lcur(l).text
        mut ll := _ladv(l)
        // Store float literal text as a string constant, then use its index
        mut str_idx := mod_find_string(ll.module, val)
        if str_idx == 0 {
            new_mod := mod_add_string(ll.module, val)
            str_idx = new_mod.string_constants.len() - 1
            ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                         table: ll.table, file: ll.file, module: new_mod,
                         current_func: ll.current_func,
                         temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                         env_names: ll.env_names, env_slots: ll.env_slots,
                         loop_start: ll.loop_start, loop_end: ll.loop_end,
                         const_names: ll.const_names, const_vals: ll.const_vals,
                         const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                         temp_types: ll.temp_types,
                         fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
        }
        // Use OpConstStr with arg2 = -9 as float marker
        // arg1 = string constant index, arg2 = -9 signals float
        nt := _lnew_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpConstStr, nt.temp, str_idx, 0 - 9, "", 0))
        ll = _lset_type(ll, nt.temp, 9)
        return LT{l: ll, temp: nt.temp}
    }

    if k == "STRING" {
        val := _lcur(l).text
        mut ll := _ladv(l)
        mut str_idx := mod_find_string(ll.module, val)
        if str_idx == 0 {
            new_mod := mod_add_string(ll.module, val)
            str_idx = new_mod.string_constants.len() - 1
            ll = Lowerer{tokens: ll.tokens, pos: ll.pos, store: ll.store, registry: ll.registry,
                         table: ll.table, file: ll.file, module: new_mod,
                         current_func: ll.current_func,
                         temp_counter: ll.temp_counter, label_counter: ll.label_counter,
                         env_names: ll.env_names, env_slots: ll.env_slots,
                         loop_start: ll.loop_start, loop_end: ll.loop_end,
                         const_names: ll.const_names, const_vals: ll.const_vals,
                         const_str_names: ll.const_str_names, const_str_vals: ll.const_str_vals,
                         temp_types: ll.temp_types,
            fn_error_type: ll.fn_error_type, defer_count: ll.defer_count, defer_start_0: ll.defer_start_0, defer_start_1: ll.defer_start_1, defer_start_2: ll.defer_start_2, defer_start_3: ll.defer_start_3, defer_end_0: ll.defer_end_0, defer_end_1: ll.defer_end_1, defer_end_2: ll.defer_end_2, defer_end_3: ll.defer_end_3}
        }
        nt := _lnew_str_temp(ll)
        ll = nt.l
        ll = _lemit(ll, new_inst(OpConstStr, nt.temp, str_idx, val.len(), "", 0))
        ll = _lset_type(ll, nt.temp, 12)
        return LT{l: ll, temp: nt.temp}
    }

    if k == "CHAR" {
        val := _lcur(l).text
        // Store char as its first byte value (codepoint for ASCII)
        mut code := 0
        if val.len() > 0 {
            ch := val.charAt(0)
            // Map ASCII characters to their codepoint values
            code = _char_to_code(ch)
        }
        nt := _lnew_temp(l)
        mut ll := _lemit(_ladv(nt.l), new_inst(OpConst, nt.temp, code, 0, "", 0))
        ll = _lset_type(ll, nt.temp, 13)  // TY_CHAR
        return LT{l: ll, temp: nt.temp}
    }

    if k == "STRING_START" {
        return _lower_interpolated_string(l)
    }

    if k == "true" {
        nt := _lnew_temp(l)
        ll := _lemit(_ladv(nt.l), new_inst(OpConst, nt.temp, 1, 0, "", 0))
        return LT{l: ll, temp: nt.temp}
    }
    if k == "false" {
        nt := _lnew_temp(l)
        ll := _lemit(_ladv(nt.l), new_inst(OpConst, nt.temp, 0, 0, "", 0))
        return LT{l: ll, temp: nt.temp}
    }

    if k == "if" { return _lower_if(l) }
    if k == "match" { return _lower_match(l) }
    if k == "fn" { return _lower_closure(l) }

    // self keyword — treat as variable reference
    if k == "self" {
        mut ll := _ladv(l)
        slot := _lenv_lookup(ll, "self")
        if slot >= 0 {
            src_type := _lget_type(ll, slot)
            nt := _lnew_temp(ll)
            ll = nt.l
            ll = _lemit(ll, new_inst(OpLoad, nt.temp, slot, 0, "", 0))
            if src_type != 0 { ll = _lset_type(ll, nt.temp, src_type) }
            return LT{l: ll, temp: nt.temp}
        }
    }

    // dyn TraitName(expr) — explicit trait object construction
    if k == "IDENT" && _lcur(l).text == "dyn" {
        mut ll := _ladv(l)  // skip dyn
        if _lk(ll) == "IDENT" {
            trait_name := _lcur(ll).text
            ll = _ladv(ll)  // skip trait name
            if _lk(ll) == "(" {
                ll = _ladv(ll)  // skip (
                // Lower the concrete value expression
                val := _lower_expr(ll)
                ll = val.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                // Determine concrete type from the value's type tracking
                obj_type := _lget_type(ll, val.temp)
                concrete_name := _struct_name_for_type(ll.store, ll.registry, obj_type)
                if concrete_name != "" {
                    result := _lower_make_trait_object(ll, val.temp, concrete_name, trait_name)
                    return result
                }
                // If we can't determine concrete type, just pass through
                return LT{l: ll, temp: val.temp}
            }
        }
    }

    if k == "IDENT" {
        name := _lcur(l).text
        mut ll := _ladv(l)

        // Function call or variant construction with data
        if _lk(ll) == "(" {
            // Ok(value) and Err(value) — Result construction
            if name == "Ok" || name == "Err" {
                ll = _ladv(ll)  // skip (
                ll = _lskip_nl(ll)
                val := _lower_expr(ll)
                ll = val.l
                ll = _lskip_nl(ll)
                if _lk(ll) == ")" { ll = _ladv(ll) }
                val_type := _lget_type(ll, val.temp)
                // Determine alloc size: 2 slots (tag + val) or 3 (tag + str_ptr + str_len)
                mut result_slots := 2
                if val_type == 12 { result_slots = 3 }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpAlloc, nt.temp, result_slots, 0, "_Result", 0))
                // Set tag: 0 for Ok, 1 for Err
                tag_nt := _lnew_temp(ll)
                ll = tag_nt.l
                mut tag_val := 0
                if name == "Err" { tag_val = 1 }
                ll = _lemit(ll, new_inst(OpConst, tag_nt.temp, tag_val, 0, "", 0))
                ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, tag_nt.temp, 0, "_tag", 0))
                // Set value at slot 1 (and slot 2 for string len)
                if val_type == 12 {
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, 1, "_val", 0))
                    val_len := val.temp + 1
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val_len, 2, "_val_len", 0))
                } else {
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, 1, "_val", 0))
                }
                // Mark as Result so implicit Ok wrapping is skipped
                ll = _lset_type(ll, nt.temp, 200)
                return LT{l: ll, temp: nt.temp}
            }

            // Some(value) — Optional construction
            if name == "Some" {
                ll = _ladv(ll)  // skip (
                ll = _lskip_nl(ll)
                val := _lower_expr(ll)
                ll = val.l
                ll = _lskip_nl(ll)
                if _lk(ll) == ")" { ll = _ladv(ll) }
                val_type := _lget_type(ll, val.temp)
                mut opt_slots := 2
                if val_type == 12 { opt_slots = 3 }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpAlloc, nt.temp, opt_slots, 0, "_Optional", 0))
                tag_nt := _lnew_temp(ll)
                ll = tag_nt.l
                ll = _lemit(ll, new_inst(OpConst, tag_nt.temp, 1, 0, "", 0))
                ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, tag_nt.temp, 0, "_tag", 0))
                if val_type == 12 {
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, 1, "_val", 0))
                    val_len := val.temp + 1
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val_len, 2, "_val_len", 0))
                } else {
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, 1, "_val", 0))
                }
                ll = _lset_type(ll, nt.temp, 201)  // type 201 = Optional
                return LT{l: ll, temp: nt.temp}
            }

            // Map() constructor
            if name == "Map" {
                ll = _ladv(ll)  // skip (
                if _lk(ll) == ")" { ll = _ladv(ll) }
                cap_nt := _lnew_temp(ll)
                ll = cap_nt.l
                ll = _lemit(ll, new_inst(OpConst, cap_nt.temp, 16, 0, "", 0))
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpMapNew, nt.temp, cap_nt.temp, 0, "", 0))
                ll = _lset_type(ll, nt.temp, 300)  // type 300 = Map
                return LT{l: ll, temp: nt.temp}
            }

            // Check for variant construction first: Circle(5), Pair(1, 2)
            vtag := _variant_tag(ll.registry, name)
            if vtag > 0 {
                vparent := _variant_parent(ll.registry, name)
                vdc := variant_data_count(vparent, vtag)
                if vdc > 0 {
                    // Variant with tuple data
                    alloc_sz := sum_alloc_size(vparent)
                    nt := _lnew_temp(ll)
                    ll = nt.l
                    ll = _lemit(ll, new_inst(OpAlloc, nt.temp, alloc_sz, 0, vparent.name, 0))
                    st_id := _struct_type_id(ll.registry, vparent.name)
                    if st_id > 0 { ll = _lset_type(ll, nt.temp, st_id) }
                    // Set tag at slot 0
                    vtag_nt := _lnew_temp(ll)
                    ll = vtag_nt.l
                    ll = _lemit(ll, new_inst(OpConst, vtag_nt.temp, vtag, 0, "", 0))
                    ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, vtag_nt.temp, 0, "_tag", 0))
                    // Parse and set data fields
                    ll = _ladv(ll)  // skip (
                    ll = _lskip_nl(ll)
                    mut vfi := 0
                    while _lk(ll) != ")" && _lk(ll) != "EOF" {
                        val := _lower_expr(ll)
                        ll = val.l
                        mut vdata_slot := 1
                        mut vsi := 0
                        while vsi < vfi {
                            vft := variant_field_type(vparent, vtag, vsi)
                            if vft == 12 {
                                vdata_slot = vdata_slot + 2
                            } else {
                                vdata_slot = vdata_slot + 1
                            }
                            vsi = vsi + 1
                        }
                        vft := variant_field_type(vparent, vtag, vfi)
                        if vft == 12 {
                            ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, vdata_slot, "", 0))
                            ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp + 1, vdata_slot + 1, "", 0))
                        } else {
                            ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, vdata_slot, "", 0))
                        }
                        vfi = vfi + 1
                        ll = _lskip_nl(ll)
                        if _lk(ll) == "," { ll = _ladv(ll) }
                        ll = _lskip_nl(ll)
                    }
                    if _lk(ll) == ")" { ll = _ladv(ll) }
                    return LT{l: ll, temp: nt.temp}
                }
            }
            // Newtype construction: UserId(42) — allocate single-field struct
            nt_def := reg_find_struct(ll.registry, name)
            if nt_def.name != "" && nt_def.is_sum == false && _is_newtype(nt_def) {
                ll = _ladv(ll)  // skip (
                ll = _lskip_nl(ll)
                val := _lower_expr(ll)
                ll = val.l
                ll = _lskip_nl(ll)
                if _lk(ll) == ")" { ll = _ladv(ll) }
                // Allocate struct with 1 slot for the value field
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpAlloc, nt.temp, 1, 0, name, 0))
                st_id := _struct_type_id(ll.registry, name)
                if st_id > 0 { ll = _lset_type(ll, nt.temp, st_id) }
                // Set value field at slot 0
                ll = _lemit(ll, new_inst(OpFieldSet, nt.temp, val.temp, 0, "value", 0))
                return LT{l: ll, temp: nt.temp}
            }
            sig := reg_find_fn(ll.registry, name)
            if sig.name != "" {
                // If generic, resolve to specialized name before lowering
                mut call_name := name
                mut call_sig := sig
                if fn_is_generic(sig) {
                    // We need to peek at arg types to build the specialized name.
                    // Save position, lower args, then use types to find specialization.
                    call_sig = sig  // placeholder, will be resolved after args
                }

                ll = _ladv(ll)  // skip (
                ll = _lskip_nl(ll)
                // Collect arg temps and types
                mut arg_temps := [0]
                mut arg_types := [0]
                mut param_idx := 1
                while _lk(ll) != ")" && _lk(ll) != "EOF" {
                    ll = _lskip_nl(ll)
                    arg := _lower_expr(ll)
                    ll = arg.l
                    arg_type := _lget_type(ll, arg.temp)
                    arg_temps = arg_temps.append(arg.temp)
                    arg_types = arg_types.append(arg_type)
                    param_idx = param_idx + 1
                    ll = _lskip_nl(ll)
                    if _lk(ll) == "," { ll = _ladv(ll) }
                }
                if _lk(ll) == ")" { ll = _ladv(ll) }

                // For generic functions, infer specialization from argument types
                if fn_is_generic(sig) {
                    // Track which TypeVar names we've already resolved (up to 3)
                    mut resolved_tv_0 := ""
                    mut resolved_ty_0 := ""
                    mut resolved_tv_1 := ""
                    mut resolved_ty_1 := ""
                    mut resolved_tv_2 := ""
                    mut resolved_ty_2 := ""
                    mut resolved_count := 0
                    // Match each arg type to the generic's TypeVar params
                    mut gi := 1
                    while gi < arg_types.len() && gi < sig.param_types.len() {
                        pt := sig.param_types[gi]
                        at := arg_types[gi]
                        if pt > 0 && pt < ll.store.types.len() {
                            ptinfo := store_get(ll.store, pt)
                            if type_kind_name(ptinfo.kind) == "TypeVar" {
                                tv_name := ptinfo.name
                                // Only add if this TypeVar hasn't been resolved yet
                                mut already := false
                                if resolved_count > 0 && resolved_tv_0 == tv_name { already = true }
                                if resolved_count > 1 && resolved_tv_1 == tv_name { already = true }
                                if resolved_count > 2 && resolved_tv_2 == tv_name { already = true }
                                if already == false {
                                    suffix := _type_name_suffix(ll.store, at)
                                    if resolved_count == 0 {
                                        resolved_tv_0 = tv_name
                                        resolved_ty_0 = suffix
                                    }
                                    if resolved_count == 1 {
                                        resolved_tv_1 = tv_name
                                        resolved_ty_1 = suffix
                                    }
                                    if resolved_count == 2 {
                                        resolved_tv_2 = tv_name
                                        resolved_ty_2 = suffix
                                    }
                                    resolved_count = resolved_count + 1
                                }
                            }
                        }
                        gi = gi + 1
                    }
                    // Build specialized name matching checker's convention
                    if resolved_count > 0 {
                        call_name = name + "_" + resolved_ty_0
                    }
                    if resolved_count > 1 {
                        call_name = call_name + "_" + resolved_ty_1
                    }
                    if resolved_count > 2 {
                        call_name = call_name + "_" + resolved_ty_2
                    }
                    // Look up the specialized sig
                    sp_sig := reg_find_fn(ll.registry, call_name)
                    if sp_sig.name != "" {
                        call_sig = sp_sig
                    }
                }

                // Count registers needed
                mut reg_count := 0
                mut ai := 1
                while ai < arg_temps.len() {
                    if arg_types[ai] == 12 {
                        reg_count = reg_count + 2
                    } else {
                        reg_count = reg_count + 1
                    }
                    ai = ai + 1
                }
                // Check if args are already consecutive
                mut already_consecutive := true
                if arg_temps.len() > 1 {
                    mut expected := arg_temps[1]
                    mut ci := 1
                    while ci < arg_temps.len() {
                        if arg_temps[ci] != expected {
                            already_consecutive = false
                        }
                        if arg_types[ci] == 12 {
                            expected = expected + 2
                        } else {
                            expected = expected + 1
                        }
                        ci = ci + 1
                    }
                }
                mut fa := 0
                if already_consecutive && arg_temps.len() > 1 {
                    fa = arg_temps[1]
                } else if arg_temps.len() > 1 {
                    // Allocate consecutive temps and copy
                    first_nt := _lnew_temp(ll)
                    ll = first_nt.l
                    mut ri := 1
                    while ri < reg_count {
                        extra := _lnew_temp(ll)
                        ll = extra.l
                        ri = ri + 1
                    }
                    mut slot := 0
                    ai = 1
                    while ai < arg_temps.len() {
                        if arg_types[ai] == 12 {
                            ll = _lemit(ll, new_inst(OpStore, first_nt.temp + slot, arg_temps[ai], 0, "", 0))
                            slot_plus := slot + 1
                            ll = _lemit(ll, new_inst(OpStore, first_nt.temp + slot_plus, arg_temps[ai] + 1, 0, "", 0))
                            slot = slot + 2
                        } else {
                            ll = _lemit(ll, new_inst(OpStore, first_nt.temp + slot, arg_temps[ai], 0, "", 0))
                            slot = slot + 1
                        }
                        ai = ai + 1
                    }
                    fa = first_nt.temp
                }
                // Allocate return temp
                mut nt_temp := 0
                if call_sig.return_type == 12 {
                    nt := _lnew_str_temp(ll)
                    ll = nt.l
                    nt_temp = nt.temp
                } else {
                    nt := _lnew_temp(ll)
                    ll = nt.l
                    nt_temp = nt.temp
                }
                ll = _lemit(ll, new_inst(OpCall, nt_temp, fa, reg_count, call_name, call_sig.return_type))
                if call_sig.return_type == 12 {
                    ll = _lset_type(ll, nt_temp, 12)
                } else if call_sig.return_type > 0 {
                    ll = _lset_type(ll, nt_temp, call_sig.return_type)
                }
                return LT{l: ll, temp: nt_temp}
            }
            // Built-in function calls
            if name == "println" || name == "print" || name == "eprintln" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                // If argument is not a string, convert to string first
                mut print_temp := arg.temp
                arg_type := _lget_type(ll, arg.temp)
                if arg_type == 1 || arg_type == 0 {
                    // Could be integer — check if it's definitely not a string
                    // Emit IntToStr to be safe when arg_type == 1
                    if arg_type == 1 {
                        conv_nt := _lnew_str_temp(ll)
                        ll = conv_nt.l
                        ll = _lemit(ll, new_inst(OpIntToStr, conv_nt.temp, arg.temp, 0, "", 0))
                        ll = _lset_type(ll, conv_nt.temp, 12)
                        print_temp = conv_nt.temp
                    }
                }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, print_temp, 2, "_aria_println_str", 0))
                return LT{l: ll, temp: nt.temp}
            }
            if name == "panic" {
                ll = _ladv(ll)
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 1, "_aria_exit", 0))
                return LT{l: ll, temp: nt.temp}
            }
            // _ariaReadFile / _ariaWriteBinaryFile builtins
            if name == "_ariaReadFile" {
                ll = _ladv(ll)  // skip (
                arg := _lower_expr(ll)
                ll = arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_str_temp(ll)
                ll = nt.l
                // String arg = 2 regs (ptr + len), returns string (type_id=12)
                ll = _lemit(ll, new_inst(OpCall, nt.temp, arg.temp, 2, "_aria_read_file", 12))
                ll = _lset_type(ll, nt.temp, 12)
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaWriteBinaryFile" {
                ll = _ladv(ll)  // skip (
                // Two args: path (str = 2 temps), data (array = 1 temp)
                path_arg := _lower_expr(ll)
                ll = path_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                data_arg := _lower_expr(ll)
                ll = data_arg.l
                if _lk(ll) == ")" { ll = _ladv(ll) }
                nt := _lnew_temp(ll)
                ll = nt.l
                ll = _lemit(ll, new_inst(OpCall, nt.temp, path_arg.temp, 4, "_aria_write_binary_file", 0))
                return LT{l: ll, temp: nt.temp}
            }
            if name == "_ariaWriteFile" {
                ll = _ladv(ll)  // skip (
                // Two args: path (str = 2 temps), content (str = 2 temps)
                path_arg := _lower_expr(ll)
                ll = path_arg.l
                if _lk(ll) == "," { ll = _ladv(ll) }
                content_arg := _lower_expr(ll)
