         c0: 0, c1: 0, c2: 0, list_start: 0, list_count: 0, span: span}

fn mk_loop(span: Span) -> Expr =
    Expr{kind: EkLoop, s1: "", s2: "", b1: false, b2: false,
         c0: 0, c1: 0, c2: 0, list_start: 0, list_count: 0, span: span}

fn mk_closure(params_str: str, span: Span) -> Expr =
