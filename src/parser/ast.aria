// --- Declaration Kind ---

type DeclKind =
    | DkFn
    | DkType
    | DkEnum
    | DkTrait
    | DkImpl
    | DkConst
    | DkEntry
    | DkTest
    | DkUse
    | DkNone

// --- Program ---

struct Program {
    module_name: str
    node_count: i64
}
