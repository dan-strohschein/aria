    rr = _add_builtin(rr, "_ariaTcpSocket", SkBuiltin)
    rr = _add_builtin(rr, "_ariaTcpBind", SkBuiltin)
    rr = _add_builtin(rr, "_ariaTcpListen", SkBuiltin)
    rr = _add_builtin(rr, "_ariaTcpAccept", SkBuiltin)
    rr = _add_builtin(rr, "_ariaTcpRead", SkBuiltin)
    rr = _add_builtin(rr, "_ariaTcpWrite", SkBuiltin)
