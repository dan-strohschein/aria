mod checker

// ============================================================
// Type Checker — Multi-Pass over Token Stream
// Pass 1: Register type declarations
// Pass 2: Register function signatures
// Pass 3: Check function/entry/test bodies
// ============================================================

use diagnostic
use lexer
use parser
use resolver


// --- Checker state ---

struct Checker {
    tokens: [Token]
    pos: i64
    store: TypeStore
    registry: TypeRegistry
    treg: TraitRegistry
    diagnostics: DiagnosticBag
    table: SymbolTable
    current_scope: i64
    file: str
    pool: NodePool
    // Type environment (parallel arrays)
    env_names: [str]
    env_types: [i64]
    env_scopes: [i64]
    // Function context
    fn_return_type: i64
    fn_error_type: i64
    fn_current_name: str
    in_loop: bool
}

// --- Checker + Expression type result ---

struct CE {
    c: Checker
    type_id: i64
}

// --- CheckResult ---

struct CheckResult {
    store: TypeStore
    registry: TypeRegistry
    treg: TraitRegistry
    diagnostics: DiagnosticBag
}

// --- Constructor ---

fn _new_checker(tokens: [Token], pool: NodePool, table: SymbolTable, file: str) -> Checker =
    Checker{
        tokens: tokens,
        pos: 0,
        store: new_store(),
        registry: new_registry(),
        treg: populate_builtins(new_trait_registry()),
        diagnostics: new_bag(),
        table: table,
        current_scope: 0,
        file: file,
        pool: pool,
        env_names: [""],
        env_types: [0],
        env_scopes: [0],
        fn_return_type: TY_UNIT,
        fn_error_type: 0,
        fn_current_name: "",
        in_loop: false
    }

// --- Helpers ---

fn _ccur(c: Checker) -> Token {
    if c.pos >= c.tokens.len() {
        return Token{kind: TkEof, text: "", line: 0, col: 0, offset: 0}
    }
    return c.tokens[c.pos]
}

fn _ck2(c: Checker) -> str = token_name(_ccur(c).kind)

fn _cadv(c: Checker) -> Checker =
    Checker{tokens: c.tokens, pos: c.pos + 1, store: c.store, registry: c.registry,
            treg: c.treg, diagnostics: c.diagnostics, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names, env_types: c.env_types, env_scopes: c.env_scopes,
            fn_return_type: c.fn_return_type, fn_error_type: c.fn_error_type, fn_current_name: c.fn_current_name, in_loop: c.in_loop}

fn _cset_pos(c: Checker, pos: i64) -> Checker =
    Checker{tokens: c.tokens, pos: pos, store: c.store, registry: c.registry,
            treg: c.treg, diagnostics: c.diagnostics, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names, env_types: c.env_types, env_scopes: c.env_scopes,
            fn_return_type: c.fn_return_type, fn_error_type: c.fn_error_type, fn_current_name: c.fn_current_name, in_loop: c.in_loop}

fn _cset_store(c: Checker, store: TypeStore) -> Checker =
    Checker{tokens: c.tokens, pos: c.pos, store: store, registry: c.registry,
            treg: c.treg, diagnostics: c.diagnostics, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names, env_types: c.env_types, env_scopes: c.env_scopes,
            fn_return_type: c.fn_return_type, fn_error_type: c.fn_error_type, fn_current_name: c.fn_current_name, in_loop: c.in_loop}

fn _cset_reg(c: Checker, reg: TypeRegistry) -> Checker =
    Checker{tokens: c.tokens, pos: c.pos, store: c.store, registry: reg,
            treg: c.treg, diagnostics: c.diagnostics, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names, env_types: c.env_types, env_scopes: c.env_scopes,
            fn_return_type: c.fn_return_type, fn_error_type: c.fn_error_type, fn_current_name: c.fn_current_name, in_loop: c.in_loop}

fn _cset_diag(c: Checker, diag: DiagnosticBag) -> Checker =
    Checker{tokens: c.tokens, pos: c.pos, store: c.store, registry: c.registry,
            treg: c.treg, diagnostics: diag, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names, env_types: c.env_types, env_scopes: c.env_scopes,
            fn_return_type: c.fn_return_type, fn_error_type: c.fn_error_type, fn_current_name: c.fn_current_name, in_loop: c.in_loop}

fn _cset_fn_ctx(c: Checker, ret: i64, err: i64) -> Checker =
    Checker{tokens: c.tokens, pos: c.pos, store: c.store, registry: c.registry,
            treg: c.treg, diagnostics: c.diagnostics, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names, env_types: c.env_types, env_scopes: c.env_scopes,
            fn_return_type: ret, fn_error_type: err, fn_current_name: c.fn_current_name, in_loop: c.in_loop}

fn _cset_treg(c: Checker, treg: TraitRegistry) -> Checker =
    Checker{tokens: c.tokens, pos: c.pos, store: c.store, registry: c.registry,
            treg: treg, diagnostics: c.diagnostics, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names, env_types: c.env_types, env_scopes: c.env_scopes,
            fn_return_type: c.fn_return_type, fn_error_type: c.fn_error_type, fn_current_name: c.fn_current_name, in_loop: c.in_loop}

fn _cset_loop(c: Checker, in_loop: bool) -> Checker =
    Checker{tokens: c.tokens, pos: c.pos, store: c.store, registry: c.registry,
            treg: c.treg, diagnostics: c.diagnostics, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names, env_types: c.env_types, env_scopes: c.env_scopes,
            fn_return_type: c.fn_return_type, fn_error_type: c.fn_error_type, fn_current_name: c.fn_current_name, in_loop: in_loop}

fn _cspan(c: Checker) -> Span {
    tok := _ccur(c)
    new_span(c.file, tok.line, tok.col, tok.offset, tok.text.len())
}

fn _cskip_nl(c: Checker) -> Checker {
    mut cc := c
    while _ck2(cc) == "NEWLINE" { cc = _cadv(cc) }
    cc
}

fn _cerror(c: Checker, code: str, msg: str) -> Checker {
    span := _cspan(c)
    _cset_diag(c, bag_add_error(c.diagnostics, code, msg, span))
}

fn _cwarning(c: Checker, code: str, msg: str) -> Checker {
    span := _cspan(c)
    _cset_diag(c, bag_add_warning(c.diagnostics, code, msg, span))
}

// --- Type environment ---

fn _env_add(c: Checker, name: str, type_id: i64, sc: i64) -> Checker =
    Checker{tokens: c.tokens, pos: c.pos, store: c.store, registry: c.registry,
            treg: c.treg, diagnostics: c.diagnostics, table: c.table,
            current_scope: c.current_scope, file: c.file, pool: c.pool,
            env_names: c.env_names.append(name),
            env_types: c.env_types.append(type_id),
            env_scopes: c.env_scopes.append(sc),
            fn_return_type: c.fn_return_type, fn_error_type: c.fn_error_type, fn_current_name: c.fn_current_name, in_loop: c.in_loop}

fn _env_lookup(c: Checker, name: str) -> i64 {
    // Walk backwards to find latest binding
    mut i := c.env_names.len() - 1
    while i > 0 {
        if c.env_names[i] == name {
            return c.env_types[i]
        }
        i = i - 1
    }
    TY_UNKNOWN
}

// --- Parse a type annotation from tokens, return type_id ---

fn _parse_type_ann(c: Checker) -> CE {
    k := _ck2(c)
    if k == "IDENT" {
        name := _ccur(c).text
        // Handle dyn Trait — trait object type
        if name == "dyn" {
            mut cc := _cadv(c)  // skip "dyn"
            if _ck2(cc) == "IDENT" {
                trait_name := _ccur(cc).text
                cc = _cadv(cc)
                // Object safety check: verify trait has no generic methods
                tdef := treg_find_trait(cc.treg, trait_name)
                if tdef.name == "" {
                    cc = _cerror(cc, E0301, "unknown trait '" + trait_name + "' in dyn")
                }
                new_st := store_add(cc.store, TypeInfo{kind: TyTraitObject, name: trait_name, type_id: 0, type_id2: 0, param_start: 0, param_count: 0})
                cc = _cset_store(cc, new_st)
                return CE{c: cc, type_id: store_last_id(cc.store)}
            }
            return CE{c: cc, type_id: TY_UNKNOWN}
        }
        mut cc := _cadv(c)
        // Check for qualified name: Type::Assoc (associated type resolution)
        if _ck2(cc) == ":" && cc.pos + 1 < cc.tokens.len() && token_name(cc.tokens[cc.pos + 1].kind) == ":" {
            cc = _cadv(_cadv(cc))  // skip ::
            if _ck2(cc) == "IDENT" {
                assoc_name := _ccur(cc).text
                cc = _cadv(cc)
                // Resolve Self::Assoc by looking up current impl type
                mut lookup_name := name + "_" + assoc_name
                if name == "Self" {
                    // Extract impl type from fn_current_name (e.g., "IntBox_get" → "IntBox")
                    mut impl_name := ""
                    mut ui := 0
                    while ui < cc.fn_current_name.len() {
                        ch := cc.fn_current_name.charAt(ui)
                        if ch == "_" { impl_name = cc.fn_current_name.substring(0, ui) }
                        ui = ui + 1
                    }
                    if impl_name != "" {
                        lookup_name = impl_name + "_" + assoc_name
                    }
                }
                tid := resolve_type_name(cc.store, lookup_name)
                if tid != TY_UNKNOWN {
                    // Follow the alias to the underlying type
                    ainfo := store_get(cc.store, tid)
                    if type_kind_name(ainfo.kind) == "Named" && ainfo.type_id > 0 {
                        return CE{c: cc, type_id: ainfo.type_id}
                    }
                    return CE{c: cc, type_id: tid}
                }
                // Fallback: return unknown
                return CE{c: cc, type_id: TY_UNKNOWN}
            }
        }
        // Check for generic type Name[T, U, ...]
        if _ck2(cc) == "[" {
            cc = _cadv(cc)  // skip [
            // Parse type arguments
            mut arg1 := TY_UNKNOWN
            mut arg2 := TY_UNKNOWN
            mut argc := 0
            while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
                pr := _parse_type_ann(cc)
                cc = pr.c
                if argc == 0 { arg1 = pr.type_id }
                if argc == 1 { arg2 = pr.type_id }
                argc = argc + 1
                if _ck2(cc) == "," { cc = _cadv(cc) }
            }
            if _ck2(cc) == "]" { cc = _cadv(cc) }
            // Construct specialized types for known generics
            if name == "Result" && argc >= 2 {
                new_store := store_add(cc.store, mk_result_type(arg1, arg2))
                cc = _cset_store(cc, new_store)
                return CE{c: cc, type_id: store_last_id(cc.store)}
            }
            if name == "Optional" && argc >= 1 {
                new_store := store_add(cc.store, mk_optional_type(arg1))
                cc = _cset_store(cc, new_store)
                return CE{c: cc, type_id: store_last_id(cc.store)}
            }
            // For other generic types (Map, user-defined), resolve base type
            tid := resolve_type_name(cc.store, name)
            return CE{c: cc, type_id: tid}
        }
        // Check for optional T?
        if _ck2(cc) == "?" {
            cc = _cadv(cc)
            inner := resolve_type_name(cc.store, name)
            new_store := store_add(cc.store, mk_optional_type(inner))
            cc = _cset_store(cc, new_store)
            return CE{c: cc, type_id: store_last_id(cc.store)}
        }
        // Check for result T ! E
        if _ck2(cc) == "!" {
            cc = _cadv(cc)
            ok_type := resolve_type_name(cc.store, name)
            err_result := _parse_type_ann(cc)
            cc = err_result.c
            new_store := store_add(cc.store, mk_result_type(ok_type, err_result.type_id))
            cc = _cset_store(cc, new_store)
            return CE{c: cc, type_id: store_last_id(cc.store)}
        }
        tid := resolve_type_name(cc.store, name)
        return CE{c: cc, type_id: tid}
    }
    if k == "[" {
        // Array type [T]
        mut cc := _cadv(c)
        elem := _parse_type_ann(cc)
        cc = elem.c
        if _ck2(cc) == "]" { cc = _cadv(cc) }
        new_store := store_add(cc.store, mk_array_type(elem.type_id))
        cc = _cset_store(cc, new_store)
        return CE{c: cc, type_id: store_last_id(cc.store)}
    }
    if k == "fn" {
        // Function type fn(A, B) -> R
        mut cc := _cadv(c)
        if _ck2(cc) == "(" {
            cc = _cadv(cc)
            while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
                pr := _parse_type_ann(cc)
                cc = pr.c
                if _ck2(cc) == "," { cc = _cadv(cc) }
            }
            if _ck2(cc) == ")" { cc = _cadv(cc) }
        }
        mut ret := TY_UNIT
        if _ck2(cc) == "->" {
            cc = _cadv(cc)
            rr := _parse_type_ann(cc)
            cc = rr.c
            ret = rr.type_id
        }
        return CE{c: cc, type_id: ret}
    }
    if k == "(" {
        // Tuple type (T1, T2, ...) or grouped type (T)
        mut cc := _cadv(c)
        mut elem_ids := ""
        mut arity := 0
        while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
            pr := _parse_type_ann(cc)
            cc = pr.c
            if arity > 0 { elem_ids = elem_ids + "," }
            elem_ids = elem_ids + i2s(pr.type_id)
            arity = arity + 1
            if _ck2(cc) == "," { cc = _cadv(cc) }
        }
        if _ck2(cc) == ")" { cc = _cadv(cc) }
        if arity <= 1 {
            // Grouped type (T) — not a tuple
            if arity == 1 {
                // Parse the single type id back out
                first_pr := _parse_type_ann(_cset_pos(c, c.pos + 1))
                return CE{c: cc, type_id: first_pr.type_id}
            }
            return CE{c: cc, type_id: TY_UNKNOWN}
        }
        new_store := store_add(cc.store, mk_tuple_type(elem_ids, arity))
        cc = _cset_store(cc, new_store)
        return CE{c: cc, type_id: store_last_id(cc.store)}
    }
    return CE{c: c, type_id: TY_UNKNOWN}
}

// --- Skip type tokens (without computing type) ---

fn _skip_type_toks(c: Checker) -> Checker {
    mut cc := c
    k := _ck2(cc)
    if k == "IDENT" || k == "Self" {
        cc = _cadv(cc)
        while _ck2(cc) == "." { cc = _cadv(_cadv(cc)) }
        if _ck2(cc) == "[" {
            mut d := 1
            cc = _cadv(cc)
            while d > 0 && _ck2(cc) != "EOF" {
                if _ck2(cc) == "[" { d = d + 1 }
                if _ck2(cc) == "]" { d = d - 1 }
                if d > 0 { cc = _cadv(cc) }
            }
            if _ck2(cc) == "]" { cc = _cadv(cc) }
        }
        if _ck2(cc) == "?" { cc = _cadv(cc) }
        if _ck2(cc) == "!" {
            cc = _cadv(cc)
            cc = _skip_type_toks(cc)
        }
        return cc
    }
    if k == "[" {
        cc = _cadv(cc)
        cc = _skip_type_toks(cc)
        if _ck2(cc) == "]" { cc = _cadv(cc) }
        return cc
    }
    if k == "fn" {
        cc = _cadv(cc)
        if _ck2(cc) == "(" {
            cc = _cadv(cc)
            while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
                cc = _skip_type_toks(cc)
                if _ck2(cc) == "," { cc = _cadv(cc) }
            }
            if _ck2(cc) == ")" { cc = _cadv(cc) }
        }
        if _ck2(cc) == "->" {
            cc = _cadv(cc)
            cc = _skip_type_toks(cc)
        }
        return cc
    }
    if k == "(" {
        cc = _cadv(cc)
        while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
            cc = _skip_type_toks(cc)
            if _ck2(cc) == "," { cc = _cadv(cc) }
        }
        if _ck2(cc) == ")" { cc = _cadv(cc) }
        if _ck2(cc) == "->" {
            cc = _cadv(cc)
            cc = _skip_type_toks(cc)
        }
        return cc
    }
    cc
}

// ============================================================
// Pass 1: Register type declarations
// ============================================================

fn _pass1_types(c: Checker, index: DeclIndex) -> Checker {
    mut cc := c
    mut di := 1
    while di < decl_index_len(index) {
        decl := decl_index_get(index, di)
        kname := decl_kind_name(decl.kind)

        if kname == "type" {
            cc = _cset_pos(cc, decl.token_start)
            if _ck2(cc) == "pub" { cc = _cadv(cc) }
            if decl.name.startsWith("_alias:") {
                // alias declaration
                cc = _register_alias_decl(cc)
            } else if decl.node_idx > 0 {
                // AST-based type registration
                cc = _register_type_decl_ast(cc, decl.node_idx)
            } else {
                // Legacy token-walk
                cc = _register_type_decl(cc)
            }
        } else if kname == "enum" {
            if decl.node_idx > 0 {
                cc = _register_enum_decl_ast(cc, decl.node_idx)
            } else {
                cc = _cset_pos(cc, decl.token_start)
                if _ck2(cc) == "pub" { cc = _cadv(cc) }
                cc = _register_enum_decl(cc)
            }
        }
        di = di + 1
    }
    cc
}

// Parse `derives [Trait1, Trait2]` clause and register trait impls
fn _parse_derives(c: Checker, type_name: str) -> Checker {
    if _ck2(c) != "derives" { return c }
    mut cc := _cadv(c)  // skip derives
    if _ck2(cc) != "[" { return cc }
    cc = _cadv(cc)  // skip [
    cc = _cskip_nl(cc)
    while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
        if _ck2(cc) == "IDENT" {
            tname := _ccur(cc).text
            cc = _cadv(cc)
            cc = _cset_treg(cc, treg_add_impl(cc.treg, _mk_impl(tname, type_name)))
        } else {
            cc = _cadv(cc)
        }
        cc = _cskip_nl(cc)
        if _ck2(cc) == "," { cc = _cadv(cc) }
        cc = _cskip_nl(cc)
    }
    if _ck2(cc) == "]" { cc = _cadv(cc) }
    // Enforce error category mutual exclusivity
    has_transient := treg_has_impl(cc.treg, type_name, "Transient")
    has_permanent := treg_has_impl(cc.treg, type_name, "Permanent")
    has_user := treg_has_impl(cc.treg, type_name, "UserFault")
    has_system := treg_has_impl(cc.treg, type_name, "SystemFault")
    if has_transient && has_permanent {
        cc = _cerror(cc, E0301, "type " + type_name + " cannot derive both Transient and Permanent")
    }
    if has_user && has_system {
        cc = _cerror(cc, E0301, "type " + type_name + " cannot derive both UserFault and SystemFault")
    }
    cc
}

fn _mk_newtype_def(name: str, underlying: i64) -> StructDef {
    mut fields := [FieldInfo{name: "", type_id: 0}]
    fields = fields.append(FieldInfo{name: "value", type_id: underlying})
    new_struct_def(name, fields, false, [""])
}

fn _register_alias_decl(c: Checker) -> Checker {
    mut cc := _cadv(c)  // skip alias
    if _ck2(cc) != "IDENT" { return cc }
    name := _ccur(cc).text
    cc = _cadv(cc)
    if _ck2(cc) == "=" { cc = _cadv(cc) }
    cc = _cskip_nl(cc)
    // Parse underlying type
    ft := _parse_type_ann(cc)
    cc = ft.c
    // Register alias as a named type pointing to the underlying type
    // The alias type_id field stores the underlying type's ID
    alias_info := TypeInfo{kind: TyNamed, name: name, type_id: ft.type_id, type_id2: 0, param_start: 0, param_count: 0}
    new_st := store_add(cc.store, alias_info)
    cc = _cset_store(cc, new_st)
    cc
}

// Parse generic params from s2 encoded string "T:Eq,U:Hash+Ord"
// Returns count and populates gp_0..2 / gb_0..2
fn _parse_generic_str(s: str, gp_0: str, gp_1: str, gp_2: str, gb_0: str, gb_1: str, gb_2: str) -> [str] {
    // Returns array: [count_str, gp_0, gp_1, gp_2, gb_0, gb_1, gb_2]
    slen := s.len()
    if slen == 0 {
        return ["0", "", "", "", "", "", ""]
    }
    mut count := 0
    mut r_gp_0 := ""
    mut r_gp_1 := ""
    mut r_gp_2 := ""
    mut r_gb_0 := ""
    mut r_gb_1 := ""
    mut r_gb_2 := ""
    // Split by commas, then each part by first colon
    mut seg_start := 0
    mut i := 0
    while i <= slen {
        mut is_sep := false
        if i == slen { is_sep = true }
        if is_sep == false {
            ch := s.charAt(i)
            if ch == "," { is_sep = true }
        }
        if is_sep {
            seg := s.substring(seg_start, i)
            // Split seg by first ':'
            mut gname := seg
            mut gbound := ""
            mut j := 0
            seglen := seg.len()
            mut found_colon := false
            while j < seglen {
                if found_colon == false {
                    sch := seg.charAt(j)
                    if sch == ":" {
                        gname = seg.substring(0, j)
                        gbound = seg.substring(j + 1, seglen)
                        found_colon = true
                    }
                }
                j = j + 1
            }
            if count == 0 { r_gp_0 = gname }
            if count == 0 { r_gb_0 = gbound }
            if count == 1 { r_gp_1 = gname }
            if count == 1 { r_gb_1 = gbound }
            if count == 2 { r_gp_2 = gname }
            if count == 2 { r_gb_2 = gbound }
            count = count + 1
            seg_start = i + 1
        }
        i = i + 1
    }
    [i2s(count), r_gp_0, r_gp_1, r_gp_2, r_gb_0, r_gb_1, r_gb_2]
}

fn _register_type_decl_ast(c: Checker, node_idx: i64) -> Checker {
    node := pool_get(c.pool, node_idx)
    name := node.s1
    mut cc := c

    // Parse generic params from s2
    gp_result := _parse_generic_str(node.s2, "", "", "", "", "", "")
    mut sgp_count := 0
    if gp_result[0] == "1" { sgp_count = 1 }
    if gp_result[0] == "2" { sgp_count = 2 }
    if gp_result[0] == "3" { sgp_count = 3 }
    sgp_0 := gp_result[1]
    sgp_1 := gp_result[2]
    sgp_2 := gp_result[3]

    // Register TypeVars
    if sgp_count > 0 {
        new_st := store_add(cc.store, mk_typevar(sgp_0))
        cc = _cset_store(cc, new_st)
    }
    if sgp_count > 1 {
        new_st := store_add(cc.store, mk_typevar(sgp_1))
        cc = _cset_store(cc, new_st)
    }
    if sgp_count > 2 {
        new_st := store_add(cc.store, mk_typevar(sgp_2))
        cc = _cset_store(cc, new_st)
    }

    lb := "\{"
    if node.b1 {
        // Sum type — iterate EkVariant children
        mut variants := [""]
        mut vf_counts := [0]
        mut vf_names := [""]
        mut vf_types := [0]
        mut vf_offsets := [0]
        mut flat_pos := 1
        mut vi := 0
        while vi < node.list_count {
            idx_node := pool_get(cc.pool, node.list_start + vi)
            vnode := pool_get(cc.pool, idx_node.c0)
            variants = variants.append(vnode.s1)
            vf_offsets = vf_offsets.append(flat_pos)
            mut field_count := 0
            // Iterate variant's EkField children
            mut fi := 0
            while fi < vnode.list_count {
                fidx_node := pool_get(cc.pool, vnode.list_start + fi)
                fnode := pool_get(cc.pool, fidx_node.c0)
                // Position to the type token and parse
                cc = _cset_pos(cc, fnode.c0)
                ft := _parse_type_ann(cc)
                cc = ft.c
                vf_names = vf_names.append(fnode.s1)
                vf_types = vf_types.append(ft.type_id)
                field_count = field_count + 1
                flat_pos = flat_pos + 1
                fi = fi + 1
            }
            vf_counts = vf_counts.append(field_count)
            vi = vi + 1
        }
        // Register as named type
        new_st := store_add(cc.store, mk_named_type(name))
        cc = _cset_store(cc, new_st)
        def := new_sum_def(name, variants, vf_counts, vf_names, vf_types, vf_offsets)
        cc = _cset_reg(cc, reg_add_struct(cc.registry, def))
        // Handle derives — use token-walk to find derives after the type body
        cc = _cset_pos(cc, c.pos)
        cc = _scan_to_derives(cc)
        cc = _parse_derives(cc, name)
        return cc
    }

    // Check for newtype (c0 > 0 and not sum)
    if node.c0 > 0 && node.list_count == 0 {
        // Newtype: type Name = Type
        cc = _cset_pos(cc, node.c0)
        ft := _parse_type_ann(cc)
        cc = ft.c
        new_st := store_add(cc.store, mk_named_type(name))
        cc = _cset_store(cc, new_st)
        def := _mk_newtype_def(name, ft.type_id)
        cc = _cset_reg(cc, reg_add_struct(cc.registry, def))
        return cc
    }

    // Struct — iterate EkField children
    mut fields := [FieldInfo{name: "", type_id: 0}]
    mut fi := 0
    while fi < node.list_count {
        idx_node := pool_get(cc.pool, node.list_start + fi)
        fnode := pool_get(cc.pool, idx_node.c0)
        cc = _cset_pos(cc, fnode.c0)
        ft := _parse_type_ann(cc)
        cc = ft.c
        fields = fields.append(FieldInfo{name: fnode.s1, type_id: ft.type_id})
        fi = fi + 1
    }
    new_st := store_add(cc.store, mk_named_type(name))
    cc = _cset_store(cc, new_st)
    mut def := new_struct_def(name, fields, false, [""])
    if sgp_count > 0 {
        def = new_generic_struct_def(name, fields, sgp_count, sgp_0, sgp_1, sgp_2)
    }
    cc = _cset_reg(cc, reg_add_struct(cc.registry, def))
    // Handle derives
    cc = _cset_pos(cc, c.pos)
    cc = _scan_to_derives(cc)
    cc = _parse_derives(cc, name)
    cc
}

// Scan forward from current position past a type declaration to find "derives"
fn _scan_to_derives(c: Checker) -> Checker {
    mut cc := c
    lb := "\{"
    rb := "\}"
    // Skip type/struct keyword and name
    if _ck2(cc) == "type" || _ck2(cc) == "struct" { cc = _cadv(cc) }
    if _ck2(cc) == "IDENT" { cc = _cadv(cc) }
    // Skip generic params
    if _ck2(cc) == "[" {
        cc = _cadv(cc)
        mut depth := 1
        while depth > 0 && _ck2(cc) != "EOF" {
            if _ck2(cc) == "[" { depth = depth + 1 }
            if _ck2(cc) == "]" { depth = depth - 1 }
            if depth > 0 { cc = _cadv(cc) }
        }
        if _ck2(cc) == "]" { cc = _cadv(cc) }
    }
    // Skip = if present
    if _ck2(cc) == "=" { cc = _cadv(cc) }
    cc = _cskip_nl(cc)
    // Skip sum type variants or braced body
    if _ck2(cc) == "|" {
        while _ck2(cc) == "|" {
            cc = _cadv(cc)
            cc = _cskip_nl(cc)
            if _ck2(cc) == "IDENT" { cc = _cadv(cc) }
            if _ck2(cc) == "(" {
                cc = _cadv(cc)
                mut depth := 1
                while depth > 0 && _ck2(cc) != "EOF" {
                    if _ck2(cc) == "(" { depth = depth + 1 }
                    if _ck2(cc) == ")" { depth = depth - 1 }
                    if depth > 0 { cc = _cadv(cc) }
                }
                if _ck2(cc) == ")" { cc = _cadv(cc) }
            } else if _ck2(cc) == lb {
                cc = _skip_braces2(cc)
            }
            cc = _cskip_nl(cc)
        }
    } else if _ck2(cc) == lb {
        cc = _skip_braces2(cc)
    } else {
        // Newtype — skip underlying type (one line)
        while _ck2(cc) != "NEWLINE" && _ck2(cc) != "EOF" && _ck2(cc) != "derives" {
            cc = _cadv(cc)
        }
    }
    cc = _cskip_nl(cc)
    cc
}

fn _register_type_decl(c: Checker) -> Checker {
    mut cc := _cadv(c)  // skip type/struct
    if _ck2(cc) != "IDENT" { return cc }
    name := _ccur(cc).text
    cc = _cadv(cc)

    // Capture generic params
    mut sgp_count := 0
    mut sgp_0 := ""
    mut sgp_1 := ""
    mut sgp_2 := ""
    if _ck2(cc) == "[" {
        cc = _cadv(cc)  // skip [
        while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
            if _ck2(cc) == "IDENT" {
                gname := _ccur(cc).text
                if sgp_count == 0 { sgp_0 = gname }
                if sgp_count == 1 { sgp_1 = gname }
                if sgp_count == 2 { sgp_2 = gname }
                sgp_count = sgp_count + 1
                cc = _cadv(cc)
                // Skip optional trait bound ": Trait"
                if _ck2(cc) == ":" {
                    cc = _cadv(cc)
                    if _ck2(cc) == "IDENT" { cc = _cadv(cc) }
                }
            } else {
                cc = _cadv(cc)
            }
            if _ck2(cc) == "," { cc = _cadv(cc) }
        }
        if _ck2(cc) == "]" { cc = _cadv(cc) }
    }

    // If generic, add TypeVar entries to the store
    if sgp_count > 0 {
        new_st := store_add(cc.store, mk_typevar(sgp_0))
        cc = _cset_store(cc, new_st)
    }
    if sgp_count > 1 {
        new_st := store_add(cc.store, mk_typevar(sgp_1))
        cc = _cset_store(cc, new_st)
    }
    if sgp_count > 2 {
        new_st := store_add(cc.store, mk_typevar(sgp_2))
        cc = _cset_store(cc, new_st)
    }

    lb := "\{"
    // Check for sum type (= | Variant ...) or newtype (= Type)
    if _ck2(cc) == "=" {
        cc = _cadv(cc)
        cc = _cskip_nl(cc)
        if _ck2(cc) == "|" {
            // Sum type — parse variants and their data fields
            mut variants := [""]
            mut vf_counts := [0]
            mut vf_names := [""]
            mut vf_types := [0]
            mut vf_offsets := [0]
            mut flat_pos := 1  // next insert position in vf_names/vf_types
            while _ck2(cc) == "|" {
                cc = _cadv(cc)
                cc = _cskip_nl(cc)
                if _ck2(cc) == "IDENT" {
                    variants = variants.append(_ccur(cc).text)
                    cc = _cadv(cc)
                }
                // Parse tuple payload: Variant(Type, Type, ...)
                vf_offsets = vf_offsets.append(flat_pos)
                mut field_count := 0
                if _ck2(cc) == "(" {
                    cc = _cadv(cc)  // skip (
                    cc = _cskip_nl(cc)
                    mut fi := 0
                    while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
                        // Check if this is Name: Type (struct-variant) or just Type (tuple-variant)
                        // For tuple variants, auto-generate field names: _0, _1, ...
                        ft := _parse_type_ann(cc)
                        cc = ft.c
                        vf_names = vf_names.append("_" + i2s(fi))
                        vf_types = vf_types.append(ft.type_id)
                        field_count = field_count + 1
                        flat_pos = flat_pos + 1
                        fi = fi + 1
                        cc = _cskip_nl(cc)
                        if _ck2(cc) == "," { cc = _cadv(cc) }
                        cc = _cskip_nl(cc)
                    }
                    if _ck2(cc) == ")" { cc = _cadv(cc) }
                }
                // Parse struct payload: Variant{name: Type, ...}
                if _ck2(cc) == lb {
                    cc = _cadv(cc)  // skip {
                    cc = _cskip_nl(cc)
                    rb := "\}"
                    while _ck2(cc) != rb && _ck2(cc) != "EOF" {
                        if _ck2(cc) == "IDENT" {
                            fname := _ccur(cc).text
                            cc = _cadv(cc)
                            if _ck2(cc) == ":" {
                                cc = _cadv(cc)
                                ft := _parse_type_ann(cc)
                                cc = ft.c
                                vf_names = vf_names.append(fname)
                                vf_types = vf_types.append(ft.type_id)
                                field_count = field_count + 1
                                flat_pos = flat_pos + 1
                            }
                        } else {
                            cc = _cadv(cc)
                        }
                        cc = _cskip_nl(cc)
                        if _ck2(cc) == "," { cc = _cadv(cc) }
                        cc = _cskip_nl(cc)
                    }
                    if _ck2(cc) == rb { cc = _cadv(cc) }
                }
                vf_counts = vf_counts.append(field_count)
                cc = _cskip_nl(cc)
            }
            // Register as named type
            new_st := store_add(cc.store, mk_named_type(name))
            cc = _cset_store(cc, new_st)
            def := new_sum_def(name, variants, vf_counts, vf_names, vf_types, vf_offsets)
            cc = _cset_reg(cc, reg_add_struct(cc.registry, def))
            cc = _cskip_nl(cc)
            cc = _parse_derives(cc, name)
            return cc
        }
        // Newtype: type Name = UnderlyingType
        // RHS is a type annotation (not | and not {)
        if _ck2(cc) != lb {
            ft := _parse_type_ann(cc)
            cc = ft.c
            // Register as named type with a single "value" field
            new_st := store_add(cc.store, mk_named_type(name))
            cc = _cset_store(cc, new_st)
            def := _mk_newtype_def(name, ft.type_id)
            cc = _cset_reg(cc, reg_add_struct(cc.registry, def))
            return cc
        }
    }

    // Struct type { fields }
    if _ck2(cc) == lb {
        cc = _cadv(cc)  // skip {
        cc = _cskip_nl(cc)
        mut fields := [FieldInfo{name: "", type_id: 0}]
        rb := "\}"
        while _ck2(cc) != rb && _ck2(cc) != "EOF" {
            if _ck2(cc) == "IDENT" {
                fname := _ccur(cc).text
                cc = _cadv(cc)
                if _ck2(cc) == ":" {
                    cc = _cadv(cc)
                    ft := _parse_type_ann(cc)
                    cc = ft.c
                    fields = fields.append(FieldInfo{name: fname, type_id: ft.type_id})
                }
            } else {
                cc = _cadv(cc)
            }
            cc = _cskip_nl(cc)
            if _ck2(cc) == "," { cc = _cadv(cc) }
            cc = _cskip_nl(cc)
        }
        if _ck2(cc) == rb { cc = _cadv(cc) }

        new_st := store_add(cc.store, mk_named_type(name))
        cc = _cset_store(cc, new_st)
        mut def := new_struct_def(name, fields, false, [""])
        if sgp_count > 0 {
            def = new_generic_struct_def(name, fields, sgp_count, sgp_0, sgp_1, sgp_2)
        }
        cc = _cset_reg(cc, reg_add_struct(cc.registry, def))
        // Check for derives clause
        cc = _cskip_nl(cc)
        cc = _parse_derives(cc, name)
    }
    cc
}

fn _register_enum_decl_ast(c: Checker, node_idx: i64) -> Checker {
    node := pool_get(c.pool, node_idx)
    name := node.s1
    mut cc := c
    new_st := store_add(cc.store, mk_named_type(name))
    cc = _cset_store(cc, new_st)
    def := new_struct_def(name, [FieldInfo{name: "", type_id: 0}], false, [""])
    cc = _cset_reg(cc, reg_add_struct(cc.registry, def))
    cc
}

fn _register_enum_decl(c: Checker) -> Checker {
    mut cc := _cadv(c)  // skip enum
    if _ck2(cc) != "IDENT" { return cc }
    name := _ccur(cc).text
    cc = _cadv(cc)
    // Skip brace block
    cc = _skip_braces2(cc)
    new_st := store_add(cc.store, mk_named_type(name))
    cc = _cset_store(cc, new_st)
    def := new_struct_def(name, [FieldInfo{name: "", type_id: 0}], false, [""])
    cc = _cset_reg(cc, reg_add_struct(cc.registry, def))
    cc
}

fn _skip_braces2(c: Checker) -> Checker {
    lb := "\{"
    rb := "\}"
    if _ck2(c) != lb { return c }
    mut cc := _cadv(c)
    mut d := 1
    while d > 0 && _ck2(cc) != "EOF" {
        if _ck2(cc) == lb { d = d + 1 }
        if _ck2(cc) == rb { d = d - 1 }
        if d > 0 { cc = _cadv(cc) }
    }
    if _ck2(cc) == rb { cc = _cadv(cc) }
    return cc
}

// ============================================================
// Pass 2: Register function signatures
// ============================================================

fn _pass2_fns(c: Checker, index: DeclIndex) -> Checker {
    mut cc := c
    mut di := 1
    while di < decl_index_len(index) {
        decl := decl_index_get(index, di)
        kname := decl_kind_name(decl.kind)

        cc = _cset_pos(cc, decl.token_start)
        if _ck2(cc) == "pub" { cc = _cadv(cc) }

        // Parse annotations before declarations
        mut ann_deprecated := ""
        mut ann_cold := false
        if _ck2(cc) == "@" {
            cc = _cadv(cc)  // skip @
            if _ck2(cc) == "IDENT" {
                ann_name := _ccur(cc).text
                cc = _cadv(cc)
                if ann_name == "deprecated" {
                    if _ck2(cc) == "(" {
                        cc = _cadv(cc)
                        if _ck2(cc) == "STRING" {
                            ann_deprecated = _ccur(cc).text
                            cc = _cadv(cc)
                        }
                        if _ck2(cc) == ")" { cc = _cadv(cc) }
                    }
                    if ann_deprecated == "" { ann_deprecated = "deprecated" }
                }
                if ann_name == "cold" { ann_cold = true }
                if _ck2(cc) == "(" {
                    cc = _cadv(cc)
                    while _ck2(cc) != ")" && _ck2(cc) != "EOF" { cc = _cadv(cc) }
                    if _ck2(cc) == ")" { cc = _cadv(cc) }
                }
            }
            cc = _cskip_nl(cc)
        }

        if kname == "fn" {
            if decl.name == "_extern" {
                cc = _register_extern(cc)
            } else if decl.name.startsWith("_fixture:") {
                // before/after fixtures — no signature registration needed
                mut _skip := 0
            } else {
                // Regular function — register annotations and signature
                next_pos := cc.pos + 1
                if next_pos < cc.tokens.len() && token_name(cc.tokens[next_pos].kind) == "IDENT" {
                    fn_name := cc.tokens[next_pos].text
                    if ann_deprecated != "" {
                        cc = _cset_reg(cc, reg_add_deprecated(cc.registry, fn_name, ann_deprecated))
                    }
                    if ann_cold {
                        cc = _cset_reg(cc, reg_add_cold(cc.registry, fn_name))
                    }
                }
                if decl.node_idx > 0 {
                    cc = _register_fn_sig_ast(cc, decl.node_idx, decl.token_start)
                } else {
                    cc = _register_fn_sig(cc)
                }
            }
        } else if kname == "impl" {
            cc = _register_impl_fns(cc, decl.node_idx)
        } else if kname == "trait" {
            if decl.node_idx > 0 {
                cc = _register_trait_decl_ast(cc, decl.node_idx)
            } else {
                cc = _register_trait_decl(cc)
            }
        } else if kname == "const" {
            if decl.node_idx > 0 {
                cc = _register_const_ast(cc, decl.node_idx)
            } else {
                cc = _register_const(cc)
            }
        }
        // type, enum, entry, test, use — skip in pass2

        di = di + 1
    }
    cc
}

fn _register_extern(c: Checker) -> Checker {
    mut cc := _cadv(c)  // skip extern
    lb := "\{"
    rb := "\}"
    // Skip optional library name string
    if _ck2(cc) == "STRING" { cc = _cadv(cc) }
    // Block form: extern "lib" { fn ...; fn ...; }
    if _ck2(cc) == lb {
        cc = _cadv(cc)  // skip {
        cc = _cskip_nl(cc)
        while _ck2(cc) != rb && _ck2(cc) != "EOF" {
            cc = _cskip_nl(cc)
            if _ck2(cc) == "fn" {
                cc = _register_fn_sig(cc)
            } else {
                cc = _cadv(cc)
            }
            cc = _cskip_nl(cc)
        }
        if _ck2(cc) == rb { cc = _cadv(cc) }
        return cc
    }
    // Single form: extern fn name(...)
    if _ck2(cc) == "fn" {
        cc = _register_fn_sig(cc)
    }
    cc
}

// AST-based trait declaration registration
fn _register_trait_decl_ast(c: Checker, node_idx: i64) -> Checker {
    node := pool_get(c.pool, node_idx)
    trait_name := node.s1
    mut cc := c

    // Parse s2 for supertraits and associated types
    // Format: "ParentA,ParentB;AssocType1,AssocType2" (separated by ";")
    s2val := node.s2
    s2len := s2val.len()
    mut parents := [""]
    mut assoc_types := [""]

    // Find the ";" separator
    mut semi_pos := -1
    mut si := 0
    while si < s2len {
        ch := s2val.charAt(si)
        if ch == ";" { semi_pos = si }
        si = si + 1
    }

    // Parse supertraits (before ";")
    mut super_str := s2val
    if semi_pos >= 0 {
        super_str = s2val.substring(0, semi_pos)
        // Parse associated types (after ";")
        assoc_str := s2val.substring(semi_pos + 1, s2len)
        alen := assoc_str.len()
        if alen > 0 {
            mut astart := 0
            mut ai := 0
            while ai <= alen {
                mut is_sep := false
                if ai == alen { is_sep = true }
                if is_sep == false {
                    ach := assoc_str.charAt(ai)
                    if ach == "," { is_sep = true }
                }
                if is_sep {
                    if ai > astart {
                        assoc_types = assoc_types.append(assoc_str.substring(astart, ai))
                    }
                    astart = ai + 1
                }
                ai = ai + 1
            }
        }
    }
    // Parse supertrait names from super_str
    slen := super_str.len()
    if slen > 0 {
        mut pstart := 0
        mut pi := 0
        while pi <= slen {
            mut is_sep := false
            if pi == slen { is_sep = true }
            if is_sep == false {
                pch := super_str.charAt(pi)
                if pch == "," { is_sep = true }
            }
            if is_sep {
                if pi > pstart {
                    parents = parents.append(super_str.substring(pstart, pi))
                }
                pstart = pi + 1
            }
            pi = pi + 1
        }
    }

    // Collect method names from FnDecl children
    mut mnames := [""]
    mut mi := 0
    while mi < node.list_count {
        midx_node := pool_get(cc.pool, node.list_start + mi)
        method_node := pool_get(cc.pool, midx_node.c0)
        mnames = mnames.append(method_node.s1)
        mi = mi + 1
    }

    // Register trait
    tdef := TraitDef{name: trait_name, method_names: mnames, parent_traits: parents, assoc_type_names: assoc_types, default_starts: [0], default_ends: [0]}
    cc = _cset_treg(cc, treg_add_trait(cc.treg, tdef))
    cc
}

fn _register_trait_decl(c: Checker) -> Checker {
    mut cc := _cadv(c)  // skip trait
    if _ck2(cc) != "IDENT" { return cc }
    trait_name := _ccur(cc).text
    cc = _cadv(cc)
    lb := "\{"
    rb := "\}"
    // Parse supertrait clause: trait B: A, C {
    mut parents := [""]
    if _ck2(cc) == ":" {
        cc = _cadv(cc)  // skip :
        mut parsing_parents := true
        while parsing_parents {
            if _ck2(cc) == "IDENT" {
                parents = parents.append(_ccur(cc).text)
                cc = _cadv(cc)
                if _ck2(cc) == "," { cc = _cadv(cc) } else { parsing_parents = false }
            } else {
                parsing_parents = false
            }
        }
    }
    // Skip to opening brace
    while _ck2(cc) != lb && _ck2(cc) != "EOF" { cc = _cadv(cc) }
    if _ck2(cc) != lb { return cc }
    cc = _cadv(cc)  // skip {
    cc = _cskip_nl(cc)
    // Collect method names and associated types
    mut method_name_0 := ""
    mut method_name_1 := ""
    mut method_name_2 := ""
    mut method_name_3 := ""
    mut method_count := 0
    mut assoc_types := [""]
    while _ck2(cc) != rb && _ck2(cc) != "EOF" {
        cc = _cskip_nl(cc)
        if _ck2(cc) == "fn" {
            cc = _cadv(cc)  // skip fn
            if _ck2(cc) == "IDENT" {
                mname := _ccur(cc).text
                if method_count == 0 { method_name_0 = mname }
                if method_count == 1 { method_name_1 = mname }
                if method_count == 2 { method_name_2 = mname }
                if method_count == 3 { method_name_3 = mname }
                method_count = method_count + 1
            }
            // Skip to end of method signature
            while _ck2(cc) != "NEWLINE" && _ck2(cc) != rb && _ck2(cc) != "EOF" {
                if _ck2(cc) == lb {
                    cc = _skip_braces2(cc)
                } else {
                    cc = _cadv(cc)
                }
            }
        } else if _ck2(cc) == "type" {
            // Associated type declaration: type Name or type Name = Type
            cc = _cadv(cc)  // skip type
            if _ck2(cc) == "IDENT" {
                assoc_types = assoc_types.append(_ccur(cc).text)
            }
            // Skip the rest of the associated type declaration
            while _ck2(cc) != "NEWLINE" && _ck2(cc) != rb && _ck2(cc) != "EOF" {
                cc = _cadv(cc)
            }
        } else if _ck2(cc) == rb || _ck2(cc) == "EOF" {
            // done
        } else {
            cc = _cadv(cc)
        }
        cc = _cskip_nl(cc)
    }
    if _ck2(cc) == rb { cc = _cadv(cc) }
    // Build method names list
    mut mnames := [""]
    if method_count > 0 { mnames = mnames.append(method_name_0) }
    if method_count > 1 { mnames = mnames.append(method_name_1) }
    if method_count > 2 { mnames = mnames.append(method_name_2) }
    if method_count > 3 { mnames = mnames.append(method_name_3) }
    // Register trait
    tdef := TraitDef{name: trait_name, method_names: mnames, parent_traits: parents, assoc_type_names: assoc_types, default_starts: [0], default_ends: [0]}
    cc = _cset_treg(cc, treg_add_trait(cc.treg, tdef))
    cc
}

// AST-based function signature registration
fn _register_fn_sig_ast(c: Checker, node_idx: i64, token_start: i64) -> Checker {
    node := pool_get(c.pool, node_idx)
    name := node.s1
    mut cc := c

    // Parse generic params from s2
    gp_result := _parse_generic_str(node.s2, "", "", "", "", "", "")
    mut gp_count := 0
    if gp_result[0] == "1" { gp_count = 1 }
    if gp_result[0] == "2" { gp_count = 2 }
    if gp_result[0] == "3" { gp_count = 3 }
    gp_0 := gp_result[1]
    gp_1 := gp_result[2]
    gp_2 := gp_result[3]
    // Split bounds from gp_result — bounds contain "+" separators
    gb_0 := gp_result[4]
    gb_1 := gp_result[5]
    gb_2 := gp_result[6]

    // Register TypeVars
    if gp_count > 0 {
        new_st := store_add(cc.store, mk_typevar(gp_0))
        cc = _cset_store(cc, new_st)
    }
    if gp_count > 1 {
        new_st := store_add(cc.store, mk_typevar(gp_1))
        cc = _cset_store(cc, new_st)
    }
    if gp_count > 2 {
        new_st := store_add(cc.store, mk_typevar(gp_2))
        cc = _cset_store(cc, new_st)
    }

    // Parse parameters from EkParam index nodes
    mut pnames := [""]
    mut ptypes := [0]
    mut pi := 0
    while pi < node.list_count {
        pidx_node := pool_get(cc.pool, node.list_start + pi)
        pnode := pool_get(cc.pool, pidx_node.c0)
        if pnode.b1 {
            // self parameter — skip type (resolved later in impl context)
            pnames = pnames.append("self")
            ptypes = ptypes.append(TY_UNKNOWN)
        } else {
            pnames = pnames.append(pnode.s1)
            cc = _cset_pos(cc, pnode.c0)
            pt := _parse_type_ann(cc)
            cc = pt.c
            ptypes = ptypes.append(pt.type_id)
        }
        pi = pi + 1
    }

    // Return type
    mut ret := TY_UNIT
    mut err := 0
    if node.b2 {
        cc = _cset_pos(cc, node.c1)
        rt := _parse_type_ann(cc)
        cc = rt.c
        rtinfo := store_get(cc.store, rt.type_id)
        if type_kind_name(rtinfo.kind) == "Result" {
            ret = rtinfo.type_id
            err = rtinfo.type_id2
        } else {
            ret = rt.type_id
        }
    }

    // Error type
    if err == 0 && node.c2 > 0 {
        cc = _cset_pos(cc, node.c2)
        et := _parse_type_ann(cc)
        cc = et.c
        err = et.type_id
    }

    // Parse effect clause — need to token-walk for with/where
    // Position after the signature in tokens
    cc = _cset_pos(cc, token_start)
    mut eff_io := false
    mut eff_fs := false
    mut eff_net := false
    mut eff_ffi := false
    mut eff_async := false
    // Scan forward to find "with" clause
    lb := "\{"
    mut scan_limit := 0
    while _ck2(cc) != "=" && _ck2(cc) != lb && _ck2(cc) != "EOF" && scan_limit < 200 {
        if _ck2(cc) == "with" {
            cc = _cadv(cc)  // skip with
            if _ck2(cc) == "[" {
                cc = _cadv(cc)  // skip [
                while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
                    if _ck2(cc) == "IDENT" {
                        eff := _ccur(cc).text
                        if eff == "Io" { eff_io = true }
                        if eff == "Fs" { eff_fs = true }
                        if eff == "Net" { eff_net = true }
                        if eff == "Ffi" { eff_ffi = true }
                        if eff == "Async" { eff_async = true }
                        cc = _cadv(cc)
                    } else {
                        cc = _cadv(cc)
                    }
                    if _ck2(cc) == "," { cc = _cadv(cc) }
                }
                if _ck2(cc) == "]" { cc = _cadv(cc) }
            }
        }
        // Parse where clause
        if _ck2(cc) == "where" {
            cc = _cadv(cc)
            mut parsing_where := true
            while parsing_where {
                if _ck2(cc) == "IDENT" {
                    wname := _ccur(cc).text
                    cc = _cadv(cc)
                    if _ck2(cc) == ":" {
                        cc = _cadv(cc)
                        if _ck2(cc) == "IDENT" {
                            mut wbound := _ccur(cc).text
                            cc = _cadv(cc)
                            while _ck2(cc) == "+" {
                                cc = _cadv(cc)
                                if _ck2(cc) == "IDENT" {
                                    wbound = wbound + "+" + _ccur(cc).text
                                    cc = _cadv(cc)
                                }
                            }
                            // These are already captured in s2; but where clause may add extra bounds
                            // For now, we only handle where clause bounds via token walk
                            mut _skip := 0
                        }
                    }
                    if _ck2(cc) == "," { cc = _cadv(cc) } else { parsing_where = false }
                } else {
                    parsing_where = false
                }
            }
        }
        cc = _cadv(cc)
        scan_limit = scan_limit + 1
    }

    mut sig := new_fn_sig(name, pnames, ptypes, ret, err)
    if gp_count > 0 {
        sig = new_generic_fn_sig(name, pnames, ptypes, ret, err, gp_count, gp_0, gp_1, gp_2, gb_0, gb_1, gb_2, token_start)
    }
    if eff_io || eff_fs || eff_net || eff_ffi || eff_async {
        sig = sig_set_effects(sig, eff_io, eff_fs, eff_net, eff_ffi, eff_async)
    }
    cc = _cset_reg(cc, reg_add_fn(cc.registry, sig))
    cc
}

// AST-based impl method signature registration
fn _register_impl_fn_sig_ast(c: Checker, impl_type: str, method_idx: i64) -> Checker {
    node := pool_get(c.pool, method_idx)
    raw_name := node.s1
    name := impl_type + "_" + raw_name
    mut cc := c

    // Parse generic params from s2
    gp_result := _parse_generic_str(node.s2, "", "", "", "", "", "")
    mut gp_count := 0
    if gp_result[0] == "1" { gp_count = 1 }
    if gp_result[0] == "2" { gp_count = 2 }
    if gp_result[0] == "3" { gp_count = 3 }
    gp_0 := gp_result[1]
    gp_1 := gp_result[2]
    gp_2 := gp_result[3]
    gb_0 := gp_result[4]
    gb_1 := gp_result[5]
    gb_2 := gp_result[6]

    // Register TypeVars
    if gp_count > 0 {
        new_st := store_add(cc.store, mk_typevar(gp_0))
        cc = _cset_store(cc, new_st)
    }
    if gp_count > 1 {
        new_st := store_add(cc.store, mk_typevar(gp_1))
        cc = _cset_store(cc, new_st)
    }
    if gp_count > 2 {
        new_st := store_add(cc.store, mk_typevar(gp_2))
        cc = _cset_store(cc, new_st)
    }

    // Parse parameters
    mut pnames := [""]
    mut ptypes := [0]
    mut pi := 0
    while pi < node.list_count {
        pidx_node := pool_get(cc.pool, node.list_start + pi)
        pnode := pool_get(cc.pool, pidx_node.c0)
        if pnode.b1 {
            // self parameter — resolve to impl type
            pnames = pnames.append("self")
            self_type := resolve_type_name(cc.store, impl_type)
            ptypes = ptypes.append(self_type)
        } else {
            pnames = pnames.append(pnode.s1)
            cc = _cset_pos(cc, pnode.c0)
            pt := _parse_type_ann(cc)
            cc = pt.c
            ptypes = ptypes.append(pt.type_id)
        }
        pi = pi + 1
    }

    // Return type
    mut ret := TY_UNIT
    mut err := 0
    if node.b2 {
        cc = _cset_pos(cc, node.c1)
        rt := _parse_type_ann(cc)
        cc = rt.c
        rtinfo := store_get(cc.store, rt.type_id)
        if type_kind_name(rtinfo.kind) == "Result" {
            ret = rtinfo.type_id
            err = rtinfo.type_id2
        } else {
            ret = rt.type_id
        }
    }

    // Error type
    if err == 0 && node.c2 > 0 {
        cc = _cset_pos(cc, node.c2)
        et := _parse_type_ann(cc)
        cc = et.c
        err = et.type_id
    }

    // Effects and where clause — token walk not needed for impl methods
    // (effects on impl methods are rare; add if needed)

    mut sig := new_fn_sig(name, pnames, ptypes, ret, err)
    if gp_count > 0 {
        // For impl methods, token_start is the fn keyword position
        // We don't have it directly from AST, but we can use 0 as fallback
        sig = new_generic_fn_sig(name, pnames, ptypes, ret, err, gp_count, gp_0, gp_1, gp_2, gb_0, gb_1, gb_2, 0)
    }
    cc = _cset_reg(cc, reg_add_fn(cc.registry, sig))
    cc
}

fn _is_fn_name_kind(tk: str) -> bool {
    if tk == "IDENT" { return true }
    if tk == "test" { return true }
    if tk == "check" { return true }
    if tk == "match" { return true }
    if tk == "type" { return true }
    if tk == "where" { return true }
    if tk == "bench" { return true }
    return false
}

fn _register_fn_sig(c: Checker) -> Checker {
    token_start := c.pos  // save position of 'fn' keyword for re-lowering
    mut cc := _cadv(c)  // skip fn
    if _is_fn_name_kind(_ck2(cc)) == false { return cc }
    name := _ccur(cc).text
    cc = _cadv(cc)

    // Capture generic params and trait bounds
    mut gp_count := 0
    mut gp_0 := ""
    mut gp_1 := ""
    mut gp_2 := ""
    mut gb_0 := ""
    mut gb_1 := ""
    mut gb_2 := ""
    if _ck2(cc) == "[" {
        cc = _cadv(cc)  // skip [
        while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
            if _ck2(cc) == "IDENT" {
                gname := _ccur(cc).text
                if gp_count == 0 { gp_0 = gname }
                if gp_count == 1 { gp_1 = gname }
                if gp_count == 2 { gp_2 = gname }
                cc = _cadv(cc)
                // Capture optional trait bound ": Trait" or ": Trait + Trait2"
                if _ck2(cc) == ":" {
                    cc = _cadv(cc)
                    if _ck2(cc) == "IDENT" {
                        mut bname := _ccur(cc).text
                        cc = _cadv(cc)
                        // Multi-bound: T: Eq + Hash + ...
                        while _ck2(cc) == "+" {
                            cc = _cadv(cc)  // skip +
                            if _ck2(cc) == "IDENT" {
                                bname = bname + "+" + _ccur(cc).text
                                cc = _cadv(cc)
                            }
                        }
                        if gp_count == 0 { gb_0 = bname }
                        if gp_count == 1 { gb_1 = bname }
                        if gp_count == 2 { gb_2 = bname }
                    }
                }
                gp_count = gp_count + 1
            } else {
                cc = _cadv(cc)
            }
            if _ck2(cc) == "," { cc = _cadv(cc) }
        }
        if _ck2(cc) == "]" { cc = _cadv(cc) }
    }

    // If generic, add TypeVar entries to the store so _parse_type_ann resolves them
    if gp_count > 0 {
        new_st := store_add(cc.store, mk_typevar(gp_0))
        cc = _cset_store(cc, new_st)
    }
    if gp_count > 1 {
        new_st := store_add(cc.store, mk_typevar(gp_1))
        cc = _cset_store(cc, new_st)
    }
    if gp_count > 2 {
        new_st := store_add(cc.store, mk_typevar(gp_2))
        cc = _cset_store(cc, new_st)
    }

    // Parse parameters — accept both IDENT and keyword tokens as parameter names
    // (keywords like before, after, where, scope can be used as param names)
    mut pnames := [""]
    mut ptypes := [0]
    if _ck2(cc) == "(" {
        cc = _cadv(cc)
        while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
            // Check if current token is followed by ":" — if so, treat as param name
            mut is_param := _ck2(cc) == "IDENT" || _ck2(cc) == "self"
            if is_param == false && cc.pos + 1 < cc.tokens.len() {
                if token_name(cc.tokens[cc.pos + 1].kind) == ":" {
                    is_param = true
                }
            }
            if is_param {
                pn := _ccur(cc).text
                cc = _cadv(cc)
                if _ck2(cc) == ":" {
                    cc = _cadv(cc)
                    pt := _parse_type_ann(cc)
                    cc = pt.c
                    pnames = pnames.append(pn)
                    ptypes = ptypes.append(pt.type_id)
                }
            } else {
                cc = _cadv(cc)
            }
            if _ck2(cc) == "," { cc = _cadv(cc) }
        }
        if _ck2(cc) == ")" { cc = _cadv(cc) }
    }

    // Return type (may include ! ErrorType parsed by _parse_type_ann)
    mut ret := TY_UNIT
    mut err := 0
    if _ck2(cc) == "->" {
        cc = _cadv(cc)
        rt := _parse_type_ann(cc)
        cc = rt.c
        // Check if _parse_type_ann already consumed T ! E
        rtinfo := store_get(cc.store, rt.type_id)
        if type_kind_name(rtinfo.kind) == "Result" {
            ret = rtinfo.type_id   // Ok type
            err = rtinfo.type_id2  // Error type
        } else {
            ret = rt.type_id
        }
    }

    // Error type (if not already parsed as part of return type)
    if err == 0 && _ck2(cc) == "!" {
        cc = _cadv(cc)
        et := _parse_type_ann(cc)
        cc = et.c
        err = et.type_id
    }

    // Parse effect clause: with [Io, Fs, ...]
    mut eff_io := false
    mut eff_fs := false
    mut eff_net := false
    mut eff_ffi := false
    mut eff_async := false
    if _ck2(cc) == "with" {
        cc = _cadv(cc)  // skip with
        if _ck2(cc) == "[" {
            cc = _cadv(cc)  // skip [
            while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
                if _ck2(cc) == "IDENT" {
                    eff := _ccur(cc).text
                    if eff == "Io" { eff_io = true }
                    if eff == "Fs" { eff_fs = true }
                    if eff == "Net" { eff_net = true }
                    if eff == "Ffi" { eff_ffi = true }
                    if eff == "Async" { eff_async = true }
                    cc = _cadv(cc)
                } else {
                    cc = _cadv(cc)
                }
                if _ck2(cc) == "," { cc = _cadv(cc) }
            }
            if _ck2(cc) == "]" { cc = _cadv(cc) }
        }
    }

    // Parse where clause: where T: Trait, U: Trait2
    if _ck2(cc) == "where" {
        cc = _cadv(cc)  // skip where
        mut parsing_where := true
        while parsing_where {
            if _ck2(cc) == "IDENT" {
                wname := _ccur(cc).text
                cc = _cadv(cc)
                if _ck2(cc) == ":" {
                    cc = _cadv(cc)
                    if _ck2(cc) == "IDENT" {
                        mut wbound := _ccur(cc).text
                        cc = _cadv(cc)
                        while _ck2(cc) == "+" {
                            cc = _cadv(cc)
                            if _ck2(cc) == "IDENT" {
                                wbound = wbound + "+" + _ccur(cc).text
                                cc = _cadv(cc)
                            }
                        }
                        if wname == gp_0 && gb_0 == "" { gb_0 = wbound }
                        if wname == gp_1 && gb_1 == "" { gb_1 = wbound }
                        if wname == gp_2 && gb_2 == "" { gb_2 = wbound }
                    }
                }
                if _ck2(cc) == "," { cc = _cadv(cc) } else { parsing_where = false }
            } else {
                parsing_where = false
            }
        }
    }

    mut sig := new_fn_sig(name, pnames, ptypes, ret, err)
    if gp_count > 0 {
        sig = new_generic_fn_sig(name, pnames, ptypes, ret, err, gp_count, gp_0, gp_1, gp_2, gb_0, gb_1, gb_2, token_start)
    }
    if eff_io || eff_fs || eff_net || eff_ffi || eff_async {
        sig = sig_set_effects(sig, eff_io, eff_fs, eff_net, eff_ffi, eff_async)
    }
    cc = _cset_reg(cc, reg_add_fn(cc.registry, sig))

    // Skip rest of function (body)
    lb := "\{"
    while _ck2(cc) != "EOF" {
        if _ck2(cc) == lb {
            cc = _skip_braces2(cc)
            return cc
        }
        if _ck2(cc) == "NEWLINE" { return cc }
        cc = _cadv(cc)
    }
    cc
}

fn _register_impl_fns(c: Checker, node_idx: i64) -> Checker {
    mut cc := _cadv(c)  // skip impl
    // Capture names: "impl TypeName {" or "impl TraitName for TypeName {"
    mut first_name := ""
    mut impl_type := ""
    mut impl_trait := ""
    if _ck2(cc) == "IDENT" {
        first_name = _ccur(cc).text
        impl_type = first_name
        cc = _cadv(cc)
    }
    // Check for "for TypeName" pattern (impl Trait for Type)
    if _ck2(cc) == "for" {
        impl_trait = first_name
        cc = _cadv(cc)
        if _ck2(cc) == "IDENT" {
            impl_type = _ccur(cc).text
            cc = _cadv(cc)
        }
    }
    // Register trait impl in trait registry
    if impl_trait != "" && impl_type != "" {
        cc = _cset_treg(cc, treg_add_impl(cc.treg, _mk_impl(impl_trait, impl_type)))
        // Check supertrait requirements
        tdef := treg_find_trait(cc.treg, impl_trait)
        if tdef.name != "" {
            mut pi := 1
            while pi < tdef.parent_traits.len() {
                parent := tdef.parent_traits[pi]
                if treg_has_impl(cc.treg, impl_type, parent) == false {
                    q := _q()
                    cc = _cerror(cc, E0200, "trait " + q + impl_trait + q + " requires " + q + parent + q + " but " + q + impl_type + q + " does not implement it")
                }
                pi = pi + 1
            }
        }
    }

    // AST path: iterate method children from the EkImplDecl node
    if node_idx > 0 {
        impl_node := pool_get(cc.pool, node_idx)
        mut mi := 0
        while mi < impl_node.list_count {
            midx_node := pool_get(cc.pool, impl_node.list_start + mi)
            method_idx := midx_node.c0
            method_node := pool_get(cc.pool, method_idx)
            // The method FnDecl has a token position — find it for token_start
            // Use the method node's span to find the token position
            // We need the token position of the fn keyword — look it up from the method node
            // Method nodes are EkFnDecl; their span points to the fn keyword
            // We need to find the token index for this method
            // Since we have the method node in the pool, use token_start from a scan
            cc = _register_impl_fn_sig_ast(cc, impl_type, method_idx)
            mi = mi + 1
        }
        // Still need to handle associated types — scan tokens for those
        lb := "\{"
        while _ck2(cc) != lb && _ck2(cc) != "EOF" { cc = _cadv(cc) }
        if _ck2(cc) != lb { return cc }
        cc = _cadv(cc)
        cc = _cskip_nl(cc)
        rb := "\}"
        while _ck2(cc) != rb && _ck2(cc) != "EOF" {
            cc = _cskip_nl(cc)
            if _ck2(cc) == "pub" { cc = _cadv(cc) }
            if _ck2(cc) == "fn" {
                // Skip fn — already registered via AST
                cc = _cadv(cc)
                while _ck2(cc) != "NEWLINE" && _ck2(cc) != "EOF" {
                    if _ck2(cc) == lb { cc = _skip_braces2(cc) } else { cc = _cadv(cc) }
                }
            } else if _ck2(cc) == "type" {
                cc = _cadv(cc)
                if _ck2(cc) == "IDENT" {
                    assoc_name := _ccur(cc).text
                    cc = _cadv(cc)
                    if _ck2(cc) == "=" {
                        cc = _cadv(cc)
                        if _ck2(cc) == "IDENT" {
                            assoc_value := _ccur(cc).text
                            if impl_type != "" {
                                alias_name := impl_type + "_" + assoc_name
                                tid := resolve_type_name(cc.store, assoc_value)
                                if tid != TY_UNKNOWN {
                                    new_st := store_add(cc.store, TypeInfo{kind: TyNamed, name: alias_name, type_id: tid, type_id2: 0, param_start: 0, param_count: 0})
                                    cc = _cset_store(cc, new_st)
                                }
                            }
                        }
                    }
                }
                while _ck2(cc) != "NEWLINE" && _ck2(cc) != rb && _ck2(cc) != "EOF" { cc = _cadv(cc) }
            } else if _ck2(cc) == rb || _ck2(cc) == "EOF" {
                return cc
            } else {
                cc = _cadv(cc)
            }
            cc = _cskip_nl(cc)
        }
        if _ck2(cc) == rb { cc = _cadv(cc) }
        return cc
    }

    lb := "\{"
    while _ck2(cc) != lb && _ck2(cc) != "EOF" { cc = _cadv(cc) }
    if _ck2(cc) != lb { return cc }
    cc = _cadv(cc)  // skip {
    cc = _cskip_nl(cc)
    rb := "\}"
    while _ck2(cc) != rb && _ck2(cc) != "EOF" {
        cc = _cskip_nl(cc)
        if _ck2(cc) == "pub" { cc = _cadv(cc) }
        if _ck2(cc) == "fn" {
            cc = _register_impl_fn_sig(cc, impl_type)
        } else if _ck2(cc) == "type" {
            // Associated type binding: type Name = ConcreteType
            cc = _cadv(cc)  // skip type
            if _ck2(cc) == "IDENT" {
                assoc_name := _ccur(cc).text
                cc = _cadv(cc)
                if _ck2(cc) == "=" {
                    cc = _cadv(cc)
                    if _ck2(cc) == "IDENT" {
                        assoc_value := _ccur(cc).text
                        // Register this associated type binding as a named type
                        // so Self::Name resolves to the concrete type
                        if impl_type != "" {
                            alias_name := impl_type + "_" + assoc_name
                            tid := resolve_type_name(cc.store, assoc_value)
                            if tid != TY_UNKNOWN {
                                new_st := store_add(cc.store, TypeInfo{kind: TyNamed, name: alias_name, type_id: tid, type_id2: 0, param_start: 0, param_count: 0})
                                cc = _cset_store(cc, new_st)
                            }
                        }
                    }
                }
            }
            while _ck2(cc) != "NEWLINE" && _ck2(cc) != rb && _ck2(cc) != "EOF" { cc = _cadv(cc) }
        } else if _ck2(cc) == rb || _ck2(cc) == "EOF" {
            return cc
        } else {
            cc = _cadv(cc)
        }
        cc = _cskip_nl(cc)
    }
    if _ck2(cc) == rb { cc = _cadv(cc) }
    cc
}

// Register a function signature from inside an impl block.
// Handles `self` parameter by injecting the impl type.
// Registers with qualified name: Type_method
fn _register_impl_fn_sig(c: Checker, impl_type: str) -> Checker {
    token_start := c.pos  // save position of 'fn' keyword
    mut cc := _cadv(c)  // skip fn
    if _ck2(cc) != "IDENT" { return cc }
    raw_name := _ccur(cc).text
    name := impl_type + "_" + raw_name
    cc = _cadv(cc)

    // Capture generic params
    mut gp_count := 0
    mut gp_0 := ""
    mut gp_1 := ""
    mut gp_2 := ""
    mut gb_0 := ""
    mut gb_1 := ""
    mut gb_2 := ""
    if _ck2(cc) == "[" {
        cc = _cadv(cc)  // skip [
        while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
            if _ck2(cc) == "IDENT" {
                gname := _ccur(cc).text
                if gp_count == 0 { gp_0 = gname }
                if gp_count == 1 { gp_1 = gname }
                if gp_count == 2 { gp_2 = gname }
                cc = _cadv(cc)
                if _ck2(cc) == ":" {
                    cc = _cadv(cc)
                    if _ck2(cc) == "IDENT" {
                        bname := _ccur(cc).text
                        if gp_count == 0 { gb_0 = bname }
                        if gp_count == 1 { gb_1 = bname }
                        if gp_count == 2 { gb_2 = bname }
                        cc = _cadv(cc)
                    }
                }
                gp_count = gp_count + 1
            } else {
                cc = _cadv(cc)
            }
            if _ck2(cc) == "," { cc = _cadv(cc) }
        }
        if _ck2(cc) == "]" { cc = _cadv(cc) }
    }

    // If generic, add TypeVar entries
    if gp_count > 0 {
        new_st := store_add(cc.store, mk_typevar(gp_0))
        cc = _cset_store(cc, new_st)
    }
    if gp_count > 1 {
        new_st := store_add(cc.store, mk_typevar(gp_1))
        cc = _cset_store(cc, new_st)
    }
    if gp_count > 2 {
        new_st := store_add(cc.store, mk_typevar(gp_2))
        cc = _cset_store(cc, new_st)
    }

    // Parse parameters, handling self
    mut pnames := [""]
    mut ptypes := [0]
    if _ck2(cc) == "(" {
        cc = _cadv(cc)
        while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
            if _ck2(cc) == "self" {
                // self parameter — resolve to impl type
                pnames = pnames.append("self")
                self_type := resolve_type_name(cc.store, impl_type)
                ptypes = ptypes.append(self_type)
                cc = _cadv(cc)
            } else if _ck2(cc) == "IDENT" {
                pn := _ccur(cc).text
                cc = _cadv(cc)
                if _ck2(cc) == ":" {
                    cc = _cadv(cc)
                    pt := _parse_type_ann(cc)
                    cc = pt.c
                    pnames = pnames.append(pn)
                    ptypes = ptypes.append(pt.type_id)
                }
            } else {
                cc = _cadv(cc)
            }
            if _ck2(cc) == "," { cc = _cadv(cc) }
        }
        if _ck2(cc) == ")" { cc = _cadv(cc) }
    }

    // Return type (may include ! ErrorType parsed by _parse_type_ann)
    mut ret := TY_UNIT
    mut err := 0
    if _ck2(cc) == "->" {
        cc = _cadv(cc)
        rt := _parse_type_ann(cc)
        cc = rt.c
        // Check if _parse_type_ann already consumed T ! E
        rtinfo := store_get(cc.store, rt.type_id)
        if type_kind_name(rtinfo.kind) == "Result" {
            ret = rtinfo.type_id   // Ok type
            err = rtinfo.type_id2  // Error type
        } else {
            ret = rt.type_id
        }
    }

    // Error type (if not already parsed as part of return type)
    if err == 0 && _ck2(cc) == "!" {
        cc = _cadv(cc)
        et := _parse_type_ann(cc)
        cc = et.c
        err = et.type_id
    }

    // Parse effect clause: with [Io, Fs, ...]
    mut eff_io := false
    mut eff_fs := false
    mut eff_net := false
    mut eff_ffi := false
    mut eff_async := false
    if _ck2(cc) == "with" {
        cc = _cadv(cc)  // skip with
        if _ck2(cc) == "[" {
            cc = _cadv(cc)  // skip [
            while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
                if _ck2(cc) == "IDENT" {
                    eff := _ccur(cc).text
                    if eff == "Io" { eff_io = true }
                    if eff == "Fs" { eff_fs = true }
                    if eff == "Net" { eff_net = true }
                    if eff == "Ffi" { eff_ffi = true }
                    if eff == "Async" { eff_async = true }
                    cc = _cadv(cc)
                } else {
                    cc = _cadv(cc)
                }
                if _ck2(cc) == "," { cc = _cadv(cc) }
            }
            if _ck2(cc) == "]" { cc = _cadv(cc) }
        }
    }

    // Parse where clause: where T: Trait, U: Trait2
    if _ck2(cc) == "where" {
        cc = _cadv(cc)  // skip where
        mut parsing_where := true
        while parsing_where {
            if _ck2(cc) == "IDENT" {
                wname := _ccur(cc).text
                cc = _cadv(cc)
                if _ck2(cc) == ":" {
                    cc = _cadv(cc)
                    if _ck2(cc) == "IDENT" {
                        mut wbound := _ccur(cc).text
                        cc = _cadv(cc)
                        while _ck2(cc) == "+" {
                            cc = _cadv(cc)
                            if _ck2(cc) == "IDENT" {
                                wbound = wbound + "+" + _ccur(cc).text
                                cc = _cadv(cc)
                            }
                        }
                        if wname == gp_0 && gb_0 == "" { gb_0 = wbound }
                        if wname == gp_1 && gb_1 == "" { gb_1 = wbound }
                        if wname == gp_2 && gb_2 == "" { gb_2 = wbound }
                    }
                }
                if _ck2(cc) == "," { cc = _cadv(cc) } else { parsing_where = false }
            } else {
                parsing_where = false
            }
        }
    }

    mut sig := new_fn_sig(name, pnames, ptypes, ret, err)
    if gp_count > 0 {
        sig = new_generic_fn_sig(name, pnames, ptypes, ret, err, gp_count, gp_0, gp_1, gp_2, gb_0, gb_1, gb_2, token_start)
    }
    if eff_io || eff_fs || eff_net || eff_ffi || eff_async {
        sig = sig_set_effects(sig, eff_io, eff_fs, eff_net, eff_ffi, eff_async)
    }
    cc = _cset_reg(cc, reg_add_fn(cc.registry, sig))

    // Skip rest of function (body)
    lb := "\{"
    while _ck2(cc) != "EOF" {
        if _ck2(cc) == lb {
            cc = _skip_braces2(cc)
            return cc
        }
        if _ck2(cc) == "NEWLINE" { return cc }
        cc = _cadv(cc)
    }
    cc
}

// AST-based const registration
fn _register_const_ast(c: Checker, node_idx: i64) -> Checker {
    node := pool_get(c.pool, node_idx)
    name := node.s1
    mut cc := c

    mut ctype := TY_UNKNOWN
    if node.c1 > 0 {
        // Type annotation stored at token position c1
        cc = _cset_pos(cc, node.c1)
        ct := _parse_type_ann(cc)
        cc = ct.c
        ctype = ct.type_id
    }

    // Register in env
    cc = _env_add(cc, name, ctype, 0)
    cc
}

fn _register_const(c: Checker) -> Checker {
    mut cc := _cadv(c)  // skip const
    if _ck2(cc) != "IDENT" { return cc }
    name := _ccur(cc).text
    cc = _cadv(cc)

    mut ctype := TY_UNKNOWN
    if _ck2(cc) == ":" {
        cc = _cadv(cc)
        ct := _parse_type_ann(cc)
        cc = ct.c
        ctype = ct.type_id
    }

    // Register in env
    cc = _env_add(cc, name, ctype, 0)

    // Skip = expr
    if _ck2(cc) == "=" {
        cc = _cadv(cc)
        while _ck2(cc) != "NEWLINE" && _ck2(cc) != "EOF" { cc = _cadv(cc) }
    }
    cc
}

// ============================================================
// Pass 3: Check function/entry/test bodies
// ============================================================

fn _pass3_bodies(c: Checker, index: DeclIndex) -> Checker {
    mut cc := c
    mut di := 1
    while di < decl_index_len(index) {
        decl := decl_index_get(index, di)
        kname := decl_kind_name(decl.kind)

        cc = _cset_pos(cc, decl.token_start)
        if _ck2(cc) == "pub" { cc = _cadv(cc) }

        // Skip annotations
        if _ck2(cc) == "@" {
            cc = _cadv(cc)
            if _ck2(cc) == "IDENT" { cc = _cadv(cc) }
            if _ck2(cc) == "(" {
                cc = _cadv(cc)
                while _ck2(cc) != ")" && _ck2(cc) != "EOF" { cc = _cadv(cc) }
                if _ck2(cc) == ")" { cc = _cadv(cc) }
            }
            cc = _cskip_nl(cc)
        }

        if kname == "fn" {
            if decl.name == "_extern" || decl.name.startsWith("_fixture:") {
                // extern and fixtures — skip body checking
                cc = _cset_pos(cc, decl.body_end)
            } else {
                cc = _check_fn_d(cc, decl)
            }
        } else if kname == "impl" {
            cc = _check_impl_d(cc, decl)
        } else if kname == "entry" {
            cc = _check_entry(cc)
        } else if kname == "test" {
            // DkTest covers both test and bench
            cc = _check_test(cc)
        } else {
            // type, enum, trait, const, use, alias — skip
            cc = _cset_pos(cc, decl.body_end)
        }

        di = di + 1
    }
    cc
}

fn _skip_decl(c: Checker) -> Checker {
    mut cc := _cadv(c)
    lb := "\{"
    while _ck2(cc) != "EOF" {
        if _ck2(cc) == lb {
            cc = _skip_braces2(cc)
            // Skip derives
            cc = _cskip_nl(cc)
            if _ck2(cc) == "derives" {
                while _ck2(cc) != "NEWLINE" && _ck2(cc) != "EOF" { cc = _cadv(cc) }
            }
            return cc
        }
        if _ck2(cc) == "NEWLINE" {
            cc = _cskip_nl(cc)
            nk := _ck2(cc)
            if nk == "fn" || nk == "pub" || nk == "type" || nk == "struct" ||
               nk == "enum" || nk == "trait" || nk == "impl" || nk == "const" ||
               nk == "entry" || nk == "test" || nk == "EOF" {
                return cc
            }
        }
        cc = _cadv(cc)
    }
    cc
}

// --- Check function ---

// DeclInfo-aware function body checker — jumps directly to body_start
fn _check_fn_d(c: Checker, decl: DeclInfo) -> Checker {
    name := decl.name
    mut cc := c

    // Look up registered signature
    sig := reg_find_fn(cc.registry, name)

    // Skip generic function bodies — they are checked per-specialization
    if fn_is_generic(sig) {
        return _cset_pos(cc, decl.body_end)
    }

    // Set function context with effect tracking
    cc = _cset_fn_ctx(cc, sig.return_type, sig.error_type)
    cc = Checker{tokens: cc.tokens, pos: cc.pos, store: cc.store, registry: cc.registry,
            treg: cc.treg, diagnostics: cc.diagnostics, table: cc.table,
            current_scope: cc.current_scope, file: cc.file, pool: cc.pool,
            env_names: cc.env_names, env_types: cc.env_types, env_scopes: cc.env_scopes,
            fn_return_type: cc.fn_return_type, fn_error_type: cc.fn_error_type, fn_current_name: name, in_loop: cc.in_loop}

    // Register params in env
    mut pi := 1  // skip sentinel
    while pi < sig.param_names.len() {
        cc = _env_add(cc, sig.param_names[pi], sig.param_types[pi], 0)
        pi = pi + 1
    }

    // Jump directly to body using DeclIndex body_start
    cc = _cset_pos(cc, decl.body_start)
    lb := "\{"

    if _ck2(cc) == "=" {
        cc = _cadv(cc)
        cc = _cskip_nl(cc)
        result := _check_expr_full(cc)
        cc = result.c
        // Check return type
        if sig.return_type != TY_UNKNOWN && sig.return_type != TY_UNIT {
            mut rt_ok := is_assignable(cc.store, result.type_id, sig.return_type)
            if rt_ok == false && result.type_id != TY_UNKNOWN {
                // Accept Result types in fallible functions
                rinfo := store_get(cc.store, result.type_id)
                if type_kind_name(rinfo.kind) == "Result" && sig.error_type > 0 {
                    rt_ok = true
                }
            }
            // Also accept array-of-unknown
            if rt_ok == false && result.type_id != TY_UNKNOWN {
                rinfo2 := store_get(cc.store, result.type_id)
                if type_kind_name(rinfo2.kind) == "Array" && rinfo2.type_id == TY_UNKNOWN { rt_ok = true }
            }
            if rt_ok == false && result.type_id != TY_UNKNOWN {
                q := _q()
                cc = _cerror(cc, E0106, "expected return type " + q + format_type(cc.store, sig.return_type) + q + ", got " + q + format_type(cc.store, result.type_id) + q)
            }
        }
    } else if _ck2(cc) == lb {
        result := _check_block(cc)
        cc = result.c
    } else {
        cc = _cskip_nl(cc)
        if _ck2(cc) == lb {
            result := _check_block(cc)
            cc = result.c
        }
    }
    cc
}

// DeclInfo-aware impl block checker — walks AST method children when available
fn _check_impl_d(c: Checker, decl: DeclInfo) -> Checker {
    mut cc := _cadv(c)  // skip impl
    // Capture impl type for qualified fn lookup
    mut impl_type := ""
    if _ck2(cc) == "IDENT" {
        impl_type = _ccur(cc).text
        cc = _cadv(cc)
    }
    if _ck2(cc) == "for" {
        cc = _cadv(cc)
        if _ck2(cc) == "IDENT" {
            impl_type = _ccur(cc).text
            cc = _cadv(cc)
        }
    }

    // AST path: walk method children from EkImplDecl
    if decl.node_idx > 0 {
        impl_node := pool_get(cc.pool, decl.node_idx)
        mut mi := 0
        while mi < impl_node.list_count {
            midx_node := pool_get(cc.pool, impl_node.list_start + mi)
            method_node := pool_get(cc.pool, midx_node.c0)
            cc = _check_impl_fn_ast(cc, impl_type, method_node)
            mi = mi + 1
        }
        cc = _cset_pos(cc, decl.body_end)
        return cc
    }

    // Legacy token-walk fallback
    lb := "\{"
    while _ck2(cc) != lb && _ck2(cc) != "EOF" { cc = _cadv(cc) }
    if _ck2(cc) != lb { return cc }
    cc = _cadv(cc)  // skip {
    cc = _cskip_nl(cc)
    rb := "\}"
    while _ck2(cc) != rb && _ck2(cc) != "EOF" {
        cc = _cskip_nl(cc)
        if _ck2(cc) == "pub" { cc = _cadv(cc) }
        if _ck2(cc) == "fn" {
            cc = _check_impl_fn(cc, impl_type)
        } else if _ck2(cc) == rb || _ck2(cc) == "EOF" {
            return cc
        } else {
            cc = _cadv(cc)
        }
        cc = _cskip_nl(cc)
    }
    if _ck2(cc) == rb { cc = _cadv(cc) }
    cc
}

// AST-aware impl method body checker — finds body via token scan within impl bounds
fn _check_impl_fn_ast(c: Checker, impl_type: str, method_node: Expr) -> Checker {
    raw_name := method_node.s1
    name := impl_type + "_" + raw_name
    mut cc := c

    // Look up registered signature by qualified name
    sig := reg_find_fn(cc.registry, name)

    // Skip generic method bodies
    if fn_is_generic(sig) {
        return cc
    }

    // No body to check
    if method_node.b1 == false {
        return cc
    }

    // Set function context
    cc = _cset_fn_ctx(cc, sig.return_type, sig.error_type)

    // Register params in env
    mut pi := 1
    while pi < sig.param_names.len() {
        cc = _env_add(cc, sig.param_names[pi], sig.param_types[pi], 0)
        pi = pi + 1
    }

    // Find method's fn keyword in token stream by scanning forward from current pos
    // Methods are ordered, so each scan continues where the last left off
    tlen := cc.tokens.len()
    mut search_pos := cc.pos
    lb := "\{"
    while search_pos < tlen {
        tk := token_name(cc.tokens[search_pos].kind)
        if tk == "fn" {
            next := search_pos + 1
            if next < tlen {
                if cc.tokens[next].text == raw_name {
                    // Found it — skip fn + name, then scan to body
                    cc = _cset_pos(cc, search_pos + 2)
                    while _ck2(cc) != "=" && _ck2(cc) != lb && _ck2(cc) != "EOF" {
                        cc = _cadv(cc)
                    }
                    if _ck2(cc) == "=" {
                        cc = _cadv(cc)
                        cc = _cskip_nl(cc)
                        result := _check_expr_full(cc)
                        cc = result.c
                    } else if _ck2(cc) == lb {
                        result := _check_block(cc)
                        cc = result.c
                    }
                    return cc
                }
            }
        }
        search_pos = search_pos + 1
    }
    cc
}

// Check a function inside an impl block — uses qualified name for sig lookup (legacy)
fn _check_impl_fn(c: Checker, impl_type: str) -> Checker {
    mut cc := _cadv(c)  // skip fn
    if _ck2(cc) != "IDENT" { return cc }
    raw_name := _ccur(cc).text
    name := impl_type + "_" + raw_name
    cc = _cadv(cc)

    // Look up registered signature by qualified name
    sig := reg_find_fn(cc.registry, name)

    // Skip generic method bodies — they are checked per-specialization
    if fn_is_generic(sig) {
        return _skip_decl(cc)
    }

    // Set function context
    cc = _cset_fn_ctx(cc, sig.return_type, sig.error_type)

    // Register params in env
    mut pi := 1
    while pi < sig.param_names.len() {
        cc = _env_add(cc, sig.param_names[pi], sig.param_types[pi], 0)
        pi = pi + 1
    }

    // Skip to body
    lb := "\{"
    while _ck2(cc) != "=" && _ck2(cc) != lb && _ck2(cc) != "EOF" {
        cc = _cadv(cc)
    }

    if _ck2(cc) == "=" {
        cc = _cadv(cc)
        cc = _cskip_nl(cc)
        result := _check_expr_full(cc)
        cc = result.c
    } else if _ck2(cc) == lb {
        result := _check_block(cc)
        cc = result.c
    }
    cc
}

fn _check_entry(c: Checker) -> Checker {
    mut cc := _cadv(c)  // skip entry
    cc = _cset_fn_ctx(cc, TY_UNIT, 0)
    // entry blocks have all effects
    cc = Checker{tokens: cc.tokens, pos: cc.pos, store: cc.store, registry: cc.registry,
            treg: cc.treg, diagnostics: cc.diagnostics, table: cc.table,
            current_scope: cc.current_scope, file: cc.file, pool: cc.pool,
            env_names: cc.env_names, env_types: cc.env_types, env_scopes: cc.env_scopes,
            fn_return_type: cc.fn_return_type, fn_error_type: cc.fn_error_type, fn_current_name: "_entry", in_loop: cc.in_loop}
    result := _check_block(cc)
    result.c
}

fn _check_test(c: Checker) -> Checker {
    mut cc := _cadv(c)  // skip test
    if _ck2(cc) == "STRING" || _ck2(cc) == "IDENT" { cc = _cadv(cc) }
    cc = _cset_fn_ctx(cc, TY_UNIT, 0)
    result := _check_block(cc)
    return result.c
}

// ============================================================
// Expression type checking
// ============================================================

// Check if token is an expression continuation
fn _is_cont(k: str) -> bool =
    k == "+" || k == "-" || k == "*" || k == "/" || k == "%" ||
    k == "==" || k == "!=" || k == "<" || k == ">" || k == "<=" || k == ">=" ||
    k == "&&" || k == "||" || k == "&" || k == "|" || k == "^" || k == "~" ||
    k == "<<" || k == ">>" || k == "|>" || k == ".." || k == "..=" ||
    k == "." || k == "(" || k == "[" || k == "?" || k == "!" ||
    k == "," || k == "=>" || k == "=" || k == "?." || k == "??" || k == "catch"

fn _check_block(c: Checker) -> CE {
    lb := "\{"
    rb := "\}"
    if _ck2(c) != lb { return CE{c: c, type_id: TY_UNIT} }
    mut cc := _cadv(c)  // skip {
    cc = _cskip_nl(cc)
    mut last_type := TY_UNIT
    while _ck2(cc) != rb && _ck2(cc) != "EOF" {
        result := _check_stmt(cc)
        cc = result.c
        last_type = result.type_id
        cc = _cskip_nl(cc)
    }
    if _ck2(cc) == rb { cc = _cadv(cc) }
    CE{c: cc, type_id: last_type}
}

fn _check_stmt(c: Checker) -> CE {
    k := _ck2(c)
    if k == "mut" { return _check_mut_binding(c) }
    if k == "return" { return _check_return(c) }
    if k == "break" { return CE{c: _cadv(c), type_id: TY_NEVER} }
    if k == "continue" { return CE{c: _cadv(c), type_id: TY_NEVER} }
    if k == "for" { return _check_for(c) }
    if k == "while" { return _check_while(c) }
    if k == "loop" { return _check_loop(c) }
    if k == "if" { return _check_if(c) }
    if k == "match" { return _check_match(c) }
    if k == "defer" {
        cc := _cadv(c)
        result := _check_expr_full(cc)
        return CE{c: result.c, type_id: TY_UNIT}
    }
    if k == "assert" {
        cc := _cadv(c)
        result := _check_expr_full(cc)
        return CE{c: result.c, type_id: TY_UNIT}
    }
    // with resource { body } — resource block (RAII)
    if k == "with" {
        mut cc := _cadv(c)  // skip with
        // Check if this is a resource block (next is expr) vs effect clause (next is [)
        if _ck2(cc) != "[" {
            // with name := expr { body }
            mut res_name := ""
            if _ck2(cc) == "IDENT" {
                next_pos := cc.pos + 1
                if next_pos < cc.tokens.len() && token_name(cc.tokens[next_pos].kind) == ":=" {
                    res_name = _ccur(cc).text
                    cc = _cadv(cc)  // skip name
                    cc = _cadv(cc)  // skip :=
                }
            }
            result := _check_expr_full(cc)
            cc = result.c
            if res_name.len() > 0 {
                cc = _env_add(cc, res_name, result.type_id, 0)
            }
            body := _check_block(cc)
            return CE{c: body.c, type_id: body.type_id}
        }
    }

    // Check for binding or expression
    _check_expr_or_binding(c)
}

fn _check_mut_binding(c: Checker) -> CE {
    mut cc := _cadv(c)  // skip mut
    if _ck2(cc) != "IDENT" { return CE{c: cc, type_id: TY_UNIT} }
    name := _ccur(cc).text
    cc = _cadv(cc)

    mut ann_type := TY_UNKNOWN
    if _ck2(cc) == ":" {
        cc = _cadv(cc)
        at := _parse_type_ann(cc)
        cc = at.c
        ann_type = at.type_id
        if _ck2(cc) == "=" { cc = _cadv(cc) }
    } else if _ck2(cc) == ":=" {
        cc = _cadv(cc)
    }

    result := _check_expr_full(cc)
    cc = result.c
    mut final_type := result.type_id
    if ann_type != TY_UNKNOWN {
        // Verify initializer type matches annotation
        if result.type_id != TY_UNKNOWN && is_assignable(cc.store, result.type_id, ann_type) == false {
            q := _q()
            cc = _cerror(cc, E0100, "type mismatch in binding: expected " + q + format_type(cc.store, ann_type) + q + ", got " + q + format_type(cc.store, result.type_id) + q)
        }
        final_type = ann_type
    }
    cc = _env_add(cc, name, final_type, 0)
    return CE{c: cc, type_id: TY_UNIT}
}

fn _check_return(c: Checker) -> CE {
    mut cc := _cadv(c)  // skip return
    rb := "\}"
    if _ck2(cc) == "NEWLINE" || _ck2(cc) == "EOF" || _ck2(cc) == rb {
        return CE{c: cc, type_id: TY_NEVER}
    }
    result := _check_expr_full(cc)
    cc = result.c
    // Check against function return type
    // For fallible functions, also accept Result types (from Ok/Err constructors)
    if cc.fn_return_type != TY_UNKNOWN && cc.fn_return_type != TY_UNIT {
        mut type_ok := is_assignable(cc.store, result.type_id, cc.fn_return_type)
        if type_ok == false && result.type_id != TY_UNKNOWN {
            // Accept Result types in fallible functions
            rinfo := store_get(cc.store, result.type_id)
            if type_kind_name(rinfo.kind) == "Result" && cc.fn_error_type > 0 {
                type_ok = true
            }
        }
        // Also accept array-of-unknown as matching any array return type
        if type_ok == false && result.type_id != TY_UNKNOWN {
            rinfo := store_get(cc.store, result.type_id)
            if type_kind_name(rinfo.kind) == "Array" && rinfo.type_id == TY_UNKNOWN { type_ok = true }
        }
        if type_ok == false && result.type_id != TY_UNKNOWN {
            q := _q()
            cc = _cerror(cc, E0106, "return type mismatch: expected " + q + format_type(cc.store, cc.fn_return_type) + q + ", got " + q + format_type(cc.store, result.type_id) + q)
        }
    }
    CE{c: cc, type_id: TY_NEVER}
}

fn _check_expr_or_binding(c: Checker) -> CE {
    // Tuple destructuring: (name1, name2) := expr
    if _ck2(c) == "(" {
        mut scan := c.pos + 1
        mut is_tuple_destr := false
        while scan < c.tokens.len() {
            sk := token_name(c.tokens[scan].kind)
            if sk == ")" {
                next2 := scan + 1
                if next2 < c.tokens.len() && token_name(c.tokens[next2].kind) == ":=" {
                    is_tuple_destr = true
                }
                scan = c.tokens.len()
            } else if sk == "IDENT" || sk == "," || sk == "_" {
                scan = scan + 1
            } else {
                scan = c.tokens.len()
            }
        }
        if is_tuple_destr {
            mut cc := _cadv(c)  // skip (
            mut names := [""]
            while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
                if _ck2(cc) == "IDENT" {
                    names = names.append(_ccur(cc).text)
                }
                cc = _cadv(cc)
                if _ck2(cc) == "," { cc = _cadv(cc) }
            }
            if _ck2(cc) == ")" { cc = _cadv(cc) }
            if _ck2(cc) == ":=" { cc = _cadv(cc) }
            result := _check_expr_full(cc)
            cc = result.c
            // Register each name with extracted tuple element type
            mut ni := 1
            while ni < names.len() {
                elem_t := tuple_elem_type(cc.store, result.type_id, ni - 1)
                cc = _env_add(cc, names[ni], elem_t, 0)
                ni = ni + 1
            }
            return CE{c: cc, type_id: TY_UNIT}
        }
    }
    if _ck2(c) == "IDENT" {
        name := _ccur(c).text
        next_pos := c.pos + 1
        if next_pos < c.tokens.len() {
            next_k := token_name(c.tokens[next_pos].kind)
            if next_k == ":=" {
                mut cc := _cadv(c)   // skip name
                cc = _cadv(cc)       // skip :=
                result := _check_expr_full(cc)
                cc = result.c
                cc = _env_add(cc, name, result.type_id, 0)
                return CE{c: cc, type_id: TY_UNIT}
            }
            // Mutability check: name = expr (reassignment)
            if next_k == "=" {
                sym := lookup(c.table, c.current_scope, name)
                if sym.name != "" && sym.is_mutable == false {
                    q := _q()
                    mut cc := _cerror(c, "E0500", "cannot assign to immutable binding " + q + name + q)
                    cc = _cadv(cc)   // skip name
                    cc = _cadv(cc)   // skip =
                    result := _check_expr_full(cc)
                    return CE{c: result.c, type_id: TY_UNIT}
                }
            }
            if next_k == ":" {
                // Typed binding: name : Type = expr
                mut cc := _cadv(c)   // skip name
                cc = _cadv(cc)       // skip :
                saved_pos := cc.pos
                at := _parse_type_ann(cc)
                cc = at.c
                if _ck2(cc) == "=" {
                    cc = _cadv(cc)  // skip =
                    result := _check_expr_full(cc)
                    cc = result.c
                    cc = _env_add(cc, name, at.type_id, 0)
                    return CE{c: cc, type_id: TY_UNIT}
                }
                // Not a binding, restore
                cc = _cset_pos(cc, c.pos)
            }
        }
    }
    // Regular expression
    _check_expr_full(c)
}

// --- Full expression (handles binary operators, postfix, assignment) ---

fn _check_expr_full(c: Checker) -> CE {
    mut result := _check_primary(c)
    mut cc := result.c
    mut left_type := result.type_id

    // Postfix and binary
    mut running := true
    while running {
        k := _ck2(cc)
        if k == "." {
            // Field access or method call
            cc = _cadv(cc)
            if _ck2(cc) != "IDENT" {
                running = false
            } else {
                field := _ccur(cc).text
                cc = _cadv(cc)
                if _ck2(cc) == "[" && (field == "to" || field == "trunc") {
                    // Conversion method: .to[Type]() or .trunc[Type]()
                    cc = _cadv(cc)  // skip [
                    mut conv_type := TY_UNKNOWN
                    if _ck2(cc) == "IDENT" {
                        ct := _parse_type_ann(cc)
                        cc = ct.c
                        conv_type = ct.type_id
                    }
                    if _ck2(cc) == "]" { cc = _cadv(cc) }
                    if _ck2(cc) == "(" { cc = _cadv(cc) }
                    if _ck2(cc) == ")" { cc = _cadv(cc) }
                    if field == "to" {
                        // Checked conversion returns Result[T, ConversionError]
                        new_st := store_add(cc.store, mk_result_type(conv_type, TY_STR))
                        cc = _cset_store(cc, new_st)
                        left_type = store_last_id(cc.store)
                    } else {
                        // Truncating conversion returns T directly
                        left_type = conv_type
                    }
                } else if _ck2(cc) == "(" {
                    // Method call
                    mr := _check_method_call(cc, left_type, field)
                    cc = mr.c
                    left_type = mr.type_id
                } else {
                    // Field access
                    fr := _check_field(cc, left_type, field)
                    cc = fr.c
                    left_type = fr.type_id
                }
            }
        } else if k == "(" {
            // Function call (callee already consumed as IDENT)
            // This handles f(args) where f was consumed as IDENT
            // We need to look up the function
            cr := _check_call_args(cc, left_type)
            cc = cr.c
            left_type = cr.type_id
        } else if k == "[" {
            // Index
            cc = _cadv(cc)
            idx := _check_expr_full(cc)
            cc = idx.c
            if _ck2(cc) == "]" { cc = _cadv(cc) }
            // Result type is element type for arrays
            info := store_get(cc.store, left_type)
            if type_kind_name(info.kind) == "Array" {
                left_type = info.type_id
            } else if type_kind_name(info.kind) == "str" {
                left_type = TY_STR
            } else {
                left_type = TY_UNKNOWN
            }
        } else if k == "?" {
            cc = _cadv(cc)
            info := store_get(cc.store, left_type)
            if type_kind_name(info.kind) == "Result" {
                left_type = info.type_id
            } else if type_kind_name(info.kind) == "Optional" {
                left_type = info.type_id
            }
        } else if k == "!" {
            cc = _cadv(cc)
            info := store_get(cc.store, left_type)
            if type_kind_name(info.kind) == "Result" {
                left_type = info.type_id
            }
        } else if k == "catch" {
            cc = _cadv(cc)
            // Parse |e| binding
            if _ck2(cc) == "|" {
                cc = _cadv(cc)
                if _ck2(cc) == "IDENT" || _ck2(cc) == "_" { cc = _cadv(cc) }
                if _ck2(cc) == "|" { cc = _cadv(cc) }
            }
            // Check catch body block
            cb := _check_block(cc)
            cc = cb.c
            // catch unwraps Result to Ok type
            info := store_get(cc.store, left_type)
            if type_kind_name(info.kind) == "Result" {
                left_type = info.type_id
            }
        } else if k == "IDENT" && _ccur(cc).text == "or" {
            // or default_value — sugar for catch { _ => yield value }
            cc = _cadv(cc)
            right := _check_primary(cc)
            cc = right.c
            info := store_get(cc.store, left_type)
            if type_kind_name(info.kind) == "Result" {
                left_type = info.type_id
            } else {
                left_type = right.type_id
            }
        } else if k == "IDENT" && _ccur(cc).text == "must" {
            // must "message" — unwrap or panic
            cc = _cadv(cc)
            right := _check_primary(cc)
            cc = right.c
            info := store_get(cc.store, left_type)
            if type_kind_name(info.kind) == "Result" {
                left_type = info.type_id
            }
        } else if k == "??" {
            // Null coalesce: unwrap Optional or use default
            cc = _cadv(cc)
            right := _check_primary(cc)
            cc = right.c
            // Result type is the inner type of the Optional
            info := store_get(cc.store, left_type)
            if type_kind_name(info.kind) == "Optional" {
                left_type = info.type_id
            } else {
                left_type = right.type_id
            }
        } else if k == "?." {
            // Optional chaining: unwrap Optional and access field
            cc = _cadv(cc)
            if _ck2(cc) == "IDENT" {
                cc = _cadv(cc)
                // Result is Optional of the field type
                // For simplicity, keep as Optional
            }
        } else if k == "+" || k == "-" || k == "*" || k == "/" || k == "%" ||
                  k == "==" || k == "!=" || k == "<" || k == ">" || k == "<=" || k == ">=" ||
                  k == "&&" || k == "||" || k == "&" || k == "|" || k == "^" ||
                  k == "<<" || k == ">>" {
            op := _ccur(cc).text
            cc = _cadv(cc)
            right := _check_primary(cc)
            cc = right.c
            // Continue consuming right side with operators
            mut rr_running := true
            while rr_running {
                rk := _ck2(cc)
                if rk == "." || rk == "(" || rk == "[" || rk == "?" || rk == "!" {
                    // Need to handle postfix on right operand
                    post := _check_postfix_chain(cc, right.type_id)
                    cc = post.c
                    right = CE{c: cc, type_id: post.type_id}
                } else {
                    rr_running = false
                }
            }

            // Type check binary operation
            // Skip check when left_type is bool (precedence flattening in flat checker)
            if type_supports_op(cc.treg, cc.store, left_type, op) == false && left_type != TY_UNKNOWN && left_type != TY_BOOL {
                q := _q()
                cc = _cerror(cc, E0102, "operator " + q + op + q + " not supported for type " + q + format_type(cc.store, left_type) + q)
            }
            // Check operand types match (for arithmetic)
            // Skip check for &&/|| and when left_type is bool (precedence flattening)
            if op != "&&" && op != "||" && left_type != TY_BOOL {
                if left_type != TY_UNKNOWN && right.type_id != TY_UNKNOWN {
                    if types_equal(cc.store, left_type, right.type_id) == false {
                        is_str_concat := left_type == TY_STR && right.type_id == TY_STR
                        is_cmp := op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">="
                        if is_str_concat == false && is_cmp {
                            q := _q()
                            cc = _cerror(cc, E0102, "cannot compare " + q + format_type(cc.store, left_type) + q + " with " + q + format_type(cc.store, right.type_id) + q)
                        }
                    }
                }
            }
            left_type = binary_result_type(cc.store, left_type, op)
        } else if k == "|>" {
            // Pipeline: left |> fn
            cc = _cadv(cc)
            if _ck2(cc) == "IDENT" {
                fname := _ccur(cc).text
                cc = _cadv(cc)
                sig := reg_find_fn(cc.registry, fname)
                if sig.name != "" {
                    if fn_is_generic(sig) {
                        // Infer type from piped value (single arg)
                        mut pipe_ret := sig.return_type
                        // Find first TypeVar param and match to left_type
                        mut tv_id := 0
                        if sig.generic_count > 0 {
                            tv_id = resolve_type_name(cc.store, sig.generic_name_0)
                        }
                        if tv_id > 0 && pipe_ret == tv_id {
                            pipe_ret = left_type
                        }
                        // Build specialized name and register if needed
                        spec_name := fname + "_" + _type_name_suffix(cc.store, left_type)
                        existing := reg_find_mono(cc.registry, spec_name)
                        if existing.specialized_name == "" {
                            mut sp_ptypes := [0]
                            mut spi := 1
                            while spi < sig.param_types.len() {
                                mut pt := sig.param_types[spi]
                                if pt == tv_id && tv_id > 0 { pt = left_type }
                                sp_ptypes = sp_ptypes.append(pt)
                                spi = spi + 1
                            }
                            sp_sig := new_fn_sig(spec_name, sig.param_names, sp_ptypes, pipe_ret, sig.error_type)
                            cc = _cset_reg(cc, reg_add_fn(cc.registry, sp_sig))
                            spec := MonoSpec{generic_name: sig.name, specialized_name: spec_name,
                                             type_arg_0: left_type, type_arg_1: 0, type_arg_2: 0}
                            cc = _cset_reg(cc, reg_add_mono(cc.registry, spec))
                        }
                        left_type = pipe_ret
                    } else {
                        left_type = sig.return_type
                    }
                } else {
                    left_type = TY_UNKNOWN
                }
            }
        } else if k == "=" {
            // Assignment — validate RHS type matches LHS type
            cc = _cadv(cc)
            rhs := _check_expr_full(cc)
            cc = rhs.c
            if left_type != TY_UNKNOWN && rhs.type_id != TY_UNKNOWN && left_type != TY_UNIT {
                if is_assignable(cc.store, rhs.type_id, left_type) == false {
                    q := _q()
                    cc = _cerror(cc, E0100, "assignment type mismatch: expected " + q + format_type(cc.store, left_type) + q + ", got " + q + format_type(cc.store, rhs.type_id) + q)
                }
            }
            left_type = TY_UNIT
            running = false
        } else {
            // Check for statement boundary
            if _is_cont(k) == false {
                running = false
            } else {
                running = false
            }
        }
    }

    CE{c: cc, type_id: left_type}
}

fn _check_postfix_chain(c: Checker, base_type: i64) -> CE {
    mut cc := c
    mut cur_type := base_type
    mut running := true
    while running {
        k := _ck2(cc)
        if k == "." {
            cc = _cadv(cc)
            if _ck2(cc) == "IDENT" {
                field := _ccur(cc).text
                cc = _cadv(cc)
                if _ck2(cc) == "(" {
                    mr := _check_method_call(cc, cur_type, field)
                    cc = mr.c
                    cur_type = mr.type_id
                } else {
                    fr := _check_field(cc, cur_type, field)
                    cc = fr.c
                    cur_type = fr.type_id
                }
            } else if _ck2(cc) == "INT" {
                // Numeric tuple field access: .0, .1, .2
                field_idx_str := _ccur(cc).text
                cc = _cadv(cc)
                // Extract element type from tuple type
                mut fidx := 0
                if field_idx_str == "1" { fidx = 1 }
                if field_idx_str == "2" { fidx = 2 }
                if field_idx_str == "3" { fidx = 3 }
                if field_idx_str == "4" { fidx = 4 }
                if field_idx_str == "5" { fidx = 5 }
                if field_idx_str == "6" { fidx = 6 }
                if field_idx_str == "7" { fidx = 7 }
                elem_tid := tuple_elem_type(cc.store, cur_type, fidx)
                if elem_tid != TY_UNKNOWN {
                    cur_type = elem_tid
                } else {
                    cur_type = TY_UNKNOWN
                }
            } else if _ck2(cc) == "\{" {
                // Record update: .{field: val, ...}
                rb := "\}"
                cc = _cadv(cc)  // skip {
                cc = _cskip_nl(cc)
                while _ck2(cc) != rb && _ck2(cc) != "EOF" {
                    if _ck2(cc) == "IDENT" { cc = _cadv(cc) }
                    if _ck2(cc) == ":" { cc = _cadv(cc) }
                    ur := _check_expr_full(cc)
                    cc = ur.c
                    cc = _cskip_nl(cc)
                    if _ck2(cc) == "," { cc = _cadv(cc) }
                    cc = _cskip_nl(cc)
                }
                if _ck2(cc) == rb { cc = _cadv(cc) }
                // Result type is the same as the original struct type
            } else {
                running = false
            }
        } else if k == "(" {
            cr := _check_call_args(cc, cur_type)
            cc = cr.c
            cur_type = cr.type_id
        } else if k == "[" {
            cc = _cadv(cc)
            idx := _check_expr_full(cc)
            cc = idx.c
            if _ck2(cc) == "]" { cc = _cadv(cc) }
            info := store_get(cc.store, cur_type)
            if type_kind_name(info.kind) == "Array" {
                cur_type = info.type_id
            } else {
                cur_type = TY_UNKNOWN
            }
        } else if k == "?" || k == "!" {
            cc = _cadv(cc)
        } else {
            running = false
        }
    }
    CE{c: cc, type_id: cur_type}
}

fn _check_primary(c: Checker) -> CE {
    k := _ck2(c)

    // Unary prefix
    if k == "-" || k == "!" || k == "~" {
        cc := _cadv(c)
        result := _check_primary(cc)
        if k == "!" {
            return CE{c: result.c, type_id: TY_BOOL}
        }
        return result
    }

    if k == "INT" { return CE{c: _cadv(c), type_id: TY_I64} }
    if k == "FLOAT" { return CE{c: _cadv(c), type_id: TY_F64} }
    if k == "STRING" { return CE{c: _cadv(c), type_id: TY_STR} }
    if k == "CHAR" { return CE{c: _cadv(c), type_id: TY_CHAR} }
    if k == "STRING_START" {
        // String interpolation — skip tokens until STRING_END, result is str
        mut cc := _cadv(c)
        while _ck2(cc) != "STRING_END" && _ck2(cc) != "EOF" { cc = _cadv(cc) }
        if _ck2(cc) == "STRING_END" { cc = _cadv(cc) }
        return CE{c: cc, type_id: TY_STR}
    }
    if k == "true" || k == "false" { return CE{c: _cadv(c), type_id: TY_BOOL} }

    if k == "if" { return _check_if(c) }
    if k == "match" { return _check_match(c) }

    if k == "IDENT" {
        name := _ccur(c).text
        mut cc := _cadv(c)

        // Some(value) — Optional constructor
        if _ck2(cc) == "(" && name == "Some" {
            cr := _check_call_args(cc, TY_UNKNOWN)
            cc = cr.c
            new_st := store_add(cc.store, mk_optional_type(cr.type_id))
            cc = _cset_store(cc, new_st)
            return CE{c: cc, type_id: store_last_id(cc.store)}
        }

        // Ok(value) and Err(value) — Result constructors
        if _ck2(cc) == "(" && (name == "Ok" || name == "Err") {
            cr := _check_call_args(cc, TY_UNKNOWN)
            cc = cr.c
            // Construct Result type from function context
            if name == "Ok" {
                if cc.fn_error_type > 0 {
                    new_st := store_add(cc.store, mk_result_type(cr.type_id, cc.fn_error_type))
                    cc = _cset_store(cc, new_st)
                    return CE{c: cc, type_id: store_last_id(cc.store)}
                }
                return CE{c: cc, type_id: cr.type_id}
            }
            if name == "Err" {
                if cc.fn_return_type > 0 {
                    new_st := store_add(cc.store, mk_result_type(cc.fn_return_type, cr.type_id))
                    cc = _cset_store(cc, new_st)
                    return CE{c: cc, type_id: store_last_id(cc.store)}
                }
                return CE{c: cc, type_id: cr.type_id}
            }
        }

        // Check for type conversion: T(x) — lossless widening
        if _ck2(cc) == "(" {
            conv_type := resolve_type_name(cc.store, name)
            if conv_type != TY_UNKNOWN && conv_type <= TY_CHAR {
                // Type name used as callable — widening conversion
                cr := _check_call_args(cc, TY_UNKNOWN)
                return CE{c: cr.c, type_id: conv_type}
            }
        }

        // Check for function call
        if _ck2(cc) == "(" {
            sig := reg_find_fn(cc.registry, name)
            if sig.name != "" {
                // Check deprecation
                if reg_is_deprecated(cc.registry, name) {
                    dep_msg := reg_deprecated_msg(cc.registry, name)
                    cc = _cwarning(cc, "W0005", "'" + name + "' is deprecated: " + dep_msg)
                }
                // Check effect compatibility (skip for entry/test blocks which have all effects)
                if fn_is_pure(sig) == false && cc.fn_current_name != "" && cc.fn_current_name != "_entry" && cc.fn_current_name != "_test" {
                    caller_sig := reg_find_fn(cc.registry, cc.fn_current_name)
                    if caller_sig.name != "" {
                        if sig.has_io && fn_has_effect(caller_sig, "Io") == false {
                            cc = _cwarning(cc, "E0300", "function '" + name + "' requires effect [Io] but '" + cc.fn_current_name + "' does not declare [Io]")
                        }
                        if sig.has_fs && fn_has_effect(caller_sig, "Fs") == false {
                            cc = _cwarning(cc, "E0301", "function '" + name + "' requires effect [Fs] but '" + cc.fn_current_name + "' does not declare [Fs]")
                        }
                        if sig.has_net && fn_has_effect(caller_sig, "Net") == false {
                            cc = _cwarning(cc, "E0302", "function '" + name + "' requires effect [Net] but '" + cc.fn_current_name + "' does not declare [Net]")
                        }
                        if sig.has_ffi && fn_has_effect(caller_sig, "Ffi") == false {
                            cc = _cwarning(cc, "E0303", "function '" + name + "' requires effect [Ffi] but '" + cc.fn_current_name + "' does not declare [Ffi]")
                        }
                        if sig.has_async && fn_has_effect(caller_sig, "Async") == false {
                            cc = _cwarning(cc, "E0304", "function '" + name + "' requires effect [Async] but '" + cc.fn_current_name + "' does not declare [Async]")
                        }
                    }
                }
                if fn_is_generic(sig) {
                    // Infer type args from call arguments
                    result := _check_generic_call(cc, sig)
                    return result
                }
                cr := _check_call_args_sig(cc, sig)
                return cr
            }
            // Check effects for built-in I/O functions (warning only for smooth adoption)
            if (name == "println" || name == "print" || name == "eprintln") &&
               cc.fn_current_name != "" && cc.fn_current_name != "_entry" && cc.fn_current_name != "_test" {
                caller_sig := reg_find_fn(cc.registry, cc.fn_current_name)
                if caller_sig.name != "" && fn_has_effect(caller_sig, "Io") == false {
                    cc = _cwarning(cc, "W0100", name + " requires effect [Io] but " + cc.fn_current_name + " is pure or missing [Io]")
                }
            }
            // Check effects for builtin _aria* functions
            if cc.fn_current_name != "" && cc.fn_current_name != "_entry" && cc.fn_current_name != "_test" {
                builtin_eff := _builtin_effect(name)
                if builtin_eff != "" {
                    caller_sig := reg_find_fn(cc.registry, cc.fn_current_name)
                    if caller_sig.name != "" && fn_has_effect(caller_sig, builtin_eff) == false {
                        mut eff_code := "E0300"
                        if builtin_eff == "Fs" { eff_code = "E0301" }
                        if builtin_eff == "Net" { eff_code = "E0302" }
                        if builtin_eff == "Ffi" { eff_code = "E0303" }
                        if builtin_eff == "Async" { eff_code = "E0304" }
                        cc = _cwarning(cc, eff_code, "'" + name + "' requires effect [" + builtin_eff + "] but '" + cc.fn_current_name + "' does not declare [" + builtin_eff + "]")
                    }
                }
            }
            // Unknown function — still consume args
            cr := _check_call_args(cc, TY_UNKNOWN)
            return CE{c: cr.c, type_id: TY_UNKNOWN}
        }

        // Check for generic struct literal: Name[Type]{...}
        lb := "\{"
        if _ck2(cc) == "[" {
            sdef := reg_find_struct(cc.registry, name)
            if sdef.name != "" && struct_is_generic(sdef) {
                result := _check_generic_struct_lit(cc, name, sdef)
                return result
            }
        }

        // Check for struct literal
        if _ck2(cc) == lb {
            // Could be struct literal
            tid := resolve_type_name(cc.store, name)
            if tid != TY_UNKNOWN {
                sr := _check_struct_lit(cc, name, tid)
                return sr
            }
        }

        // None — empty Optional
        if name == "None" {
            new_st := store_add(cc.store, mk_optional_type(TY_UNKNOWN))
            cc = _cset_store(cc, new_st)
            return CE{c: cc, type_id: store_last_id(cc.store)}
        }

        // Variable lookup
        env_type := _env_lookup(cc, name)
        if env_type != TY_UNKNOWN {
            return CE{c: cc, type_id: env_type}
        }

        // Lookup fn sig (for function references)
        sig := reg_find_fn(cc.registry, name)
        if sig.name != "" {
            return CE{c: cc, type_id: sig.return_type}
        }

        // Check builtins
        if name == "true" { return CE{c: cc, type_id: TY_BOOL} }
        if name == "false" { return CE{c: cc, type_id: TY_BOOL} }

        return CE{c: cc, type_id: TY_UNKNOWN}
    }

    if k == "(" {
        // Grouped expression or tuple literal
        mut cc := _cadv(c)
        cc = _cskip_nl(cc)
        result := _check_expr_full(cc)
        cc = result.c
        cc = _cskip_nl(cc)
        if _ck2(cc) == "," {
            // Tuple literal: (expr1, expr2, ...)
            mut elem_ids := i2s(result.type_id)
            mut arity := 1
            while _ck2(cc) == "," && _ck2(cc) != "EOF" {
                cc = _cadv(cc)  // skip comma
                cc = _cskip_nl(cc)
                if _ck2(cc) != ")" {
                    er := _check_expr_full(cc)
                    cc = er.c
                    elem_ids = elem_ids + "," + i2s(er.type_id)
                    arity = arity + 1
                }
                cc = _cskip_nl(cc)
            }
            if _ck2(cc) == ")" { cc = _cadv(cc) }
            new_store := store_add(cc.store, mk_tuple_type(elem_ids, arity))
            cc = _cset_store(cc, new_store)
            return CE{c: cc, type_id: store_last_id(cc.store)}
        }
        // Single grouped expression
        while _ck2(cc) != ")" && _ck2(cc) != "EOF" { cc = _cadv(cc) }
        if _ck2(cc) == ")" { cc = _cadv(cc) }
        return CE{c: cc, type_id: result.type_id}
    }

    if k == "[" {
        // Array literal
        mut cc := _cadv(c)
        cc = _cskip_nl(cc)
        mut elem_type := TY_UNKNOWN
        mut count := 0
        while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
            cc = _cskip_nl(cc)
            result := _check_expr_full(cc)
            cc = result.c
            if count == 0 {
                elem_type = result.type_id
            } else if elem_type != TY_UNKNOWN && result.type_id != TY_UNKNOWN {
                // Verify element type consistency
                if is_assignable(cc.store, result.type_id, elem_type) == false {
                    q := _q()
                    cc = _cerror(cc, E0100, "array element type mismatch: expected " + q + format_type(cc.store, elem_type) + q + ", got " + q + format_type(cc.store, result.type_id) + q)
                }
            }
            count = count + 1
            cc = _cskip_nl(cc)
            if _ck2(cc) == "," { cc = _cadv(cc) }
        }
        if _ck2(cc) == "]" { cc = _cadv(cc) }
        new_st := store_add(cc.store, mk_array_type(elem_type))
        cc = _cset_store(cc, new_st)
        return CE{c: cc, type_id: store_last_id(cc.store)}
    }

    if k == "fn" {
        // Closure — skip and return Unknown for now
        mut cc := _cadv(c)
        if _ck2(cc) == "(" {
            cc = _cadv(cc)
            while _ck2(cc) != ")" && _ck2(cc) != "EOF" { cc = _cadv(cc) }
            if _ck2(cc) == ")" { cc = _cadv(cc) }
        }
        if _ck2(cc) == "->" {
            cc = _cadv(cc)
            cc = _skip_type_toks(cc)
        }
        if _ck2(cc) == "=>" {
            cc = _cadv(cc)
            result := _check_expr_full(cc)
            cc = result.c
        }
        return CE{c: cc, type_id: TY_UNKNOWN}
    }

    // Unknown
    CE{c: _cadv(c), type_id: TY_UNKNOWN}
}

// --- Check function call arguments ---

fn _check_call_args(c: Checker, callee_type: i64) -> CE {
    mut cc := _cadv(c)  // skip (
    cc = _cskip_nl(cc)
    mut arg_count := 0
    while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
        cc = _cskip_nl(cc)
        result := _check_expr_full(cc)
        cc = result.c
        arg_count = arg_count + 1
        cc = _cskip_nl(cc)
        if _ck2(cc) == "," { cc = _cadv(cc) }
    }
    if _ck2(cc) == ")" { cc = _cadv(cc) }
    return CE{c: cc, type_id: callee_type}
}

// Check call arguments with type validation against function signature
fn _check_call_args_sig(c: Checker, sig: FnSig) -> CE {
    mut cc := _cadv(c)  // skip (
    cc = _cskip_nl(cc)
    mut arg_idx := 1  // param_types[0] is sentinel
    while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
        cc = _cskip_nl(cc)
        result := _check_expr_full(cc)
        cc = result.c
        // Validate argument type against parameter type (skip unknowns and type vars)
        if arg_idx < sig.param_types.len() {
            expected := sig.param_types[arg_idx]
            if expected != TY_UNKNOWN && expected > 0 && result.type_id != TY_UNKNOWN && result.type_id > 0 {
                // Skip validation if either side involves type variables or unknown wrapping
                exp_info := store_get(cc.store, expected)
                res_info := store_get(cc.store, result.type_id)
                exp_kn := type_kind_name(exp_info.kind)
                res_kn := type_kind_name(res_info.kind)
                mut should_check := true
                if exp_kn == "TypeVar" { should_check = false }
                if res_kn == "TypeVar" { should_check = false }
                if res_kn == "Unknown" { should_check = false }
                if exp_kn == "Unknown" { should_check = false }
                // Skip if wrapping unknown (e.g. Optional[Unknown], Result[Unknown,...])
                if res_info.type_id == TY_UNKNOWN && (res_kn == "Optional" || res_kn == "Result" || res_kn == "Array") { should_check = false }
                if exp_info.type_id == TY_UNKNOWN && (exp_kn == "Optional" || exp_kn == "Result" || exp_kn == "Array") { should_check = false }
                if should_check {
                    if is_assignable(cc.store, result.type_id, expected) == false {
                        q := _q()
                        pname := ""
                        if arg_idx < sig.param_names.len() { pname = sig.param_names[arg_idx] }
                        cc = _cerror(cc, E0100, "argument " + q + pname + q + " expects " + format_type(cc.store, expected) + ", got " + format_type(cc.store, result.type_id))
                    }
                }
            }
        }
        arg_idx = arg_idx + 1
        cc = _cskip_nl(cc)
        if _ck2(cc) == "," { cc = _cadv(cc) }
    }
    if _ck2(cc) == ")" { cc = _cadv(cc) }
    return CE{c: cc, type_id: sig.return_type}
}

// --- Check generic function call: infer type args, register specialization ---

// Check multi-bounds: split "Eq+Hash+Clone" and verify each
fn _check_multi_bound(c: Checker, type_name: str, bound: str, param_name: str) -> Checker {
    mut cc := c
    // Split bound on +
    mut start := 0
    mut i := 0
    while i <= bound.len() {
        mut at_sep := false
        if i == bound.len() { at_sep = true }
        if i < bound.len() && bound.charAt(i) == "+" { at_sep = true }
        if at_sep && i > start {
            single := bound.substring(start, i)
            if treg_has_impl(cc.treg, type_name, single) == false {
                cc = _cerror(cc, E0106, "type " + type_name + " does not satisfy bound " + single + " for " + param_name)
            }
            start = i + 1
        }
        i = i + 1
    }
    cc
}

fn _check_generic_call(c: Checker, sig: FnSig) -> CE {
    mut cc := _cadv(c)  // skip (
    cc = _cskip_nl(cc)
    // Collect argument types (up to 8 args)
    mut arg_type_0 := 0
    mut arg_type_1 := 0
    mut arg_type_2 := 0
    mut arg_type_3 := 0
    mut arg_type_4 := 0
    mut arg_type_5 := 0
    mut arg_type_6 := 0
    mut arg_type_7 := 0
    mut arg_count := 0
    while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
        cc = _cskip_nl(cc)
        result := _check_expr_full(cc)
        cc = result.c
        if arg_count == 0 { arg_type_0 = result.type_id }
        if arg_count == 1 { arg_type_1 = result.type_id }
        if arg_count == 2 { arg_type_2 = result.type_id }
        if arg_count == 3 { arg_type_3 = result.type_id }
        if arg_count == 4 { arg_type_4 = result.type_id }
        if arg_count == 5 { arg_type_5 = result.type_id }
        if arg_count == 6 { arg_type_6 = result.type_id }
        if arg_count == 7 { arg_type_7 = result.type_id }
        arg_count = arg_count + 1
        cc = _cskip_nl(cc)
        if _ck2(cc) == "," { cc = _cadv(cc) }
    }
    if _ck2(cc) == ")" { cc = _cadv(cc) }

    // Infer type arguments by matching param types (TypeVars) to arg types
    // Find the TypeVar IDs for each generic param
    mut tv_id_0 := 0
    mut tv_id_1 := 0
    mut tv_id_2 := 0
    mut concrete_0 := 0
    mut concrete_1 := 0
    mut concrete_2 := 0
    if sig.generic_count > 0 {
        tv_id_0 = resolve_type_name(cc.store, sig.generic_name_0)
    }
    if sig.generic_count > 1 {
        tv_id_1 = resolve_type_name(cc.store, sig.generic_name_1)
    }
    if sig.generic_count > 2 {
        tv_id_2 = resolve_type_name(cc.store, sig.generic_name_2)
    }

    // Match each param to its arg — if param type is a TypeVar, the arg provides the concrete type
    mut pi := 1
    while pi < sig.param_types.len() {
        pt := sig.param_types[pi]
        mut at := 0
        ai := pi - 1
        if ai == 0 { at = arg_type_0 }
        if ai == 1 { at = arg_type_1 }
        if ai == 2 { at = arg_type_2 }
        if ai == 3 { at = arg_type_3 }
        if ai == 4 { at = arg_type_4 }
        if ai == 5 { at = arg_type_5 }
        if ai == 6 { at = arg_type_6 }
        if ai == 7 { at = arg_type_7 }
        if at > 0 && at != TY_UNKNOWN {
            if pt == tv_id_0 && tv_id_0 > 0 { concrete_0 = at }
            if pt == tv_id_1 && tv_id_1 > 0 { concrete_1 = at }
            if pt == tv_id_2 && tv_id_2 > 0 { concrete_2 = at }
        }
        pi = pi + 1
    }

    // Build specialized name
    mut spec_name := sig.name
    if sig.generic_count > 0 && concrete_0 > 0 {
        spec_name = spec_name + "_" + _type_name_suffix(cc.store, concrete_0)
    }
    if sig.generic_count > 1 && concrete_1 > 0 {
        spec_name = spec_name + "_" + _type_name_suffix(cc.store, concrete_1)
    }
    if sig.generic_count > 2 && concrete_2 > 0 {
        spec_name = spec_name + "_" + _type_name_suffix(cc.store, concrete_2)
    }

    // Check if specialization already exists
    existing := reg_find_mono(cc.registry, spec_name)
    if existing.specialized_name == "" {
        // Create specialized FnSig with substituted types
        mut sp_ptypes := [0]
        pi = 1
        while pi < sig.param_types.len() {
            mut pt := sig.param_types[pi]
            if pt == tv_id_0 && tv_id_0 > 0 { pt = concrete_0 }
            if pt == tv_id_1 && tv_id_1 > 0 { pt = concrete_1 }
            if pt == tv_id_2 && tv_id_2 > 0 { pt = concrete_2 }
            sp_ptypes = sp_ptypes.append(pt)
            pi = pi + 1
        }
        mut sp_ret := sig.return_type
        if sp_ret == tv_id_0 && tv_id_0 > 0 { sp_ret = concrete_0 }
        if sp_ret == tv_id_1 && tv_id_1 > 0 { sp_ret = concrete_1 }
        if sp_ret == tv_id_2 && tv_id_2 > 0 { sp_ret = concrete_2 }

        sp_sig := new_fn_sig(spec_name, sig.param_names, sp_ptypes, sp_ret, sig.error_type)
        cc = _cset_reg(cc, reg_add_fn(cc.registry, sp_sig))

        spec := MonoSpec{generic_name: sig.name, specialized_name: spec_name,
                         type_arg_0: concrete_0, type_arg_1: concrete_1, type_arg_2: concrete_2}
        cc = _cset_reg(cc, reg_add_mono(cc.registry, spec))
    }

    // Check trait bounds (supports multi-bounds: "Eq+Hash+Clone")
    if sig.generic_bound_0 != "" && concrete_0 > 0 && concrete_0 != TY_UNKNOWN {
        cname := format_type(cc.store, concrete_0)
        cc = _check_multi_bound(cc, cname, sig.generic_bound_0, sig.generic_name_0)
    }
    if sig.generic_bound_1 != "" && concrete_1 > 0 && concrete_1 != TY_UNKNOWN {
        cname := format_type(cc.store, concrete_1)
        cc = _check_multi_bound(cc, cname, sig.generic_bound_1, sig.generic_name_1)
    }
    if sig.generic_bound_2 != "" && concrete_2 > 0 && concrete_2 != TY_UNKNOWN {
        cname := format_type(cc.store, concrete_2)
        cc = _check_multi_bound(cc, cname, sig.generic_bound_2, sig.generic_name_2)
    }

    // Determine return type
    mut ret_type := sig.return_type
    if ret_type == tv_id_0 && tv_id_0 > 0 { ret_type = concrete_0 }
    if ret_type == tv_id_1 && tv_id_1 > 0 { ret_type = concrete_1 }
    if ret_type == tv_id_2 && tv_id_2 > 0 { ret_type = concrete_2 }
    if ret_type == 0 { ret_type = TY_UNKNOWN }

    CE{c: cc, type_id: ret_type}
}

// --- Check method call ---

fn _check_method_call(c: Checker, obj_type: i64, method: str) -> CE {
    mut cc := _cadv(c)  // skip (
    cc = _cskip_nl(cc)
    while _ck2(cc) != ")" && _ck2(cc) != "EOF" {
        cc = _cskip_nl(cc)
        result := _check_expr_full(cc)
        cc = result.c
        cc = _cskip_nl(cc)
        if _ck2(cc) == "," { cc = _cadv(cc) }
    }
    if _ck2(cc) == ")" { cc = _cadv(cc) }

    // Conversion methods
    if method == "toStr" || method == "toString" {
        return CE{c: cc, type_id: TY_STR}
    }

    // Built-in method return types
    if method == "len" { return CE{c: cc, type_id: TY_I64} }
    if method == "contains" { return CE{c: cc, type_id: TY_BOOL} }
    if method == "starts_with" || method == "startsWith" { return CE{c: cc, type_id: TY_BOOL} }
    if method == "ends_with" || method == "endsWith" { return CE{c: cc, type_id: TY_BOOL} }
    if method == "indexOf" { return CE{c: cc, type_id: TY_I64} }
    if method == "is_empty" { return CE{c: cc, type_id: TY_BOOL} }

    // String methods returning str
    if method == "trim" || method == "to_upper" || method == "to_lower" ||
       method == "replace" || method == "substring" || method == "charAt" ||
       method == "toUpper" || method == "toLower" {
        return CE{c: cc, type_id: TY_STR}
    }

    // split returns [str]
    if method == "split" {
        new_st := store_add(cc.store, mk_array_type(TY_STR))
        cc = _cset_store(cc, new_st)
        return CE{c: cc, type_id: store_last_id(cc.store)}
    }

    // append returns same array type
    if method == "append" {
        return CE{c: cc, type_id: obj_type}
    }

    CE{c: cc, type_id: TY_UNKNOWN}
}

// --- Check field access ---

fn _check_field(c: Checker, obj_type: i64, field: str) -> CE {
    info := store_get(c.store, obj_type)
    if type_kind_name(info.kind) == "Named" {
        fi := reg_find_field(c.registry, info.name, field)
        if fi.name != "" {
            return CE{c: c, type_id: fi.type_id}
        }
        if obj_type != TY_UNKNOWN {
            q := _q()
            cc := _cerror(c, E0107, "field " + q + field + q + " not found on type " + q + info.name + q)
            return CE{c: cc, type_id: TY_UNKNOWN}
        }
    }
    CE{c: c, type_id: TY_UNKNOWN}
}

// --- Check struct literal ---

fn _check_struct_lit(c: Checker, name: str, type_id: i64) -> CE {
    lb := "\{"
    rb := "\}"
    mut cc := _cadv(c)  // skip {
    cc = _cskip_nl(cc)
    while _ck2(cc) != rb && _ck2(cc) != "EOF" {
        if _ck2(cc) == "IDENT" {
            field_name := _ccur(cc).text
            cc = _cadv(cc)  // skip field name
            if _ck2(cc) == ":" {
                cc = _cadv(cc)
                result := _check_expr_full(cc)
                cc = result.c
                // Check field type matches expected
                fi := reg_find_field(cc.registry, name, field_name)
                if fi.name != "" && result.type_id != TY_UNKNOWN && fi.type_id != TY_UNKNOWN {
                    if types_equal(cc.store, result.type_id, fi.type_id) == false {
                        q := _q()
                        cc = _cerror(cc, E0100, "field " + q + field_name + q + " expects " + format_type(cc.store, fi.type_id) + ", got " + format_type(cc.store, result.type_id))
                    }
                }
            }
        } else {
            cc = _cadv(cc)
        }
        cc = _cskip_nl(cc)
        if _ck2(cc) == "," {
            cc = _cadv(cc)
            cc = _cskip_nl(cc)
        }
    }
    if _ck2(cc) == rb { cc = _cadv(cc) }
    CE{c: cc, type_id: type_id}
}

// --- Check generic struct literal: Name[Type]{...} ---

fn _check_generic_struct_lit(c: Checker, name: str, sdef: StructDef) -> CE {
    mut cc := _cadv(c)  // skip [
    // Parse type arguments
    mut ta_0 := 0
    mut ta_1 := 0
    mut ta_2 := 0
    mut ta_count := 0
    while _ck2(cc) != "]" && _ck2(cc) != "EOF" {
        ta := _parse_type_ann(cc)
        cc = ta.c
        if ta_count == 0 { ta_0 = ta.type_id }
        if ta_count == 1 { ta_1 = ta.type_id }
        if ta_count == 2 { ta_2 = ta.type_id }
        ta_count = ta_count + 1
        if _ck2(cc) == "," { cc = _cadv(cc) }
    }
    if _ck2(cc) == "]" { cc = _cadv(cc) }

    // Build specialized struct name: Name_Type0_Type1
    mut spec_name := name
    if ta_count > 0 { spec_name = spec_name + "_" + _type_name_suffix(cc.store, ta_0) }
    if ta_count > 1 { spec_name = spec_name + "_" + _type_name_suffix(cc.store, ta_1) }
    if ta_count > 2 { spec_name = spec_name + "_" + _type_name_suffix(cc.store, ta_2) }

    // Check if specialization already exists
    existing := reg_find_struct(cc.registry, spec_name)
    if existing.name == "" {
        // Create specialized StructDef with substituted field types
        // Find TypeVar IDs for each generic param
        mut tv_0 := 0
        mut tv_1 := 0
        mut tv_2 := 0
        if sdef.generic_count > 0 { tv_0 = resolve_type_name(cc.store, sdef.generic_name_0) }
        if sdef.generic_count > 1 { tv_1 = resolve_type_name(cc.store, sdef.generic_name_1) }
        if sdef.generic_count > 2 { tv_2 = resolve_type_name(cc.store, sdef.generic_name_2) }

        // Substitute field types
        mut sp_fields := [FieldInfo{name: "", type_id: 0}]
        mut fi := 1
        while fi < sdef.fields.len() {
            fld := sdef.fields[fi]
            mut ft := fld.type_id
            if ft == tv_0 && tv_0 > 0 { ft = ta_0 }
            if ft == tv_1 && tv_1 > 0 { ft = ta_1 }
            if ft == tv_2 && tv_2 > 0 { ft = ta_2 }
            sp_fields = sp_fields.append(FieldInfo{name: fld.name, type_id: ft})
            fi = fi + 1
        }

        sp_def := new_struct_def(spec_name, sp_fields, false, [""])
        cc = _cset_reg(cc, reg_add_struct(cc.registry, sp_def))
        // Register as named type
        new_st := store_add(cc.store, mk_named_type(spec_name))
        cc = _cset_store(cc, new_st)
    }

    // Resolve specialized type ID
    spec_tid := resolve_type_name(cc.store, spec_name)

    // Now parse the struct literal body: { field: expr, ... }
    lb := "\{"
    if _ck2(cc) == lb {
        sr := _check_struct_lit(cc, spec_name, spec_tid)
        return sr
    }

    CE{c: cc, type_id: spec_tid}
}

// --- Check if expression ---

fn _check_if(c: Checker) -> CE {
    mut cc := _cadv(c)  // skip if
    lb := "\{"
    // Check condition
    mut cond_type := TY_UNKNOWN
    while _ck2(cc) != lb && _ck2(cc) != "EOF" {
        result := _check_primary(cc)
        cc = result.c
        cond_type = result.type_id
        // Handle operators in condition
        k := _ck2(cc)
        if k == "==" || k == "!=" || k == "<" || k == ">" || k == "<=" || k == ">=" ||
           k == "&&" || k == "||" {
            cc = _cadv(cc)
            right := _check_primary(cc)
            cc = right.c
            cond_type = TY_BOOL
        } else if _is_cont(k) == false || k == lb {
            // done with condition
        } else {
            cc = _cadv(cc)
        }
    }

    // Then block
    then_result := _check_block(cc)
    cc = then_result.c
    mut result_type := then_result.type_id

    // Else
    if _ck2(cc) == "else" {
        cc = _cadv(cc)
        mut else_type := TY_UNKNOWN
        if _ck2(cc) == "if" {
            else_result := _check_if(cc)
            cc = else_result.c
            else_type = else_result.type_id
        } else {
            else_result := _check_block(cc)
            cc = else_result.c
            else_type = else_result.type_id
        }
        // If both branches have known types, verify compatibility
        if result_type != TY_UNKNOWN && else_type != TY_UNKNOWN &&
           result_type != TY_UNIT && else_type != TY_UNIT &&
           result_type != TY_NEVER && else_type != TY_NEVER {
            if is_assignable(cc.store, else_type, result_type) == false &&
               is_assignable(cc.store, result_type, else_type) == false {
                q := _q()
                cc = _cerror(cc, E0100, "if/else branch type mismatch: then returns " + q + format_type(cc.store, result_type) + q + ", else returns " + q + format_type(cc.store, else_type) + q)
            }
        }
        // Use the more specific type (prefer non-Never)
        if result_type == TY_NEVER { result_type = else_type }
    }

    CE{c: cc, type_id: result_type}
}

// --- Check match expression ---

fn _check_match(c: Checker) -> CE {
    mut cc := _cadv(c)  // skip match
    lb := "\{"
    rb := "\}"

    // Subject
    mut subj_type := TY_UNKNOWN
    while _ck2(cc) != lb && _ck2(cc) != "EOF" {
        result := _check_primary(cc)
        cc = result.c
        subj_type = result.type_id
        if _is_cont(_ck2(cc)) && _ck2(cc) != lb {
            cc = _cadv(cc)
        }
    }

    cc = _cskip_nl(cc)
    if _ck2(cc) != lb { return CE{c: cc, type_id: TY_UNKNOWN} }
    cc = _cadv(cc)  // skip {
    cc = _cskip_nl(cc)

    // Exhaustiveness tracking
    mut has_wildcard := false
    mut covered := [""]  // sentinel at index 0
    mut has_true := false
    mut has_false := false

    mut arm_type := TY_UNKNOWN
    mut arm_count := 0
    while _ck2(cc) != rb && _ck2(cc) != "EOF" {
        // Read pattern for exhaustiveness tracking
        // Note: `is` type-check in guards is reserved for future versions (not in v0.1 spec)
        mut arm_is_guarded := false
        // Float, tuple (, and array [ patterns are never exhaustive on their own
        // Just skip to => for these pattern types
        if _ck2(cc) == "IDENT" {
            pat_name := _ccur(cc).text
            // Check for named pattern: name @ Pattern — skip name and @ to get real pattern
            mut real_name := pat_name
            atp := cc.pos + 1
            if atp < cc.tokens.len() {
                if token_name(cc.tokens[atp].kind) == "@" {
                    // Skip past name and @ to find real pattern
                    atp2 := atp + 1
                    if atp2 < cc.tokens.len() {
                        if token_name(cc.tokens[atp2].kind) == "IDENT" {
                            real_name = cc.tokens[atp2].text
                        }
                    }
                }
            }
            if pat_name == "_" {
                // Check if guarded: scan ahead to => looking for "if"
                mut scan := cc
                mut found_guard := false
                while _ck2(scan) != "=>" && _ck2(scan) != "EOF" {
                    if _ck2(scan) == "if" { found_guard = true }
                    scan = _cadv(scan)
                }
                if found_guard == false { has_wildcard = true }
                arm_is_guarded = found_guard
            } else if real_name == "true" {
                has_true = true
            } else if real_name == "false" {
                has_false = true
            } else {
                // Check if name is a known variant — if not, it's a binding (catch-all)
                mut is_variant_name := false
                mut si := 1
                while si < cc.registry.struct_defs.len() {
                    sdef := cc.registry.struct_defs[si]
                    if sdef.is_sum {
                        mut vvi := 1
                        while vvi < sdef.variant_names.len() {
                            if sdef.variant_names[vvi] == real_name { is_variant_name = true }
                            vvi = vvi + 1
                        }
                    }
                    si = si + 1
                }
                if is_variant_name == false {
                    // Binding pattern — catch-all (unless guarded)
                    mut scan := cc
                    mut found_guard := false
                    while _ck2(scan) != "=>" && _ck2(scan) != "EOF" {
                        if _ck2(scan) == "if" { found_guard = true }
                        scan = _cadv(scan)
                    }
                    if found_guard == false { has_wildcard = true }
                    arm_is_guarded = found_guard
                }
                // Track covered variant (only if not guarded)
                // Also handle or-patterns: A | B => ...
                if arm_is_guarded == false {
                    covered = covered.append(real_name)
                }
            }
        }
        // Scan pattern for or-patterns: skip to =>, collecting | variants
        while _ck2(cc) != "=>" && _ck2(cc) != "EOF" {
            if _ck2(cc) == "|" {
                cc = _cadv(cc)
                if _ck2(cc) == "IDENT" && arm_is_guarded == false {
                    covered = covered.append(_ccur(cc).text)
                }
            }
            cc = _cadv(cc)
        }
        if _ck2(cc) == "=>" { cc = _cadv(cc) }
        cc = _cskip_nl(cc)

        // Check arm body
        if _ck2(cc) == lb {
            body := _check_block(cc)
            cc = body.c
            if arm_count == 0 { arm_type = body.type_id }
        } else {
            body := _check_expr_full(cc)
            cc = body.c
            if arm_count == 0 { arm_type = body.type_id }
        }
        arm_count = arm_count + 1
        cc = _cskip_nl(cc)
    }
    if _ck2(cc) == rb { cc = _cadv(cc) }

    // Exhaustiveness check
    if has_wildcard == false {
        info := store_get(cc.store, subj_type)
        kind_name := type_kind_name(info.kind)

        // Sum type exhaustiveness
        if kind_name == "Named" {
            iname := type_info_name(info)
            def := reg_find_struct(cc.registry, iname)
            if def.is_sum {
                if def.variant_names.len() > 1 {
                    mut vi := 1
                    mut first_missing := ""
                    while vi < def.variant_names.len() {
                        vname := def.variant_names[vi]
                        mut found := false
                        mut ci := 1
                        while ci < covered.len() {
                            if covered[ci] == vname { found = true }
                            ci = ci + 1
                        }
                        if found == false {
                            if first_missing == "" {
                                first_missing = vname
                            }
                        }
                        vi = vi + 1
                    }
                    if first_missing != "" {
                        cc = _cerror(cc, E0400, "non-exhaustive match: variant '" + first_missing + "' not covered")
                    }
                }
            }
            // Optional exhaustiveness (Some/None)
            if iname == "Optional" || iname == "Option" {
                mut has_some := false
                mut has_none := false
                mut oi := 1
                while oi < covered.len() {
                    if covered[oi] == "Some" { has_some = true }
                    if covered[oi] == "None" { has_none = true }
                    oi = oi + 1
                }
                if (has_some == false || has_none == false) {
                    mut missing := "Some"
                    if has_some { missing = "None" }
                    cc = _cerror(cc, E0400, "non-exhaustive match: variant '" + missing + "' not covered")
                }
            }
            // Result exhaustiveness (Ok/Err)
            if iname == "Result" {
                mut has_ok := false
                mut has_err := false
                mut ri := 1
                while ri < covered.len() {
                    if covered[ri] == "Ok" { has_ok = true }
                    if covered[ri] == "Err" { has_err = true }
                    ri = ri + 1
                }
                if (has_ok == false || has_err == false) {
                    mut missing := "Ok"
                    if has_ok { missing = "Err" }
                    cc = _cerror(cc, E0400, "non-exhaustive match: variant '" + missing + "' not covered")
                }
            }
        }

        // Bool exhaustiveness
        if kind_name == "bool" || subj_type == TY_BOOL {
            if (has_true == false || has_false == false) {
                mut missing := "true"
                if has_true { missing = "false" }
                cc = _cerror(cc, E0400, "non-exhaustive match: case '" + missing + "' not covered")
            }
        }

        // Optional/Result from type store
        if kind_name == "Optional" {
            mut has_some := false
            mut has_none := false
            mut oi := 1
            while oi < covered.len() {
                if covered[oi] == "Some" { has_some = true }
                if covered[oi] == "None" { has_none = true }
                oi = oi + 1
            }
            if (has_some == false || has_none == false) {
                mut missing := "Some"
                if has_some { missing = "None" }
                cc = _cerror(cc, E0400, "non-exhaustive match: variant '" + missing + "' not covered")
            }
        }
        if kind_name == "Result" {
            mut has_ok := false
            mut has_err := false
            mut ri := 1
            while ri < covered.len() {
                if covered[ri] == "Ok" { has_ok = true }
                if covered[ri] == "Err" { has_err = true }
                ri = ri + 1
            }
            if (has_ok == false || has_err == false) {
                mut missing := "Ok"
                if has_ok { missing = "Err" }
                cc = _cerror(cc, E0400, "non-exhaustive match: variant '" + missing + "' not covered")
            }
        }
    }

    CE{c: cc, type_id: arm_type}
}

// --- Check for loop ---

fn _check_for(c: Checker) -> CE {
    mut cc := _cadv(c)  // skip for
    lb := "\{"

    // Loop variable
    mut var_name := ""
    if _ck2(cc) == "IDENT" {
        var_name = _ccur(cc).text
        cc = _cadv(cc)
    }
    if _ck2(cc) == "in" { cc = _cadv(cc) }

    // Iterator expression
    mut iter_type := TY_UNKNOWN
    while _ck2(cc) != lb && _ck2(cc) != "EOF" {
        result := _check_expr_full(cc)
        cc = result.c
        iter_type = result.type_id
    }

    // Determine element type
    mut elem_type := TY_UNKNOWN
    info := store_get(cc.store, iter_type)
    if type_kind_name(info.kind) == "Array" {
        elem_type = info.type_id
    }

    // Register loop variable
    if var_name != "" {
        cc = _env_add(cc, var_name, elem_type, 0)
    }

    cc = _cset_loop(cc, true)
    body := _check_block(cc)
    cc = body.c
    cc = _cset_loop(cc, false)
    CE{c: cc, type_id: TY_UNIT}
}

// --- Check while loop ---

fn _check_while(c: Checker) -> CE {
    mut cc := _cadv(c)  // skip while
    lb := "\{"
    while _ck2(cc) != lb && _ck2(cc) != "EOF" {
        result := _check_primary(cc)
        cc = result.c
        if _is_cont(_ck2(cc)) && _ck2(cc) != lb { cc = _cadv(cc) }
    }
    cc = _cset_loop(cc, true)
    body := _check_block(cc)
    cc = body.c
    cc = _cset_loop(cc, false)
    CE{c: cc, type_id: TY_UNIT}
}

// --- Check loop ---

fn _check_loop(c: Checker) -> CE {
    cc := _cadv(c)  // skip loop
    body := _check_block(cc)
    CE{c: body.c, type_id: TY_UNIT}
}

// ============================================================
// Public API
// ============================================================

fn check(tokens: [Token], index: DeclIndex, pool: NodePool, table: SymbolTable, file: str) -> CheckResult {
    mut c := _new_checker(tokens, pool, table, file)

    // Pass 1: register type declarations
    c = _pass1_types(c, index)

    // Pass 2: register function signatures
    c = _pass2_fns(c, index)

    // Pass 3: check bodies
    c = _pass3_bodies(c, index)

    CheckResult{store: c.store, registry: c.registry, treg: c.treg, diagnostics: c.diagnostics}
}
