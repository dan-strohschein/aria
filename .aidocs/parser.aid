---

@type DeclInfo
@kind struct
@fields
  kind: DeclKind — Declaration type
  name: str — Declaration name
  token_start: i64 — Token index where declaration starts
  body_start: i64 — Token index where body starts
  body_end: i64 — Token index where body ends
  is_pub: bool — Whether declaration is public
  node_idx: i64 — Index into NodePool
@source_file src/parser/ast.aria
