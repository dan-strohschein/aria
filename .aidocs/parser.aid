@module parser
@lang aria
@aid_version 0.2
@purpose Recursive descent parser producing AST node pool and declaration index
@depends [lexer, diagnostic]

---

@type ExprKind
@kind sum
@variants
  EkIntLit — Integer literal expression
  EkFloatLit — Float literal expression
  EkStringLit — String literal expression
  EkBoolLit — Boolean literal expression
  EkIdent — Identifier reference
  EkBinary — Binary operator expression
  EkUnary — Unary operator expression
  EkCall — Function call
  EkMethodCall — Method call (dot syntax)
  EkFieldAccess — Field access (dot syntax)
  EkIndex — Index expression (brackets)
  EkBlock — Block expression (braces)
  EkIf — If/else expression
  EkMatch — Match expression
  EkClosure — Closure expression
  EkArray — Array literal
  EkStruct — Struct literal
  EkAssign — Assignment expression
  EkBinding — Variable binding (:= or mut)
  EkReturn — Return expression
  EkBreak — Break expression
  EkContinue — Continue expression
  EkFor — For loop
  EkWhile — While loop
  EkLoop — Infinite loop
  EkDefer — Defer expression
  EkWith — With expression
  EkTuple — Tuple expression
  EkCatch — Catch expression
  EkPipeline — Pipeline expression (|>)
  EkRange — Range expression (.. or ..=)
  EkPropagate — Error propagation (?)
  EkAssertOk — Assert success (!)
  EkFnDecl — Function declaration
  EkTypeDecl — Type declaration
  EkEnumDecl — Enum declaration
  EkTraitDecl — Trait declaration
  EkImplDecl — Impl block declaration
  EkConstDecl — Constant declaration
  EkUseDecl — Use/import declaration
  EkParam — Function parameter
  EkField — Struct field
  EkVariant — Sum type / enum variant
  EkListComp — List comprehension
  EkYield — Yield expression
  EkSelect — Select expression
  EkNone — Sentinel / empty
@source_file src/parser/ast.aria
@source_line 13

---

@type DeclKind
@kind sum
@variants
  DkFn — Function declaration
  DkType — Type declaration
  DkEnum — Enum declaration
  DkTrait — Trait declaration
  DkImpl — Impl block
  DkConst — Constant declaration
  DkEntry — Entry block
  DkTest — Test block
  DkUse — Use/import declaration
  DkNone — Sentinel
@source_file src/parser/ast.aria
@source_line 349

---

@type Expr
@kind struct
@fields
  kind: ExprKind — Node type discriminator
  s1: str — Primary string payload (name, operator, value)
  s2: str — Secondary string payload
  b1: bool — Primary boolean flag
  b2: bool — Secondary boolean flag
  c0: i64 — Child node index 0
  c1: i64 — Child node index 1
  c2: i64 — Child node index 2
  list_start: i64 — Start index into pool for child lists
  list_count: i64 — Number of children in list
  span: Span — Source location
@source_file src/parser/ast.aria
@source_line 115

---

@type NodePool
@kind struct
@fields
  nodes: [Expr] — Flat array of all AST nodes
