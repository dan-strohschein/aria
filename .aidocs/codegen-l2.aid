@const COND_EQ
@value_type i64
@value 0
@source_file src/codegen/arm64.aria
@source_line 47
@purpose Equal (Z=1). Used after CMP for == comparison.

---

@const COND_NE
@value_type i64
@value 1
@source_file src/codegen/arm64.aria
@source_line 48
@purpose Not equal (Z=0). Used for != comparison.

---

@const COND_GE
@value_type i64
@value 10
@source_file src/codegen/arm64.aria
@source_line 57
@purpose Signed greater than or equal (N=V).

---

@const COND_LT
@value_type i64
@value 11
@source_file src/codegen/arm64.aria
@source_line 58
@purpose Signed less than (N!=V).

---

@const COND_GT
@value_type i64
@value 12
@source_file src/codegen/arm64.aria
@source_line 59
@purpose Signed greater than (Z=0 && N=V).

---

@const COND_LE
@value_type i64
@value 13
@source_file src/codegen/arm64.aria
@source_line 60
@purpose Signed less than or equal (Z=1 || N!=V).

