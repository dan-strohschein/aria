@module resolver
@lang aria
@aid_version 0.2
@purpose Name resolution, scope hierarchy, and symbol table construction
@depends [lexer, parser, diagnostic]

---

@type SymbolKind
@kind sum
@variants
  SkFunction — Function declaration
  SkType — Type declaration
  SkEnum — Enum declaration
  SkTrait — Trait declaration
  SkConst — Constant declaration
  SkVariable — Local variable binding
  SkParameter — Function parameter
  SkVariant — Sum type or enum variant
  SkModule — Module name
  SkBuiltin — Built-in symbol
  SkNone — Sentinel / not found
@source_file src/resolver/scope.aria
@source_line 13

---

@type ScopeKind
@kind sum
@variants
  ScUniverse — Top-level built-in scope
  ScModule — Module scope
  ScFunction — Function body scope
  ScBlock — Block scope (if, for, etc.)
  ScNone — Sentinel
@source_file src/resolver/scope.aria
@source_line 72

---

@type Symbol
@kind struct
@fields
  name: str — Symbol name
  kind: SymbolKind — Symbol classification
  span: Span — Declaration location
  scope_id: i64 — Scope where declared
  is_mutable: bool — Whether binding is mutable
  is_public: bool — Whether symbol is pub
