---

@type Scope
@kind struct
@fields
  kind: ScopeKind — Scope classification
  parent: i64 — Parent scope ID (-1 for root)
  name: str — Scope name (function name, module name)
  depth: i64 — Nesting depth
@source_file src/resolver/scope.aria
