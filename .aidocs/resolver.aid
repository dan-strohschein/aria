---

@type Resolver
@kind struct
@fields
  tokens: [Token] — Token stream
  pos: i64 — Current position
  table: SymbolTable — Symbol table being built
  diagnostics: DiagnosticBag — Accumulated diagnostics
  current_scope: i64 — Active scope ID
  file: str — Source file path
  is_public: bool — Whether current declaration is pub
  pool: NodePool — AST node pool
  index: DeclIndex — Declaration index
