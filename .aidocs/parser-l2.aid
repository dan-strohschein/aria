@type ParseResult
@kind struct
@purpose Combined output of build_decl_index: the declaration index, the full AST node pool, and any parse diagnostics. This is the primary data structure handed to downstream compiler stages.
@fields
  index: DeclIndex — Declaration index
  pool: NodePool — AST node pool
  diagnostics: DiagnosticBag — Parse diagnostics
