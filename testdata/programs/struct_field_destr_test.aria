// Test: Named-field struct variant destructuring in match

type Shape =
    | Circle(f64)
    | Rect(f64, f64)

entry {
    // Test 1: Tuple variant destructuring
    s1 := Circle(3.14)
    r1 := match s1 {
        Circle(r) => 1
        Rect(w, h) => 2
    }
    assert r1 == 1

    // Test 2: Second variant
    s2 := Rect(4.0, 5.0)
    r2 := match s2 {
        Circle(r) => 1
        Rect(w, h) => 2
    }
    assert r2 == 2

    print("struct_field_destr_test passed")
}
