// Test strings returned through chains of function calls
fn wrap(s: str, before: str, after: str) -> str {
    return before + s + after
}

fn quote(s: str) -> str = wrap(s, "\"", "\"")

fn bracket(s: str) -> str = wrap(s, "[", "]")

fn build_label(name: str, id: i64) -> str =
    name + "#" + id.toString()

entry {
    // Simple chain
    q := quote("hello")
    if q == "\"hello\"" {
        println("quote ok")
    }
    b := bracket("x")
    if b == "[x]" {
        println("bracket ok")
    }

    // Nested calls
    nb := bracket(quote("hi"))
    if nb == "[\"hi\"]" {
        println("nested ok")
    }

    // Chain through multiple functions
    label := build_label("item", 42)
    if label == "item#42" {
        println("label ok")
    }

    println("string_chain_test passed")
}
