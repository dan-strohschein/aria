// Test array element access

entry {
    // Build array using append (array literal with multiple elements has codegen issue)
    mut arr := [0]
    arr = arr.append(10)
    arr = arr.append(20)
    arr = arr.append(30)

    assert arr[1] == 10
    assert arr[2] == 20
    assert arr[3] == 30

    // Sum via while loop
    mut total := 0
    mut i := 1
    while i < arr.len() {
        total = total + arr[i]
        i = i + 1
    }
    assert total == 60

    println("array_pattern_test passed")
}
