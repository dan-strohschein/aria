// Test nested pattern matching (simplified — using sequential matches)

type Inner =
    | Leaf(i64)
    | Empty

type Outer =
    | Wrap(Inner)
    | None

fn unwrap_outer(val: Outer) -> i64 {
    match val {
        Wrap(inner) => match inner {
            Leaf(n) => n
            Empty => 0
        }
        None => 0 - 1
    }
}

entry {
    val := Wrap(Leaf(42))
    assert unwrap_outer(val) == 42

    val2 := Wrap(Empty)
    assert unwrap_outer(val2) == 0

    val3 := None
    assert unwrap_outer(val3) == 0 - 1

    println("nested_pattern_test passed")
}
