// Test: Nested patterns in match expressions

type Inner =
    | Leaf(i64)
    | Empty

type Outer =
    | Wrap(Inner)
    | None

entry {
    val := Wrap(Leaf(42))
    result := match val {
        Wrap(Leaf(n)) => n
        Wrap(Empty) => 0
        None => 0 - 1
    }
    assert result == 42

    val2 := Wrap(Empty)
    result2 := match val2 {
        Wrap(Leaf(n)) => n
        Wrap(Empty) => 0
        None => 0 - 1
    }
    assert result2 == 0

    val3 := None
    result3 := match val3 {
        Wrap(Leaf(n)) => n
        Wrap(Empty) => 0
        None => 0 - 1
    }
    assert result3 == 0 - 1

    print("nested_pattern: all tests passed")
}
