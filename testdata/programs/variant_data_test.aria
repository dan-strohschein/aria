type Shape =
    | Circle(i64)
    | Rect(i64, i64)
    | Empty

fn area(s: Shape) -> i64 = match s {
    Circle(r) => r * r * 3
    Rect(w, h) => w * h
    Empty => 0
    _ => 0
}

entry {
    c := Circle(5)
    r := Rect(3, 4)
    e := Empty

    assert area(c) == 75
    assert area(r) == 12
    assert area(e) == 0

    println("variant_data_test passed")
}
