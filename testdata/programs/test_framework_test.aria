fn add(a: i64, b: i64) -> i64 = a + b
fn double(x: i64) -> i64 = x * 2

test "addition works" {
    assert add(2, 3) == 5
    assert add(0, 0) == 0
    assert add(-1, 1) == 0
}

test "doubling works" {
    assert double(21) == 42
    assert double(0) == 0
    assert double(-5) == -10
}

test "combined operations" {
    r := add(double(10), 2)
    assert r == 22
}
