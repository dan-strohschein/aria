// Test closures + error handling interaction

fn apply_safe(f: fn(i64) -> i64, x: i64) -> i64 ! str {
    if x < 0 {
        return Err("negative input")
    }
    Ok(f(x))
}

entry {
    // Closure passed to fallible function
    double := fn(x: i64) -> i64 => x * 2
    r1 := apply_safe(double, 5)!
    assert r1 == 10

    // Error path with closure
    r2 := apply_safe(double, -1) catch |e| {
        0
    }
    assert r2 == 0

    // Closure with capture in fallible context
    factor := 3
    triple := fn(x: i64) -> i64 => x * factor
    r3 := apply_safe(triple, 7)!
    assert r3 == 21

    println("closure_result_test passed")
}
