// NEGATIVE TEST: type mismatches are caught at compile time
// This test verifies the positive side — correct typing works.

fn returns_int() -> i64 = 42

fn add_one(x: i64) -> i64 = x + 1

entry {
    assert returns_int() == 42
    assert add_one(10) == 11

    println("negative_type_mismatch_test passed")
}
