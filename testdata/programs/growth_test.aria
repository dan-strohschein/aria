// Test array capacity growth beyond initial 4 elements
fn build_array() -> [i64] {
    mut arr := [0]
    mut i := 1
    while i <= 100 {
        arr = arr.append(i)
        i = i + 1
    }
    arr
}

entry {
    arr := build_array()
    assert arr.len() == 101
    assert arr[1] == 1
    assert arr[100] == 100
    println("growth OK")
}
