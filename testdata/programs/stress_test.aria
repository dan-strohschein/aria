// #12: Stress test — larger program exercising compiler performance

fn fib(n: i64) -> i64 {
    if n <= 1 { return n }
    fib(n - 1) + fib(n - 2)
}

fn is_prime(n: i64) -> bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 { return false }
    mut i := 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    true
}

fn count_primes(limit: i64) -> i64 {
    mut count := 0
    mut n := 2
    while n < limit {
        if is_prime(n) { count = count + 1 }
        n = n + 1
    }
    count
}

struct Stats {
    min: i64
    max: i64
    sum: i64
    count: i64
}

fn compute_stats(arr: [i64]) -> Stats {
    mut mn := 999999999
    mut mx := -999999999
    mut sm := 0
    mut ct := 0
    mut i := 1
    while i < arr.len() {
        v := arr[i]
        if v < mn { mn = v }
        if v > mx { mx = v }
        sm = sm + v
        ct = ct + 1
        i = i + 1
    }
    Stats{min: mn, max: mx, sum: sm, count: ct}
}

fn build_array(size: i64) -> [i64] {
    mut arr := [0]
    mut i := 0
    while i < size {
        arr = arr.append(i * i)
        i = i + 1
    }
    arr
}

entry {
    // Fibonacci
    assert fib(0) == 0
    assert fib(1) == 1
    assert fib(10) == 55
    assert fib(20) == 6765

    // Prime counting
    assert count_primes(10) == 4    // 2, 3, 5, 7
    assert count_primes(20) == 8
    assert count_primes(100) == 25

    // Array building and stats
    arr := build_array(50)
    stats := compute_stats(arr)
    assert stats.count == 50
    assert stats.min == 0
    assert stats.max == 2401  // 49*49
    assert stats.sum > 0

    // Map with entries
    m := Map()
    m.set("a", 1)
    m.set("b", 2)
    m.set("c", 3)
    m.set("d", 4)
    m.set("e", 5)
    assert m.len() == 5
    assert m.get("a") == 1
    assert m.get("e") == 5

    println("stress_test passed")
}
