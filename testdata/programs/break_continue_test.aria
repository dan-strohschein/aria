// #5: Break in complex loops

entry {
    // Break from while loop
    mut i := 0
    while true {
        if i >= 5 { break }
        i = i + 1
    }
    assert i == 5

    // Break from for loop
    mut found := -1
    for j in 0..100 {
        if j * j > 50 {
            found = j
            break
        }
    }
    assert found == 8  // 8*8=64 > 50

    // Nested loops with break (inner only)
    mut outer_count := 0
    mut inner_total := 0
    mut oi := 0
    while oi < 5 {
        mut ij := 0
        while ij < 10 {
            if ij >= 3 { break }
            inner_total = inner_total + 1
            ij = ij + 1
        }
        outer_count = outer_count + 1
        oi = oi + 1
    }
    assert outer_count == 5
    assert inner_total == 15  // 5 outer * 3 inner

    // Break with accumulated value
    mut acc := 0
    for n in 0..1000 {
        acc = acc + n
        if acc > 100 {
            break
        }
    }
    assert acc > 100

    // Skip even numbers using if (instead of continue)
    mut odd_sum := 0
    for k in 0..10 {
        if k % 2 != 0 {
            odd_sum = odd_sum + k
        }
    }
    assert odd_sum == 25  // 1+3+5+7+9

    println("break_continue_test passed")
}
