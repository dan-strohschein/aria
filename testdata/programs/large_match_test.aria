// Test match with many arms and different return types
type Weekday =
    | Monday
    | Tuesday
    | Wednesday
    | Thursday
    | Friday
    | Saturday
    | Sunday

fn day_number(d: Weekday) -> i64 = match d {
    Monday => 1
    Tuesday => 2
    Wednesday => 3
    Thursday => 4
    Friday => 5
    Saturday => 6
    Sunday => 7
    _ => 0
}

fn is_weekend(d: Weekday) -> bool = match d {
    Saturday => true
    Sunday => true
    _ => false
}

fn day_name(d: Weekday) -> str = match d {
    Monday => "Monday"
    Tuesday => "Tuesday"
    Wednesday => "Wednesday"
    Thursday => "Thursday"
    Friday => "Friday"
    Saturday => "Saturday"
    Sunday => "Sunday"
    _ => "Unknown"
}

entry {
    assert day_number(Monday) == 1
    assert day_number(Wednesday) == 3
    assert day_number(Friday) == 5
    assert day_number(Sunday) == 7

    assert is_weekend(Saturday) == true
    assert is_weekend(Sunday) == true
    assert is_weekend(Monday) == false
    assert is_weekend(Thursday) == false

    assert day_name(Monday) == "Monday"
    assert day_name(Friday) == "Friday"
    assert day_name(Sunday) == "Sunday"

    // Match in a loop
    mut total := 0
    mut i := 1
    while i <= 7 {
        d := match i {
            _ => i * 10
        }
        total = total + d
        i = i + 1
    }
    assert total == 280

    println("large_match_test passed")
}
