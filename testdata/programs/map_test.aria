entry {
    // Create a new map
    m := Map()

    // Set key-value pairs
    m.set("name", 42)
    m.set("age", 30)
    m.set("score", 100)

    // Get values
    assert m.get("name") == 42
    assert m.get("age") == 30
    assert m.get("score") == 100

    // Check length
    assert m.len() == 3

    // Check containment
    assert m.has("name") == true
    assert m.has("missing") == false

    // Update existing key
    m.set("score", 200)
    assert m.get("score") == 200
    assert m.len() == 3

    println("map_test passed")
}
