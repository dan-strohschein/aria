// #4: Nested closures — closure creating closure

fn make_inc(n: i64) -> fn(i64) -> i64 {
    return fn(x: i64) -> i64 => x + n
}

fn make_mul(n: i64) -> fn(i64) -> i64 {
    return fn(x: i64) -> i64 => x * n
}

entry {
    // Function returning closure
    inc5 := make_inc(5)
    assert inc5(10) == 15
    assert inc5(0) == 5

    inc100 := make_inc(100)
    assert inc100(1) == 101

    // Multiple closures from different factories
    mul3 := make_mul(3)
    assert mul3(7) == 21

    // Closures coexist independently
    assert inc5(10) == 15
    assert mul3(10) == 30

    // Inline closure inside closure
    outer := 10
    f := fn(x: i64) -> i64 => x + outer
    assert f(5) == 15

    println("nested_closure_test passed")
}
