// Test else-if chains and nested conditionals
fn classify(n: i64) -> str {
    if n < 0 {
        return "negative"
    } else if n == 0 {
        return "zero"
    } else if n < 10 {
        return "small"
    } else if n < 100 {
        return "medium"
    } else {
        return "large"
    }
}

fn fizzbuzz(n: i64) -> str {
    if n % 15 == 0 {
        return "fizzbuzz"
    } else if n % 3 == 0 {
        return "fizz"
    } else if n % 5 == 0 {
        return "buzz"
    }
    return "none"
}

entry {
    assert classify(0 - 5) == "negative"
    assert classify(0) == "zero"
    assert classify(7) == "small"
    assert classify(42) == "medium"
    assert classify(999) == "large"

    assert fizzbuzz(15) == "fizzbuzz"
    assert fizzbuzz(9) == "fizz"
    assert fizzbuzz(25) == "buzz"
    assert fizzbuzz(7) == "none"

    // Nested if
    x := 42
    mut label := "unknown"
    if x > 0 {
        if x > 100 {
            label = "big"
        } else {
            label = "small positive"
        }
    }
    assert label == "small positive"

    println("else_if_test passed")
}
