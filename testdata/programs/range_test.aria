// Test range expressions in for-in loops

entry {
    // Half-open range: 0..5 = [0, 1, 2, 3, 4]
    mut sum := 0
    for i in 0..5 {
        sum += i
    }
    assert sum == 10

    // Inclusive range: 1..=5 = [1, 2, 3, 4, 5]
    mut sum2 := 0
    for i in 1..=5 {
        sum2 += i
    }
    assert sum2 == 15

    // Range with variable bounds
    n := 10
    mut count := 0
    for i in 0..n {
        count += 1
    }
    assert count == 10

    // Range with break
    mut last := 0
    for i in 0..100 {
        if i == 5 { break }
        last = i
    }
    assert last == 4

    // Nested ranges
    mut pairs := 0
    for i in 0..3 {
        for j in 0..3 {
            pairs += 1
        }
    }
    assert pairs == 9

    println("range_test passed")
}
