// Test assert with complex expressions
fn double(n: i64) -> i64 = n * 2

entry {
    // Assert with arithmetic
    assert 2 + 3 == 5
    assert 10 * 10 == 100
    assert 100 / 4 == 25
    assert 17 % 5 == 2

    // Assert with function calls
    assert double(21) == 42
    assert double(0) == 0

    // Assert with boolean expressions
    assert 5 > 3
    assert 10 >= 10
    assert 1 < 100
    assert 0 <= 0

    // Assert with logical operators
    assert 5 > 0 && 5 < 10
    assert 0 == 0 || 1 == 2

    // Assert with string expressions
    assert "hello" + " " + "world" == "hello world"
    assert "abc".len() == 3

    // Assert with negation
    assert 3 != 4
    assert "a" != "b"

    println("assert_expr_test passed")
}
