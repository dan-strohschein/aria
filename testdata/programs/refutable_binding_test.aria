// Test result handling patterns (without variant destructuring)

type MyResult =
    | MyOk(i64)
    | MyErr(str)

fn try_get(ok: bool) -> MyResult {
    if ok { return MyOk(42) }
    MyErr("failed")
}

fn is_ok(r: MyResult) -> bool {
    match r {
        MyOk => true
        MyErr => false
    }
}

entry {
    val := try_get(true)
    assert is_ok(val) == true

    val2 := try_get(false)
    assert is_ok(val2) == false

    println("refutable_binding_test passed")
}
