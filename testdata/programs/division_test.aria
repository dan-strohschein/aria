// Test integer division edge cases
entry {
    // Basic division
    assert 10 / 2 == 5
    assert 7 / 2 == 3
    assert 100 / 10 == 10
    assert 1 / 1 == 1

    // Large numbers
    assert 1000000 / 1000 == 1000
    assert 999999 / 3 == 333333

    // Division with negative (via subtraction)
    assert (0 - 10) / 2 == 0 - 5
    assert 10 / (0 - 2) == 0 - 5

    // Modulo edge cases
    assert 0 % 5 == 0
    assert 1 % 5 == 1
    assert 4 % 5 == 4
    assert 5 % 5 == 0
    assert 13 % 7 == 6

    // Division and modulo together (quotient-remainder)
    n := 47
    d := 10
    q := n / d
    r := n % d
    assert q == 4
    assert r == 7
    assert q * d + r == n

    println("division_test passed")
}
