// Test logical operators: &&, ||, !, and precedence with comparisons
fn in_range(x: i64, lo: i64, hi: i64) -> bool {
    if x >= lo && x <= hi {
        return true
    }
    return false
}

fn is_vowel(ch: str) -> bool {
    if ch == "a" || ch == "e" || ch == "i" || ch == "o" || ch == "u" {
        return true
    }
    return false
}

entry {
    // Basic && and ||
    assert in_range(5, 1, 10) == true
    assert in_range(0, 1, 10) == false
    assert in_range(11, 1, 10) == false

    assert is_vowel("a") == true
    assert is_vowel("e") == true
    assert is_vowel("x") == false
    assert is_vowel("z") == false

    // Comparison + arithmetic precedence with &&
    // a > b + 1 should be a > (b + 1)
    a := 10
    b := 5
    if a > b + 1 && b > 0 {
        assert true
    } else {
        assert false
    }

    // Nested conditions
    x := 42
    if x > 0 && x < 100 && x != 50 {
        assert true
    } else {
        assert false
    }

    println("logical_ops_test passed")
}
